async def example_usage():
    """Example usage of SIEM connectors"""
    
    # Initialize connector registry
    registry = SIEMConnectorRegistry()
    
    # Register Splunk connector
    splunk_config = {
        'base_url': 'https://splunk.example.com:8089',
        'auth_method': 'token',
        'token': 'your-hec-token-here',
        'verify_ssl': True,
        'rate_limit': {
            'requests_per_second': 10,
            'requests_per_minute': 600,
            'requests_per_hour': 36000
        },
        'retry_config': {
            'max_retries': 3,
            'initial_delay': 1.0,
            'max_delay': 30.0
        }
    }
    
    await registry.register_connector('splunk-prod', 'splunk', splunk_config)
    
    # Register Elastic connector
    elastic_config = {
        'base_url': 'https://elastic.example.com:9200',
        'auth_method': 'basic_auth',
        'username': 'elastic',
        'password': 'your-password-here',
        'verify_ssl': True,
        'index_pattern': 'security-events-*'
    }
    
    await registry.register_connector('elastic-prod', 'elastic', elastic_config)
    
    # Send a security event
    event = {
        'timestamp': datetime.utcnow().isoformat(),
        'event_id': 'evt_12345',
        'severity': 'high',
        'category': 'network',
        'event_type': 'connection_attempt',
        'source_ip': '192.168.1.100',
        'destination_ip': '10.0.0.50',
        'destination_port': 22,
        'username': 'admin',
        'description': 'Suspicious SSH connection attempt'
    }
    
    results = await registry.send_event_to_all(event)
    print(f"Event sent results: {results}")
    
    # Query threat intelligence
    indicators = ['192.168.1.100', 'malicious.example.com', 'bad-hash-123']
    intel_results = await registry.query_threat_intel_from_all(indicators)
    print(f"Threat intel results: {intel_results}")
    
    # Health check
    health_results = await registry.health_check_all()
    print(f"Health check results: {health_results}")
    
    # Get connector status
    status = registry.get_connector_status()
    print(f"Connector status: {status}")
    
    # Cleanup
    await registry.close_all()

