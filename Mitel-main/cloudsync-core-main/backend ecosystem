class SIEMConnectorFactory:
    """Factory for creating SIEM connectors"""
    
    _connectors = {
        'splunk': SplunkConnector,
        'qradar': QRadarConnector,
        'sentinel': SentinelConnector,
        'elastic': ElasticConnector
    }
    
    @classmethod
    def create_connector(cls, siem_type: str, connection_params: Dict[str, Any]) -> SIEMConnectorBase:
        """Create a SIEM connector instance"""
        if siem_type.lower() not in cls._connectors:
            raise ValueError(f"Unsupported SIEM type: {siem_type}")
        
        connector_class = cls._connectors[siem_type.lower()]
        return connector_class(connection_params)
    
    @classmethod
    def get_supported_siems(cls) -> List[str]:
        """Get list of supported SIEM types"""
        return list(cls._connectors.keys())

class SIEMConnectorRegistry:
    """Registry for managing active SIEM connections"""
    
    def __init__(self):
        self.active_connectors: Dict[str, SIEMConnectorBase] = {}
        self.connection_status: Dict[str, Dict[str, Any]] = {}
        self.logger = logging.getLogger(self.__class__.__name__)
    
    async def register_connector(self, connector_id: str, siem_type: str, 
                               connection_params: Dict[str, Any]) -> bool:
        """Register and initialize a SIEM connector"""
        try:
            # Create connector
            connector = SIEMConnectorFactory.create_connector(siem_type, connection_params)
            
            # Initialize
            await connector.initialize()
            
            # Test connection
            if not await connector.test_connection():
                await connector.close()
                return False
            
            # Store connector
            self.active_connectors[connector_id] = connector
            self.connection_status[connector_id] = {
                'siem_type': siem_type,
                'status': 'active',
                'connected_at': datetime.now(),
                'last_test': datetime.now(),
                'events_sent': 0,
                'queries_executed': 0,
                'errors': 0
            }
            
            self.logger.info(f"SIEM connector registered successfully: {connector_id} ({siem_type})")
            return True
            
        except Exception as e:
            self.logger.error(f"Failed to register SIEM connector {connector_id}: {e}")
            return False
    
    async def unregister_connector(self, connector_id: str):
        """Unregister and cleanup a SIEM connector"""
        if connector_id in self.active_connectors:
            try:
                await self.active_connectors[connector_id].close()
            except Exception as e:
                self.logger.warning(f"Error closing connector {connector_id}: {e}")
            
            del self.active_connectors[connector_id]
            del self.connection_status[connector_id]
            
            self.logger.info(f"SIEM connector unregistered: {connector_id}")
    
    async def send_event_to_all(self, event_data: Dict[str, Any]) -> Dict[str, bool]:
        """Send event to all registered connectors"""
        results = {}
        
        for connector_id, connector in self.active_connectors.items():
            try:
                success = await connector.send_event(event_data)
                results[connector_id] = success
                
                # Update stats
                status = self.connection_status[connector_id]
                if success:
                    status['events_sent'] += 1
                else:
                    status['errors'] += 1
                    
            except Exception as e:
                self.logger.error(f"Error sending event to {connector_id}: {e}")
                results[connector_id] = False
                self.connection_status[connector_id]['errors'] += 1
        
        return results
    
    async def query_threat_intel_from_all(self, indicators: List[str]) -> Dict[str, Any]:
        """Query threat intelligence from all connectors"""
        results = {}
        
        for connector_id, connector in self.active_connectors.items():
            try:
                intel_data = await connector.query_threat_intel(indicators)
                results[connector_id] = intel_data
                
                # Update stats
                self.connection_status[connector_id]['queries_executed'] += 1
                
            except Exception as e:
                self.logger.error(f"Error querying threat intel from {connector_id}: {e}")
                results[connector_id] = {'error': str(e)}
                self.connection_status[connector_id]['errors'] += 1
        
        return results
    
    async def health_check_all(self) -> Dict[str, bool]:
        """Perform health check on all connectors"""
        results = {}
        
        for connector_id, connector in self.active_connectors.items():
            try:
                is_healthy = await connector.test_connection()
                results[connector_id] = is_healthy
                
                # Update status
                status = self.connection_status[connector_id]
                status['last_test'] = datetime.now()
                if not is_healthy:
                    status['status'] = 'unhealthy'
                    status['errors'] += 1
                else:
                    status['status'] = 'active'
                    
            except Exception as e:
                self.logger.error(f"Health check failed for {connector_id}: {e}")
                results[connector_id] = False
                self.connection_status[connector_id]['status'] = 'error'
                self.connection_status[connector_id]['errors'] += 1
        
        return results
    
    def get_connector_status(self, connector_id: str = None) -> Dict[str, Any]:
        """Get status of specific connector or all connectors"""
        if connector_id:
            return self.connection_status.get(connector_id, {})
        return dict(self.connection_status)
    
    async def close_all(self):
        """Close all active connectors"""
        for connector_id in list(self.active_connectors.keys()):
            await self.unregister_connector(connector_id)

