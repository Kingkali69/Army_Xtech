        return
    
    @classmethod
    def _get_unified_time(cls):
        """Get unified time - master's time if master, master time + offset if peer"""
        try:
            engine = cls._engine_ref
            if engine and hasattr(engine, 'is_master') and engine.is_master():
                # Master uses its own time
                return time.time()
            elif engine and hasattr(engine, 'config') and hasattr(engine.config, 'time_offset'):
                # Peer uses master time + offset
                # Get master time from status if available
                if hasattr(engine, 'get_status'):
                    status = engine.get_status()
                    master_time = status.get('master_time')
                    if master_time:
                        return master_time + engine.config.time_offset
                # Fallback: use local time if master time not available
                return time.time() + engine.config.time_offset
        except:
            pass
        # Fallback to local time
        return time.time()
    
    @staticmethod
    def _timestamped_print(msg):
        """Print message with timestamp for terminal output (with milliseconds) - uses unified time"""
        from datetime import datetime
        unified_time = GhostOpsServer._get_unified_time()
        dt = datetime.fromtimestamp(unified_time)
        timestamp = dt.strftime('%H:%M:%S.%f')[:-3]  # HH:MM:SS.mmm format
        print(f"[{timestamp}] {msg}")
        # Also add to log buffer for unified monitoring
        GhostOpsServer.add_log(msg, 'SYSTEM')
    
    @classmethod
    def add_log(cls, message, device_name=None, timestamp=None):
        """Add a log message to the buffer with millisecond precision - uses unified time"""
        if timestamp is None:
            timestamp = cls._get_unified_time()
        if device_name is None:
            device_name = 'SYSTEM'
        
        # Format timestamp with milliseconds (HH:MM:SS.mmm)
        from datetime import datetime
        dt = datetime.fromtimestamp(timestamp)
        time_str = dt.strftime('%H:%M:%S.%f')[:-3]
        
        log_entry = {
            'message': str(message),
            'device': device_name,
            'timestamp': timestamp,
            'time_str': time_str  # HH:MM:SS.mmm format for investor demos
        }
        
        with cls._log_buffer_lock:
            cls._command_log_buffer.append(log_entry)
            # Keep only last N entries
            if len(cls._command_log_buffer) > cls._max_log_entries:
                cls._command_log_buffer.pop(0)
    
    @classmethod
    def get_logs(cls, since_timestamp=0, max_entries=100):
        """Get log entries since a timestamp"""
        with cls._log_buffer_lock:
            if since_timestamp == 0:
                # Return last N entries
                return cls._command_log_buffer[-max_entries:]
            else:
                # Return entries since timestamp
                return [log for log in cls._command_log_buffer if log['timestamp'] > since_timestamp]
    
