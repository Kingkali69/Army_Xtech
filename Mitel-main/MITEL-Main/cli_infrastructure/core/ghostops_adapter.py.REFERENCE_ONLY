                        })
                    else:
                        self.send_json({'status': 'error', 'message': 'UI sync not available'})
                except Exception as e:
                    self.send_json({'status': 'error', 'message': str(e)})
                return
            
            if self.path == '/ui_takeover':
                # Device taking over UI control
                try:
                    data = self.read_json()
                    device_name = data.get('device_name', engine.config.device_id)
                    
                    # Take authority
                    engine.state.authority = engine.config.device_id
                    engine.state.authority_timestamp = time.time()
                    engine.state.authority_device_name = device_name
                    
                    if hasattr(engine, 'ui_sync') and engine.ui_sync:
                        engine.ui_sync.trigger_action('authority_change', 'system', {
                            'new_authority': engine.config.device_id,
                            'device_name': device_name
                        })
                    
                    self.send_json({
                        'status': 'ok',
                        'authority': engine.state.authority,
                        'device_name': device_name
                    })
                except Exception as e:
                    self.send_json({'status': 'error', 'message': str(e)})
                return
            
            if self.path == '/sync/files':
                try:
                    # Rate limiting: prevent spam from same peer
                    # Ensure time module is accessible (fix for UnboundLocalError)
                    import time as time_module
                    peer_ip = self.client_address[0]
                    current_time = time_module.time()
                    
                    with GhostOpsServer._sync_rate_lock:
                        last_sync = GhostOpsServer._sync_rate_limit.get(peer_ip, 0)
                        time_since_last = current_time - last_sync
                        
                        if time_since_last < GhostOpsServer._min_sync_interval:
                            # Rate limited - return cached/empty response
                            GhostOpsServer._timestamped_print(
                                f"[FILE SYNC] ⏱️ Rate limited: {peer_ip} (last sync {time_since_last:.1f}s ago, min {GhostOpsServer._min_sync_interval}s)"
                            )
                            self.send_json({
                                'status': 'rate_limited',
                                'message': f'Please wait {GhostOpsServer._min_sync_interval - time_since_last:.1f}s between syncs',
                                'files': {},
                                'retry_after': GhostOpsServer._min_sync_interval - time_since_last
                            })
                            return
                        
                        # Update last sync time
                        GhostOpsServer._sync_rate_limit[peer_ip] = current_time
                    
                    data = self.read_json()
                    peer_files_info = data.get('files', {})
                    peer_device_id = data.get('device_id', 'unknown')
                    peer_platform = data.get('platform', 'unknown')
                    
                    # Identify peer from connection if device_id not provided
                    if peer_device_id == 'unknown':
                        # Try to identify from client address or existing nodes
                        client_ip = self.client_address[0] if hasattr(self, 'client_address') else 'unknown'
                        if hasattr(engine, 'state') and hasattr(engine.state, 'nodes'):
                            for node_id, node_data in engine.state.nodes.items():
                                if node_data.get('ip') == client_ip:
                                    peer_device_id = node_id
                                    peer_platform = node_data.get('platform', 'unknown')
                                    break
                    
                    msg = f"[FILE SYNC] Master received sync request: {len(peer_files_info)} files from {peer_device_id} ({peer_platform})"
                    GhostOpsServer._timestamped_print(msg)
                    GhostOpsServer.add_log(msg, device_name=engine.config.device_id)
                    
                    result = GhostOpsMasterLogic.handle_sync_files(engine.state, peer_files_info, source=peer_device_id)
                    files_count = len(result.get('files', {}))
                    
                    if files_count > 0:
                        file_list = list(result.get('files', {}).keys())
                        total_size = sum(f.get('size', 0) for f in result.get('files', {}).values())
                        msg1 = f"[FILE SYNC] 📤 Sending {files_count} file(s) to peer: {file_list}"
                        msg2 = f"[FILE SYNC] 📦 Total size: {total_size} bytes"
                        GhostOpsServer._timestamped_print(msg1)
                        GhostOpsServer._timestamped_print(msg2)
                        GhostOpsServer.add_log(msg1, device_name=engine.config.device_id)
                        GhostOpsServer.add_log(msg2, device_name=engine.config.device_id)
                    else:
                        msg = f"[FILE SYNC] ✓ Peer files up to date"
                        GhostOpsServer._timestamped_print(msg)
                        GhostOpsServer.add_log(msg, device_name=engine.config.device_id)
                    
                    # Send response - handle large payloads
                    try:
                        self.send_json(result)
                    except Exception as send_error:
                        GhostOpsServer._timestamped_print(f"[FILE SYNC] [ERROR] Error sending response: {send_error}")
                        import traceback
                        traceback.print_exc()
                        # Send error response
                        self.send_json({
                            'status': 'error',
                            'message': f'Failed to send sync response: {str(send_error)}',
                            'files': {}
                        })
                    return
                except Exception as e:
                    GhostOpsServer._timestamped_print(f"[FILE SYNC] [ERROR] Error in /sync/files endpoint: {e}")
                    import traceback
                    traceback.print_exc()
                    self.send_json({
                        'status': 'error',
                        'message': f'Sync error: {str(e)}',
                        'files': {}
                    })
                    return
            
            # File sharing endpoints
            if self.path == '/file/send':
                try:
                    try:
                        from file_sharing import TunnelFileTransfer
                    except ImportError as e:
                        self.send_json({'ok': False, 'message': f'File sharing module not available: {e}'})
                        return
                    import tempfile
                    data = self.read_json()
                    file_name = data.get('file_name')
                    file_data = data.get('file_data')  # Base64 encoded
                    file_size = data.get('file_size')
                    target_node = data.get('target_node')
                    
                    if not file_name or not file_data:
                        self.send_json({'ok': False, 'message': 'Missing file data'})
                        return
                    
                    # Save uploaded file to temp location
                    import base64
                    file_content = base64.b64decode(file_data)
                    temp_dir = tempfile.gettempdir()
                    import time as time_module
                    temp_file_path = os.path.join(temp_dir, f"ghostops_transfer_{int(time_module.time())}_{file_name}")
                    
                    with open(temp_file_path, 'wb') as f:
                        f.write(file_content)
                    
                    # Get or create file transfer manager
                    if not hasattr(engine, 'file_transfer'):
                        engine.file_transfer = TunnelFileTransfer(
                            ex_api=getattr(engine, 'tunnel_manager', None) and engine.tunnel_manager.ex_api,
                            engine=engine
                        )
                    
                    result = engine.file_transfer.send_file(temp_file_path, target_node)
                    # Store temp file path for cleanup
                    if result.get('ok'):
                        result['temp_file'] = temp_file_path
                    self.send_json(result)
                except Exception as e:
                    import traceback
                    error_trace = traceback.format_exc()
                    print(f"[FILE TRANSFER ERROR] {str(e)}")
                    print(f"[FILE TRANSFER TRACE] {error_trace}")
                    self.send_json({'ok': False, 'message': f'Transfer error: {str(e)}', 'error_type': type(e).__name__})
                return
            
            if self.path.startswith('/file/transfer/'):
                try:
                    transfer_id = self.path.split('/')[-1]
                    if hasattr(engine, 'file_transfer'):
                        status = engine.file_transfer.get_transfer_status(transfer_id)
                        self.send_json(status)
                    else:
                        self.send_json({'status': 'not_found'})
                except Exception as e:
                    self.send_json({'status': 'error', 'error': str(e)})
                return
            
            if self.path == '/file/receive':
                try:
                    # Receive file chunk
                    data = self.read_json()
                    try:
                        from file_sharing import SecureFileTransfer
                    except ImportError:
                        self.send_json({'status': 'error', 'message': 'File sharing module not available'})
                        return
                    
                    # This would save the received file
                    # Implementation depends on chunked transfer handling
                    self.send_json({'status': 'ok'})
                except Exception as e:
                    self.send_json({'status': 'error', 'message': str(e)})
                return
            
            if self.path == '/plugins/start':
                data = self.read_json()
                name = data.get('name')
                if not name:
                    self.send_json({'status': 'error', 'message': 'Missing plugin name'})
                    return
                
                # Handle tunnel plugin directly
                if name == 'tunnel':
                    if hasattr(engine, 'tunnel_manager'):
                        try:
                            result = engine.tunnel_manager.start_tunnel()
                            engine.state.add_command('tunnel_start', engine.config.device_id)
                            engine.state.save_state_cache()
                            
                            # Log result for debugging
                            if result.get('ok'):
                                print(f"[+] Tunnel start successful: {result.get('message')}")
                            else:
                                print(f"[!] Tunnel start failed: {result.get('message')}")
                                if result.get('details'):
                                    for detail in result.get('details', []):
                                        print(f"    - {detail}")
                            
                            self.send_json({'status': 'ok' if result.get('ok') else 'error', 'result': result})
                        except Exception as e:
                            error_msg = f"Tunnel start exception: {str(e)}"
                            print(f"[!] {error_msg}")
                            import traceback
                            traceback.print_exc()
                            self.send_json({'status': 'error', 'result': {'ok': False, 'message': error_msg}})
                        return
                
                # Fall back to plugin manager
                if pm is None:
                    self.send_json({'status': 'error', 'message': 'Plugin manager unavailable'})
                    return
                result = pm.start_plugin(name, data.get('args'))
                engine.state.add_command('plugin_start', engine.config.device_id, name=name)
                self.send_json({'status': 'ok' if result.get('ok') else 'error', 'result': result})
                return
            
            if self.path == '/plugins/stop':
                data = self.read_json()
                name = data.get('name')
                if not name:
                    self.send_json({'status': 'error', 'message': 'Missing plugin name'})
                    return
                
                # Handle tunnel plugin directly
                if name == 'tunnel':
                    if hasattr(engine, 'tunnel_manager'):
                        try:
                            result = engine.tunnel_manager.stop_tunnel()
                            engine.state.add_command('tunnel_stop', engine.config.device_id)
                            engine.state.save_state_cache()
                            
                            # Log result for debugging
                            if result.get('ok'):
                                print(f"[+] Tunnel stop successful: {result.get('message')}")
                            else:
                                print(f"[!] Tunnel stop failed: {result.get('message')}")
                                if result.get('details'):
                                    for detail in result.get('details', []):
                                        print(f"    - {detail}")
                            
                            self.send_json({'status': 'ok' if result.get('ok') else 'error', 'result': result})
                        except Exception as e:
                            error_msg = f"Tunnel stop exception: {str(e)}"
                            print(f"[!] {error_msg}")
                            import traceback
                            traceback.print_exc()
                            self.send_json({'status': 'error', 'result': {'ok': False, 'message': error_msg}})
                        return
                
                # Fall back to plugin manager
                if pm is None:
                    self.send_json({'status': 'error', 'message': 'Plugin manager unavailable'})
                    return
                result = pm.stop_plugin(name)
                engine.state.add_command('plugin_stop', engine.config.device_id, name=name)
                self.send_json({'status': 'ok' if result.get('ok') else 'error', 'result': result})
                return
            
            # Direct tunnel endpoints (alternative to /plugins/start and /plugins/stop)
            if self.path == '/tunnel/start':
                if hasattr(engine, 'tunnel_manager'):
                    result = engine.tunnel_manager.start_tunnel()
                    engine.state.add_command('tunnel_start', engine.config.device_id)
                    self.send_json({'status': 'ok' if result.get('ok') else 'error', 'result': result})
                else:
                    self.send_json({'status': 'error', 'message': 'Tunnel manager unavailable'})
                return
            
            if self.path == '/tunnel/stop':
                if hasattr(engine, 'tunnel_manager'):
                    result = engine.tunnel_manager.stop_tunnel()
                    engine.state.add_command('tunnel_stop', engine.config.device_id)
                    self.send_json({'status': 'ok' if result.get('ok') else 'error', 'result': result})
                else:
                    self.send_json({'status': 'error', 'message': 'Tunnel manager unavailable'})
                return
            
            if self.path == '/tunnel/status':
                if hasattr(engine, 'tunnel_manager'):
                    status = engine.tunnel_manager.get_tunnel_status()
                    self.send_json({'status': 'ok', 'tunnel': status})
                else:
                    self.send_json({'status': 'ok', 'tunnel': {'active': False}})
                return
            
            if self.path == '/upload':
                try:
                    result, error = GhostOpsHTTPHandler.parse_multipart(
                        self.rfile, self.headers
                    )
                    
                    if error:
                        print(f"[!] Upload error: {error}")
                        self.send_json({'status': 'error', 'message': error})
                        return
                    
                    if not result or 'files' not in result or len(result['files']) == 0:
                        self.send_json({'status': 'error', 'message': 'No files uploaded'})
                        return
                    
                    saved_files = []
                    for field_name, file_info in result['files'].items():
                        saved_file = GhostOpsFileManager.save_uploaded_file(
                            file_info, os.path.join(os.path.dirname(__file__), 'uploads')
                        )
                        if saved_file:
                            saved_files.append(saved_file)
                            print(f"[+] File uploaded: {saved_file['name']} ({saved_file['size']} bytes)")
                    
                    if not saved_files:
                        self.send_json({'status': 'error', 'message': 'No files saved'})
                        return
                    
                    result_obj = GhostOpsMasterLogic.handle_file_upload(
                        engine.state, {'saved_files': saved_files}, engine.config.device_id
                    )
                    self.send_json(result_obj)
                    return
                    
                except Exception as e:
                    error_msg = f"Upload failed: {str(e)}"
                    print(f"[!] {error_msg}")
                    self.send_json({'status': 'error', 'message': error_msg})
                    return
        
        # Peer forwarding logic - handle standalone mode
        if not engine.is_master():
            try:
                data = self.read_json()
                if 'device_id' not in data:
                    data['device_id'] = engine.config.device_id
                
                # Check if we're in standalone mode
                is_standalone = engine.state.standalone_mode or not engine.config.master_ip
                
                if is_standalone:
                    # Handle locally in standalone mode
                    if self.path == '/sync/tool':
                        engine.state.tool_state = data.get('tool')
                        engine.state.add_command('tool_activate', engine.config.device_id, tool=data.get('tool'))
                        engine.state.add_to_sync_queue('tool_activate', tool=data.get('tool'), source=engine.config.device_id)
                        engine.state.save_state_cache()
                        self.send_json({'status': 'ok', 'message': 'Handled locally (standalone mode)'})
                    elif self.path == '/sync/page':
                        engine.state.page_state = data.get('page', 1)
                        engine.state.add_command('page_change', engine.config.device_id, page=data.get('page', 1))
                        engine.state.add_to_sync_queue('page_change', page=data.get('page', 1), source=engine.config.device_id)
                        engine.state.save_state_cache()
                        self.send_json({'status': 'ok', 'message': 'Handled locally (standalone mode)'})
                    elif self.path == '/sync/authority':
                        print(f"[AUTHORITY] [PEER STANDALONE] Authority change request in standalone mode")
                        has_authority = data.get('has_authority', False)
                        device_id = data.get('device_id', engine.config.device_id)
                        password = data.get('password', '')
                        timestamp = data.get('timestamp', time.time())  # PHASE 2: Get timestamp

                        # PASSWORD VERIFICATION - Required for taking control (STRICT)
                        if has_authority:
                            if not password or password.strip() != 'ghostops':
                                print(f"[AUTHORITY] [PEER STANDALONE] [DENIED] Invalid or missing password from {device_id}")
                                self.send_json({
                                    'status': 'error',
                                    'has_authority': False,
                                    'message': 'Invalid password. MDCS requires password: ghostops'
                                })
                                return

                        # Handle 'local_device' mapping
                        if device_id == 'local_device':
                            device_id = engine.config.device_id

                        print(f"[AUTHORITY] [PEER STANDALONE] device_id={device_id}, has_authority={has_authority}, timestamp={timestamp}")
                        if has_authority:
                            print(f"[AUTHORITY] [PEER STANDALONE] [OK] Password verified")
                        print(f"[AUTHORITY] [PEER STANDALONE] Current authority before: {engine.state.authority}")

                        # Use the same logic as master for consistency
                        result = GhostOpsMasterLogic.handle_authority(engine.state, device_id, has_authority, timestamp)

                        # If this device is taking control, update mode
                        if has_authority and device_id == engine.config.device_id:
                            if engine.mode == 'peer':
                                print(f"[AUTHORITY] [PEER STANDALONE] Updating mode to master")
                                engine.mode = 'master'
                        else:
                            if not has_authority and device_id == engine.config.device_id:
                                engine.mode = 'peer'

                        print(f"[AUTHORITY] [PEER STANDALONE] Current authority after: {engine.state.authority}")
                        print(f"[AUTHORITY] [PEER STANDALONE] Engine mode: {engine.mode}")

                        engine.state.add_command('authority', device_id, has_authority=has_authority, timestamp=timestamp)
                        engine.state.add_to_sync_queue('authority', device_id=device_id, has_authority=has_authority, timestamp=timestamp)
                        engine.state.save_state_cache()

                        result['mode'] = engine.mode
                        result['message'] = 'Handled locally (standalone mode)'
                        self.send_json(result)
                    elif self.path == '/sync/all':
                        engine.state.update_sync()
                        engine.state.add_command('sync_all', engine.config.device_id)
                        engine.state.add_to_sync_queue('sync_all')
                        engine.state.save_state_cache()
                        self.send_json({'status': 'ok', 'message': 'Handled locally (standalone mode)'})
                    else:
                        # Try to forward, but don't fail if master unavailable
                        result = GhostOpsNetwork.forward_to_master(
                            engine.config.master_ip,
                            engine.config.master_port,
                            self.path,
                            data
                        )
                        if result:
                            self.send_json(result)
                        else:
                            self.send_json({'status': 'ok', 'message': 'Queued for sync when connected', 'standalone': True})
                else:
                    # Connected mode - forward to master
                    result = GhostOpsNetwork.forward_to_master(
                        engine.config.master_ip,
                        engine.config.master_port,
                        self.path,
                        data
                    )
                    
                    if result:
                        # Handle local state updates
                        if self.path == '/sync/tool':
                            engine.state.tool_state = data.get('tool')
                            print(f"[+] Tool activated: {engine.state.tool_state}")
                        elif self.path == '/sync/page':
                            engine.state.page_state = data.get('page', 1)
                            print(f"[+] Page changed: {engine.state.page_state}")
                        elif self.path == '/sync/authority':
                            print(f"[+] Authority {'granted' if data.get('has_authority', False) else 'revoked'}")
                        elif self.path == '/sync/all':
                            engine.state.update_sync()
                            print(f"[+] Sync triggered")
                        
                        self.send_json(result)
                    else:
                        # Master connection failed, queue for later
                        if self.path in ['/sync/tool', '/sync/page', '/sync/authority', '/sync/all']:
                            action_map = {
                                '/sync/tool': ('tool_activate', {'tool': data.get('tool')}),
                                '/sync/page': ('page_change', {'page': data.get('page', 1)}),
                                '/sync/authority': ('authority', {'device_id': data.get('device_id'), 'has_authority': data.get('has_authority', False)}),
                                '/sync/all': ('sync_all', {})
                            }
                            action, kwargs = action_map.get(self.path, (None, {}))
                            if action:
                                engine.state.add_to_sync_queue(action, **kwargs)
                                engine.state.connection_status = 'standalone'
                                engine.state.standalone_mode = True
                        self.send_json({'status': 'ok', 'message': 'Queued for sync when reconnected', 'standalone': True})
            except Exception as e:
                self.send_json({'status': 'error', 'message': str(e)})
        
        # UI Mirror System Endpoints
        if self.path == '/ui/state':
            # Get current UI state (for mirrors to poll)
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                state = engine.ui_mirror.get_ui_state()
                self.send_json({
                    'status': 'ok',
                    'ui_state': state,
                    'ui_hash': state.get('ui_hash', ''),
                    'is_master': engine.ui_mirror.is_master
                })
            else:
