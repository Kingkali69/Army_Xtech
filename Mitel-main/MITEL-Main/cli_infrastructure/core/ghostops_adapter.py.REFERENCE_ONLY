class GhostOpsServer(BaseHTTPRequestHandler):
    """Unified HTTP server using the core engine"""
    
    # Class-level log buffer - shared across all instances
    _command_log_buffer = []
    _log_buffer_lock = threading.Lock()
    _max_log_entries = 500  # Keep last 500 log entries
    _engine_ref = None  # Reference to engine for unified time sync
    
    # Rate limiting for sync requests (prevent spam loops)
    _sync_rate_limit = {}  # {peer_ip: last_sync_time}
    _sync_rate_lock = threading.Lock()
    _min_sync_interval = 5.0  # Minimum 5 seconds between syncs per peer
    
    # Mesh API token and job tracking
    _mesh_api_token = None
    _mesh_jobs = {}  # {job_id: {'status': 'pending/completed', 'results': {...}, 'created_at': timestamp}}
    _mesh_jobs_lock = threading.Lock()
    
    @classmethod
    def _generate_mesh_token(cls):
        """Generate secure random token for Mesh API"""
        if cls._mesh_api_token is None:
            # Generate 32-byte random token
            token = secrets.token_urlsafe(32)
            cls._mesh_api_token = token
            # Store in environment variable
            import os
            os.environ['MESH_API_TOKEN'] = token
            # Save to file for easy access
            token_file = os.path.join(os.path.dirname(os.path.dirname(__file__)), 'MESH_API_TOKEN.txt')
            try:
                with open(token_file, 'w') as f:
                    f.write(f"MESH API TOKEN\n")
                    f.write(f"==============\n\n")
                    f.write(f"TOKEN: {token}\n\n")
                    f.write(f"BASE URL: http://192.168.1.116:7890\n\n")
                    f.write(f"AUTH HEADER: X-Mesh-Token: {token}\n")
            except:
                pass
            print(f"[MESH API] Token generated: {token}")
            print(f"[MESH API] Token saved to: {token_file}")
        return cls._mesh_api_token
    
    @classmethod
    def _validate_mesh_token(cls, provided_token):
        """Validate Mesh API token"""
        if cls._mesh_api_token is None:
            cls._generate_mesh_token()
        return provided_token == cls._mesh_api_token
    
    @classmethod
    def _create_job(cls, job_id=None):
        """Create new async job"""
        if job_id is None:
            job_id = str(uuid.uuid4())
        with cls._mesh_jobs_lock:
            cls._mesh_jobs[job_id] = {
                'status': 'pending',
                'results': {},
                'created_at': time.time()
            }
        return job_id
    
    @classmethod
    def _update_job(cls, job_id, platform, result):
        """Update job with result from platform"""
        with cls._mesh_jobs_lock:
            if job_id in cls._mesh_jobs:
                cls._mesh_jobs[job_id]['results'][platform] = result
                # Check if all platforms completed
                all_complete = all(
                    r.get('status') in ['success', 'error'] 
                    for r in cls._mesh_jobs[job_id]['results'].values()
                )
                if all_complete:
                    cls._mesh_jobs[job_id]['status'] = 'completed'
    
    def _check_mesh_auth(self):
        """Check Mesh API authentication"""
        token = self.headers.get('X-Mesh-Token', '')
        if not token:
            self.send_response(401)
            self.send_header('Content-type', 'application/json')
            self.end_headers()
            self.wfile.write(json.dumps({'error': 'Missing X-Mesh-Token header'}).encode())
            return False
        if not self._validate_mesh_token(token):
            self.send_response(403)
            self.send_header('Content-type', 'application/json')
            self.end_headers()
            self.wfile.write(json.dumps({'error': 'Invalid token'}).encode())
            return False
        return True
    
