    def _execute_on_platform(self, platform, command, job_id=None):
        """Execute command on specific platform via mesh"""
        engine = self.server.engine
        
        # If this is the target platform, execute locally
        current_platform = engine.platform if hasattr(engine, 'platform') else 'unknown'
        if platform == current_platform or (platform == 'linux' and current_platform == 'linux'):
            try:
                import subprocess
                result = subprocess.run(
                    command,
                    shell=True,
                    capture_output=True,
                    text=True,
                    timeout=30
                )
                return {
                    'status': 'success' if result.returncode == 0 else 'error',
                    'output': result.stdout,
                    'error': result.stderr,
                    'returncode': result.returncode
                }
            except subprocess.TimeoutExpired:
                return {'status': 'error', 'output': '', 'error': 'Command timeout'}
            except Exception as e:
                return {'status': 'error', 'output': '', 'error': str(e)}
        
        # Route to peer node
        if hasattr(engine, 'state') and hasattr(engine.state, 'nodes'):
            nodes = engine.state.nodes
            for device_id, node_info in nodes.items():
                node_platform = node_info.get('platform', '').lower()
                if node_platform == platform:
                    # Found target node
                    node_ip = node_info.get('ip', '')
                    node_port = node_info.get('port', 7892)
                    
                    try:
                        import urllib.request
                        import json
                        url = f"http://{node_ip}:{node_port}/mesh/execute_local"
                        data = {
                            'command': command,
                            'job_id': job_id
                        }
                        req = urllib.request.Request(
                            url,
                            data=json.dumps(data).encode('utf-8'),
                            headers={'Content-Type': 'application/json'}
                        )
                        with urllib.request.urlopen(req, timeout=30) as response:
                            result = json.loads(response.read().decode('utf-8'))
                            return result
                    except Exception as e:
                        return {'status': 'error', 'output': '', 'error': f'Failed to route to {platform}: {str(e)}'}
        
        return {'status': 'error', 'output': '', 'error': f'Platform {platform} not found in mesh'}
    
