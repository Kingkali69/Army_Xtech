            elif hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                ui_state = data.get('ui_state', data.get('state', {}))
                master_id = data.get('master_id', data.get('master', ''))
                engine.ui_mirror.update_ui_state(ui_state, source='sync')
                engine.ui_mirror.set_master(master_id)
                self.send_json({'status': 'ok', 'synced': True})
            else:
                self.send_json({'status': 'error', 'error': 'UI Sync not available'})
            return
        
        if self.path == '/ui/update':
            data = self.read_json()
            changes = data.get('ui_changes', data.get('changes', {}))
            # Try ui_sync first
            if hasattr(engine, 'ui_sync') and engine.ui_sync:
                engine.ui_sync.update_ui(changes, local=False)
                self.send_json({'status': 'ok', 'applied': engine.ui_sync.is_master})
            elif hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                engine.ui_mirror.update_ui_state(changes, source='local')
                self.send_json({'status': 'ok', 'applied': engine.ui_mirror.is_master})
            else:
                self.send_json({'status': 'error', 'error': 'UI Sync not available'})
            return
        
        if self.path == '/ui/master_change':
            data = self.read_json()
            new_master = data.get('new_master', '')
            # Update both systems
            if hasattr(engine, 'ui_sync') and engine.ui_sync:
                engine.ui_sync.handle_master_change(data)
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                engine.ui_mirror.set_master(new_master)
            self.send_json({'status': 'ok', 'acknowledged': True})
            return
        
        if self.path == '/ui/become_master':
            # Request to become master (atomic handoff)
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                data = self.read_json()
                seamless = data.get('seamless', True)
                
                success = engine.ui_mirror.become_master(seamless=seamless)
                
                self.send_json({
                    'status': 'ok' if success else 'error',
                    'is_master': success,
                    'device_id': engine.config.device_id if success else None
                })
            else:
                self.send_json({'status': 'error', 'error': 'UI Mirror System not available'})
            return
        
        if self.path == '/ui/tri_node_mode':
            # Toggle Tri-Node Synchronized Operation mode
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                data = self.read_json()
                enabled = data.get('enabled', False)
                
                engine.ui_mirror.set_tri_node_mode(enabled)
                
                self.send_json({
                    'status': 'ok',
                    'tri_node_mode': enabled,
                    'coordinated_nodes': len(engine.ui_mirror.coordinated_nodes)
                })
            else:
                self.send_json({'status': 'error', 'error': 'UI Mirror System not available'})
            return
        
        if self.path == '/ui/offline_mode':
            # Enable/disable offline mode
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                data = self.read_json()
                enabled = data.get('enabled', False)
                
                if enabled:
                    engine.ui_mirror.enable_offline_mode()
                else:
                    engine.ui_mirror.disable_offline_mode()
                
                self.send_json({
                    'status': 'ok',
                    'offline_mode': engine.ui_mirror.offline_mode,
                    'queued_operations': len(engine.ui_mirror.offline_queue)
                })
            else:
                self.send_json({'status': 'error', 'error': 'UI Mirror System not available'})
            return
        
        if self.path == '/ui/failover_status':
            # Get failover status
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                self.send_json({
                    'status': 'ok',
                    'is_master': engine.ui_mirror.is_master,
                    'master_device_id': engine.ui_mirror.master_device_id,
                    'master_alive': engine.ui_mirror._ping_master() if engine.ui_mirror.master_device_id else False,
                    'failover_enabled': engine.ui_mirror.failover_enabled,
                    'offline_mode': engine.ui_mirror.offline_mode,
                    'queued_operations': len(engine.ui_mirror.offline_queue)
                })
            else:
                self.send_json({'status': 'error', 'error': 'UI Mirror System not available'})
            return
        
        if self.path == '/ui/reload':
            # Force reload UI mirror system (reloads module)
            try:
                import importlib
                import sys
                
                # Reload ui_mirror_system module
                if 'ui_mirror_system' in sys.modules:
                    importlib.reload(sys.modules['ui_mirror_system'])
                    print("[UI MIRROR] Module reloaded")
                
                # Reinitialize UI mirror
                if hasattr(engine, 'ui_mirror'):
                    engine.ui_mirror.stop()
                    from ui_mirror_system import UIMirrorSystem
                    engine.ui_mirror = UIMirrorSystem(engine)
                    if engine.is_master():
                        engine.ui_mirror.is_master = True
                        engine.ui_mirror.master_device_id = engine.config.device_id
                    engine.ui_mirror.start()
                    print("[UI MIRROR] System restarted")
                
                self.send_json({
                    'status': 'ok',
                    'message': 'UI Mirror system reloaded',
                    'is_master': engine.ui_mirror.is_master if hasattr(engine, 'ui_mirror') else False
                })
            except Exception as e:
                import traceback
                traceback.print_exc()
                self.send_json({'status': 'error', 'error': str(e)})
            return
        
        if self.path == '/ui/force_sync':
            # Force immediate UI state sync (master broadcasts to all peers)
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                if engine.ui_mirror.is_master:
                    # Force broadcast
                    engine.ui_mirror._broadcast_state()
                    self.send_json({
                        'status': 'ok',
                        'message': 'UI state broadcasted to all peers',
                        'peers': len(engine.state.nodes) - 1
                    })
                else:
                    # Request state from master
                    engine.ui_mirror._poll_master_state()
                    self.send_json({
                        'status': 'ok',
                        'message': 'Requested UI state from master'
                    })
            else:
                self.send_json({'status': 'error', 'error': 'UI Mirror System not available'})
            return
        
        # OPAS POST endpoints
        if self.path == '/opas/apply':
            if hasattr(engine, 'opas') and engine.opas:
                data = self.read_json()
                result = engine.opas.apply_incoming(data)
                self.send_json(result)
            else:
                self.send_json({'status': 'error', 'error': 'OPAS not available'})
            return
        
        if self.path == '/opas/register':
            if hasattr(engine, 'opas') and engine.opas:
                data = self.read_json()
                engine.opas.register_node(
                    data['node_id'], data['ip'], data['port'], data['platform'],
                    data.get('ssh_user'), data.get('ssh_port', 22)
                )
                self.send_json({'status': 'ok', 'registered': data['node_id']})
            else:
                self.send_json({'status': 'error', 'error': 'OPAS not available'})
            return
        
        if self.path == '/opas/force_sync':
            if hasattr(engine, 'opas') and engine.opas:
                result = engine.opas.force_sync()
                self.send_json(result)
            else:
                self.send_json({'status': 'error', 'error': 'OPAS not available'})
            return
        
        if self.path == '/ui/resync':
            self.send_json({'status': 'ok', 'message': 'UI resync triggered'})
            return
        
        # File Sync (ui_sync_live)
        if self.path == '/file/sync':
            if hasattr(engine, 'ui_sync') and engine.ui_sync:
                import base64
                data = self.read_json()
                rel_path = data.get('path', '')
                content = base64.b64decode(data.get('content', ''))
                fhash = data.get('hash', '')
                if rel_path:
                    engine.ui_sync.apply_file_sync(rel_path, content, fhash)
                    GhostOpsServer._timestamped_print(f"[FILE SYNC] [OK] Synced: {rel_path}")
                self.send_json({'status': 'ok'})
            else:
                self.send_json({'status': 'error', 'error': 'UI Sync not available'})
            return
        
        # File Hot Update Endpoints
        if self.path == '/file/hot_update':
            # Receive and apply file update from master
            try:
                data = self.read_json()
                file_path = data.get('file_path') or data.get('absolute_path', '')
                
                if not file_path:
                    self.send_json({'status': 'error', 'error': 'No file path provided'})
                    return
                
                # Convert relative path to absolute if needed
                # ANDROID: Use sandbox ~/ghost/ghost instead of script directory
                if not os.path.isabs(file_path):
                    if engine.platform == 'android':
                        termux_home = os.path.expanduser('~')
                        project_dir = os.path.join(termux_home, 'ghost', 'ghost')
                        os.makedirs(project_dir, exist_ok=True)
                    else:
                        project_dir = os.path.dirname(os.path.abspath(__file__))
                    file_path = os.path.join(project_dir, file_path)
                else:
                    # Even if absolute, redirect Android paths to sandbox
                    if engine.platform == 'android':
                        termux_home = os.path.expanduser('~')
                        sandbox_dir = os.path.join(termux_home, 'ghost', 'ghost')
                        os.makedirs(sandbox_dir, exist_ok=True)
                        # If absolute path is outside sandbox, redirect to sandbox
                        if not file_path.startswith(sandbox_dir):
                            file_path = os.path.join(sandbox_dir, os.path.basename(file_path))
                
                # Update data with absolute path
                data['absolute_path'] = file_path
                
                # Try unified engine first, then ui_mirror (compatibility)
                if hasattr(engine, 'ui_sync') and engine.ui_sync and hasattr(engine.ui_sync, 'apply_file_update'):
                    result = engine.ui_sync.apply_file_update(data)
                elif hasattr(engine, 'ui_mirror') and engine.ui_mirror and hasattr(engine.ui_mirror, 'apply_file_update'):
                    result = engine.ui_mirror.apply_file_update(data)
                else:
                    self.send_json({'status': 'error', 'error': 'File sync not available'})
                    return
                
                if result.get('status') == 'ok':
                    GhostOpsServer._timestamped_print(f"[FILE SYNC] [OK] Hot update applied: {os.path.basename(file_path)}")
                elif result.get('status') == 'conflict':
                    GhostOpsServer._timestamped_print(f"[FILE SYNC] [WARN]  Conflict resolved: {os.path.basename(file_path)} (kept local)")
                else:
                    GhostOpsServer._timestamped_print(f"[FILE SYNC] [ERROR] Hot update failed: {os.path.basename(file_path)} - {result.get('error', 'Unknown')}")
                
                self.send_json(result)
            except Exception as e:
                    import traceback
                    traceback.print_exc()
                    self.send_json({'status': 'error', 'error': str(e)})
            return
        
        if self.path == '/file/sync_all':
            # Get all registered files for sync (master endpoint)
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror and engine.ui_mirror.is_master:
                # Return all files in registry
                files = []
                for file_path, metadata in engine.ui_mirror.file_registry.items():
                    try:
                        with open(file_path, 'rb') as f:
                            file_content = f.read()
                        import base64
                        files.append({
                            'file_path': os.path.relpath(file_path, os.path.dirname(os.path.abspath(__file__))),
                            'absolute_path': file_path,
                            'file_data': base64.b64encode(file_content).decode('utf-8'),
                            'file_hash': metadata['hash'],
                            'file_size': metadata['size'],
                            'timestamp': metadata['timestamp'],
                            'source_node': engine.config.device_id
                        })
                    except Exception as e:
                        engine.ui_mirror.logger.error(f"[FILE SYNC] Error reading {file_path}: {e}")
                
                self.send_json({
                    'status': 'ok',
                    'files': files,
                    'count': len(files)
                })
            else:
                self.send_json({'status': 'error', 'error': 'Not master or UI Mirror not available'})
            return
        
        # DEVELOPER: Force push ALL files to ALL connected nodes immediately
        if self.path == '/file/force_push_all' and self.command == 'POST':
            print("[DEV] ⚡ Force push triggered - using GhostLang transport system...")
            
            try:
                # Import GhostCommsSystem from merged ghostlang package
                # GhostLang is now merged into this repo at ghostlang/
                try:
                    from ghostlang.ghost_comms import GhostCommsSystem, CommandPriority
                    print("[DEV] ✅ GhostLang imported from merged package")
                except ImportError as e:
                    # Fallback: try to find ghostlang in common locations (for backward compatibility)
                    import sys
                    project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))  # Go up from core/ to project root
                    possible_paths = [
                        os.path.join(project_root, 'ghostlang'),  # ghostlang/ (merged location)
                        os.path.join(os.path.dirname(project_root), 'ghostlang', 'ghostlang-main'),  # ../ghostlang/ghostlang-main
                        os.path.join(os.path.expanduser('~'), 'ghostlang', 'ghostlang-main'),  # ~/ghostlang/ghostlang-main
                        os.path.join(os.path.expanduser('~'), 'Downloads', 'ghostlang', 'ghostlang-main'),  # ~/Downloads/ghostlang/ghostlang-main
                    ]
                    
                    ghostlang_path = None
                    for path in possible_paths:
                        abs_path = os.path.abspath(path)
                        if os.path.exists(abs_path) and os.path.isdir(abs_path):
                            ghostlang_path = abs_path
                            break
                    
                    if ghostlang_path and ghostlang_path not in sys.path:
                        sys.path.insert(0, ghostlang_path)
                        print(f"[DEV] Found GhostLang at: {ghostlang_path}")
                    
                    from ghost_comms import GhostCommsSystem, CommandPriority
                
                # Get or create GhostComms instance
                if not hasattr(engine, 'ghost_comms'):
                    print("[DEV] Initializing GhostLang transport system...")
                    
                    # ANDROID: Use Termux sandbox ~/ghost/ghost (only writable location)
                    if engine.platform == 'android':
                        termux_home = os.path.expanduser('~')
                        comms_data_dir = os.path.join(termux_home, 'ghost', 'ghost')
                        os.makedirs(comms_data_dir, exist_ok=True)
                        print(f"[DEV] Android detected - using sandbox: {comms_data_dir}")
                    else:
                        comms_data_dir = os.path.join(os.path.expanduser('~'), '.ghost', 'comms')
                    
                    engine.ghost_comms = GhostCommsSystem(
                        node_id=engine.config.device_id,
                        auth_key=getattr(engine.config, 'auth_key', 'ghostops'),
                        data_dir=comms_data_dir,
                        master_ip=None if engine.mode == 'master' else getattr(engine.config, 'master_ip', None),
                        master_port=engine.config.local_port
                    )
                    engine.ghost_comms.start()
                    print("[DEV] ✅ GhostLang transport system initialized")
                
                # Get all core files - INCLUDING UI FILES so Windows/Linux look the same
                project_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))  # Go up one level from core/
                core_files = [
                    # Platform entry points
                    'platforms/kali.py', 'platforms/windows.py', 'platforms/android.py',
                    # Core engine files
                    'core/ghostops_adapter.py', 'core/ghostops_core.py', 'core/ui_mirror_system.py',
                    'core/unified_ui_engine.py', 'core/unified_sync_authority.py',
                    # UI and sync files
                    'core/opas_core.py', 'core/ghostops_cli.py',
                    # Root level files
                    'kali.py', 'windows.py', 'android.py', 'autolaunch.py',
                ]
                
                # Also sync all files in core/ directory (UI components)
                import glob
                core_dir = os.path.join(project_dir, 'core')
                if os.path.exists(core_dir):
                    for py_file in glob.glob(os.path.join(core_dir, '*.py')):
                        rel_path = os.path.relpath(py_file, project_dir)
                        if rel_path not in core_files:
                            core_files.append(rel_path.replace('\\', '/'))
                
                pushed_to = []
                failed = []
                files_pushed = 0
                
                # Get target nodes (try registered nodes first)
                target_nodes = [
                    device_id
                    for device_id, node_info in engine.state.nodes.items()
                    if device_id != engine.config.device_id
                ]
                
                # If no registered nodes, GhostLang will use USB/mesh fallback automatically
                if not target_nodes:
                    print("[DEV] No registered nodes - GhostLang will use USB/mesh fallback")
                    target_nodes = [None]  # None = broadcast to all available transports
                
                print(f"[DEV] Pushing {len(core_files)} files via GhostLang transport ({engine.ghost_comms.transport_mode.value})...")
                
                # Push each file using GhostLang's automatic transport selection
                for filename in core_files:
                    # Handle both relative paths (core/file.py) and absolute paths
                    if os.path.isabs(filename):
                        file_path = filename
                    else:
                        file_path = os.path.join(project_dir, filename)
                    
                    if not os.path.exists(file_path):
                        print(f"[DEV] [SKIP] File not found: {file_path}")
                        continue
                    
                    # Try to push to each target node
                    file_success = False
                    for target_node in target_nodes:
                        try:
                            success = engine.ghost_comms.send_file(
                                file_path=file_path,
                                target_node=target_node,
                                priority=CommandPriority.HIGH
                            )
                            
                            if success:
                                files_pushed += 1
                                file_success = True
                                print(f"[DEV] [OK] Queued {filename} via {engine.ghost_comms.transport_mode.value}")
                                break  # Success, move to next file
                            else:
                                print(f"[DEV] [WARN] Failed to queue {filename} to {target_node or 'broadcast'}")
                                
                        except Exception as e:
                            print(f"[DEV] [ERROR] Error pushing {filename}: {e}")
                    
                    if file_success:
                        # Track successful pushes
                        for target_node in target_nodes:
                            node_id = target_node or 'broadcast'
                            if node_id not in pushed_to:
                                pushed_to.append(node_id)
                    else:
                        # Track failures
                        for target_node in target_nodes:
                            node_id = target_node or 'broadcast'
                            if node_id not in failed:
                                failed.append(node_id)
                
                print(f"[DEV] ⚡ GhostLang push complete: {files_pushed} files queued, transport: {engine.ghost_comms.transport_mode.value}")
                
                # CRITICAL FIX: Also rebuild manifest for UnifiedSyncAuthority (mesh sync)
                # This ensures peers can sync via standard polling even if GhostLang fails
                if hasattr(engine, 'sync_authority') and engine.sync_authority:
                    try:
                        engine.sync_authority._rebuild_manifest()
                        manifest = engine.sync_authority.get_manifest()
                        manifest_files = len(manifest.get('files', {}))
                        version = manifest.get('version', 0)
                        print(f"[SYNC] ✅ Manifest rebuilt: {manifest_files} files, version {version}")
                        print(f"[SYNC] ✅ Peers will auto-sync within 5 seconds (polling)")
                    except Exception as e:
                        print(f"[SYNC] ⚠️  Error rebuilding manifest: {e}")
                        import traceback
                        traceback.print_exc()
                
                self.send_json({
                    'status': 'ok',
                    'pushed_to': pushed_to,
                    'failed': failed,
                    'files_count': files_pushed,
                    'transport_mode': engine.ghost_comms.transport_mode.value,
                    'message': f'Queued {files_pushed} files via GhostLang ({engine.ghost_comms.transport_mode.value})'
                })
                return
                
            except ImportError as e:
                print(f"[DEV] [ERROR] GhostLang not available: {e}")
                import traceback
                traceback.print_exc()
                self.send_json({
                    'status': 'error',
                    'error': f'GhostLang not available: {str(e)}. GhostLang should be merged in ghostlang/ directory.',
                    'pushed_to': [],
                    'failed': []
                })
                return
            except Exception as e:
                import traceback
                traceback.print_exc()
                print(f"[DEV] [ERROR] GhostLang push failed: {e}")
                self.send_json({
                    'status': 'error',
                    'error': f'GhostLang push failed: {str(e)}',
                    'pushed_to': [],
                    'failed': []
                })
                return
        
        if self.path == '/file/push_update':
            # UNIFIED SYNC AUTHORITY: Update master manifest, peers auto-pull
            if hasattr(engine, 'sync_authority') and engine.sync_authority and engine.sync_authority.is_master:
                data = self.read_json()
                file_path = data.get('file_path')
                
                if file_path:
                    # Update file in manifest (triggers version bump)
                    success = engine.sync_authority.update_file(file_path)
                    if success:
                        version = engine.sync_authority.state_manifest['version']
                        self.send_json({
                            'status': 'ok',
                            'message': f'File updated in manifest (version {version}). Peers will auto-pull within 2 seconds.',
                            'version': version
                        })
                    else:
                        self.send_json({
                            'status': 'ok',
                            'message': 'File unchanged (hash matches)',
                            'version': engine.sync_authority.state_manifest['version']
                        })
                else:
                    # Rebuild entire manifest
                    engine.sync_authority._rebuild_manifest()
                    version = engine.sync_authority.state_manifest['version']
                    self.send_json({
                        'status': 'ok',
                        'message': f'Manifest rebuilt (version {version}). Peers will auto-pull within 2 seconds.',
                        'version': version
                    })
                return
            
            # Legacy fallback (for compatibility)
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror and engine.ui_mirror.is_master:
                data = self.read_json()
                file_path = data.get('file_path')
                watch_paths = data.get('watch_paths')
                
                if file_path:
                    # Single file update
                    metadata = engine.ui_mirror.register_file(file_path)
                    if metadata:
                        change = {
                            'action': 'modified',
                            'file': os.path.basename(file_path),
                            'absolute_path': file_path,
                            'metadata': metadata
                        }
                        result = engine.ui_mirror.propagate_file_update(change)
                        self.send_json({'status': 'ok', 'result': result})
                    else:
                        self.send_json({'status': 'error', 'error': 'Failed to register file'})
                else:
                    # Full sync
                    result = engine.ui_mirror.sync_all_files(watch_paths)
                    self.send_json({'status': 'ok', 'result': result})
            else:
                self.send_json({'status': 'error', 'error': 'Not master or UI Mirror not available'})
            return
        
        if self.path == '/file/pull_updates':
            # Pull updates from master (mirror endpoint)
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                result = engine.ui_mirror.pull_updates_from_master()
                self.send_json({'status': 'ok' if result.get('success') else 'error', 'result': result})
            else:
                self.send_json({'status': 'error', 'error': 'UI Mirror System not available'})
            return
        
        if self.path == '/file/registry':
            # Get file registry status
            if hasattr(engine, 'ui_mirror') and engine.ui_mirror:
                self.send_json({
                    'status': 'ok',
                    'registry': engine.ui_mirror.file_registry,
                    'count': len(engine.ui_mirror.file_registry),
                    'is_master': engine.ui_mirror.is_master
                })
            else:
                self.send_json({'status': 'error', 'error': 'UI Mirror System not available'})
            return
        
        # NOGOE CLI command execution (POST)
        if self.path.startswith('/command/execute'):
            try:
                data = self.read_json()
                command = data.get('command', '').strip()
                
                if not command:
                    self.send_json({'status': 'error', 'output': 'No command provided'})
                    return
                
                # Try NOGOE handler first
                try:
                    import sys
                    import os
                    parent_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
                    if parent_dir not in sys.path:
                        sys.path.insert(0, parent_dir)
                    from nogoe_command_handler import NOGOECommandHandler
                    handler = NOGOECommandHandler(engine)
                    result = handler.execute_command(command)
                    GhostOpsServer.add_log(f"[COMMAND] {command} -> {result.get('status', 'unknown')}", 'SYSTEM')
                    self.send_json(result)
                    return
                except (ImportError, Exception) as e:
                    # Fallback: Simple command handling
                    result = self._handle_simple_command(command, engine)
                    self.send_json(result)
                    return
            except Exception as e:
                import traceback
                traceback.print_exc()
                self.send_json({'status': 'error', 'output': f'Command execution failed: {str(e)}'})
                return
        
        # Unknown endpoint
        self.send_json({'status': 'error', 'message': 'Unknown endpoint'})


class GhostOpsServerHTTPServer(HTTPServer):
    """Custom HTTP server with engine integration"""
    def __init__(self, *args, engine=None, get_html=None, **kwargs):
        super().__init__(*args, **kwargs)
        self.engine = engine
        # CRITICAL FIX: Store get_html and ensure it's callable
        if get_html and not callable(get_html):
            raise ValueError(f"get_html must be callable, got {type(get_html)}")
        self.get_html = get_html
        self.ws_clients = []  # WebSocket clients
        self.ws_lock = threading.Lock()
        # Set engine reference for unified time sync
        if engine:
            GhostOpsServer._engine_ref = engine
            # Add startup message to log buffer
            platform = engine.platform if hasattr(engine, 'platform') else 'unknown'
            mode = 'MASTER' if engine.is_master() else 'PEER'
            port = engine.config.local_port if hasattr(engine, 'config') else 'unknown'
            GhostOpsServer.add_log(f"GhostOps {mode} server starting on port {port} ({platform})", 'SYSTEM')


class GhostOpsAdapter:
    """Platform adapter factory"""
    
    @staticmethod
    def create_master_adapter(platform='unknown', port=7890, master_ip=None):
        """
        Create a master node adapter
        
        Args:
            platform: 'linux', 'windows', 'android', None, or 'unknown' (auto-detects)
            port: Port to listen on
            master_ip: Optional override for local IP
        """
        engine = GhostOpsEngine(platform=platform, mode='master')
        
        # Override port if provided
        if port:
            engine.config.local_port = port
        
        # Override IP if provided
        if master_ip:
            engine.config.local_ip = master_ip
        
        return engine
    
    @staticmethod
    def create_peer_adapter(platform='unknown', master_ip=None, local_port=None, port=None):
        """
        Create a peer node adapter
        
        Args:
            platform: 'linux', 'windows', 'android', None, or 'unknown' (auto-detects)
            master_ip: IP of master node
            local_port: Port to listen on locally
            port: Alias for local_port (for compatibility)
        """
        # Support both 'port' and 'local_port' arguments
        if port is not None and local_port is None:
            local_port = port
        engine = GhostOpsEngine(platform=platform, mode='peer')
        
        # Set master IP
        if master_ip:
            engine.config.master_ip = master_ip
        
        # Override local port if provided
        if local_port:
            engine.config.local_port = local_port
        
        return engine
    
    @staticmethod
    def start_master_server(engine, html_provider, auto_open_browser=True):
        """
        Start master server
        
        Args:
            engine: GhostOpsEngine instance
            html_provider: Function that returns HTML string
            auto_open_browser: Whether to auto-open browser
        """
        # Initialize Mesh API token
        GhostOpsServer._generate_mesh_token()
        token = GhostOpsServer._mesh_api_token
        
        print(f"""
===========================================
  GHOSTOPS MASTER NODE - {engine.config.local_ip}:{engine.config.local_port}
===========================================
  AUTH KEY: {engine.config.auth_key}
  DEVICE ID: {engine.config.device_id}
  PLATFORM: {engine.platform.upper()}
===========================================
  MESH API TOKEN: {token}
  MESH API ENDPOINTS: http://{engine.config.local_ip}:{engine.config.local_port}/mesh/*
  AUTH HEADER: X-Mesh-Token: {token}
===========================================
""")
        
        server = GhostOpsServerHTTPServer(
            ('0.0.0.0', engine.config.local_port),
            GhostOpsServer,
            engine=engine,
            get_html=html_provider
        )
        
        print(f"[+] Server running at http://{engine.config.local_ip}:{engine.config.local_port}")
        print(f"[+] Connect other devices to this master node")
        print(f"[+] Open the UI in your browser at: http://localhost:{engine.config.local_port}")
        
        # Add startup messages to log buffer for terminal display
        GhostOpsServer.add_log(f"GhostOps MASTER server started on port {engine.config.local_port}", 'SYSTEM')
        GhostOpsServer.add_log(f"Platform: {engine.platform.upper()} | Device ID: {engine.config.device_id}", 'SYSTEM')
        GhostOpsServer.add_log(f"Mesh API Token: {token}", 'SYSTEM')
        GhostOpsServer.add_log("Server ready - waiting for connections...", 'SYSTEM')
        
        if auto_open_browser and WEBBROWSER_AVAILABLE and webbrowser:
            threading.Thread(
                target=lambda: webbrowser.open(f"http://localhost:{engine.config.local_port}")
            ).start()
        
        # Start cleanup thread
        def cleanup_loop():
            while True:
                try:
                    engine.cleanup_task()
                except Exception as e:
                    print(f"[!] Error in cleanup: {e}")
                time.sleep(30)
        
        threading.Thread(target=cleanup_loop, daemon=True).start()
        
        # Start continuous status monitoring (keeps terminal alive with activity)
        def status_monitor_loop():
            """Print periodic status updates to keep terminal showing activity"""
            from datetime import datetime
            last_status_time = 0
            status_interval = 10  # Print status every 10 seconds
            
            while True:
                try:
                    current_time = time.time()
                    
                    # Print status every interval
                    if current_time - last_status_time >= status_interval:
                        timestamp = datetime.now().strftime('%H:%M:%S')
                        
                        # Get engine status
                        if hasattr(engine, 'get_status'):
                            status = engine.get_status()
                            nodes = status.get('nodes', {})
                            role = 'MASTER' if engine.is_master() else 'PEER'
                            print(f"[{timestamp}] [STATUS] Role: {role}, Nodes: {len(nodes)}")
                            
                            # Show connected peers
                            if nodes:
                                for node_id, node_data in list(nodes.items())[:3]:
                                    platform = node_data.get('platform', 'unknown')
                                    ip = node_data.get('ip', 'unknown')
                                    print(f"[{timestamp}] [MESH]   - {node_id} ({platform}) @ {ip}")
                        
                        # Show sync activity
                        if hasattr(engine, 'sync_authority') and engine.sync_authority:
                            version = engine.sync_authority.state_manifest.get('version', 0)
                            print(f"[{timestamp}] [SYNC] Manifest version: {version}")
                        
                        # Show connection status for peers
                        if hasattr(engine, 'connection_manager') and not engine.is_master():
                            master_ip = getattr(engine.config, 'master_ip', 'unknown')
                            print(f"[{timestamp}] [MESH] Connected to master: {master_ip}")
                        
                        last_status_time = current_time
                    
                    time.sleep(1)  # Check every second
                except Exception as e:
                    time.sleep(5)  # On error, wait longer
        
        threading.Thread(target=status_monitor_loop, daemon=True).start()
        print("[+] Status monitor started - terminal will show continuous activity")
        
        try:
            server.serve_forever()
        except KeyboardInterrupt:
            print("[+] Shutting down server")
            server.shutdown()
    
    @staticmethod
    def start_peer_server(engine, html_provider, auto_open_browser=True):
        """
        Start peer server
        
        Args:
            engine: GhostOpsEngine instance
            html_provider: Function that returns HTML string
            auto_open_browser: Whether to auto-open browser
        """
        print(f"""
===========================================
  GHOSTOPS PEER NODE - {engine.platform.upper()}
===========================================
  MASTER: {engine.config.master_ip}:{engine.config.master_port}
  LOCAL: 127.0.0.1:{engine.config.local_port}
  DEVICE ID: {engine.config.device_id}
===========================================
""")
        
        # Add startup messages to log buffer for terminal display
        GhostOpsServer.add_log(f"GhostOps PEER server started on port {engine.config.local_port}", 'SYSTEM')
        GhostOpsServer.add_log(f"Platform: {engine.platform.upper()} | Device ID: {engine.config.device_id}", 'SYSTEM')
        if engine.config.master_ip:
            GhostOpsServer.add_log(f"Connecting to master at {engine.config.master_ip}:{engine.config.master_port}...", 'SYSTEM')
        else:
            GhostOpsServer.add_log("No master IP configured - will auto-discover...", 'SYSTEM')
        
        # Try initial connection to master (non-blocking) - ESTABLISH CLIENT CONNECTION
        def try_initial_connection():
            # If no master IP, try auto-discovery first
            if not engine.config.master_ip:
                print(f"[AUTO-DISCOVERY] No master IP configured, scanning network...")
                if hasattr(engine, 'connection_manager'):
                    discovered_ip = engine.connection_manager._auto_discover_master()
                    if discovered_ip:
                        engine.config.master_ip = discovered_ip
                        print(f"[AUTO-DISCOVERY] [OK] Found master at {discovered_ip}")
                    else:
                        print(f"[AUTO-DISCOVERY] [WARN] No master found, will keep scanning in background")
                        engine.state.connection_status = 'standalone'
                        engine.state.standalone_mode = True
                        return
            
            # Try to connect to master - ESTABLISH CLIENT CONNECTION
            if engine.config.master_ip:
                print(f"[CONNECTION] Establishing client connection to master at {engine.config.master_ip}:{engine.config.master_port}...")
                result = GhostOpsNetwork.connect_to_master(
                    engine.config.master_ip,
                    engine.config.master_port,
                    engine.config.device_id,
                    engine.platform,
                    engine.config.local_port  # Tell master our listening port
                )
                
                if result and 'auth_key' in result:
                    engine.config.auth_key = result['auth_key']
                    print(f"[+] [OK] Client connection established - got auth key from master")
                    print(f"[+] [OK] Mesh coordination active - connected to master")
                    engine.state.connection_status = 'connected'
                    engine.state.standalone_mode = False
                elif result:
                    print(f"[+] [OK] Client connection established - mesh coordination active")
                    engine.state.connection_status = 'connected'
                    engine.state.standalone_mode = False
                else:
                    print(f"[!] [WARN] Could not connect to master {engine.config.master_ip}:{engine.config.master_port}")
                    print(f"[!] [WARN] Will keep trying in background (reconnection loop active)")
                    engine.state.connection_status = 'standalone'
                    engine.state.standalone_mode = True
            else:
                print(f"[+] No master configured, will auto-discover in background")
                engine.state.connection_status = 'standalone'
                engine.state.standalone_mode = True
        
        # Try connection in background - don't block startup
        threading.Thread(target=try_initial_connection, daemon=True).start()
        
        server = GhostOpsServerHTTPServer(
            ('0.0.0.0', engine.config.local_port),
            GhostOpsServer,
            engine=engine,
            get_html=html_provider
        )
        
        # Get actual network IP for better accessibility info
        try:
            import socket
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(('8.8.8.8', 80))
            network_ip = s.getsockname()[0]
            s.close()
            print(f"[+] Server running at http://localhost:{engine.config.local_port}")
            print(f"[+] 🌐 Network access: http://{network_ip}:{engine.config.local_port}")
        except:
            print(f"[+] Server running at http://localhost:{engine.config.local_port}")
        
        if auto_open_browser and WEBBROWSER_AVAILABLE and webbrowser:
            threading.Thread(
                target=lambda: webbrowser.open(f"http://localhost:{engine.config.local_port}")
            ).start()
        
        # Start reconnection loop
        if hasattr(engine, 'connection_manager'):
            engine.connection_manager.start_reconnection_loop()
        
        # Track last sync times for files to detect changes
        last_file_sync_times = {}
        
        def perform_file_sync(retry_count=0, max_retries=1):
            """Perform file sync - ALWAYS RUN, NO EXCUSES"""
            if not engine.config.master_ip:
                return False
            
            try:
                # Get local file versions
                peer_files_info = GhostOpsFileManager.get_core_files_info()
                # REMOVED: Fake "Checking for updates" message - only log when ACTUAL updates happen
                
                # Request sync from master (master sends newer files to peer)
                import urllib.request
                request = urllib.request.Request(
                    f"http://{engine.config.master_ip}:{engine.config.master_port}/sync/files",
                    data=json.dumps({'files': peer_files_info}).encode(),
                    headers={'Content-Type': 'application/json'}
                )
                
                with urllib.request.urlopen(request, timeout=30) as response:
                    sync_result = json.loads(response.read().decode())
                    if sync_result.get('status') == 'sync_ready':
                        files_to_sync = sync_result.get('files', {})
                        # ONLY print if there are ACTUAL files to sync (not empty dict)
                        if files_to_sync and len(files_to_sync) > 0:
                            GhostOpsServer._timestamped_print(f"[FILE SYNC] 📥 {len(files_to_sync)} file(s) ACTUALLY need updating from master")
                            sync_success = True
                            
                            for filename, file_info in files_to_sync.items():
                                content = file_info.get('content', '')
                                expected_size = file_info.get('size', 0)
                                
                                # Determine save location - Desktop/Documents for user-friendliness
                                import os
                                home = os.path.expanduser('~')
                                
                                # Platform-specific Desktop/Documents paths
                                if engine.platform == 'windows':
                                    # Windows: Use project directory FIRST to avoid path validation issues
                                    # Then fallback to Desktop/Documents if project dir not writable
                                    project_dir = os.getcwd()
                                    save_dirs = [
                                        project_dir,  # Project directory FIRST - avoids path validation blocks
                                        os.path.join(home, 'Desktop'),
                                        os.path.join(home, 'Documents'),
                                        os.path.join(home, 'Downloads'),
                                    ]
                                elif engine.platform == 'android':
                                    # Android: Termux sandbox ~/ghost/ghost (only writable location)
                                    termux_home = os.path.expanduser('~')
                                    sandbox_dir = os.path.join(termux_home, 'ghost', 'ghost')
                                    os.makedirs(sandbox_dir, exist_ok=True)
                                    save_dirs = [
                                        sandbox_dir,  # Termux sandbox FIRST - only writable location
                                        termux_home,  # Fallback to home
                                        os.getcwd()  # Current working directory
                                    ]
                                else:  # Linux/macOS
                                    save_dirs = [
                                        os.path.join(home, 'Desktop'),
                                        os.path.join(home, 'Documents'),
                                        os.path.join(home, 'Downloads'),
                                        os.getcwd()
                                    ]
                                
                                # Find first writable directory
                                save_dir = os.getcwd()
                                for test_dir in save_dirs:
                                    try:
                                        if os.path.exists(test_dir) and os.access(test_dir, os.W_OK):
                                            save_dir = test_dir
                                            break
                                    except:
                                        continue
                                
                                # Ensure directory exists
                                os.makedirs(save_dir, exist_ok=True)
                                
                                # Save to Desktop/Documents (user-friendly location)
                                file_path = os.path.join(save_dir, filename)
                                
                                if not content:
                                    GhostOpsServer._timestamped_print(f"[FILE SYNC] [ERROR] No content provided for {filename}")
                                    sync_success = False
                                    continue
                                
                                # SMART SYNC: Check if file exists and create backup
                                import shutil
                                backup_created = False
                                if os.path.exists(file_path):
                                    # Check if it's a backup file (protect these)
                                    filename_lower = os.path.basename(file_path).lower()
                                    is_backup = any(kw in filename_lower for kw in [
                                        'backup', 'checkpoint', '.bak', '.orig', '_backup', '_old'
                                    ])
                                    
                                    if is_backup:
                                        GhostOpsServer._timestamped_print(f"[FILE SYNC] [SKIP] Protected backup file: {filename}")
                                        continue
                                    
                                    # Create backup before overwriting
                                    try:
                                        backup_dir = os.path.join(save_dir, '.sync_backups')
                                        os.makedirs(backup_dir, exist_ok=True)
                                        timestamp = int(time.time())
                                        backup_name = f"{os.path.basename(filename)}.backup_{timestamp}"
                                        backup_path = os.path.join(backup_dir, backup_name)
                                        shutil.copy2(file_path, backup_path)
                                        backup_created = True
                                        GhostOpsServer._timestamped_print(f"[FILE SYNC] [BACKUP] Created backup: {backup_name}")
                                    except Exception as e:
                                        GhostOpsServer._timestamped_print(f"[FILE SYNC] [WARN] Could not create backup: {e}")
                                
                                # Save file to Desktop/Documents (user-friendly location)
                                if GhostOpsFileManager.save_file(file_path, content, is_base64=True):
                                    # VERIFY file was actually updated
                                    if os.path.exists(file_path):
                                        actual_size = os.path.getsize(file_path)
                                        if actual_size == expected_size:
                                            # CLEAR MESSAGE: Tell user EXACTLY where file is
                                            full_path_msg = f"[FILE SYNC] [OK] {filename} → {file_path} ({actual_size} bytes)"
                                            GhostOpsServer._timestamped_print(full_path_msg)
                                            GhostOpsServer.add_log(full_path_msg, device_name=engine.config.device_id)
                                            last_file_sync_times[filename] = time.time()
                                            engine.state.save_state_cache()
                                        else:
                                            GhostOpsServer._timestamped_print(f"[FILE SYNC] [ERROR] Size mismatch for {filename}: expected {expected_size}, got {actual_size}")
                                            sync_success = False
                                    else:
                                        GhostOpsServer._timestamped_print(f"[FILE SYNC] [ERROR] File {file_path} does not exist after save")
                                        sync_success = False
                                else:
                                    GhostOpsServer._timestamped_print(f"[FILE SYNC] [ERROR] Failed to save {filename}")
                                    sync_success = False
                            
                            if sync_success and len(files_to_sync) > 0:
                                # Only log if files actually synced (not fake placeholder)
                                # FIX: files_to_sync is a dict, convert to list for slicing
                                file_names = list(files_to_sync.keys())[:5]
                                file_list_str = ', '.join([os.path.basename(f) for f in file_names])
                                msg = f"[FILE SYNC] [OK] Synced {len(files_to_sync)} file(s): {file_list_str}"
                                if len(files_to_sync) > 5:
                                    msg += f" and {len(files_to_sync) - 5} more"
                                GhostOpsServer._timestamped_print(msg)
                                GhostOpsServer.add_log(msg, device_name=engine.config.device_id)
                            
                            return sync_success
                        else:
                            # All files up to date - NO MESSAGE (user requested removal of fake messages)
                            return True
                    else:
                        GhostOpsServer._timestamped_print(f"[FILE SYNC] [WARN] Unexpected sync status: {sync_result.get('status')}")
                        return False
                        
            except urllib.error.URLError as e:
                if retry_count < max_retries:
                    GhostOpsServer._timestamped_print(f"[FILE SYNC] [WARN] Connection error (retry {retry_count+1}/{max_retries}): {e}")
                    return perform_file_sync(retry_count + 1, max_retries)
                else:
                    # Don't print error every time - just fail silently and retry
                    return False
            except Exception as e:
                print(f"[FILE SYNC] [ERROR] Error during sync: {e}")
                return False
        
        # Start sync task with forced sync on startup - ALWAYS RUN
        def sync_loop():
            """WiFi-style auto-sync: Only syncs when IN RANGE, auto-syncs when back in range"""
            startup_sync_done = False
            consecutive_failures = 0
            sync_interval = 5  # Start with 5 seconds - reduced CPU load (was 1s)
            was_in_range = False
            
            while True:
                try:
                    # Check if device is in range (like WiFi signal detection)
                    in_range = (engine.state.connection_status == 'connected' and 
                               not engine.state.standalone_mode)
                    
                    # Only sync if IN RANGE (like WiFi only syncs when connected)
                    if engine.config.master_ip and in_range:
                        try:
                            # FIRST: Try to sync files IMMEDIATELY when in range
                            file_sync_result = perform_file_sync()
                            if file_sync_result:
                                consecutive_failures = 0
                                sync_interval = 5  # Reduced CPU load (was 1s)
                                print(f"[FILE SYNC] ✅ Sync successful (device in range)")
                            else:
                                consecutive_failures += 1
                                sync_interval = min(2 + consecutive_failures, 5)  # Max 5 seconds
                            
                            # SECOND: Sync state data when in range
                            data = GhostOpsNetwork.sync_with_master(
                                engine.config.master_ip,
                                engine.config.master_port,
                                engine  # Pass as positional argument, not keyword
                            )
                            if data:
                                engine.state.nodes = data.get('nodes', {})
                                engine.state.tool_state = data.get('tool')
                                engine.state.page_state = data.get('page', 1)
                                engine.state.authority = data.get('authority')
                                if data.get('last_sync', 0) > engine.state.last_sync:
                                    engine.state.update_sync(data.get('last_sync'))
                                engine.state.save_state_cache()
                                engine.state.connection_status = 'connected'
                                engine.state.standalone_mode = False
                                
                                # Auto-sync when coming back in range (like WiFi auto-sync) - CHECKPOINT RESTORED
                                if not was_in_range:
                                    print(f"[+] 📶 Device BACK IN RANGE - Auto-syncing files...")
                                    print(f"[+] Reconnected to master: {len(engine.state.nodes)} nodes")
                                    # Force immediate sync when back in range
                                    if not startup_sync_done:
                                        print(f"[FILE SYNC] 🚀 IMMEDIATE SYNC (device back in range)...")
                                        startup_success = perform_file_sync()
                                        startup_sync_done = True
                                        if startup_success:
                                            print(f"[FILE SYNC] ✅ Auto-sync completed (like WiFi auto-sync)")
                                
                                was_in_range = True
                                consecutive_failures = 0
                                
                                # FORCED SYNC ON STARTUP - do this once when first connected - CHECKPOINT RESTORED
                                if not startup_sync_done:
                                    print(f"[FILE SYNC] 🚀 STARTUP: Performing forced sync...")
                                    startup_success = perform_file_sync()
                                    startup_sync_done = True
                                    if startup_success:
                                        print(f"[FILE SYNC] ✅ Startup sync completed successfully")
                                    else:
                                        print(f"[FILE SYNC] ⚠️ Startup sync had issues, will retry")
                            else:
                                # Connection lost - device out of range
                                if was_in_range:
                                    print(f"[!] 📴 Device OUT OF RANGE - Stopping sync (like Mobile Data)")
                                was_in_range = False
                                engine.state.connection_status = 'standalone'
                                engine.state.standalone_mode = True
                                consecutive_failures += 1
                                sync_interval = 5  # Slower when out of range
                        except Exception as e:
                            # Connection failed - device out of range
                            if was_in_range:
                                print(f"[!] 📴 Connection lost - Device OUT OF RANGE")
                            was_in_range = False
                            engine.state.connection_status = 'standalone'
                            engine.state.standalone_mode = True
                            consecutive_failures += 1
                            sync_interval = 5  # Slower when out of range
                            print(f"[FILE SYNC] ⚠️ Sync error (out of range): {e}")
                    else:
                        # No master configured or out of range - standalone mode
                        if was_in_range:
                            print(f"[!] 📴 Device OUT OF RANGE - Standalone mode (like Mobile Data)")
                        was_in_range = False
                        engine.state.connection_status = 'standalone'
                        engine.state.standalone_mode = True
                        sync_interval = 5  # Slower when out of range
                    
                    # Occasionally re-register if connected and in range
                    if engine.state.connection_status == 'connected' and in_range and random.random() < 0.2:
                        GhostOpsNetwork.connect_to_master(
                            engine.config.master_ip,
                            engine.config.master_port,
                            engine.config.device_id,
                            engine.platform,
                            engine.config.local_port
                        )
                    
                except Exception as e:
                    print(f"[!] Error in sync task: {e}")
                    import traceback
                    traceback.print_exc()
                
                # WiFi-style sync: Fast when in range, slower when out of range
                time.sleep(sync_interval)
        
        threading.Thread(target=sync_loop, daemon=True).start()
        
        # Start file receiver if available
        try:
            from file_transfer_module import FileTransferManager
            def start_file_receiver():
                try:
                    default_dir = os.path.join(os.path.expanduser('~'), 'GhostOps', 'downloads')
                    if engine.platform == 'android':
                        try:
                            default_dir = os.path.join(os.path.expanduser('~'), 'storage', 'downloads', 'GhostOps')
                        except:
                            pass
                except:
                    default_dir = os.path.join(os.path.expanduser('~'), 'GhostOps', 'downloads')
                
                ftm = FileTransferManager(save_dir=default_dir)
                os.makedirs(ftm.save_dir, exist_ok=True)
                
                def loop():
                    try:
                        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                        app_port = 51820 + 1000
                        sock.bind(('0.0.0.0', app_port))
                        sock.settimeout(1.0)
                        print(f"[+] File receiver listening on UDP {app_port}, saving to {ftm.save_dir}")
                        while True:
                            try:
                                data, addr = sock.recvfrom(1024 * 128)
                                ftm.handle_incoming_udp(data, addr)
                            except socket.timeout:
                                pass
                            except Exception:
                                pass
                    except Exception as e:
                        print(f"[!] File receiver error: {e}")
                
                threading.Thread(target=loop, daemon=True).start()
            
            start_file_receiver()
        except ImportError:
            pass  # File transfer not available
        
        try:
            server.serve_forever()
        except KeyboardInterrupt:
            print("[+] Shutting down")
            server.shutdown()

