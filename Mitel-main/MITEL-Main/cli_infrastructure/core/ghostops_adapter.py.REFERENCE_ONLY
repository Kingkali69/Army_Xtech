                    self.send_json({'status': 'error', 'message': str(e)})
                return
            
            if self.path == '/ui_action':
                # Trigger UI action and broadcast to mesh
                try:
                    data = self.read_json()
                    if hasattr(engine, 'ui_sync') and engine.ui_sync:
                        success = engine.ui_sync.trigger_action(
                            data.get('action_type'),
                            data.get('target'),
                            data.get('data', {})
                        )
                        # Get sequence safely (works with unified engine)
                        sequence = 0
                        if hasattr(engine.ui_sync, 'current_state'):
                            sequence = getattr(engine.ui_sync.current_state, 'sequence', 0)
                        elif hasattr(engine.ui_sync, 'sequence_counter'):
                            sequence = engine.ui_sync.sequence_counter
                        self.send_json({
                            'status': 'ok' if success else 'error',
