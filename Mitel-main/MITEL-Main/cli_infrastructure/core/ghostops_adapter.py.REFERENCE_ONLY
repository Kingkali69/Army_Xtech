            self.send_json({'status': 'error', 'message': 'Unknown endpoint'})
    
    def do_POST(self):
        """Handle POST requests"""
        engine = self.server.engine
        
        # ═══════════════════════════════════════════════════════════════
        # MESH API ENDPOINTS (External AI Agent Access)
        # ═══════════════════════════════════════════════════════════════
        if self.path.startswith('/mesh/'):
            # Check authentication
            if not self._check_mesh_auth():
                return
            
            if self.path == '/mesh/execute':
                # POST /mesh/execute - Execute commands on platform(s)
                try:
                    data = self.read_json()
                    platforms = data.get('platforms', [])
                    command = data.get('command', '')
                    async_mode = data.get('async', False)
                    
                    if not command:
                        self.send_json({'status': 'error', 'error': 'Missing command'}, status=400)
                        return
                    
                    # Normalize platforms
                    if platforms == 'all' or platforms == ['all']:
                        # Get all connected platforms
                        platforms = []
                        if hasattr(engine, 'state') and hasattr(engine.state, 'nodes'):
                            for device_id, node_info in engine.state.nodes.items():
                                platform = node_info.get('platform', '').lower()
                                if platform and platform not in platforms:
                                    platforms.append(platform)
                        # Add master platform
                        master_platform = engine.platform if hasattr(engine, 'platform') else 'linux'
                        if master_platform not in platforms:
                            platforms.append(master_platform)
                    
                    if not platforms:
                        self.send_json({'status': 'error', 'error': 'No platforms available'}, status=400)
                        return
                    
                    # Create job if async
                    job_id = None
                    if async_mode:
                        job_id = self._create_job()
                    
                    # Execute on each platform
                    results = {}
                    
                    def execute_platform(platform):
                        result = self._execute_on_platform(platform, command, job_id)
                        if async_mode:
                            self._update_job(job_id, platform, result)
                        else:
                            results[platform] = result
                    
                    if async_mode:
                        # Async execution - start threads
                        threads = []
                        for platform in platforms:
                            thread = threading.Thread(target=execute_platform, args=(platform,))
                            thread.daemon = True
                            thread.start()
                            threads.append(thread)
                        
                        # Wait a bit for initial execution
                        time.sleep(0.1)
                        
                        self.send_json({
                            'status': 'ok',
                            'job_id': job_id,
                            'message': 'Command executing asynchronously',
                            'platforms': platforms
                        })
                    else:
                        # Synchronous execution
                        for platform in platforms:
                            results[platform] = self._execute_on_platform(platform, command, job_id)
                        
                        self.send_json({
                            'status': 'ok',
                            'results': results
                        })
                except Exception as e:
                    import traceback
                    traceback.print_exc()
                    self.send_json({'status': 'error', 'error': str(e)}, status=500)
                return
            
            elif self.path == '/mesh/upload' or self.path == '/mesh/push_file':
                # POST /mesh/upload or /mesh/push_file - DIRECT FILE PUSH (bypasses all sync complexity)
                # Simple: Master pushes file → Peer receives → Peer saves → DONE
                try:
                    data = self.read_json()
                    platforms = data.get('platforms', [])
                    file_data = data.get('file_data', '')  # Base64 encoded
                    file_path = data.get('file_path', '')
                    
                    if not file_data or not file_path:
                        self.send_json({'status': 'error', 'error': 'Missing file_data or file_path'}, status=400)
                        return
                    
                    # Decode base64
                    try:
                        file_content = base64.b64decode(file_data)
                    except:
                        self.send_json({'status': 'error', 'error': 'Invalid base64 file_data'}, status=400)
                        return
                    
                    # Normalize platforms
                    if platforms == 'all' or platforms == ['all']:
                        # Get all connected platforms from nodes
                        platforms = []
                        if hasattr(engine, 'state') and hasattr(engine.state, 'nodes'):
                            for device_id, node_info in engine.state.nodes.items():
                                platform = node_info.get('platform', '').lower()
                                if platform and platform not in platforms:
                                    platforms.append(platform)
                        # Add master platform
                        master_platform = engine.platform if hasattr(engine, 'platform') else 'linux'
                        if master_platform not in platforms:
                            platforms.append(master_platform)
                    
                    if not platforms:
                        self.send_json({'status': 'error', 'error': 'No platforms available'}, status=400)
                        return
                    
                    results = {}
                    
                    # Push to each platform
                    for platform in platforms:
                        if platform == engine.platform:
                            # Save locally on master
                            try:
                                # Determine save directory
                                project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
                                target_path = os.path.join(project_root, file_path)
                                
                                # Ensure directory exists
                                os.makedirs(os.path.dirname(target_path), exist_ok=True)
                                
                                # Write file
                                with open(target_path, 'wb') as f:
                                    f.write(file_content)
                                
                                results[platform] = {
                                    'status': 'success',
                                    'message': f'File saved to {target_path}',
                                    'size': len(file_content)
                                }
                            except Exception as e:
                                results[platform] = {
                                    'status': 'error',
                                    'error': str(e)
                                }
                        else:
                            # Push to peer node
                            try:
                                # Find node with matching platform
                                target_node = None
                                target_ip = None
                                target_port = None
                                
                                if hasattr(engine, 'state') and hasattr(engine.state, 'nodes'):
                                    for device_id, node_info in engine.state.nodes.items():
                                        if node_info.get('platform', '').lower() == platform:
                                            target_node = device_id
                                            target_ip = node_info.get('ip')
                                            target_port = node_info.get('port', 7892)
                                            break
                                
                                if not target_ip:
                                    results[platform] = {
                                        'status': 'error',
                                        'error': f'Platform {platform} not found in mesh'
                                    }
                                    continue
                                
                                # Push file to peer via HTTP POST
                                url = f"http://{target_ip}:{target_port}/mesh/push_file_local"
                                push_data = {
                                    'file_path': file_path,
                                    'file_data': file_data  # Already base64 encoded
                                }
                                
                                req = urllib.request.Request(
                                    url,
                                    data=json.dumps(push_data).encode('utf-8'),
                                    headers={'Content-Type': 'application/json'}
                                )
                                
                                with urllib.request.urlopen(req, timeout=10) as response:
                                    peer_result = json.loads(response.read().decode('utf-8'))
                                    results[platform] = peer_result
                                    
                            except urllib.error.URLError as e:
                                results[platform] = {
                                    'status': 'error',
                                    'error': f'Failed to connect to {platform}: {str(e)}'
                                }
                            except Exception as e:
                                results[platform] = {
                                    'status': 'error',
                                    'error': str(e)
                                }
                    
                    self.send_json({
                        'status': 'ok',
                        'results': results
                    })
                except Exception as e:
                    self.send_json({'status': 'error', 'error': str(e)}, status=500)
                return
            
            elif self.path == '/mesh/execute_local':
                # Internal endpoint for peer nodes to execute commands locally
                try:
                    data = self.read_json()
                    command = data.get('command', '')
                    job_id = data.get('job_id')
                    
                    if not command:
                        self.send_json({'status': 'error', 'error': 'Missing command'}, status=400)
                        return
                    
                    import subprocess
                    result = subprocess.run(
                        command,
                        shell=True,
                        capture_output=True,
                        text=True,
                        timeout=30
                    )
                    
                    response = {
                        'status': 'success' if result.returncode == 0 else 'error',
                        'output': result.stdout,
                        'error': result.stderr,
                        'returncode': result.returncode
                    }
                    
                    self.send_json(response)
                except subprocess.TimeoutExpired:
                    self.send_json({'status': 'error', 'output': '', 'error': 'Command timeout'})
                except Exception as e:
                    self.send_json({'status': 'error', 'output': '', 'error': str(e)})
                return
            
            elif self.path == '/mesh/push_file_local':
                # Internal endpoint for peer nodes to receive and save files directly
                # BYPASSES ALL VALIDATION - Simple: Receive → Save → Done
                try:
                    data = self.read_json()
                    file_path = data.get('file_path', '')
                    file_data = data.get('file_data', '')  # Base64 encoded
                    
                    if not file_path or not file_data:
                        self.send_json({'status': 'error', 'error': 'Missing file_path or file_data'}, status=400)
                        return
                    
                    # Decode base64
                    try:
                        file_content = base64.b64decode(file_data)
                    except:
                        self.send_json({'status': 'error', 'error': 'Invalid base64 file_data'}, status=400)
                        return
                    
                    # Determine save location (project directory)
                    project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
                    target_path = os.path.join(project_root, file_path)
                    
                    # Normalize path (prevent directory traversal)
                    target_path = os.path.normpath(target_path)
                    project_root = os.path.normpath(project_root)
                    
                    # Security: Ensure path is within project
                    if not target_path.startswith(project_root):
                        self.send_json({'status': 'error', 'error': 'Path traversal blocked'}, status=403)
                        return
                    
                    # Ensure directory exists
                    os.makedirs(os.path.dirname(target_path), exist_ok=True)
                    
                    # Write file
                    with open(target_path, 'wb') as f:
                        f.write(file_content)
                    
                    # Verify it was written
                    if os.path.exists(target_path) and os.path.getsize(target_path) == len(file_content):
                        self.send_json({
                            'status': 'success',
                            'message': f'File saved to {target_path}',
                            'size': len(file_content),
                            'path': target_path
                        })
                    else:
                        self.send_json({
                            'status': 'error',
                            'error': 'File write verification failed'
                        })
                        
                except Exception as e:
                    self.send_json({'status': 'error', 'error': str(e)}, status=500)
                return
        
        # ═══════════════════════════════════════════════════════════════
        # UNIFIED SYNC AUTHORITY ENDPOINTS (Master only)
        # ═══════════════════════════════════════════════════════════════
        if self.path == '/sync/acknowledge':
            # POST /sync/acknowledge - Peer acknowledges receiving update (master only)
            try:
                data = self.read_json()
                node_id = data.get('node_id', 'unknown')
                version = data.get('version', 0)
                
                if hasattr(engine, 'sync_authority') and engine.sync_authority:
                    success = engine.sync_authority.acknowledge_update(node_id, version)
                    self.send_json({'status': 'ok' if success else 'error'})
                else:
                    self.send_json({'error': 'Sync authority not initialized'})
            except Exception as e:
                self.send_json({'error': str(e)})
            return
        
        # WebSocket API endpoint for sync
        if self.path == '/api/sync':
            data = self.read_json()
            device_name = data.get('device', engine.config.device_id)
            action = data.get('action', 'sync')
            
            # Log to command output
            msg = f"[{device_name.upper()}] {action.upper()} at {time.strftime('%H:%M:%S')}"
            print(msg)
            GhostOpsServer.add_log(msg, device_name=device_name)
            
            # Broadcast via WebSocket
            GhostOpsServer._broadcast_ws(self.server, json.dumps({'type': 'sync', 'device': device_name, 'action': action}))
            
            self.send_json({'ok': 1})
            return
        
        # Authentication (DISABLED - always allow in dev mode)
        if self.path == '/auth/login':
            device_name = engine.config.device_id
            msg = f"[{device_name.upper()}] AUTHENTICATED at {time.strftime('%H:%M:%S')}"
            print(msg)
            GhostOpsServer.add_log(msg, device_name=device_name)
            GhostOpsServer._broadcast_ws(self.server, json.dumps({'type': 'auth', 'device': device_name}))
            
            self.send_json({
                'status': 'authenticated',
                'token': 'dev-mode'
            })
            return
        
        # Ghost Agent Chat - Developer Mode Only
        if self.path == '/ghost/chat':
            data = self.read_json()
            user_message = data.get('message', '').strip()
            conversation_history = data.get('conversation_history', [])
            
            print(f"[GHOST] 💬 Message: {user_message}")
            print(f"[GHOST] 📚 Conversation history: {len(conversation_history)} messages")
            
            # Import INSIDE handler to avoid scoping issues
            try:
                from ghost_brain import generate_response as _generate_response
                from ghost_brain import check_model_status as _check_model_status
                from ghost_brain import load_model as _load_model
                ghost_brain_ready = True
                print("[GHOST CHAT] [OK] Ghost brain functions imported successfully")
            except Exception as import_error:
                print(f"[GHOST CHAT] [ERROR] Ghost brain import failed: {import_error}")
                import traceback
                traceback.print_exc()
                ghost_brain_ready = False
                _generate_response = None
                _check_model_status = None
                _load_model = None
            
            if not ghost_brain_ready or _generate_response is None or _check_model_status is None:
                # ALWAYS respond even if module unavailable
                msg_lower = user_message.lower().strip()
                if msg_lower in ['hi', 'hello', 'hey', 'sup', 'yo']:
                    response = "Hey! Ghost here. The AI model is still loading, but I'm listening. What's up?"
                elif 'how are you' in msg_lower:
                    response = "I'm good! Running in fallback mode right now. What do you need?"
                else:
                    response = f"I hear you: '{user_message}'. Ghost brain is loading. Try again in a moment!"
                self.send_json({'status': 'ok', 'response': response, 'mode': 'FALLBACK'})
                return
            
