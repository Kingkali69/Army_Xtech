    def _get_cors_headers(self):
        """Get CORS headers"""
        cors_headers = {}
        for header, value in GhostOpsHTTPHandler.send_cors_headers().items():
            cors_headers[header] = value
        return cors_headers
    
    def _handle_simple_command(self, command: str, engine) -> dict:
        """Simple command handler when NOGOE handler unavailable"""
        cmd_lower = command.strip().lower()
        
        if cmd_lower == 'help' or cmd_lower == '?':
            return {
                'status': 'ok',
                'output': '''╔══════════════════════════════════════════════════════════════╗
║ NOGOE CLI - IT Administrative Commands ║
╚══════════════════════════════════════════════════════════════╝
ENGINE LIFECYCLE:
  engine start - Start the engine
  engine stop - Stop the engine
  engine restart - Restart the engine
  engine status - Show engine status

NODE MANAGEMENT:
  node list - List all connected nodes
  node status <node-id> - Get node status

QUICK COMMANDS:
  status - Show system status
  nodes - List nodes
  help - Show this help'''
            }
        elif cmd_lower == 'status':
            nodes = engine.state.nodes if hasattr(engine, 'state') else {}
            return {
                'status': 'ok',
                'output': f'System Status:\n  Mode: {engine.mode if hasattr(engine, "mode") else "unknown"}\n  Nodes: {len(nodes)}\n  Platform: {engine.platform if hasattr(engine, "platform") else "unknown"}'
            }
        elif cmd_lower == 'nodes' or cmd_lower == 'node list':
            nodes = engine.state.nodes if hasattr(engine, 'state') else {}
            if not nodes:
                return {'status': 'ok', 'output': 'No nodes connected'}
            output = 'Connected Nodes:\n'
            for node_id, node_info in list(nodes.items())[:10]:
                platform = node_info.get('platform', 'unknown')
                ip = node_info.get('ip', 'unknown')
                output += f'  {node_id} ({platform}) - {ip}\n'
            return {'status': 'ok', 'output': output}
        else:
            return {'status': 'error', 'output': f'Unknown command: {command}. Type "help" for available commands.'}
    
    def send_json(self, data):
        """Send JSON response - handles large payloads properly"""
        try:
            # Encode JSON first
            json_str = json.dumps(data)
            json_bytes = json_str.encode('utf-8')
            
            # Send headers
            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.send_header('Content-Length', str(len(json_bytes)))
            for header, value in self._get_cors_headers().items():
                self.send_header(header, value)
            self.end_headers()
            
            # Write in chunks if very large (>1MB)
            chunk_size = 1024 * 1024  # 1MB chunks
            if len(json_bytes) > chunk_size:
                offset = 0
                while offset < len(json_bytes):
                    chunk = json_bytes[offset:offset+chunk_size]
                    self.wfile.write(chunk)
                    self.wfile.flush()
                    offset += chunk_size
            else:
                self.wfile.write(json_bytes)
                self.wfile.flush()
        except BrokenPipeError:
            # Client closed connection - not critical
            pass
        except Exception as e:
            print(f"[!] Error in send_json: {e}")
            import traceback
            traceback.print_exc()
            # Try to send error response
            try:
                error_bytes = json.dumps({'status': 'error', 'message': str(e)}).encode('utf-8')
                self.send_response(500)
                self.send_header('Content-type', 'application/json')
                self.send_header('Content-Length', str(len(error_bytes)))
                self.end_headers()
                self.wfile.write(error_bytes)
            except:
                pass
    
    def read_json(self):
        """Read JSON from request - handles empty/invalid JSON gracefully"""
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            if content_length > 0:
                post_data = self.rfile.read(content_length)
                if post_data:
                    decoded = post_data.decode('utf-8', errors='ignore').strip()
                    if decoded:
                        return json.loads(decoded)
            return {}
        except (json.JSONDecodeError, UnicodeDecodeError, ValueError) as e:
            print(f"[WARN] Failed to parse JSON: {e}")
            return {}
        except Exception as e:
            print(f"[WARN] Error reading JSON: {e}")
            return {}
    
    def _handle_websocket_upgrade(self):
        """Handle WebSocket upgrade request"""
        try:
            key = self.headers.get('Sec-WebSocket-Key', '')
            if not key:
                self.send_response(400)
                self.end_headers()
                return
            
            accept = base64.b64encode(hashlib.sha1((key + '258EAFA5-E914-47DA-95CA-C5AB0DC85B11').encode()).digest()).decode()
            
            self.send_response(101)
            self.send_header('Upgrade', 'websocket')
            self.send_header('Connection', 'Upgrade')
            self.send_header('Sec-WebSocket-Accept', accept)
            self.end_headers()
            
            # Add to clients (use self.request which is the socket)
            with self.server.ws_lock:
                self.server.ws_clients.append(self.request)
            
            # Keep connection alive in background thread
            threading.Thread(target=self._handle_websocket_messages, daemon=True).start()
        except Exception as e:
            print(f"[WS] Upgrade error: {e}")
    
    def _handle_websocket_messages(self):
        """Handle WebSocket messages"""
        try:
            self.request.settimeout(1.0)
            while True:
                try:
                    data = self.request.recv(1024)
                    if not data:
                        break
                except socket.timeout:
                    continue
                except:
                    break
        except:
            pass
        finally:
            with self.server.ws_lock:
                if self.request in self.server.ws_clients:
                    self.server.ws_clients.remove(self.request)
    
    @staticmethod
    def _broadcast_ws(server, message):
        """Broadcast message to all WebSocket clients"""
        with server.ws_lock:
            dead_clients = []
            for client in server.ws_clients:
                try:
                    msg_bytes = message.encode('utf-8')
                    frame = bytearray([0x81])
                    if len(msg_bytes) < 126:
                        frame.append(len(msg_bytes))
                    elif len(msg_bytes) < 65536:
                        frame.append(126)
                        frame.extend(struct.pack('>H', len(msg_bytes)))
                    else:
                        frame.append(127)
                        frame.extend(struct.pack('>Q', len(msg_bytes)))
                    frame.extend(msg_bytes)
                    client.sendall(bytes(frame))
                except:
                    dead_clients.append(client)
            for client in dead_clients:
                if client in server.ws_clients:
                    server.ws_clients.remove(client)
    
