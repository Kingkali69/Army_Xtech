        // Fetch master time and calculate offset
        function syncMasterTime() {{
            fetch('/status')
                .then(r => r.json())
                .then(data => {{
                    isMaster = data.is_master || false;
                    if (!isMaster && data.master_time) {{
                        // Calculate offset: master_time - local_time
                        const localTime = Date.now() / 1000;
                        masterTimeOffset = data.master_time - localTime;
                        console.log(`[TIME SYNC] Offset: ${{masterTimeOffset.toFixed(3)}}s`);
                    }} else if (isMaster) {{
                        masterTimeOffset = 0;
                    }}
                }})
                .catch(e => {{}});
        }}
        
        // Get unified time for display
        function getUnifiedTime() {{
            if (isMaster) {{
                return Date.now() / 1000;
            }} else {{
                return (Date.now() / 1000) + masterTimeOffset;
            }}
        }}
        
        // Format unified timestamp
        function formatUnifiedTimestamp(timestamp) {{
            const date = new Date(timestamp * 1000);
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');
            const seconds = String(date.getSeconds()).padStart(2, '0');
            const ms = String(date.getMilliseconds()).padStart(3, '0');
            return `${{hours}}:${{minutes}}:${{seconds}}.${{ms}}`;
        }}
        
