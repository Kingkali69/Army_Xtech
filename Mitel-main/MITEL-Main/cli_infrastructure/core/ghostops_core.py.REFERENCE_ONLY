                            continue

                    if filename in master_files_info:
                        master_version = master_files_info[filename]['version']
                        peer_version = peer_info.get('version', 0)

                        # If peer has newer version AND provides content, save to master
                        if peer_version > master_version and peer_info.get('content'):
                            try:
                                content_str = peer_info['content']
                                content = base64.b64decode(content_str)

                                # Verify we got content
