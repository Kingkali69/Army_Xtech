    @staticmethod
    def handle_authority(state, device_id, has_authority, timestamp=None):
        """
        Handle authority change with timestamp-based conflict resolution
        PHASE 2: Enhanced with conflict resolution and device name tracking
        """
        print(f"[AUTHORITY] handle_authority called: device_id={device_id}, has_authority={has_authority}")
        print(f"[AUTHORITY] Current authority: {state.authority} (timestamp: {state.authority_timestamp})")
        print(f"[AUTHORITY] State has config: {hasattr(state, 'config')}")
        if hasattr(state, 'config'):
            print(f"[AUTHORITY] State.config.device_id: {state.config.device_id}")

        # Handle 'local_device' mapping to actual device_id
        if device_id == 'local_device' and hasattr(state, 'config'):
            actual_device_id = state.config.device_id
            print(f"[AUTHORITY] Mapping 'local_device' to actual device_id: {actual_device_id}")
            device_id = actual_device_id

        # Get timestamp for conflict resolution
        request_timestamp = timestamp if timestamp else time.time()

        # Extract device name from device_id (e.g., "linux_Desktop" -> "Linux-Desktop")
        device_name = device_id.replace('_', '-').title()

        if has_authority:
            # Check for conflicts - newest timestamp wins
            if state.authority and state.authority != device_id:
                if request_timestamp < state.authority_timestamp:
                    # Reject - existing authority is newer
                    print(f"[AUTHORITY] CONFLICT: Request denied (older timestamp)")
                    print(f"[AUTHORITY] Current: {state.authority} @ {state.authority_timestamp}")
                    print(f"[AUTHORITY] Request: {device_id} @ {request_timestamp}")
                    return {
                        'status': 'authority_conflict',
                        'device_id': device_id,
                        'has_authority': False,
                        'current_authority': state.authority,
                        'current_authority_name': state.authority_device_name,
                        'authority_timestamp': state.authority_timestamp,
                        'is_master': False,
                        'message': f'Authority held by {state.authority_device_name}'
                    }
                else:
                    # Accept - this request is newer
                    print(f"[AUTHORITY] CONFLICT RESOLVED: Newer timestamp wins")
                    print(f"[AUTHORITY] Replacing {state.authority} with {device_id}")

            # Grant authority
            state.authority = device_id
            state.authority_timestamp = request_timestamp
            state.authority_device_name = device_name
            print(f"[AUTHORITY] Authority GRANTED to: {device_id} ({device_name}) @ {request_timestamp}")
        else:
            # Revoke authority
            if state.authority == device_id:
                state.authority = None
                state.authority_timestamp = 0
                state.authority_device_name = None
                print(f"[AUTHORITY] Authority REVOKED from: {device_id}")
            else:
                print(f"[AUTHORITY] Authority revocation skipped (not current authority)")

        print(f"[AUTHORITY] Final authority: {state.authority}")

        state.add_command('authority', device_id, has_authority=has_authority, timestamp=request_timestamp)

        return {
            'status': 'authority_updated',
            'device_id': device_id,
            'has_authority': has_authority,
            'current_authority': state.authority,
            'current_authority_name': state.authority_device_name,
            'authority_timestamp': state.authority_timestamp,
            'is_master': state.authority == device_id or state.authority == 'local_device'
        }
    
