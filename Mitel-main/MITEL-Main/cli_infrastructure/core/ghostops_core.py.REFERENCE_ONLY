    def _check_range(self):
        """Check if master is in range (WiFi-style ping detection) - with auto-discovery"""
        # If no master IP configured, try auto-discovery
        if not self.engine.config.master_ip:
            discovered_ip = self._auto_discover_master()
            if discovered_ip:
                self.engine.config.master_ip = discovered_ip
                print(f"[AUTO-DISCOVERY] [OK] Found master at {discovered_ip}, connecting...")
            else:
                return False
        
        try:
            import urllib.request
            start_time = time.time()

            # Fast ping to check range (like WiFi signal detection)
            with urllib.request.urlopen(
                f"http://{self.engine.config.master_ip}:{self.engine.config.master_port}/status",
                timeout=1  # Fast timeout for range detection
            ) as response:
                # Calculate latency
                self.connection_latency = time.time() - start_time

                # In range if latency < 500ms (like WiFi signal strength)
                if self.connection_latency < 0.5:
                    self.consecutive_failures = 0  # Reset failure counter on success
                    return True
                else:
                    # High latency = out of range
                    return False
        except Exception as e:
            # Connection failed = out of range - try auto-discovery to find new master
            self.connection_latency = None
            self.consecutive_failures += 1
            
            # AGGRESSIVE AUTO-DISCOVERY: If master is unreachable, try auto-discovery immediately
            # Don't wait for 3 failures - master might have changed IP or restarted
            error_str = str(e)
            is_connection_refused = 'refused' in error_str.lower() or 'actively refused' in error_str.lower()
            
            if self.consecutive_failures >= 1:  # Try on first failure
                print(f"[AUTO-DISCOVERY] Master {self.engine.config.master_ip} unreachable ({error_str[:50]}...), scanning for master...")
                discovered_ip = self._auto_discover_master()
                if discovered_ip:
                    if discovered_ip != self.engine.config.master_ip:
                        print(f"[AUTO-DISCOVERY] [OK] Found new master at {discovered_ip}, switching from {self.engine.config.master_ip}...")
                        self.engine.config.master_ip = discovered_ip
                        self.consecutive_failures = 0  # Reset on discovery
                        # Try connecting immediately with new IP
                        return self._check_range()  # Recursive call with new IP
                    else:
                        print(f"[AUTO-DISCOVERY] [WARN]  Same IP found but still unreachable - master may be restarting")
                        # If connection refused, clear IP to force fresh discovery
                        if is_connection_refused and self.consecutive_failures >= 3:
                            print(f"[AUTO-DISCOVERY] Connection refused - clearing cached IP to force fresh discovery")
                            old_ip = self.engine.config.master_ip
                            self.engine.config.master_ip = None
                            # Try discovery again immediately
                            discovered_ip = self._auto_discover_master()
                            if discovered_ip and discovered_ip != old_ip:
                                print(f"[AUTO-DISCOVERY] [OK] Found master at {discovered_ip} after clearing cache")
                                self.engine.config.master_ip = discovered_ip
                                self.consecutive_failures = 0
                                return self._check_range()
                else:
                    print(f"[AUTO-DISCOVERY] [ERROR] No master found on network - will keep scanning")
                    # Clear master IP after 5 failures to force fresh discovery
                    if self.consecutive_failures >= 5:
                        print(f"[AUTO-DISCOVERY] [RESET] Clearing cached master IP to force fresh discovery")
                        self.engine.config.master_ip = None
            
            # PHASE 2: Check for master failure and trigger failover
            self._check_master_failure()
            return False
    
    def _auto_discover_master(self):
        """Auto-discover master node on local network using UDP broadcast + TCP fallback"""
        import socket
        import subprocess
        import re
        import threading
        
        DISCOVERY_PORT = 7891  # UDP port for discovery
        MASTER_PORT = 7890     # TCP port for master HTTP
        
        def get_local_ip():
            """Get local IP address - works completely offline (LAN-only)"""
            # Method 1: Use ip route (Linux/Android) - works offline
            try:
                result = subprocess.run(['ip', 'route', 'get', '1'], 
                                      capture_output=True, text=True, timeout=1)
                match = re.search(r'src (\d+\.\d+\.\d+\.\d+)', result.stdout)
                if match:
                    ip = match.group(1)
                    if not ip.startswith('127.'):
                        return ip
            except:
                pass
            
            # Method 2: Use hostname (works offline, but may return 127.0.0.1)
            try:
                hostname = socket.gethostname()
                ip = socket.gethostbyname(hostname)
                if not ip.startswith('127.'):
                    return ip
            except:
                pass
            
            # Method 3: Try network interfaces directly (offline)
            try:
                import netifaces
                gateways = netifaces.gateways()
                if 'default' in gateways and netifaces.AF_INET in gateways['default']:
                    interface = gateways['default'][netifaces.AF_INET][1]
                    addrs = netifaces.ifaddresses(interface)
                    if netifaces.AF_INET in addrs:
                        ip = addrs[netifaces.AF_INET][0]['addr']
                        if not ip.startswith('127.'):
                            return ip
            except:
                pass
            
            # Method 4: Fallback - try connecting to local network (offline)
            try:
                s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                for router_ip in ['192.168.1.1', '192.168.0.1', '10.0.0.1']:
                    try:
                        s.connect((router_ip, 1))
                        ip = s.getsockname()[0]
                        s.close()
                        if not ip.startswith('127.'):
                            return ip
                    except:
                        continue
                s.close()
            except:
                pass
            
            return None
        
        def udp_broadcast_discovery():
            """UDP broadcast discovery - fastest method"""
            local_ip = get_local_ip()
            if not local_ip:
                return None
            
            try:
                # Create UDP socket for broadcast
                sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                sock.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
                sock.settimeout(2.0)  # Wait 2 seconds for responses
                
                # Send discovery request
                discovery_msg = json.dumps({
                    'type': 'discover',
                    'device_id': self.engine.config.device_id,
                    'platform': self.engine.platform,
                    'timestamp': time.time()
                }).encode('utf-8')
                
                # Broadcast to all interfaces
                subnet = '.'.join(local_ip.split('.')[:3])
                broadcast_addrs = [
                    f"{subnet}.255",      # Standard broadcast
                    "255.255.255.255"     # Global broadcast
                ]
                
                for broadcast_addr in broadcast_addrs:
                    try:
                        sock.sendto(discovery_msg, (broadcast_addr, DISCOVERY_PORT))
                    except:
                        pass
                
                # Listen for responses
                start_time = time.time()
                discovered_masters = []
                
                while time.time() - start_time < 2.0:
                    try:
                        data, addr = sock.recvfrom(1024)
                        response = json.loads(data.decode('utf-8'))
                        
                        if response.get('type') == 'master_announce':
                            master_ip = response.get('ip')
                            if master_ip and master_ip not in discovered_masters:
                                discovered_masters.append(master_ip)
                                print(f"[AUTO-DISCOVERY] [OK] Master found via UDP broadcast: {master_ip}")
                    except socket.timeout:
                        break
                    except:
                        continue
                
                sock.close()
                
                # Return first discovered master
                if discovered_masters:
                    return discovered_masters[0]
                    
            except Exception as e:
                print(f"[AUTO-DISCOVERY] [WARN] UDP broadcast failed: {e}")
            
            return None
        
        def scan_port(ip, port, timeout=0.3):
            """Check if port is open"""
            try:
                s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                s.settimeout(timeout)
                result = s.connect_ex((ip, port))
                s.close()
                return result == 0
            except:
                return False
        
        # METHOD 1: Try UDP broadcast first (fastest)
        discovered = udp_broadcast_discovery()
        if discovered:
            return discovered
        
        # METHOD 2: Check known IPs (user provided or cached)
        local_ip = get_local_ip()
        if not local_ip:
            return None
        
        # REMOVED HARDCODED IPs - Fully automatic discovery
        # Check cached master IP first (if exists)
        known_ips = []
        if self.engine.config.master_ip:
            known_ips.append(self.engine.config.master_ip)
        
        # Check cached nodes from state
        if hasattr(self.engine.state, 'nodes') and self.engine.state.nodes:
            for node_id, node_info in self.engine.state.nodes.items():
                node_ip = node_info.get('ip') or node_info.get('address')
                if node_ip and node_ip not in known_ips:
                    known_ips.append(node_ip)
        
        for ip in known_ips:
            if scan_port(ip, MASTER_PORT, timeout=0.5):
                print(f"[AUTO-DISCOVERY] [OK] Master found at {ip} (known IP)")
                return ip
        
        # METHOD 3: TCP port scan (slower fallback)
        subnet = '.'.join(local_ip.split('.')[:3]) + '.'
        
        # Scan more thoroughly - check every 5th IP instead of every 10th
        for i in range(1, 255, 5):
            ip = subnet + str(i)
            if ip == local_ip:
                continue
            if scan_port(ip, MASTER_PORT, timeout=0.2):
                print(f"[AUTO-DISCOVERY] [OK] Master found at {ip} (port scan)")
                return ip
        
        return None

    def _check_master_failure(self):
        """
        PHASE 2: Detect master failure and trigger failover
        If master is down for too long, oldest peer becomes new master
        """
        current_time = time.time()

        # Track consecutive failures
        self.consecutive_failures += 1

        # Failover after 3 consecutive failures (optimized for sub-100ms promotion)
        # Reduced from 5 to 3 for faster failover while maintaining stability
        FAILOVER_THRESHOLD = 3

        if self.consecutive_failures >= FAILOVER_THRESHOLD:
            # Check if there's currently a master with authority
            if self.engine.state.authority and self.engine.state.authority != self.engine.config.device_id:
                print(f"[FAILOVER] Master failure detected: {self.engine.state.authority}")
