    def _network_detection_loop(self):
        """
        Continuously detect network mode (HOME_LAN vs AWAY)
        Runs in background thread to automatically switch modes
        """
        while True:
            try:
                current_time = time.time()

                # Check network every 5 seconds
                if current_time - self.engine.state.last_network_check < 5:
                    time.sleep(1)
                    continue

                self.engine.state.last_network_check = current_time

                # Detect current network
                network_mode = self._detect_network_mode()

                # Check if mode changed
                if network_mode != self.engine.state.network_mode:
                    old_mode = self.engine.state.network_mode
                    self.engine.state.network_mode = network_mode

                    print(f"[NETWORK] Mode changed: {old_mode} → {network_mode}")

                    if network_mode == 'HOME_LAN':
                        print(f"[NETWORK] 🏠 On HOME network - Switching to LAN mode")
                        print(f"[NETWORK] Subnet: {self.engine.state.home_network_subnet}")
                        # Switch to connected mode if master is available
                        if not self.engine.is_master():
                            self.check_connection()
                    else:
                        print(f"[NETWORK] 🌐 AWAY from home - Standalone mode")
                        # Remain standalone but keep trying to reconnect

                    self.engine.state.save_state_cache()

                time.sleep(1)
            except Exception as e:
                print(f"[!] Network detection error: {e}")
                time.sleep(5)

    def _detect_network_mode(self):
        """
        Detect if we're on home network or away
        Returns: 'HOME_LAN' or 'AWAY'
        """
        try:
            import socket
            import subprocess

            # Get current IP address (offline method)
            local_ip = None
            
            # Method 1: Use ip route (Linux/Android) - works offline
            try:
                import subprocess
                import re
                result = subprocess.run(['ip', 'route', 'get', '1'], 
                                      capture_output=True, text=True, timeout=1)
                match = re.search(r'src (\d+\.\d+\.\d+\.\d+)', result.stdout)
                if match:
                    local_ip = match.group(1)
            except:
                pass
            
            # Method 2: Use hostname (works offline)
            if not local_ip or local_ip.startswith('127.'):
                try:
                    local_ip = socket.gethostbyname(socket.gethostname())
                except:
                    pass
            
            # Method 3: Try network interfaces (offline)
            if not local_ip or local_ip.startswith('127.'):
                try:
                    import netifaces
                    gateways = netifaces.gateways()
                    if 'default' in gateways and netifaces.AF_INET in gateways['default']:
                        interface = gateways['default'][netifaces.AF_INET][1]
                        addrs = netifaces.ifaddresses(interface)
                        if netifaces.AF_INET in addrs:
                            local_ip = addrs[netifaces.AF_INET][0]['addr']
                except:
                    pass
            
            # Method 4: Fallback - try local network router (offline)
            if not local_ip or local_ip.startswith('127.'):
                try:
                    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                    for router_ip in ['192.168.1.1', '192.168.0.1', '10.0.0.1']:
                        try:
                            s.connect((router_ip, 1))
                            local_ip = s.getsockname()[0]
                            s.close()
                            if not local_ip.startswith('127.'):
                                break
                        except:
                            continue
                    s.close()
                except:
                    pass

            # Extract subnet (e.g., '192.168.1.' from '192.168.1.100')
            subnet = '.'.join(local_ip.split('.')[:3]) + '.'

            # First time detection - learn the home network
            if self.engine.state.home_network_subnet is None:
                # Check if other nodes are on same subnet
                if self._check_for_peers_on_subnet(subnet):
                    self.engine.state.home_network_subnet = subnet
                    print(f"[NETWORK] 🏠 Detected HOME network subnet: {subnet}")
                    return 'HOME_LAN'
                else:
                    # No peers detected - assume away
                    return 'AWAY'
            else:
                # Check if current subnet matches home subnet
                if subnet == self.engine.state.home_network_subnet:
                    return 'HOME_LAN'
                else:
                    # Different subnet - we're away from home
                    return 'AWAY'

        except Exception as e:
            print(f"[!] Network mode detection error: {e}")
            return 'AWAY'

    def _check_for_peers_on_subnet(self, subnet):
        """
        Check if any known peers or master are on this subnet
        This helps identify the home network
        """
        try:
            # Check master IP
            if self.engine.config.master_ip:
                if self.engine.config.master_ip.startswith(subnet):
                    return True

            # Check known nodes
            for node in self.engine.state.nodes.values():
                if node.get('ip', '').startswith(subnet):
                    return True

            # Try to ping master to verify it's on this network
            if self.engine.config.master_ip:
                try:
                    import urllib.request
                    with urllib.request.urlopen(
                        f"http://{self.engine.config.master_ip}:{self.engine.config.master_port}/status",
                        timeout=2
                    ) as response:
                        # Master is reachable on this network
                        return True
                except:
                    pass

            return False
        except Exception as e:
            print(f"[!] Peer check error: {e}")
            return False

