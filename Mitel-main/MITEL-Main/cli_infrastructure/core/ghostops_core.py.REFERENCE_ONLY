    def _get_node_hierarchy_priority(self, device_id: str, platform: str) -> int:
        """
        Get node priority for failover hierarchy
        Returns: 1 (highest) = Linux, 2 = Windows, 3 = macOS, 4 = Android (lowest)
        """
        platform_lower = platform.lower() if platform else 'unknown'
        
        if 'linux' in platform_lower and 'android' not in platform_lower:
            return 1  # Linux = primary master
        elif 'windows' in platform_lower:
            return 2  # Windows = secondary
        elif 'darwin' in platform_lower or 'macos' in platform_lower or 'mac' in platform_lower:
            return 3  # macOS = tertiary
        elif 'android' in platform_lower:
            return 4  # Android = fallback
        else:
            return 5  # Unknown = lowest priority
    
    def _should_become_failover_master(self):
        """
        PHASE 2: Determine if this peer should become master in failover
        Uses hierarchy: Linux (primary) → Windows (secondary) → macOS (tertiary) → Android (fallback)
        """
        # Get all known peers (including self) with their platforms
        all_peers = []
        
        # Add self
        all_peers.append({
            'device_id': self.engine.config.device_id,
            'platform': self.engine.platform,
            'priority': self._get_node_hierarchy_priority(self.engine.config.device_id, self.engine.platform)
        })
        
        # Add other nodes
        for device_id, node_info in self.engine.state.nodes.items():
            if device_id == self.engine.state.authority:
                continue  # Skip failed master
            platform = node_info.get('platform', 'unknown')
            all_peers.append({
                'device_id': device_id,
                'platform': platform,
                'priority': self._get_node_hierarchy_priority(device_id, platform)
            })
        
        if len(all_peers) == 0:
            # No other peers - become master
            return True
        
        # Sort by priority (lower number = higher priority), then by device_id
        all_peers.sort(key=lambda x: (x['priority'], x['device_id']))
        
        # Highest priority peer becomes master
        highest_priority_peer = all_peers[0]
        is_highest_priority = highest_priority_peer['device_id'] == self.engine.config.device_id
        
        from datetime import datetime
        ts = datetime.now().strftime('%H:%M:%S.%f')[:-3]
        print(f"[{ts}] [FAILOVER] Hierarchy check:")
        print(f"[{ts}] [FAILOVER]   Peers: {[(p['device_id'], p['platform'], f'priority={p['priority']}') for p in all_peers]}")
        print(f"[{ts}] [FAILOVER]   Highest priority: {highest_priority_peer['device_id']} ({highest_priority_peer['platform']})")
        print(f"[{ts}] [FAILOVER]   This device: {self.engine.config.device_id} ({self.engine.platform})")
        print(f"[{ts}] [FAILOVER]   Should become master: {is_highest_priority}")
        
        # Log to unified monitoring
        try:
            from ghostops_adapter import GhostOpsServer
            GhostOpsServer.add_log(f"[FAILOVER] Hierarchy: {highest_priority_peer['device_id']} ({highest_priority_peer['platform']}) should become master", 
                                 self.engine.config.device_id)
        except:
            pass
        
        return is_highest_priority
    
