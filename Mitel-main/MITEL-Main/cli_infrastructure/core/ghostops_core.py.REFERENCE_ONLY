                                print(f"[FILE SYNC] [ERROR] Failed to encode {filename}: {e}")
                except Exception as e:
                    print(f"[FILE SYNC] [ERROR] Error processing missing file {filename}: {e}")
                    continue
            
            # Peer -> Master: Bidirectional sync - peer can update master
            for filename, peer_info in peer_files_info.items():
                try:
                    # FIX: Normalize absolute paths to relative filenames
                    if os.path.isabs(filename):
                        filename = os.path.basename(filename)
                    
                    # SECURITY: Validate filename before processing
                    if SECURITY_MODULES_AVAILABLE:
