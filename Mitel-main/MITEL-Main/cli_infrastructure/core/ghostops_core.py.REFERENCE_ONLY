            print("[!] Using temporary key for this session")
            import secrets
            return secrets.token_urlsafe(32)


class GhostOpsHTTPHandler:
    """Base HTTP request handler with CORS support"""
    
    @staticmethod
    def send_cors_headers():
        """Get CORS headers"""
        return {
            "Access-Control-Allow-Origin": "*",
            "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
            "Access-Control-Allow-Headers": "Content-Type"
        }
    
    @staticmethod
    def send_json_handler(wfile, data, cors_headers=None):
        """Send JSON response"""
        if cors_headers is None:
            cors_headers = GhostOpsHTTPHandler.send_cors_headers()
        
        response_data = json.dumps(data).encode()
        headers = {
            'Content-type': 'application/json',
            **cors_headers
        }
        
        return response_data, headers
    
    @staticmethod
    def read_json(rfile, content_length):
        """Read JSON from request"""
        if content_length > 0:
            post_data = rfile.read(content_length)
            return json.loads(post_data.decode())
        return {}
    
    @staticmethod
    def parse_multipart(rfile, headers):
        """Parse multipart/form-data for file uploads"""
        try:
            content_type = headers.get('Content-Type', '')
            if 'multipart/form-data' not in content_type:
                return None, "Invalid content type"
            
            # Get content length and check file size limit (50MB)
            content_length = int(headers.get('Content-Length', 0))
            if content_length == 0:
                return None, "No data received"
            if content_length > 50 * 1024 * 1024:  # 50MB limit
                return None, "File too large (max 50MB)"
            
            # Parse the multipart form data
            form = cgi.FieldStorage(
                fp=rfile,
                headers=headers,
                environ={
                    'REQUEST_METHOD': 'POST',
                    'CONTENT_TYPE': content_type,
                    'CONTENT_LENGTH': content_length
                }
            )
            
            files = {}
            fields = {}
            
            for key in form.keys():
                item = form[key]
                if item.filename:
                    # It's a file
                    files[key] = {
                        'filename': item.filename,
                        'data': item.file.read(),
                        'content_type': item.type
                    }
                else:
                    # It's a regular field
                    fields[key] = item.value
            
            return {'files': files, 'fields': fields}, None
        except Exception as e:
            return None, f"Error parsing upload: {str(e)}"


class GhostOpsAuthentication:
    """
    Authentication management
    SECURITY FIX: Integrated with secure authentication system
    """

    # Singleton instance of authentication system
    _auth_system = None
    _lock = threading.Lock()

    @staticmethod
    def get_auth_system():
        """
        Get singleton instance of authentication system

        Returns:
            AuthenticationSystem: Singleton auth system instance
        """
        if GhostOpsAuthentication._auth_system is None:
            with GhostOpsAuthentication._lock:
                if GhostOpsAuthentication._auth_system is None:
                    try:
                        from authentication import AuthenticationSystem
                        GhostOpsAuthentication._auth_system = AuthenticationSystem()
                    except ImportError:
                        print("[!] WARNING: Authentication system not available")
                        return None
        return GhostOpsAuthentication._auth_system

    @staticmethod
    def authenticate(auth_key, provided_key):
        """
        Verify authentication key

        Args:
            auth_key: Expected auth key
            provided_key: Provided auth key

        Returns:
            bool: True if keys match
        """
        import secrets
        # Use constant-time comparison to prevent timing attacks
        try:
            return secrets.compare_digest(auth_key, provided_key)
        except:
            # Fallback to regular comparison if secrets not available
            return auth_key == provided_key

    @staticmethod
    def authenticate_session(session_token):
        """
        Authenticate using session token

        Args:
            session_token: Session token to validate

        Returns:
            dict: Session data if valid, None otherwise
        """
        auth_system = GhostOpsAuthentication.get_auth_system()
        if auth_system:
            return auth_system.verify_session(session_token)
        return None

    @staticmethod
    def login(username, password):
        """
        Authenticate user with username and password

        Args:
            username: Username
            password: Password

        Returns:
            tuple: (success: bool, message: str, session_token: str or None)
        """
        auth_system = GhostOpsAuthentication.get_auth_system()
        if auth_system:
            return auth_system.login(username, password)
        return False, "Authentication system not available", None

    @staticmethod
    def logout(session_token):
        """
        Log out user (invalidate session)

        Args:
            session_token: Session token to invalidate

        Returns:
            bool: True if logout successful
        """
        auth_system = GhostOpsAuthentication.get_auth_system()
        if auth_system:
            return auth_system.logout(session_token)
        return False

    @staticmethod
    def generate_token():
        """
        Generate authentication token (DEPRECATED - use session tokens instead)

        Returns:
            str: Cryptographically secure random token
        """
        import secrets
        return secrets.token_urlsafe(32)

    @staticmethod
    def is_authenticated_request(headers):
        """
        Check if HTTP request is authenticated

        Args:
            headers: HTTP headers dict

        Returns:
            bool: True if authenticated
        """
        # Check for session token in Authorization header
        auth_header = headers.get('Authorization', '')
        if auth_header.startswith('Bearer '):
            token = auth_header[7:]  # Remove 'Bearer ' prefix
            session = GhostOpsAuthentication.authenticate_session(token)
            return session is not None

        # Check for API key in X-API-Key header
        api_key = headers.get('X-API-Key', '')
        if api_key:
            # Load expected key
            try:
                from key_manager import KeyManager
                km = KeyManager()
                key_data = km.load_key()
                if key_data and 'admin_key' in key_data:
                    return GhostOpsAuthentication.authenticate(key_data['admin_key'], api_key)
            except:
                pass

        return False


class GhostOpsNetwork:
    """Network communication utilities"""
    
    @staticmethod
    def _create_lan_proxy_handler():
        """
        Create a proxy handler that bypasses proxies for LAN traffic
        This fixes issues with TORSOCKS and other proxy tools interfering with LAN discovery
        """
        import urllib.request

        # Check if proxy environment variables are set
        proxy_vars = ['HTTP_PROXY', 'HTTPS_PROXY', 'http_proxy', 'https_proxy',
                      'ALL_PROXY', 'all_proxy']
        has_proxy = any(os.environ.get(var) for var in proxy_vars)

        if has_proxy:
            print("[LAN FIX] Proxy detected - bypassing for LAN traffic")
            # Force NO proxy for LAN connections by using ProxyHandler with empty dict
            return urllib.request.ProxyHandler({})

        return None

    @staticmethod
    def _is_lan_address(ip):
        """Check if IP is a LAN address (private network)"""
        if not ip:
            return False

        # Check for private IP ranges
        parts = ip.split('.')
        if len(parts) != 4:
            return False

        try:
            first_octet = int(parts[0])
            second_octet = int(parts[1])
            
            # 10.0.0.0/8
            if first_octet == 10:
                return True
            # 172.16.0.0/12
            if first_octet == 172 and 16 <= second_octet <= 31:
                return True
            # 192.168.0.0/16
            if first_octet == 192 and second_octet == 168:
                return True
            # 127.0.0.0/8 (localhost)
            if first_octet == 127:
                return True
        except ValueError:
            return False

        return False
    
    @staticmethod
    def connect_to_master(master_ip, master_port, device_id, platform, local_port=7890):
        """Connect to master node and register"""
        import urllib.request
        try:
            data = {
                'device_id': device_id,
                'platform': platform,
                'port': local_port,  # Tell master what port we listen on
                'last_seen': time.time()
            }
            request = urllib.request.Request(
                f"http://{master_ip}:{master_port}/sync/discover",
                data=json.dumps(data).encode(),
                headers={'Content-Type': 'application/json'}
            )
            
            # LAN FIX: Bypass proxy for LAN connections
            proxy_handler = GhostOpsNetwork._create_lan_proxy_handler()
            if proxy_handler and GhostOpsNetwork._is_lan_address(master_ip):
                opener = urllib.request.build_opener(proxy_handler)
                response = opener.open(request)
            else:
                response = urllib.request.urlopen(request)
            
            with response:
                result = json.loads(response.read().decode())
                print(f"[+] Successfully registered with master: {device_id}")
                return result
        except Exception as e:
            print(f"[!] Registration failed: {e}")
            return None
    
    @staticmethod
    def sync_with_master(master_ip, master_port, engine=None):
        """Sync state with master node and calculate time offset for unified timestamps"""
        import urllib.request
        try:
            local_time_before = time.time()
            # LAN FIX: Bypass proxy for LAN connections
            proxy_handler = GhostOpsNetwork._create_lan_proxy_handler()
            if proxy_handler and GhostOpsNetwork._is_lan_address(master_ip):
                opener = urllib.request.build_opener(proxy_handler)
                response = opener.open(f"http://{master_ip}:{master_port}/status")
            else:
                response = urllib.request.urlopen(f"http://{master_ip}:{master_port}/status")
            
            local_time_after = time.time()
            network_delay = (local_time_after - local_time_before) / 2.0  # Estimate half the round-trip
            
            with response:
                data = json.loads(response.read().decode())
                # Calculate time offset: master_time - (local_time + network_delay)
                master_time = data.get('master_time')
                if master_time and engine and hasattr(engine, 'config'):
                    local_time_mid = local_time_before + network_delay
                    engine.config.time_offset = master_time - local_time_mid
                    print(f"[TIME SYNC] Offset calculated: {engine.config.time_offset:.3f}s (master ahead by {abs(engine.config.time_offset):.3f}s)")
                return data
        except Exception as e:
            print(f"[!] Sync failed: {e}")
            return None
    
    @staticmethod
    def forward_to_master(master_ip, master_port, path, data):
        """Forward request to master node"""
        import urllib.request
        try:
            request = urllib.request.Request(
                f"http://{master_ip}:{master_port}{path}",
                data=json.dumps(data).encode(),
                headers={'Content-Type': 'application/json'}
            )
            # LAN FIX: Bypass proxy for LAN connections
            proxy_handler = GhostOpsNetwork._create_lan_proxy_handler()
            if proxy_handler and GhostOpsNetwork._is_lan_address(master_ip):
                opener = urllib.request.build_opener(proxy_handler)
                response = opener.open(request)
            else:
                response = urllib.request.urlopen(request)
            
