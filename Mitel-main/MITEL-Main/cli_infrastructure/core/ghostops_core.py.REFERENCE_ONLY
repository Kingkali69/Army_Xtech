            import traceback
            traceback.print_exc()
            self.file_messenger = None
        
        # Initialize Unified UI Engine (combines ui_mirror + ui_sync)
        try:
            from unified_ui_engine import UnifiedUIEngine
            self.ui_sync = UnifiedUIEngine(self)
            self.ui_mirror = self.ui_sync  # Compatibility alias
            self.ui_sync.start()
            print("[GhostOps] [OK] Unified UI Engine initialized (real-time + polling + file sync)")
        except ImportError as e:
            print(f"[GhostOps] [WARN] Unified UI Engine not available: {e}")
            self.ui_sync = None
            self.ui_mirror = None
        except Exception as e:
            print(f"[GhostOps] [WARN] UI Sync Engine error: {e}")
            self.ui_sync = None
        
        # Initialize Subsystem Monitor
        try:
            from subsystem_monitor import get_subsystem_monitor
            self.subsystem_monitor = get_subsystem_monitor()
            print("[GhostOps] [OK] Subsystem Monitor initialized (SC-SUB, EB-SUB, SEC-SUB)")
        except Exception as e:
            print(f"[GhostOps] [WARN] Subsystem Monitor not available: {e}")
            self.subsystem_monitor = None
        
        # Initialize Offline Buffer
        try:
            from offline_buffer import get_offline_buffer
            self.offline_buffer = get_offline_buffer()
            print("[GhostOps] [OK] Offline Buffer initialized")
        except Exception as e:
            print(f"[GhostOps] [WARN] Offline Buffer not available: {e}")
            self.offline_buffer = None
        
        # Initialize OPAS (OmniPlatform AI Substrate) - Layer 12
        try:
            from opas_core import OPAS
            work_dir = os.path.dirname(os.path.abspath(__file__))
            self.opas = OPAS(work_dir=work_dir, node_id=self.config.device_id)
            for device_id, node_info in self.state.nodes.items():
                if device_id != self.config.device_id:
                    self.opas.register_node(
                        node_id=device_id,
                        ip=node_info.get('ip', ''),
                        port=node_info.get('port', 7890),
                        platform=node_info.get('platform', 'unknown'),
                        ssh_user=node_info.get('ssh_user'),
                        ssh_port=node_info.get('ssh_port', 22)
                    )
            self.opas.start()
            print("[GhostOps] [OK] OPAS Layer 12 initialized")
        except ImportError:
            self.opas = None
        except Exception as e:
            print(f"[GhostOps] [WARN] OPAS error: {e}")
            self.opas = None
        
        # Auto-load all Kali Linux tools on startup
        try:
            from tool_registry import ToolRegistry
            tools = ToolRegistry.load_kali_tools()
            print(f"[GhostOps] [OK] Loaded {len(tools)} Kali Linux tools into registry")
        except ImportError:
            print("[GhostOps] [WARN]  Tool registry not available - tools will use legacy mode")
        except Exception as e:
            print(f"[GhostOps] [WARN]  Error loading tools: {e}")
        
        # Initialize connection status
        if self.is_master():
            # Master is always "connected" (can work standalone)
            self.state.connection_status = 'connected'
            self.state.standalone_mode = False
            # Start UDP discovery listener for master
            self._start_udp_discovery_listener()
        else:
            # Check if we can connect to master
            self.connection_manager.check_connection()
    
    def _start_udp_discovery_listener(self):
        """Start UDP listener to respond to discovery requests (master only)"""
        import threading
        import socket
        
        DISCOVERY_PORT = 7891
        
        def udp_listener():
            """Listen for UDP discovery requests and respond"""
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                sock.bind(('0.0.0.0', DISCOVERY_PORT))
                sock.settimeout(1.0)  # Non-blocking with timeout
                
                print(f"[AUTO-DISCOVERY] [OK] UDP discovery listener started on port {DISCOVERY_PORT}")
                
                while True:
                    try:
                        data, addr = sock.recvfrom(1024)
                        request = json.loads(data.decode('utf-8'))
                        
                        if request.get('type') == 'discover':
                            # Respond with master announcement
                            response = json.dumps({
                                'type': 'master_announce',
                                'ip': self.config.local_ip,
                                'port': self.config.local_port,
                                'device_id': self.config.device_id,
                                'platform': self.platform,
                                'timestamp': time.time()
                            }).encode('utf-8')
                            
                            sock.sendto(response, addr)
                            print(f"[AUTO-DISCOVERY] [OK] Responded to discovery from {addr[0]}")
                    except socket.timeout:
                        continue
                    except Exception as e:
                        # Silently ignore errors (firewall, etc.)
                        continue
            except Exception as e:
                print(f"[AUTO-DISCOVERY] [WARN] UDP listener error: {e}")
        
        # Start listener in background thread
        listener_thread = threading.Thread(target=udp_listener, daemon=True)
        listener_thread.start()
        
    def get_status(self):
        """Get current system status"""
        # CRITICAL FIX: Clean up stale nodes before counting
        # Remove nodes that haven't been seen in 5 minutes (300 seconds)
        removed = self.state.cleanup_old_nodes(timeout=300)
        if removed:
            print(f"[CLEANUP] Removed {len(removed)} stale node(s): {', '.join(removed)}")
            self.state.save_state_cache()
        
        # Update tunnel status
        tunnel_status = self.tunnel_manager.get_tunnel_status() if hasattr(self, 'tunnel_manager') else {'active': False}

        # Update connection status for peer nodes
        if not self.is_master() and hasattr(self, 'connection_manager'):
            self.connection_manager.check_connection()

        # Determine if this device is master based on authority (not mode)
        # Only check authority - if we have authority, we're master
        # CRITICAL FIX: Only ONE device can be master at a time
        is_master_now = (
            self.state.authority == self.config.device_id or
            (self.state.authority == 'local_device' and self.mode == 'master')
        )
        
        # If we're in master mode but don't have authority, we're NOT master
        if self.mode == 'master' and not is_master_now:
            is_master_now = False

        # For peers, include master info for file transfer
        # FIX: Count all nodes properly
        # Master sees all peers, peers see other peers + master
        node_count = len(self.state.nodes)
        if is_master_now:
            # Master counts all peers it knows about
            node_count = len(self.state.nodes)
        else:
            # Peer counts other peers + master (if master exists)
            if self.state.authority and self.state.authority != self.config.device_id:
                # There's a master - count it
                node_count = len(self.state.nodes) + 1
            else:
                # No master or we're the master - just count peers
                node_count = len(self.state.nodes)
        
        # Add master time for unified timestamp sync
        master_time = time.time() if is_master_now else None
        
        result = {
            'status': 'online',
            'nodes': self.state.nodes,
            'node_count': node_count,  # Explicit node count
            'device_id': self.config.device_id,
            'platform': self.platform,  # Add platform for OS display
            'authority': self.state.authority,
            'authority_timestamp': self.state.authority_timestamp,  # PHASE 2
            'authority_device_name': self.state.authority_device_name,  # PHASE 2
            'is_master': is_master_now,
            'mode': self.mode,
            'tool': self.state.tool_state,
            'page': self.state.page_state,
            'last_sync': self.state.last_sync,
            'commands': self.state.commands,
            'tunnel': tunnel_status,
            'connection_status': self.state.connection_status,
            'standalone_mode': self.state.standalone_mode,
            'pending_sync': len(self.state.pending_sync_queue),
            'network_mode': self.state.network_mode,  # HOME_LAN or AWAY
            'home_network_subnet': self.state.home_network_subnet,
            'master_time': master_time  # Master's current time for unified timestamps
        }
        
        # If peer, include master device ID for file transfer targeting
        # BUGFIX: Don't add master to nodes dict - causes double-counting!
        # Instead, provide master info separately for file transfers
        if not is_master_now and self.config.master_ip:
            # Try to get master device ID from nodes or state
            # Master's device ID might be in authority or we can derive it
            # For now, if we're connected, the master should be the one with authority
            if self.state.authority and self.state.authority != self.config.device_id:
                result['master_device_id'] = self.state.authority
                # Provide master info separately without modifying nodes dict
                result['master_info'] = {
                    'device_id': self.state.authority,
                    'ip': self.config.master_ip,
                    'platform': 'master',
                    'last_seen': time.time()
                }
        
        return result
    
    def is_master(self):
        """Check if this is a master node - checks both mode AND authority"""
        # Check if we have authority (actual master status)
        has_authority = (self.state.authority == self.config.device_id or 
                        self.state.authority == 'local_device')
        # Also check mode for backward compatibility
        return self.mode == 'master' or has_authority
    
    def cleanup_task(self, timeout=300):
        """Background cleanup task"""
        removed = self.state.cleanup_old_nodes(timeout)
        for node_id in removed:
            print(f"[+] Node removed due to inactivity: {node_id}")

