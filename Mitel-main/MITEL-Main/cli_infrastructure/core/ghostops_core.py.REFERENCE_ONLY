class GhostOpsFileManager:
    """File management utilities with security validation"""

    # Initialize secure file handler (class-level)
    _secure_handler = None

    @classmethod
    def _get_secure_handler(cls):
        """Get or create secure file handler"""
        if cls._secure_handler is None and SECURITY_MODULES_AVAILABLE:
            # Android: Use sandbox path ~/ghost/ghost, others use current directory
            current_platform = detect_platform()
            if current_platform == 'android':
                # Android needs sandbox path
                allowed_dir = os.path.expanduser('~/ghost/ghost')
                os.makedirs(allowed_dir, exist_ok=True)
                cls._secure_handler = SafeFileHandler(allowed_base_dir=allowed_dir)
            else:
                cls._secure_handler = SafeFileHandler(allowed_base_dir='.')
        return cls._secure_handler

    @staticmethod
    def get_file_version(file_path):
        """Get file modification time as version"""
        try:
            if os.path.exists(file_path):
                return os.path.getmtime(file_path)
            return 0
        except:
            return 0

    @staticmethod
    def calculate_file_hash(file_path):
        """Calculate SHA256 hash of file for integrity verification"""
        import hashlib

        # Use secure handler if available
        if SECURITY_MODULES_AVAILABLE:
            handler = GhostOpsFileManager._get_secure_handler()
            if handler:
                try:
                    return handler.get_file_hash(file_path, source="file_manager")
                except ValueError as e:
                    print(f"[SECURITY] File access blocked: {e}")
                    return None

        # Fallback to legacy method (VULNERABLE - for backward compatibility only)
        try:
            if not os.path.exists(file_path):
                return None
            sha256_hash = hashlib.sha256()
            with open(file_path, 'rb') as f:
                for byte_block in iter(lambda: f.read(4096), b""):
                    sha256_hash.update(byte_block)
            return sha256_hash.hexdigest()
        except Exception as e:
            print(f"[!] Error calculating hash for {file_path}: {e}")
            return None

    @staticmethod
    def get_file_content(file_path, source="unknown"):
        """Read file content with security validation"""

        # SECURITY FIX: Use secure handler if available
        if SECURITY_MODULES_AVAILABLE:
            handler = GhostOpsFileManager._get_secure_handler()
            if handler:
                try:
                    return handler.read_file(file_path, source=source)
                except ValueError as e:
                    print(f"[SECURITY] File access blocked: {e}")
                    log_blocked_access(file_path, str(e), source)
                    return None

        # LEGACY METHOD (VULNERABLE) - Only used if security modules unavailable
        print(f"[!] WARNING: Using vulnerable file read for {file_path}")
        try:
            if os.path.exists(file_path):
                with open(file_path, 'rb') as f:
                    return f.read()
            return None
        except:
            return None
    
    @staticmethod
    def save_file(file_path, content, is_base64=False, expected_hash=None, source="unknown"):
        """Save file content with security validation and verification"""

        # SECURITY FIX: Use secure handler if available
        if SECURITY_MODULES_AVAILABLE:
            handler = GhostOpsFileManager._get_secure_handler()
            if handler:
                try:
                    # Verify hash if provided
                    verify_hash = expected_hash if expected_hash else None

                    result = handler.write_file(
                        file_path,
                        content,
                        is_base64=is_base64,
                        source=source,
                        verify_hash=verify_hash
                    )
                    return result
                except ValueError as e:
                    print(f"[SECURITY] File write blocked: {e}")
                    log_blocked_access(file_path, str(e), source)
                    return False

        # LEGACY METHOD (VULNERABLE) - Only used if security modules unavailable
        print(f"[!] WARNING: Using vulnerable file write for {file_path}")
        try:
            # SECURITY: Define allowed base directory
            base_dir = os.path.abspath('.')  # Current working directory

            # SECURITY: Normalize and resolve the requested path
            if not os.path.isabs(file_path):
                file_path = os.path.join('.', file_path)
            file_path = os.path.normpath(file_path)

            # Ensure parent directory exists
            parent_dir = os.path.dirname(file_path)
            if parent_dir:
                os.makedirs(parent_dir, exist_ok=True)

            # Decode base64 if needed
            if is_base64:
                if isinstance(content, str):
                    content = base64.b64decode(content)
                else:
                    try:
                        content = base64.b64decode(content.decode('utf-8'))
                    except:
                        content = base64.b64decode(content)

            # Ensure content is bytes
            if isinstance(content, str):
                content = content.encode('utf-8')

            # Save file with atomic write (write to temp then rename)
            temp_path = file_path + '.tmp'
            try:
                with open(temp_path, 'wb') as f:
                    f.write(content)
                # Atomic replace
                if os.path.exists(file_path):
                    os.remove(file_path)
                os.rename(temp_path, file_path)
            except:
                # Fallback to direct write
                if os.path.exists(temp_path):
                    os.remove(temp_path)
                with open(file_path, 'wb') as f:
                    f.write(content)

            # VERIFY FILE WAS ACTUALLY SAVED
            if not os.path.exists(file_path):
                print(f"[!] VERIFICATION FAILED: File {file_path} does not exist after save")
                return False

            saved_size = os.path.getsize(file_path)
            if saved_size != len(content):
                print(f"[!] VERIFICATION FAILED: File size mismatch. Expected {len(content)}, got {saved_size}")
                return False

            # Verify content matches by reading back
            with open(file_path, 'rb') as f:
                read_back = f.read()
            if read_back != content:
                print(f"[!] VERIFICATION FAILED: File content mismatch")
                return False

            print(f"[FILE SYNC] [OK] File saved and verified: {file_path} ({saved_size} bytes)")
            return True
        except PermissionError as e:
            print(f"[!] PERMISSION ERROR saving {file_path}: {e}")
            print(f"[!] Check file permissions and write access")
            return False
        except Exception as e:
            print(f"[!] Error saving file {file_path}: {e}")
            import traceback
            traceback.print_exc()
            return False
    
    @staticmethod
    def get_core_files_info(base_dir='.'):
        """Get version info for all core files (with checksums)"""
        core_files = ['ghostops_core.py', 'ghostops_adapter.py', 'ex_api.py', 'file_sharing.py', 'kali.py', 'windows.py', 'android.py', 'ghost.sh']
