def detect_platform():
    """Auto-detect the current operating system"""
    system = platform.system().lower()
    # Check multiple Android indicators (mobile Python often reports as Linux)
    android_indicators = [
        'android' in system,
        'android' in os.environ.get('ANDROID_ROOT', '').lower(),
        'android' in os.environ.get('ANDROID_DATA', '').lower(),
        'android' in os.environ.get('ANDROID_STORAGE', '').lower(),
        os.path.exists('/system/build.prop'),  # Android system file
        os.path.exists('/system/etc/hosts'),  # Android system file
        'termux' in os.environ.get('PREFIX', '').lower(),  # Termux (Android terminal)
    ]
    if any(android_indicators):
        return 'android'
    elif system == 'linux':
        return 'linux'
    elif system == 'windows':
        return 'windows'
    else:
        return 'unknown'

class GhostOpsState:
    """Unified state management for all platforms"""
    def __init__(self):
        self.nodes = {}
        self.last_sync = 0
        self.tool_state = None
        self.page_state = 1
        self.authority = None
        self.authority_timestamp = 0  # PHASE 2: Timestamp for conflict resolution
        self.authority_device_name = None  # PHASE 2: Human-readable name of authority holder
        self.commands = []
        self.tunnel_active = False
        self.tunnel_status = {
            'active': False,
            'mesh_id': None,
            'node_id': None,
            'peers': {},
            'uptime': 0
        }
        # Standalone mode support
        self.connection_status = 'standalone'  # 'connected', 'standalone', 'connecting'
        self.last_connection_attempt = 0
        self.pending_sync_queue = []  # Queue of changes made while offline
        self.pending_push_queue = []  # Queue of file pushes for offline master mode (Android)
        self.standalone_mode = True  # Default to standalone
        self.offline_master_mode = False  # Android can act as local master when offline
        self.state_cache_file = None  # Will be set by engine

        # Network mode detection (HOME_LAN vs AWAY)
        self.network_mode = 'AWAY'  # 'HOME_LAN' or 'AWAY'
        self.home_network_ssid = None  # Home WiFi SSID (if detected)
        self.home_network_subnet = None  # Home network subnet (e.g., '192.168.1.')
        self.last_network_check = 0
        
    def add_node(self, device_id, ip, platform, port=7890):
        """Register a new node"""
        # CRITICAL FIX: Remove duplicate nodes with same IP address
        # This prevents multiple registrations of the same device
        nodes_to_remove = []
        for existing_id, existing_info in self.nodes.items():
            if existing_info.get('ip') == ip and existing_info.get('port') == port:
                # Same IP and port - remove old entry
                if existing_id != device_id:
                    nodes_to_remove.append(existing_id)
        
        for node_id in nodes_to_remove:
            del self.nodes[node_id]
            print(f"[CLEANUP] Removed duplicate node: {node_id} (same IP: {ip})")
        
        self.nodes[device_id] = {
            'ip': ip,
            'platform': platform,
            'port': port,
            'last_seen': time.time()
        }
        
    def update_sync(self, timestamp=None):
        """Update last sync time"""
        self.last_sync = timestamp if timestamp else time.time()
        
    def add_command(self, cmd_type, source, **kwargs):
        """Add command to history"""
        self.commands.append({
            'type': cmd_type,
            'timestamp': time.time(),
            'source': source,
            **kwargs
        })
        
    def cleanup_old_nodes(self, timeout=300):
        """Remove nodes that haven't been seen in timeout seconds"""
        now = time.time()
        removed = []
        for node_id in list(self.nodes.keys()):
            if now - self.nodes[node_id].get('last_seen', 0) > timeout:
                removed.append(node_id)
                del self.nodes[node_id]
        return removed
    
    def add_to_sync_queue(self, action, **kwargs):
        """Add an action to the sync queue for later execution when connected"""
        self.pending_sync_queue.append({
            'action': action,
            'timestamp': time.time(),
            'kwargs': kwargs
        })
        # Limit queue size to prevent memory issues
        if len(self.pending_sync_queue) > 1000:
            self.pending_sync_queue = self.pending_sync_queue[-1000:]
        self.save_state_cache()
    
    def clear_sync_queue(self):
        """Clear the sync queue after successful sync"""
        self.pending_sync_queue = []
        self.save_state_cache()
    
    def save_state_cache(self):
        """Save state to disk for offline persistence"""
        if not self.state_cache_file:
            return

        try:
            cache_data = {
                'nodes': self.nodes,
                'last_sync': self.last_sync,
                'tool_state': self.tool_state,
                'page_state': self.page_state,
                'authority': self.authority,
                'authority_timestamp': self.authority_timestamp,  # PHASE 2
                'authority_device_name': self.authority_device_name,  # PHASE 2
                'commands': self.commands[-100:],  # Keep last 100 commands
                'pending_sync_queue': self.pending_sync_queue,
                'connection_status': self.connection_status,
                'network_mode': self.network_mode,
                'home_network_ssid': self.home_network_ssid,
                'home_network_subnet': self.home_network_subnet
            }
            
            # Ensure directory exists
            os.makedirs(os.path.dirname(self.state_cache_file), exist_ok=True)
            
            with open(self.state_cache_file, 'w') as f:
                json.dump(cache_data, f, indent=2)
        except Exception as e:
            print(f"[!] Failed to save state cache: {e}")
    
    def load_state_cache(self):
        """Load state from disk cache"""
        if not self.state_cache_file or not os.path.exists(self.state_cache_file):
            return False

        try:
            with open(self.state_cache_file, 'r') as f:
                cache_data = json.load(f)

            # Restore state
            self.nodes = cache_data.get('nodes', {})
            self.last_sync = cache_data.get('last_sync', 0)
            self.tool_state = cache_data.get('tool_state', None)
            self.page_state = cache_data.get('page_state', 1)
            self.authority = cache_data.get('authority', None)
            self.authority_timestamp = cache_data.get('authority_timestamp', 0)  # PHASE 2
            self.authority_device_name = cache_data.get('authority_device_name', None)  # PHASE 2
            self.commands = cache_data.get('commands', [])
            self.pending_sync_queue = cache_data.get('pending_sync_queue', [])
            self.pending_push_queue = cache_data.get('pending_push_queue', [])
            self.offline_master_mode = cache_data.get('offline_master_mode', False)
            self.connection_status = cache_data.get('connection_status', 'standalone')
            self.network_mode = cache_data.get('network_mode', 'AWAY')
            self.home_network_ssid = cache_data.get('home_network_ssid', None)
            self.home_network_subnet = cache_data.get('home_network_subnet', None)

            return True
        except Exception as e:
            print(f"[!] Failed to load state cache: {e}")
            return False


class GhostOpsConfig:
    """Configuration management"""
    def __init__(self, platform='unknown', mode='peer'):
        # Auto-detect platform if not specified
        # IMPORTANT: If platform is explicitly set (not 'unknown'), keep it!
        if platform == 'unknown':
            platform = detect_platform()
        # Force platform to stay as specified (don't override explicit settings)
        self.platform = platform

        # SECURITY FIX: Never use hardcoded auth key
        # Load from environment or generate secure random key (MASTERS ONLY!)
        self.auth_key = self._get_or_generate_auth_key(mode)

        self.device_id = self._generate_device_id()
        self.local_ip = socket.gethostbyname(socket.gethostname())
        self.master_ip = None
        self.master_port = 7890
        self.local_port = self._get_default_port()
        self.time_offset = 0.0  # Time offset from master for unified timestamps

    def _get_or_generate_auth_key(self, mode='peer'):
        """
        SECURITY FIX: Get or generate secure authentication key
        CRITICAL: Peers MUST NOT generate keys - only masters can!

        Args:
            mode: 'master' or 'peer' - determines if key generation is allowed
        """
        import secrets

        # 1. Check environment variable (highest priority)
        env_key = os.environ.get('GHOSTOPS_AUTH_KEY')
        if env_key and len(env_key) >= 16:
            print("[AUTH] [OK] Using auth key from GHOSTOPS_AUTH_KEY environment variable")
            return env_key

        # 2. Check config file
        config_dir = os.path.expanduser("~/.ghostops")
        auth_key_file = os.path.join(config_dir, "auth_key")

        if os.path.exists(auth_key_file):
            try:
                with open(auth_key_file, 'r') as f:
                    stored_key = f.read().strip()
                if stored_key and len(stored_key) >= 16:
                    print(f"[AUTH] [OK] Loaded auth key from {auth_key_file}")
                    return stored_key
            except Exception as e:
                print(f"[AUTH] [WARN]  Failed to load auth key: {e}")

        # 3. Generate new secure random key - MASTERS ONLY!
        if mode == 'master':
            print("[AUTH] 🔑 Generating new secure authentication key (MASTER MODE)...")
            new_key = secrets.token_urlsafe(32)  # 32 bytes = 256 bits of entropy

            # Save to file for persistence
            try:
                os.makedirs(config_dir, exist_ok=True)
                with open(auth_key_file, 'w') as f:
                    f.write(new_key)
                # Secure permissions (user read/write only)
                os.chmod(auth_key_file, 0o600)
                print(f"[AUTH] [OK] Generated and saved new auth key to {auth_key_file}")
                print("")
                print("=" * 70)
                print("[AUTH] 🔑 AUTHENTICATION KEY (COPY THIS FOR ANDROID/WINDOWS):")
                print("=" * 70)
                print(f"[AUTH] {new_key}")
                print("=" * 70)
                print("[AUTH] [WARN]  IMPORTANT: Share this key with peer nodes securely!")
                print(f"[AUTH] [WARN]  To use on Android/Windows: export GHOSTOPS_AUTH_KEY='{new_key}'")
                print("=" * 70)
                print("")
            except Exception as e:
                print(f"[AUTH] [WARN]  Failed to save auth key: {e}")
                print("[AUTH] [WARN]  Key will not persist across restarts!")

            return new_key
        else:
            # PEER MODE - Use simple default password (no key required)
            print("[AUTH] ℹ️  Peer mode - using default password 'ghostops' for control switching")
            print("[AUTH] ℹ️  No key required to start - password only needed when taking control")
            return "ghostops"  # Simple default password for control switching

    def _generate_device_id(self):
        """Generate device ID based on platform"""
        import random
        hostname = socket.gethostname()
        if self.platform == 'linux':
            return f"linux_{hostname}"
        elif self.platform == 'windows':
            return f"win_{hostname}"
        elif self.platform == 'android':
            return f"android_{hostname}_{random.randint(1000,9999)}"
        else:
            return f"unknown_{hostname}"
            
    def _get_default_port(self):
        """Get default port based on platform"""
        if self.platform == 'linux':
            return 7890
        elif self.platform == 'windows':
            return 7891
        elif self.platform == 'android':
            return 5000
        return 8000

    def _load_auth_key(self):
        """
        Load authentication key from secure key manager
        If not found, prompts user to run setup wizard

        Returns:
            str: Authentication key
        """
        try:
            from key_manager import KeyManager
            km = KeyManager()

            # Check if key exists
            if not km.key_exists():
                print("[!] =" * 35)
                print("[!] SECURITY WARNING: No admin key found!")
                print("[!] =" * 35)
                print("[!] GhostOps requires secure authentication setup.")
                print("[!] Please run the setup wizard:")
                print("[!]   python3 setup_wizard.py")
                print("[!] =" * 35)
                print()
                # Generate temporary key for this session only
                print("[!] Generating TEMPORARY key for this session...")
                print("[!] This key will NOT persist across restarts!")
                temp_key = km.generate_key()
                print(f"[!] Temporary key: {temp_key}")
