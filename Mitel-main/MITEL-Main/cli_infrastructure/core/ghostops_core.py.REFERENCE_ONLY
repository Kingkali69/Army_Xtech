        """Stop reconnection loop"""
        self.reconnect_enabled = False


class GhostOpsEngine:
    """Main unified engine that coordinates all subsystems"""
    
    def __init__(self, platform='unknown', mode='peer'):
        """
        Initialize the unified engine
        
        Args:
            platform: 'linux', 'windows', 'android', None, or 'unknown' (auto-detects)
            mode: 'master' or 'peer'
        """
        # Handle None platform
        if platform is None:
            platform = 'unknown'
        # Store original platform before creating config
        original_platform = platform
        self.mode = mode
        self.config = GhostOpsConfig(platform, mode)
        self.state = GhostOpsState()
        self.state.config = self.config  # Link config to state
        # Use platform from config (which respects explicit platform or auto-detects)
        # BUT: If platform was explicitly set (not 'unknown'), keep it
        if original_platform != 'unknown':
            self.platform = original_platform
            # Also update config to match explicit platform
            self.config.platform = original_platform
            # Regenerate device_id with correct platform
            self.config.device_id = self.config._generate_device_id()
        else:
            # Auto-detected - use detected value
            self.platform = self.config.platform
        
        # REMOVED: Android auto-master bug - Android should be peer by default
        # Android can take control via password, but doesn't auto-become master
        
        # Set up state cache file
        cache_dir = os.path.expanduser("~/.ghostops")
        os.makedirs(cache_dir, exist_ok=True)
        self.state.state_cache_file = os.path.join(cache_dir, f"state_{self.config.device_id}.json")
        
        # Load cached state if available
        if self.state.load_state_cache():
            print(f"[+] Loaded cached state from {self.state.state_cache_file}")
        
        # CRITICAL FIX: Set authority for master nodes, clear for peers
        if self.mode == 'master':
            # Linux master by design - set authority immediately
            if not self.state.authority or self.state.authority != self.config.device_id:
                import time
                print(f"[AUTHORITY] Setting master authority for {self.config.device_id} (Linux master by design)")
                self.state.authority = self.config.device_id
                self.state.authority_timestamp = time.time()
                self.state.authority_device_name = self.config.device_id
                self.state.save_state_cache()
        elif self.mode == 'peer':
            # If we're a peer, we should NOT have authority unless we're taking control
            if self.state.authority == self.config.device_id:
                print(f"[AUTHORITY FIX] Clearing incorrect cached authority for peer node")
                self.state.authority = None
                self.state.authority_timestamp = 0
                self.state.authority_device_name = None
                self.state.save_state_cache()
        
        # Initialize tunnel manager
        self.tunnel_manager = GhostOpsTunnelManager(self)
        
        # Initialize connection manager
        self.connection_manager = GhostOpsConnectionManager(self)
        
        # Initialize Unified Sync Authority (ONE transport, ONE authority)
        try:
            from unified_sync_authority import UnifiedSyncAuthority
            self.sync_authority = UnifiedSyncAuthority(self)
            self.sync_authority.start()
            print("[GhostOps] [OK] Unified Sync Authority initialized (pull-based, HTTP only)")
        except ImportError as e:
            print(f"[GhostOps] [WARN] Unified Sync Authority not available: {e}")
            self.sync_authority = None
        except Exception as e:
            print(f"[GhostOps] [WARN] Sync Authority error: {e}")
            self.sync_authority = None
        
        # Initialize File Messenger (direct peer-to-peer file transfer)
        try:
            from ghost_file_messenger import GhostFileMessenger
            project_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
            self.file_messenger = GhostFileMessenger(
                node_id=self.config.device_id,
                port=self.config.local_port,
                project_dir=project_dir
            )
            print("[GhostOps] [OK] File Messenger initialized - Direct peer-to-peer file transfer enabled")
        except ImportError as e:
            print(f"[GhostOps] [WARN] File Messenger not available: {e}")
