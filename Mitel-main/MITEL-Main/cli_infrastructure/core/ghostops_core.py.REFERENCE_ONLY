                                traceback.print_exc()
                except Exception as e:
                    print(f"[FILE SYNC] [ERROR] Error in bidirectional sync for {filename}: {e}")
                    continue
            
            sync_count = len(files_to_sync)
            if sync_count > 0:
                total_size = sum(f.get('size', 0) for f in files_to_sync.values())
                print(f"[FILE SYNC] [OK] Ready to send {sync_count} file(s) to peer (total: {total_size} bytes)")
                for fname in files_to_sync.keys():
                    print(f"      - {fname} ({files_to_sync[fname]['size']} bytes)")
                
                # Limit response size - if too large, split into multiple syncs
                # 5MB limit per response
                MAX_RESPONSE_SIZE = 5 * 1024 * 1024  # 5MB
                if total_size > MAX_RESPONSE_SIZE:
                    print(f"[FILE SYNC] [WARN] Response too large ({total_size} bytes), will sync in chunks")
                    # Send largest files first, limit to 5MB
                    sorted_files = sorted(files_to_sync.items(), key=lambda x: x[1]['size'], reverse=True)
