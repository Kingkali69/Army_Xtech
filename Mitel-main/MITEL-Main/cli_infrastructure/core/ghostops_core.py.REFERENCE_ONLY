                            files_to_sync[fname] = finfo
                            current_size += finfo['size']
                        else:
                            print(f"[FILE SYNC] [WARN] Skipping {fname} (too large), will sync in next request")
            else:
                print(f"[FILE SYNC] ✓ All files up to date")
            
            return {
                'status': 'sync_ready',
