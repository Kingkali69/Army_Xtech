    def _process_sync_queue(self):
        """Process pending sync queue when reconnected"""
        # Process file pushes first (offline master mode)
        if self.engine.state.pending_push_queue:
            print(f"[+] [OFFLINE MASTER] Processing {len(self.engine.state.pending_push_queue)} queued file pushes...")
            try:
                # Trigger push via HTTP endpoint (internal call)
                import urllib.request
                import json
                push_url = f"http://localhost:{self.engine.config.local_port}/file/force_push_all"
                req = urllib.request.Request(
                    push_url,
                    data=json.dumps({'force': True}).encode('utf-8'),
                    headers={'Content-Type': 'application/json'},
                    method='POST'
                )
                with urllib.request.urlopen(req, timeout=10) as response:
                    result = json.loads(response.read().decode('utf-8'))
                    if result.get('status') == 'ok':
                        print(f"[+] [OFFLINE MASTER] ✅ Executed queued push: {result.get('files_count', 0)} files")
                        self.engine.state.pending_push_queue.clear()
                        self.engine.state.save_state_cache()
                    else:
                        print(f"[!] [OFFLINE MASTER] Push execution failed: {result.get('error', 'Unknown')}")
            except Exception as e:
                print(f"[!] [OFFLINE MASTER] Error executing queued push: {e}")
        
        # Process sync operations
        if not self.engine.state.pending_sync_queue:
            return
        
        print(f"[+] Processing {len(self.engine.state.pending_sync_queue)} pending sync operations")
        processed = 0
        
        for item in list(self.engine.state.pending_sync_queue):
            try:
                action = item['action']
                kwargs = item.get('kwargs', {})
                
                # Re-execute the action
                if action == 'sync_all':
                    GhostOpsMasterLogic.handle_sync_all(self.engine.state, self.engine.config.device_id)
                elif action == 'authority':
                    GhostOpsMasterLogic.handle_authority(
                        self.engine.state, 
                        kwargs.get('device_id', self.engine.config.device_id),
                        kwargs.get('has_authority', False)
                    )
                elif action == 'tool_activate':
                    GhostOpsMasterLogic.handle_tool_activate(
                        self.engine.state,
                        kwargs.get('tool', 'unknown'),
                        kwargs.get('source', self.engine.config.device_id)
                    )
                elif action == 'page_change':
                    GhostOpsMasterLogic.handle_page_change(
                        self.engine.state,
                        kwargs.get('page', 1),
                        kwargs.get('source', self.engine.config.device_id)
                    )
                
                processed += 1
            except Exception as e:
                print(f"[!] Failed to process sync queue item: {e}")
        
        # Clear processed items
        self.engine.state.clear_sync_queue()
        print(f"[+] Processed {processed} sync operations")
    
