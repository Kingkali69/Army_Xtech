        """Authenticate with Elasticsearch"""
        try:
            if self.connection.username and self.connection.password:
                # Basic auth for Elasticsearch
                auth_str = f"{self.connection.username}:{self.connection.password}"
                auth_bytes = auth_str.encode('utf-8')
                self._auth_token = base64.b64encode(auth_bytes).decode('ascii')
                return await self._validate_token()
            elif self.connection.api_key:
                # API key auth
                self._auth_token = self.connection.api_key
                return await self._validate_token()
            
            return False
            
