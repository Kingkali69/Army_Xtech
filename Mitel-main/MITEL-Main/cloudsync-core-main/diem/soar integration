class SplunkConnector(BaseSIEMConnector):
    """Splunk Enterprise and Cloud connector"""
    
    async def _authenticate(self) -> bool:
        """Authenticate with Splunk using username/password or token"""
        try:
            if self.connection.token:
                # Use bearer token
                self._auth_token = self.connection.token
                return await self._validate_token()
            
            elif self.connection.username and self.connection.password:
                # Login to get session key
                auth_url = f"{self.connection.base_url}/services/auth/login"
                data = {
                    'username': self.connection.username,
                    'password': self.connection.password,
                    'output_mode': 'json'
                }
                
                async with self.session.post(auth_url, data=data) as response:
                    if response.status == 200:
                        result = await response.json()
                        self._auth_token = result['sessionKey']
                        self._token_expires = datetime.now() + timedelta(hours=1)
                        return True
                        
            return False
            
        except Exception as e:
            self.logger.error(f"Splunk authentication failed: {e}")
            return False
    
    async def _validate_token(self) -> bool:
        """Validate Splunk authentication token"""
        try:
            headers = {'Authorization': f'Bearer {self._auth_token}'}
            url = f"{self.connection.base_url}/services/server/info"
            
            async with self.session.get(url, headers=headers) as response:
                return response.status == 200
                
        except Exception as e:
            self.logger.error(f"Token validation failed: {e}")
            return False
    
    async def send_event(self, event: SecurityEvent) -> bool:
        """Send event to Splunk HEC or via REST API"""
        try:
            await self._refresh_auth_if_needed()
            
            # Format event for Splunk
            splunk_event = {
                'time': int(event.timestamp.timestamp()),
                'source': 'ghost_engine',
                'sourcetype': 'ghost:security:event',
                'event': {
                    'event_id': event.event_id,
                    'severity': event.severity.value,
                    'event_type': event.event_type,
                    'title': event.title,
                    'description': event.description,
                    'source_ip': event.source_ip,
                    'source_host': event.source_host,
                    'source_user': event.source_user,
                    'dest_ip': event.dest_ip,
                    'dest_host': event.dest_host,
                    'dest_port': event.dest_port,
                    'indicators': event.indicators,
                    'tags': event.tags,
                    'raw_data': event.raw_data
                }
            }
            
            # Send to HEC endpoint
            headers = {
                'Authorization': f'Splunk {self._auth_token}',
                'Content-Type': 'application/json'
            }
            
            url = f"{self.connection.base_url}/services/collector/event"
            async with self.session.post(url, headers=headers, 
                                       json=splunk_event) as response:
                if response.status in [200, 201]:
                    self.logger.debug(f"Event {event.event_id} sent to Splunk")
                    return True
                else:
                    error_text = await response.text()
                    self.logger.error(f"Failed to send event: {error_text}")
                    return False
                    
        except Exception as e:
            self.logger.error(f"Splunk send_event failed: {e}")
            return False
    
    async def query_events(self, query: str, time_range: Dict[str, datetime], 
                          limit: int = 100) -> List[SecurityEvent]:
        """Query events from Splunk using SPL"""
        try:
            await self._refresh_auth_if_needed()
            
            # Build SPL query
            earliest = time_range['start'].strftime('%m/%d/%Y:%H:%M:%S')
            latest = time_range['end'].strftime('%m/%d/%Y:%H:%M:%S')
            
            spl_query = f"""
            search {query} earliest="{earliest}" latest="{latest}" 
            | head {limit}
            | sort -_time
            """
            
            # Execute search
            headers = {'Authorization': f'Splunk {self._auth_token}'}
            search_url = f"{self.connection.base_url}/services/search/jobs"
            
            search_data = {
                'search': spl_query,
                'output_mode': 'json',
                'exec_mode': 'oneshot'
            }
            
            async with self.session.post(search_url, headers=headers, 
                                       data=search_data) as response:
                if response.status == 200:
                    results = await response.json()
                    return self._parse_splunk_results(results)
                else:
                    self.logger.error(f"Splunk query failed: {response.status}")
                    return []
                    
        except Exception as e:
            self.logger.error(f"Splunk query_events failed: {e}")
            return []
    
    def _parse_splunk_results(self, results: Dict[str, Any]) -> List[SecurityEvent]:
        """Parse Splunk search results into SecurityEvent objects"""
        events = []
        
        for result in results.get('results', []):
            try:
                event = SecurityEvent(
                    event_id=result.get('event_id', str(uuid.uuid4())),
                    timestamp=datetime.fromtimestamp(float(result.get('_time', time.time()))),
                    source_platform=SIEMPlatform.SPLUNK_ENTERPRISE,
                    severity=EventSeverity(result.get('severity', 'info')),
                    event_type=result.get('event_type', 'unknown'),
                    title=result.get('title', 'Untitled Event'),
                    description=result.get('description', ''),
