@dataclass
class SIEMAlert:
    """Standardized SIEM alert format for Ghost Engine"""
    alert_id: str
    source_platform: str
    severity: str
    title: str
    description: str
    timestamp: datetime
    source_ip: Optional[str] = None
    destination_ip: Optional[str] = None
    user: Optional[str] = None
    asset: Optional[str] = None
    raw_data: Optional[Dict[str, Any]] = None
    indicators: Optional[List[str]] = None
    
    def get_orchestrator_status(self) -> Dict[str, Any]:
        """Get comprehensive orchestrator status"""
        siem_status = {}
        for name, connector in self.siem_connectors.items():
            siem_status[name] = {
                'status': connector.status.value,
                'platform': connector.platform_name,
                'last_poll': self.stats.get('last_poll'),
                'health': await connector.health_check() if asyncio.iscoroutinefunction(connector.health_check) else connector.health_check()
            }
        
        soar_status = {}
        for name, connector in self.soar_connectors.items():
            soar_status[name] = {
                'status': connector.status.value,
                'platform': connector.platform_name
            }
        
        return {
            'is_running': self.is_running,
            'siem_connectors': siem_status,
            'soar_connectors': soar_status,
            'statistics': self.stats,
            'recent_alerts_count': len(self.recent_alerts),
            'automation_rules_count': len(self.automation_rules)
        }
    
    async def manual_playbook_trigger(self, soar_platform: str, playbook_id: str, context: Dict[str, Any]) -> str:
        """Manually trigger a SOAR playbook"""
        if soar_platform not in self.soar_connectors:
            raise ValueError(f"SOAR platform {soar_platform} not connected")
        
        return await self.soar_connectors[soar_platform].trigger_playbook(playbook_id, context)
    
    async def get_playbook_status(self, soar_platform: str, execution_id: str) -> Dict[str, Any]:
        """Get status of a running playbook"""
        if soar_platform not in self.soar_connectors:
            raise ValueError(f"SOAR platform {soar_platform} not connected")
        
        return await self.soar_connectors[soar_platform].get_playbook_status(execution_id)

