class GhostSIEMSOARIntegration:
    """
    KK&G DevOps Ghost Engine - Main SIEM/SOAR Integration Module
    
    Drop-in module for the Ghost Engine core that provides enterprise-grade
    SIEM and SOAR platform integrations with zero manual configuration.
    """
    
    def __init__(self, ghost_engine_instance, config_file: str = "ghost_siem_soar_config.yaml"):
        self.ghost_engine = ghost_engine_instance
        self.config_file = config_file
        self.orchestrator: Optional[GhostSIEMSOAROrchestrator] = None
        self.is_initialized = False
        self.logger = logging.getLogger("ghost.siem_soar_integration")
        
        # Load configuration
        self.config = self._load_or_create_config()
        
    def _load_or_create_config(self) -> Dict[str, Any]:
        """Load configuration or create default enterprise config"""
        try:
            import yaml
            with open(self.config_file, 'r') as f:
                config = yaml.safe_load(f)
                self.logger.info(f"Loaded SIEM/SOAR configuration from {self.config_file}")
                return config
        except FileNotFoundError:
            # Create default enterprise configuration
            config = GhostSIEMSOARConfigFactory.create_enterprise_config()
            
            try:
                import yaml
                with open(self.config_file, 'w') as f:
                    yaml.dump(config, f, default_flow_style=False, indent=2)
                self.logger.info(f"Created default SIEM/SOAR configuration: {self.config_file}")
            except Exception as e:
                self.logger.warning(f"Could not save default configuration: {e}")
            
            return config
        except Exception as e:
            self.logger.error(f"Error loading configuration: {e}")
            return GhostSIEMSOARConfigFactory.create_enterprise_config()
    
    async def initialize(self) -> bool:
        """Initialize the SIEM/SOAR integration module"""
        try:
            self.orchestrator = GhostSIEMSOAROrchestrator(self.config)
            
            if await self.orchestrator.initialize():
                # Register event handler with Ghost Engine
                if hasattr(self.ghost_engine, 'event_pipeline'):
                    self.ghost_engine.event_pipeline.add_processor(self._handle_ghost_engine_event)
                
                self.is_initialized = True
                self.logger.info("Ghost Engine SIEM/SOAR integration initialized successfully")
                return True
            else:
                self.logger.error("Failed to initialize SIEM/SOAR orchestrator")
                return False
                
        except Exception as e:
            self.logger.error(f"Error initializing SIEM/SOAR integration: {e}")
            return False
    
    async def start(self):
        """Start SIEM/SOAR monitoring and integration"""
        if not self.is_initialized:
            raise RuntimeError("SIEM/SOAR integration not initialized")
        
        self.logger.info("Starting Ghost Engine SIEM/SOAR integration")
        await self.orchestrator.start_monitoring()
    
    async def stop(self):
        """Stop SIEM/SOAR integration"""
        if self.orchestrator:
            await self.orchestrator.stop_monitoring()
            self.logger.info("Stopped Ghost Engine SIEM/SOAR integration")
    
    async def _handle_ghost_engine_event(self, event: SecurityEvent):
        """Handle Ghost Engine security events and distribute to SIEM platforms"""
        try:
            if self.orchestrator and self.orchestrator.is_running:
                await self.orchestrator._distribute_event_to_siems(event)
                
        except Exception as e:
            self.logger.error(f"Error handling Ghost Engine event: {e}")
    
    def get_integration_status(self) -> Dict[str, Any]:
        """Get integration status"""
        if not self.orchestrator:
            return {"status": "not_initialized"}
        
        return self.orchestrator.get_orchestrator_status()
    
    async def trigger_manual_response(self, soar_platform: str, playbook_id: str, 
                                    event: SecurityEvent) -> str:
        """Manually trigger SOAR response for a specific event"""
        if not self.orchestrator:
            raise RuntimeError("SIEM/SOAR integration not initialized")
        
        context = {
            'event_id': event.event_id,
            'title': f'Manual Ghost Engine Response',
            'description': f'Manual SOAR response for {event.event_type.value}',
            'severity': event.threat_level.value,
            'threat_level': event.threat_level.value,
            'platform': event.platform,
            'timestamp': event.timestamp.isoformat(),
            'raw_data': event.data
        }
        
        return await self.orchestrator.manual_playbook_trigger(soar_platform, playbook_id, context)
    
    def add_automation_rule(self, rule: Dict[str, Any]):
        """Add new automation rule at runtime"""
        if self.orchestrator:
            self.orchestrator.automation_rules.append(rule)
            self.logger.info(f"Added automation rule: {rule.get('name', 'Unnamed')}")
    
    def list_available_playbooks(self, soar_platform: str) -> List[SOARPlaybook]:
        """List available playbooks for a SOAR platform"""
        if not self.orchestrator or soar_platform not in self.orchestrator.soar_connectors:
            return []
        
        return asyncio.run(self.orchestrator.soar_connectors[soar_platform].list_playbooks())

