def register_siem_soar_integration(ghost_engine_instance, config_file: str = None) -> GhostSIEMSOARIntegration:
    """
    KK&G DevOps Ghost Engine - SIEM/SOAR Integration Registration Helper
    
    Drop-in function to register SIEM/SOAR capabilities with an existing Ghost Engine instance.
    
    Args:
        ghost_engine_instance: Running Ghost Engine instance
        config_file: Optional path to SIEM/SOAR configuration file
    
    Returns:
        GhostSIEMSOARIntegration: Initialized integration module
    
    Example:
        # In your Ghost Engine main code:
        from ghost_siem_soar_integration import register_siem_soar_integration
        
        engine = SecurityEngine()
        siem_soar = register_siem_soar_integration(engine)
        
        # Start both Ghost Engine and SIEM/SOAR integration
        asyncio.run(asyncio.gather(
            engine.start(),
            siem_soar.start()
        ))
    """
    config_file = config_file or "ghost_siem_soar_config.yaml"
    integration = GhostSIEMSOARIntegration(ghost_engine_instance, config_file)
    
    logging.getLogger("ghost.siem_soar").info(
        "KK&G DevOps Ghost Engine - Enterprise SIEM/SOAR integration module loaded"
    )
    
    return integration

