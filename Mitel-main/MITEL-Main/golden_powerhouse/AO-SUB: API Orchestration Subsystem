    async def acquire(self, tokens: int = 1, key: Optional[str] = None) -> bool:
        """Acquire tokens for rate limiting"""
        with self._lock:
            current_time = time.time()
            
            if self.strategy == RateLimitStrategy.TOKEN_BUCKET:
                return self._token_bucket_acquire(tokens, current_time)
            elif self.strategy == RateLimitStrategy.LEAKY_BUCKET:
                return self._leaky_bucket_acquire(tokens, current_time)
            elif self.strategy == RateLimitStrategy.SLIDING_WINDOW:
                return self._sliding_window_acquire(tokens, current_time)
            
            return True
    
    def _token_bucket_acquire(self, tokens: int, current_time: float) -> bool:
        """Token bucket algorithm"""
        # Add tokens based on elapsed time
        elapsed = current_time - self.last_update
        self.tokens = min(self.capacity, self.tokens + elapsed * self.rate)
        self.last_update = current_time
        
        if self.tokens >= tokens:
            self.tokens -= tokens
            return True
        
        return False
    
    def _leaky_bucket_acquire(self, tokens: int, current_time: float) -> bool:
        """Leaky bucket algorithm"""
        # Similar to token bucket but with constant leak rate
        elapsed = current_time - self.last_update
        leaked = elapsed * self.rate
        self.tokens = max(0, self.tokens - leaked)
        self.last_update = current_time
        
        if self.tokens + tokens <= self.capacity:
            self.tokens += tokens
            return True
        
        return False
    
    def _sliding_window_acquire(self, tokens: int, current_time: float) -> bool:
        """Sliding window algorithm"""
        # Remove old requests outside the window
        cutoff = current_time - self.window_size
        self.requests = [req_time for req_time in self.requests if req_time > cutoff]
        
        if len(self.requests) + tokens <= self.capacity:
            for _ in range(tokens):
                self.requests.append(current_time)
            return True
        
        return False
    
    def get_stats(self) -> Dict:
        """Get rate limiter statistics"""
        with self._lock:
            current_time = time.time()
            
            if self.strategy == RateLimitStrategy.TOKEN_BUCKET:
                elapsed = current_time - self.last_update
                available = min(self.capacity, self.tokens + elapsed * self.rate)
                return {
                    'strategy': self.strategy.value,
                    'available_tokens': available,
                    'capacity': self.capacity,
                    'rate': self.rate,
                    'utilization': (self.capacity - available) / self.capacity
                }
            elif self.strategy == RateLimitStrategy.SLIDING_WINDOW:
                cutoff = current_time - self.window_size
                active_requests = [r for r in self.requests if r > cutoff]
                return {
                    'strategy': self.strategy.value,
                    'active_requests': len(active_requests),
                    'capacity': self.capacity,
                    'window_size': self.window_size,
                    'utilization': len(active_requests) / self.capacity
                }
            
            return {'strategy': self.strategy.value}


class DataTransformer:
    """Transforms data between external APIs and Ghost native format"""
    
    def __init__(self):
        self.transformers: Dict[str, Callable] = {}
        self.reverse_transformers: Dict[str, Callable] = {}
        self.logger = logging.getLogger(f"{self.__class__.__name__}")
    
    def register_transformer(self, data_type: str, 
                           to_ghost: Callable[[Any], Dict],
                           from_ghost: Callable[[Dict], Any] = None):
        """Register data transformation functions"""
        self.transformers[data_type] = to_ghost
        if from_ghost:
            self.reverse_transformers[data_type] = from_ghost
        
        self.logger.debug(f"Registered transformer for {data_type}")
    
    def to_ghost_format(self, data: Any, data_type: str = "json") -> Dict:
        """Transform external data to Ghost native format"""
        try:
            if data_type in self.transformers:
                return self.transformers[data_type](data)
            
            # Default transformations
            if data_type == "json":
                return self._json_to_ghost(data)
            elif data_type == "yaml":
                return self._yaml_to_ghost(data)
            elif data_type == "xml":
                return self._xml_to_ghost(data)
            else:
                return self._generic_to_ghost(data)
                
        except Exception as e:
            self.logger.error(f"Transformation error for {data_type}: {e}")
            return self._error_response(data, str(e))
    
    def from_ghost_format(self, data: Dict, data_type: str = "json") -> Any:
        """Transform Ghost native format to external format"""
        try:
            if data_type in self.reverse_transformers:
                return self.reverse_transformers[data_type](data)
            
            # Default reverse transformations
            if data_type == "json":
                return self._ghost_to_json(data)
            elif data_type == "yaml":
                return self._ghost_to_yaml(data)
            else:
                return data
                
        except Exception as e:
            self.logger.error(f"Reverse transformation error for {data_type}: {e}")
            return data
    
    def _json_to_ghost(self, data: Any) -> Dict:
        """Transform JSON to Ghost format"""
        return {
            'data_type': 'json',
            'payload': data,
            'timestamp': datetime.now().isoformat(),
            'metadata': {
                'source': 'external_api',
                'format': 'json'
            }
        }
    
    def _yaml_to_ghost(self, data: str) -> Dict:
        """Transform YAML to Ghost format"""
        parsed = yaml.safe_load(data) if isinstance(data, str) else data
        return {
            'data_type': 'yaml',
            'payload': parsed,
            'timestamp': datetime.now().isoformat(),
            'metadata': {
                'source': 'external_api',
                'format': 'yaml'
            }
        }
    
    def _xml_to_ghost(self, data: str) -> Dict:
        """Basic XML to Ghost format (would need xml library in production)"""
        return {
            'data_type': 'xml',
            'payload': {'raw_xml': data},
            'timestamp': datetime.now().isoformat(),
            'metadata': {
                'source': 'external_api',
                'format': 'xml',
                'note': 'Basic XML parsing - extend with xml.etree or lxml'
            }
        }
    
    def _generic_to_ghost(self, data: Any) -> Dict:
        """Generic transformation for unknown data types"""
        return {
            'data_type': 'generic',
            'payload': str(data) if not isinstance(data, (dict, list)) else data,
            'timestamp': datetime.now().isoformat(),
            'metadata': {
                'source': 'external_api',
                'format': 'generic',
                'original_type': type(data).__name__
            }
        }
    
    def _ghost_to_json(self, data: Dict) -> Any:
        """Transform Ghost format to JSON"""
        return data.get('payload', data)
    
    def _ghost_to_yaml(self, data: Dict) -> str:
        """Transform Ghost format to YAML"""
        payload = data.get('payload', data)
        return yaml.dump(payload, default_flow_style=False)
    
    def _error_response(self, original_data: Any, error: str) -> Dict:
        """Generate error response in Ghost format"""
        return {
            'data_type': 'error',
            'payload': {
                'error': error,
                'original_data': str(original_data)[:1000]  # Truncate large data
            },
            'timestamp': datetime.now().isoformat(),
            'metadata': {
                'source': 'ao_sub_transformer',
                'format': 'error'
            }
        }


class APIHealthMonitor:
    """Monitors API endpoint health and manages fallbacks"""
    
    def __init__(self, check_interval: int = 300):
        self.check_interval = check_interval
        self.endpoint_status: Dict[str, APIStatus] = {}
        self.health_history: Dict[str, List[Tuple[datetime, bool]]] = {}
        self.fallback_endpoints: Dict[str, List[str]] = {}
        self._monitoring_task = None
        self._is_running = False
        self.logger = logging.getLogger(f"{self.__class__.__name__}")
    
    def add_endpoint(self, endpoint: APIEndpoint, fallbacks: List[str] = None):
        """Add endpoint for health monitoring"""
        self.endpoint_status[endpoint.name] = APIStatus.UNKNOWN
        self.health_history[endpoint.name] = []
        if fallbacks:
            self.fallback_endpoints[endpoint.name] = fallbacks
        
        self.logger.info(f"Added endpoint {endpoint.name} for monitoring")
    
    def start_monitoring(self, client_manager):
        """Start health monitoring background task"""
        if not self._is_running:
            self._is_running = True
            loop = asyncio.get_event_loop()
            self._monitoring_task = loop.create_task(
                self._monitoring_loop(client_manager)
            )
            self.logger.info("Health monitoring started")
    
    async def stop_monitoring(self):
        """Stop health monitoring"""
        if self._is_running:
            self._is_running = False
            if self._monitoring_task:
                self._monitoring_task.cancel()
                try:
                    await self._monitoring_task
                except asyncio.CancelledError:
                    pass
            self.logger.info("Health monitoring stopped")
    
    async def _monitoring_loop(self, client_manager):
        """Main monitoring loop"""
        while self._is_running:
            try:
                for endpoint_name in self.endpoint_status.keys():
                    await self._check_endpoint_health(endpoint_name, client_manager)
                
                await asyncio.sleep(self.check_interval)
                
            except asyncio.CancelledError:
                break
            except Exception as e:
                self.logger.error(f"Health monitoring error: {e}")
                await asyncio.sleep(min(self.check_interval, 60))
    
    async def _check_endpoint_health(self, endpoint_name: str, client_manager):
        """Check health of a specific endpoint"""
        try:
            endpoint = client_manager.get_endpoint(endpoint_name)
            if not endpoint or not endpoint.enabled:
                return
            
            # Perform health check
            start_time = time.time()
            
            health_url = urljoin(endpoint.base_url, endpoint.health_check_path)
            
            async with client_manager._session.get(
                health_url,
                timeout=aiohttp.ClientTimeout(total=10),
                headers=client_manager._get_auth_headers(endpoint)
            ) as response:
                response_time = time.time() - start_time
                is_healthy = 200 <= response.status < 400
                
                # Update status
                if is_healthy and response_time < 5.0:
                    self.endpoint_status[endpoint_name] = APIStatus.HEALTHY
                elif is_healthy:
                    self.endpoint_status[endpoint_name] = APIStatus.DEGRADED
                else:
                    self.endpoint_status[endpoint_name] = APIStatus.UNHEALTHY
                
                # Record history
                self.health_history[endpoint_name].append(
                    (datetime.now(), is_healthy)
                )
                
                # Keep only last 100 checks
                if len(self.health_history[endpoint_name]) > 100:
                    self.health_history[endpoint_name] = \
                        self.health_history[endpoint_name][-100:]
                
                self.logger.debug(
                    f"Health check {endpoint_name}: "
                    f"{self.endpoint_status[endpoint_name].value} "
                    f"({response_time:.2f}s)"
                )
                
        except Exception as e:
            self.endpoint_status[endpoint_name] = APIStatus.UNHEALTHY
            self.health_history[endpoint_name].append(
                (datetime.now(), False)
            )
            self.logger.warning(f"Health check failed for {endpoint_name}: {e}")
    
    def get_healthy_endpoint(self, primary_endpoint: str) -> Optional[str]:
        """Get healthy endpoint, including fallbacks"""
        # Check primary endpoint
        if (self.endpoint_status.get(primary_endpoint) in 
            [APIStatus.HEALTHY, APIStatus.DEGRADED]):
            return primary_endpoint
        
        # Check fallbacks
        fallbacks = self.fallback_endpoints.get(primary_endpoint, [])
        for fallback in fallbacks:
            if (self.endpoint_status.get(fallback) in 
                [APIStatus.HEALTHY, APIStatus.DEGRADED]):
                return fallback
        
        # Return primary if no healthy fallbacks (let it fail with proper error)
        return primary_endpoint
    
    def get_health_stats(self) -> Dict:
        """Get health statistics for all endpoints"""
        stats = {}
        for endpoint_name, status in self.endpoint_status.items():
            history = self.health_history.get(endpoint_name, [])
            recent_checks = [check for check in history 
                           if check[0] > datetime.now() - timedelta(hours=1)]
            
            success_rate = 0
            if recent_checks:
                successful = sum(1 for _, success in recent_checks if success)
                success_rate = successful / len(recent_checks) * 100
            
            stats[endpoint_name] = {
                'status': status.value,
                'total_checks': len(history),
                'recent_success_rate': success_rate,
                'last_check': history[-1][0].isoformat() if history else None
            }
        
        return stats


class APIClientManager:
    """Manages external API clients with advanced features"""
    
    def __init__(self, config_path: Optional[str] = None):
        self.endpoints: Dict[str, APIEndpoint] = {}
        self.rate_limiters: Dict[str, RateLimiter] = {}
        self.transformer = DataTransformer()
        self.health_monitor = APIHealthMonitor()
        self._session: Optional[aiohttp.ClientSession] = None
        self._is_initialized = False
        
        self.logger = logging.getLogger(f"{self.__class__.__name__}")
        
        # Load configuration if provided
        if config_path:
            self.load_config(config_path)
    
    def load_config(self, config_path: str):
        """Load configuration from YAML file"""
        try:
            with open(config_path, 'r') as f:
                config = yaml.safe_load(f)
            
            # Load endpoints
            for endpoint_config in config.get('endpoints', []):
                endpoint = APIEndpoint(**endpoint_config)
                self.add_endpoint(endpoint)
            
            # Load rate limiting configs
            rate_configs = config.get('rate_limiting', {})
            for endpoint_name, rate_config in rate_configs.items():
                if endpoint_name in self.endpoints:
                    strategy = RateLimitStrategy(
                        rate_config.get('strategy', 'token_bucket')
                    )
                    limiter = RateLimiter(
                        strategy=strategy,
                        rate=rate_config.get('rate', 10),
                        capacity=rate_config.get('capacity', 100),
                        window_size=rate_config.get('window_size', 60)
                    )
                    self.rate_limiters[endpoint_name] = limiter
            
            # Load transformer configs
            transformers = config.get('transformers', {})
            for data_type, transform_config in transformers.items():
                # This would load custom transformer functions
                # For now, we use built-in transformations
                pass
            
            self.logger.info(f"Loaded configuration from {config_path}")
            
        except Exception as e:
            self.logger.error(f"Failed to load config from {config_path}: {e}")
            raise
    
    async def initialize(self):
        """Initialize the API client manager"""
        if not self._is_initialized:
            # Create aiohttp session with appropriate settings
            connector = aiohttp.TCPConnector(
                limit=100,
                limit_per_host=20,
                keepalive_timeout=30,
                enable_cleanup_closed=True
            )
            
            timeout = aiohttp.ClientTimeout(total=30, connect=10)
            
            self._session = aiohttp.ClientSession(
                connector=connector,
                timeout=timeout,
                headers={'User-Agent': 'Ghost-AO-SUB/1.0'}
            )
            
            # Start health monitoring
            for endpoint in self.endpoints.values():
                self.health_monitor.add_endpoint(endpoint)
            
            self.health_monitor.start_monitoring(self)
            
            self._is_initialized = True
            self.logger.info("API Client Manager initialized")
    
    async def shutdown(self):
        """Shutdown the API client manager"""
        if self._is_initialized:
            await self.health_monitor.stop_monitoring()
            
            if self._session:
                await self._session.close()
            
            self._is_initialized = False
            self.logger.info("API Client Manager shutdown")
    
    def add_endpoint(self, endpoint: APIEndpoint):
        """Add an API endpoint"""
        self.endpoints[endpoint.name] = endpoint
        
        # Create rate limiter if specified
        if endpoint.rate_limit:
            strategy = RateLimitStrategy(
                endpoint.rate_limit.get('strategy', 'token_bucket')
            )
            limiter = RateLimiter(
                strategy=strategy,
                rate=endpoint.rate_limit.get('rate', 10),
                capacity=endpoint.rate_limit.get('capacity', 100)
            )
            self.rate_limiters[endpoint.name] = limiter
        
        self.logger.info(f"Added endpoint: {endpoint.name}")
    
    def get_endpoint(self, name: str) -> Optional[APIEndpoint]:
        """Get endpoint by name"""
        return self.endpoints.get(name)
    
    def _get_auth_headers(self, endpoint: APIEndpoint) -> Dict[str, str]:
        """Get authentication headers for endpoint"""
        headers = endpoint.headers.copy()
        
        if endpoint.auth_type == APIAuthType.API_KEY and endpoint.api_key:
            headers['X-API-Key'] = endpoint.api_key
        elif endpoint.auth_type == APIAuthType.BEARER and endpoint.bearer_token:
            headers['Authorization'] = f'Bearer {endpoint.bearer_token}'
        elif (endpoint.auth_type == APIAuthType.BASIC and 
              endpoint.username and endpoint.password):
            credentials = f"{endpoint.username}:{endpoint.password}"
            encoded = base64.b64encode(credentials.encode()).decode()
            headers['Authorization'] = f'Basic {encoded}'
        
        return headers
    
    async def make_request(self, request: APIRequest) -> APIResponse:
        """Make an API request with full feature support"""
        if not self._is_initialized:
            await self.initialize()
        
        start_time = time.time()
        endpoint_name = request.endpoint_name
        
        try:
            # Get healthy endpoint (includes fallback logic)
            actual_endpoint_name = self.health_monitor.get_healthy_endpoint(
                endpoint_name
            )
            endpoint = self.endpoints.get(actual_endpoint_name)
            
            if not endpoint or not endpoint.enabled:
                raise ValueError(f"Endpoint {endpoint_name} not found or disabled")
            
            # Apply rate limiting
            if endpoint_name in self.rate_limiters:
                limiter = self.rate_limiters[endpoint_name]
                if not await limiter.acquire():
                    raise Exception("Rate limit exceeded")
            
            # Prepare request
            url = urljoin(endpoint.base_url, request.path.lstrip('/'))
            headers = self._get_auth_headers(endpoint)
            
            if request.headers:
                headers.update(request.headers)
            
            timeout = aiohttp.ClientTimeout(
                total=request.timeout or endpoint.timeout
            )
            
            # Make the request with retries
            response = await self._make_request_with_retries(
                request, endpoint, url, headers, timeout, start_time
            )
            
            return response
            
        except Exception as e:
            response_time = time.time() - start_time
            self.logger.error(f"Request {request.request_id} failed: {e}")
            
            return APIResponse(
                request_id=request.request_id,
                endpoint_name=endpoint_name,
                status_code=0,
                error=str(e),
                response_time=response_time,
                retry_count=request.retry_count
            )
    
    async def _make_request_with_retries(self, request: APIRequest, 
                                       endpoint: APIEndpoint, url: str,
                                       headers: Dict, timeout: aiohttp.ClientTimeout,
                                       start_time: float) -> APIResponse:
        """Make request with exponential backoff retries"""
        last_error = None
        
        for attempt in range(endpoint.max_retries + 1):
            try:
                # Prepare request data
                request_kwargs = {
                    'url': url,
                    'method': request.method.value,
                    'headers': headers,
                    'timeout': timeout,
                    'params': request.params
                }
                
                if request.data is not None:
                    if request.method in [APIMethod.POST, APIMethod.PUT, 
                                        APIMethod.PATCH]:
                        if isinstance(request.data, (dict, list)):
                            request_kwargs['json'] = request.data
                        else:
                            request_kwargs['data'] = request.data
                
                # Make the actual request
                async with self._session.request(**request_kwargs) as response:
                    response_time = time.time() - start_time
                    
                    # Read response data
                    try:
                        if response.content_type == 'application/json':
                            data = await response.json()
                        else:
                            data = await response.text()
                    except:
                        data = None
                    
                    # Transform response data
                    if data is not None:
                        content_type = response.content_type or 'json'
                        if 'json' in content_type:
                            data = self.transformer.to_ghost_format(data, 'json')
                        elif 'yaml' in content_type:
                            data = self.transformer.to_ghost_format(data, 'yaml')
                        else:
                            data = self.transformer.to_ghost_format(data, 'generic')
                    
                    return APIResponse(
                        request_id=request.request_id,
                        endpoint_name=request.endpoint_name,
                        status_code=response.status,
                        data=data,
                        headers=dict(response.headers),
                        response_time=response_time,
                        retry_count=attempt
                    )
                    
            except Exception as e:
                last_error = e
                
                # Don't retry on certain errors
                if isinstance(e, aiohttp.ClientError):
                    if hasattr(e, 'status') and 400 <= e.status < 500:
                        break  # Client errors shouldn't be retried
                
                if attempt < endpoint.max_retries:
                    # Exponential backoff
                    backoff_time = endpoint.retry_backoff * (2 ** attempt)
                    await asyncio.sleep(backoff_time)
                    self.logger.warning(
                        f"Request {request.request_id} attempt {attempt + 1} failed: {e}. "
                        f"Retrying in {backoff_time:.1f}s"
                    )
        
        # All retries exhausted
        response_time = time.time() - start_time
        raise Exception(f"All {endpoint.max_retries + 1} attempts failed. "
                       f"Last error: {last_error}")
    
    def get_stats(self) -> Dict:
        """Get comprehensive API client statistics"""
        stats = {
            'endpoints': {},
            'rate_limiters': {},
            'health': self.health_monitor.get_health_stats()
        }
        
        # Endpoint stats
        for name, endpoint in self.endpoints.items():
            stats['endpoints'][name] = {
                'enabled': endpoint.enabled,
                'base_url': endpoint.base_url,
                'auth_type': endpoint.auth_type.value,
                'max_retries': endpoint.max_retries,
                'timeout': endpoint.timeout
            }
        
        # Rate limiter stats
        for name, limiter in self.rate_limiters.items():
            stats['rate_limiters'][name] = limiter.get_stats()
        
        return stats


