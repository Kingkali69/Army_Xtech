class APIMethod(Enum):
    GET = "GET"
    POST = "POST"
    PUT = "PUT"
    DELETE = "DELETE"
    PATCH = "PATCH"
    HEAD = "HEAD"
    OPTIONS = "OPTIONS"


class APIAuthType(Enum):
    NONE = "none"
    API_KEY = "api_key"
    BEARER = "bearer"
    BASIC = "basic"
    OAUTH2 = "oauth2"
    CUSTOM = "custom"


class RateLimitStrategy(Enum):
    TOKEN_BUCKET = "token_bucket"
    LEAKY_BUCKET = "leaky_bucket"
    SLIDING_WINDOW = "sliding_window"


class APIStatus(Enum):
    HEALTHY = "healthy"
    DEGRADED = "degraded" 
    UNHEALTHY = "unhealthy"
    UNKNOWN = "unknown"


@dataclass
class APIEndpoint:
    """Configuration for an external API endpoint"""
    name: str
    base_url: str
    auth_type: APIAuthType = APIAuthType.NONE
    api_key: Optional[str] = None
    bearer_token: Optional[str] = None
    username: Optional[str] = None
    password: Optional[str] = None
    headers: Dict[str, str] = field(default_factory=dict)
    timeout: float = 30.0
    max_retries: int = 3
    retry_backoff: float = 1.0
    rate_limit: Optional[Dict] = None
    health_check_path: str = "/health"
    health_check_interval: int = 300  # seconds
    enabled: bool = True
    priority: int = 1
    tags: Set[str] = field(default_factory=set)


@dataclass
class APIRequest:
    """Represents an API request"""
    endpoint_name: str
    path: str
    method: APIMethod = APIMethod.GET
    params: Optional[Dict] = None
    data: Optional[Any] = None
    headers: Optional[Dict[str, str]] = None
    timeout: Optional[float] = None
    retry_count: int = 0
    request_id: str = field(default_factory=lambda: str(uuid.uuid4()))
    metadata: Dict[str, Any] = field(default_factory=dict)
    callback: Optional[Callable] = None


@dataclass
class APIResponse:
    """Represents an API response"""
    request_id: str
    endpoint_name: str
    status_code: int
    data: Any = None
    headers: Optional[Dict] = None
    error: Optional[str] = None
    response_time: float = 0.0
    timestamp: datetime = field(default_factory=datetime.now)
    retry_count: int = 0


class RateLimiter:
    """Advanced rate limiter with multiple strategies"""
    
    def __init__(self, strategy: RateLimitStrategy = RateLimitStrategy.TOKEN_BUCKET,
                 rate: float = 10.0, capacity: int = 100, window_size: int = 60):
        self.strategy = strategy
        self.rate = rate  # requests per second
        self.capacity = capacity  # max requests
        self.window_size = window_size  # for sliding window
        
        # Token bucket state
        self.tokens = float(capacity)
        self.last_update = time.time()
        
        # Sliding window state
        self.requests = []
        
        # Thread safety
        self._lock = threading.RLock()
        
        self.logger = logging.getLogger("Ghost.AO-SUB")
        
        # Register event handlers
        self._register_event_handlers()
    
    def _register_event_handlers(self):
        """Register handlers for Ghost events"""
        self.event_bus.subscribe("API_REQUEST", self._handle_api_request_event)
        self.event_bus.subscribe("SYSTEM_SHUTDOWN", self._handle_shutdown_event)
        self.event_bus.subscribe("AO_STATUS_REQUEST", self._handle_status_request)
    
    async def start(self):
        """Start the AO-SUB subsystem"""
        if not self._is_running:
            self._is_running = True
            
            # Start components
            await self.client_manager.initialize()
            self.event_bus.start()
            
            # Start request processor
            loop = asyncio.get_event_loop()
            self._processor_task = loop.create_task(self._process_requests())
            
            # Publish startup event
            await self.event_bus.publish_async(
                "AO_SUBSYSTEM_READY",
                {"subsystem": "AO-SUB", "timestamp": datetime.now().isoformat()},
                priority=EventPriority.HIGH
            )
            
            self.logger.info("AO-SUB started successfully")
    
    async def stop(self):
        """Stop the AO-SUB subsystem"""
        if self._is_running:
            self._is_running = False
            
            # Stop processor
            if self._processor_task:
                self._processor_task.cancel()
                try:
                    await self._processor_task
                except asyncio.CancelledError:
                    pass
            
            # Stop components
            await self.client_manager.shutdown()
            await self.event_bus.stop()
            
            self.logger.info("AO-SUB stopped")
    
    async def _process_requests(self):
        """Process queued API requests"""
        while self._is_running:
            try:
                # Get request from queue with timeout
                request = await asyncio.wait_for(
                    self.request_queue.get(), timeout=1.0
                )
                
                # Make the API request
                response = await self.client_manager.make_request(request)
                
                # Handle response
                await self._handle_response(request, response)
                
            except asyncio.TimeoutError:
                continue
            except Exception as e:
                self.logger.error(f"Request processor error: {e}")
    
    async def _handle_response(self, request: APIRequest, response: APIResponse):
        """Handle API response"""
        # Call response callback if provided
        if request.callback:
            try:
                if asyncio.iscoroutinefunction(request.callback):
                    await request.callback(response)
                else:
                    request.callback(response)
            except Exception as e:
                self.logger.error(f"Response callback error: {e}")
        
        # Publish response event
        event_data = {
            'request_id': response.request_id,
            'endpoint': response.endpoint_name,
            'status_code': response.status_code,
            'response_time': response.response_time,
            'success': response.error is None,
            'data': response.data
        }
        
        event_type = "API_RESPONSE_SUCCESS" if response.error is None else "API_RESPONSE_ERROR"
        priority = EventPriority.NORMAL if response.error is None else EventPriority.HIGH
        
        await self.event_bus.publish_async(event_type, event_data, priority=priority)
    
    async def _handle_api_request_event(self, event: GhostEvent):
        """Handle API request events from other subsystems"""
        try:
            data = event.data
            
            request = APIRequest(
                endpoint_name=data['endpoint'],
                path=data['path'],
                method=APIMethod(data.get('method', 'GET')),
                params=data.get('params'),
                data=data.get('data'),
                headers=data.get('headers'),
                timeout=data.get('timeout'),
                metadata=data.get('metadata', {})
            )
            
            # Add to processing queue
            await self.request_queue.put(request)
            
            self.logger.debug(f"Queued API request: {request.request_id}")
            
        except Exception as e:
            self.logger.error(f"Error handling API request event: {e}")
    
    async def _handle_shutdown_event(self, event: GhostEvent):
        """Handle system shutdown events"""
        self.logger.info("Received shutdown event, stopping AO-SUB")
        await self.stop()
    
    async def _handle_status_request(self, event: GhostEvent):
        """Handle status request events"""
        stats = self.get_comprehensive_stats()
        
        await self.event_bus.publish_async(
            "AO_STATUS_RESPONSE",
            {
                'subsystem': 'AO-SUB',
                'stats': stats,
                'timestamp': datetime.now().isoformat()
            },
            priority=EventPriority.NORMAL
        )
    
    async def make_request(self, endpoint_name: str, path: str, 
                          method: APIMethod = APIMethod.GET,
                          params: Optional[Dict] = None,
                          data: Optional[Any] = None,
                          headers: Optional[Dict] = None,
                          callback: Optional[Callable] = None) -> str:
        """Make an API request and return request ID"""
        request = APIRequest(
            endpoint_name=endpoint_name,
            path=path,
            method=method,
            params=params,
            data=data,
            headers=headers,
            callback=callback
        )
        
        await self.request_queue.put(request)
        return request.request_id
    
    async def make_request_sync(self, endpoint_name: str, path: str,
                               method: APIMethod = APIMethod.GET,
                               **kwargs) -> APIResponse:
        """Make a synchronous API request and wait for response"""
        request = APIRequest(
            endpoint_name=endpoint_name,
            path=path,
            method=method,
            **kwargs
        )
        
        return await self.client_manager.make_request(request)
    
    def get_comprehensive_stats(self) -> Dict:
        """Get comprehensive subsystem statistics"""
        return {
            'ao_sub': {
                'is_running': self._is_running,
                'queue_size': self.request_queue.qsize(),
                'registered_callbacks': len(self.response_callbacks)
            },
            'client_manager': self.client_manager.get_stats(),
            'event_bus': self.event_bus.get_stats() if hasattr(self.event_bus, 'get_stats') else {}
        }
    
    def __enter__(self):
        return self
    
    async def __aenter__(self):
        await self.start()
        return self
    
    async def __aexit__(self, exc_type, exc_val, exc_tb):
        await self.stop()


