async def run_daemon(ao_sub: AOSubsystem):
    """Run AO-SUB as a daemon"""
    print("🚀 Starting AO-SUB daemon...")
    print("Press Ctrl+C to stop")
    
    try:
        # Keep running until interrupted
        while True:
            await asyncio.sleep(10)
            
            # Periodic health check
            stats = ao_sub.get_comprehensive_stats()
            if not stats['ao_sub']['is_running']:
                print("⚠️  AO-SUB stopped unexpectedly, restarting...")
                await ao_sub.start()
    
    except KeyboardInterrupt:
        print("\n🛑 Daemon shutdown requested")


async def run_interactive(ao_sub: AOSubsystem):
    """Run AO-SUB in interactive mode"""
    print("🎮 AO-SUB Interactive Mode")
    print("Commands:")
    print("  stats    - Show statistics")
    print("  test     - Test endpoints") 
    print("  request  - Make API request")
    print("  quit     - Exit")
