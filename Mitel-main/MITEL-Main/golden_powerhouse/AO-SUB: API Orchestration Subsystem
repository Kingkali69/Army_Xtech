# CLI Interface
async def main():
    """Main CLI interface for AO-SUB"""
    parser = argparse.ArgumentParser(
        description="Ghost AO-SUB (API Orchestration Subsystem)"
    )
    
    parser.add_argument(
        '--config', '-c',
        default='ao_sub_config.yaml',
        help='Configuration file path'
    )
    
    parser.add_argument(
        '--generate-config',
        action='store_true',
        help='Generate sample configuration file'
    )
    
    parser.add_argument(
        '--test-endpoints',
        action='store_true',
        help='Test all configured endpoints'
    )
    
    parser.add_argument(
        '--stats',
        action='store_true',
        help='Show current statistics'
    )
    
    parser.add_argument(
        '--daemon', '-d',
        action='store_true',
        help='Run as daemon'
    )
    
    parser.add_argument(
        '--log-level',
        choices=['DEBUG', 'INFO', 'WARNING', 'ERROR'],
        default='INFO',
        help='Logging level'
    )
    
    args = parser.parse_args()
    
    # Setup logging
    logging.basicConfig(
        level=getattr(logging, args.log_level),
        format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
    )
    
    # Generate config if requested
    if args.generate_config:
        generate_sample_config(args.config)
        return
    
    # Check if config exists
    if not Path(args.config).exists():
        print(f"Configuration file {args.config} not found.")
        print("Generate one with: python ao_sub.py --generate-config")
        return
    
    # Initialize AO-SUB
    ao_sub = AOSubsystem(args.config)
    
    try:
        await ao_sub.start()
        
        if args.test_endpoints:
            await test_endpoints(ao_sub)
        elif args.stats:
            show_stats(ao_sub)
        elif args.daemon:
            await run_daemon(ao_sub)
        else:
            await run_interactive(ao_sub)
    
    except KeyboardInterrupt:
        print("\nShutdown requested by user")
    finally:
        await ao_sub.stop()


async def test_endpoints(ao_sub: AOSubsystem):
    """Test all configured endpoints"""
    print("🧪 Testing API endpoints...\n")
    
    for endpoint_name, endpoint in ao_sub.client_manager.endpoints.items():
        if not endpoint.enabled:
            print(f"⏭️  Skipping {endpoint_name} (disabled)")
            continue
        
        print(f"🔍 Testing {endpoint_name}...")
        
        try:
            # Simple health check request
            response = await ao_sub.make_request_sync(
                endpoint_name=endpoint_name,
                path=endpoint.health_check_path,
                method=APIMethod.GET
            )
            
            if response.error:
                print(f"❌ {endpoint_name}: {response.error}")
            else:
                print(f"✅ {endpoint_name}: {response.status_code} "
                      f"({response.response_time:.2f}s)")
        
        except Exception as e:
            print(f"❌ {endpoint_name}: {e}")
        
        print()


