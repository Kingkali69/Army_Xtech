async def start_engine(config_path, daemon=False):
    """Start the Ghost Engine"""
    engine = EngineCore(config_path)
    
    try:
        await engine.initialize()
        await engine.start()
        
        if daemon:
            # Daemon mode - run in background
            await engine.run()
        else:
            # Interactive mode
            print("Ghost Engine started. Press Ctrl+C to stop.")
            await engine.run()
            
    except KeyboardInterrupt:
        print("\\nShutdown requested...")
    except Exception as e:
        print(f"Engine failed: {e}")
        return 1
    finally:
        await engine.stop()
    
    return 0

