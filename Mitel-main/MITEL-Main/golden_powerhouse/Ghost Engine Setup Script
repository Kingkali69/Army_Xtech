        "data/ao_sub"
    ]
    
    for directory in directories:
        Path(directory).mkdir(parents=True, exist_ok=True)
        print(f"✓ Created directory: {directory}")

def install_dependencies():
    """Install required Python dependencies"""
    requirements = [
        "PyYAML>=6.0",
        "asyncio-mqtt>=0.13.0",
        "cryptography>=41.0.0",
        "aiofiles>=23.0.0",
        "websockets>=11.0",
        "uvloop>=0.17.0; sys_platform != 'win32'",
        "pytest>=7.0.0",
        "pytest-asyncio>=0.21.0"
    ]
    
    print("Installing Python dependencies...")
    for requirement in requirements:
        try:
            subprocess.check_call([
                sys.executable, "-m", "pip", "install", requirement
            ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            print(f"✓ Installed: {requirement.split('>=')[0]}")
        except subprocess.CalledProcessError as e:
            print(f"⚠ Warning: Failed to install {requirement}: {e}")

def create_systemd_service():
    """Create systemd service file for Linux"""
    if platform.system().lower() != "linux":
        return
    
    service_content = f"""[Unit]
Description=Ghost Engine - CloudCore_Sync_2
Documentation=https://docs.ghostengine.io
After=network.target
Wants=network.target

[Service]
Type=simple
User=ghost
Group=ghost
WorkingDirectory={os.getcwd()}
ExecStart={sys.executable} -m ghost_engine.engine_core
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ghost-engine

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={os.getcwd()}

[Install]
WantedBy=multi-user.target
"""
    
    try:
        service_path = Path("/etc/systemd/system/ghost-engine.service")
        if os.geteuid() == 0:  # Running as root
            with open(service_path, 'w') as f:
                f.write(service_content)
            subprocess.run(["systemctl", "daemon-reload"])
            print("✓ Created systemd service file")
        else:
            # Create in user directory for non-root installation
            user_service_dir = Path.home() / ".config/systemd/user"
            user_service_dir.mkdir(parents=True, exist_ok=True)
            with open(user_service_dir / "ghost-engine.service", 'w') as f:
                f.write(service_content.replace("multi-user.target", "default.target"))
            print("✓ Created user systemd service file")
    except Exception as e:
        print(f"⚠ Warning: Could not create systemd service: {e}")

