import time
import json
from typing import Dict, Any, List, Optional
from datetime import datetime, timezone

class CRDTUserState:
    """CRDT model for user state synchronization"""
    
    def __init__(self, user_id: str, node_id: str):
        self.user_id = user_id
        self.node_id = node_id
        self.state = {}
        self.vector_clock = {node_id: 0}
        self.tombstones = {}  # For deleted keys
        
    def set_field(self, field: str, value: Any) -> Dict[str, Any]:
        """Set a field and return delta"""
        self.vector_clock[self.node_id] = self.vector_clock.get(self.node_id, 0) + 1
        timestamp = time.time()
        
        # Remove from tombstones if present
        if field in self.tombstones:
            del self.tombstones[field]
        
        old_value = self.state.get(field)
        self.state[field] = {
            'value': value,
            'timestamp': timestamp,
            'node_id': self.node_id,
            'vector_clock': self.vector_clock.copy()
        }
        
        return {
            'type': 'user_state_set',
            'entity_id': self.user_id,
            'field': field,
            'value': value,
            'timestamp': timestamp,
            'node_id': self.node_id,
            'vector_clock': self.vector_clock.copy(),
            'old_value': old_value
        }
    
    def delete_field(self, field: str) -> Dict[str, Any]:
        """Delete a field and return delta"""
        self.vector_clock[self.node_id] = self.vector_clock.get(self.node_id, 0) + 1
        timestamp = time.time()
        
        old_value = self.state.get(field)
        
        if field in self.state:
            # Add tombstone
            self.tombstones[field] = {
                'timestamp': timestamp,
                'node_id': self.node_id,
                'vector_clock': self.vector_clock.copy()
            }
            del self.state[field]
        
        return {
            'type': 'user_state_delete',
            'entity_id': self.user_id,
            'field': field,
            'timestamp': timestamp,
            'node_id': self.node_id,
            'vector_clock': self.vector_clock.copy(),
            'old_value': old_value
        }
    
    def merge_delta(self, delta: Dict[str, Any]) -> bool:
        """Merge incoming delta using CRDT rules"""
        try:
            field = delta.get('field')
            delta_timestamp = delta.get('timestamp', 0)
            delta_node = delta.get('node_id')
            delta_vector_clock = delta.get('vector_clock', {})
            
            # Update our vector clock
            for node, clock in delta_vector_clock.items():
                self.vector_clock[node] = max(self.vector_clock.get(node, 0), clock)
            
            if delta.get('type') == 'user_state_set':
                value = delta.get('value')
                
                # Check if we should accept this update
                current = self.state.get(field)
                tombstone = self.tombstones.get(field)
                
                accept_update = False
                
                if not current and not tombstone:
                    # New field
                    accept_update = True
                elif tombstone:
                    # Field was deleted - accept if delta is newer
                    if delta_timestamp > tombstone.get('timestamp', 0):
                        accept_update = True
                        del self.tombstones[field]
                    elif delta_timestamp == tombstone.get('timestamp', 0):
                        # Same timestamp - use node_id as tiebreaker
                        if delta_node > tombstone.get('node_id', ''):
                            accept_update = True
                            del self.tombstones[field]
                else:
                    # Field exists - accept if delta is newer
                    current_timestamp = current.get('timestamp', 0)
                    if delta_timestamp > current_timestamp:
                        accept_update = True
                    elif delta_timestamp == current_timestamp:
                        # Same timestamp - use node_id as tiebreaker (hash comparison)
                        current_hash = self._hash_value(current.get('value'))
                        delta_hash = self._hash_value(value)
                        if delta_hash > current_hash:
                            accept_update = True
                
                if accept_update:
                    self.state[field] = {
                        'value': value,
                        'timestamp': delta_timestamp,
                        'node_id': delta_node,
                        'vector_clock': delta_vector_clock.copy()
                    }
                    return True
                    
            elif delta.get('type') == 'user_state_delete':
                current = self.state.get(field)
                tombstone = self.tombstones.get(field)
                
                accept_delete = False
                
                if current:
                    # Field exists - accept delete if delta is newer
                    current_timestamp = current.get('timestamp', 0)
                    if delta_timestamp > current_timestamp:
                        accept_delete = True
                    elif delta_timestamp == current_timestamp:
                        # Same timestamp - use node_id as tiebreaker
                        if delta_node > current.get('node_id', ''):
                            accept_delete = True
                elif not tombstone:
                    # No current value or tombstone - accept delete
                    accept_delete = True
                elif tombstone:
                    # Already deleted - accept if delta is newer
                    if delta_timestamp > tombstone.get('timestamp', 0):
                        accept_delete = True
                
                if accept_delete:
                    if field in self.state:
                        del self.state[field]
                    self.tombstones[field] = {
                        'timestamp': delta_timestamp,
                        'node_id': delta_node,
                        'vector_clock': delta_vector_clock.copy()
                    }
                    return True
            
            return False
            
        except Exception as e:
            return False
    
    def _hash_value(self, value: Any) -> str:
        """Create hash of value for tiebreaking"""
        import hashlib
        value_str = json.dumps(value, sort_keys=True, default=str)
        return hashlib.sha256(value_str.encode()).hexdigest()
    
    def get_state(self) -> Dict[str, Any]:
        """Get current state values only"""
        return {field: data['value'] for field, data in self.state.items()}
    
    def to_dict(self) -> Dict[str, Any]:
        """Serialize to dict"""
        return {
            'user_id': self.user_id,
            'node_id': self.node_id,
            'state': self.state,
            'vector_clock': self.vector_clock,
            'tombstones': self.tombstones
        }


class CRDTFileChunk:
    """CRDT model for file chunk synchronization"""
    
    def __init__(self, file_id: str, chunk_id: str, node_id: str):
        self.file_id = file_id
        self.chunk_id = chunk_id
        self.node_id = node_id
        self.content = b""
        self.metadata = {}
        self.version = 0
        self.vector_clock = {node_id: 0}
        self.is_deleted = False
        
    def update_content(self, content: bytes, metadata: Dict[str, Any] = None) -> Dict[str, Any]:
        """Update chunk content and return delta"""
        self.vector_clock[self.node_id] = self.vector_clock.get(self.node_id, 0) + 1
        self.version += 1
        timestamp = time.time()
        
        old_content = self.content
        old_metadata = self.metadata.copy()
        
        self.content = content
        self.metadata.update(metadata or {})
        self.is_deleted = False
        
        return {
            'type': 'file_chunk_update',
            'entity_id': f"{self.file_id}#{self.chunk_id}",
            'file_id': self.file_id,
            'chunk_id': self.chunk_id,
            'content': content,
            'metadata': metadata or {},
            'version': self.version,
            'timestamp': timestamp,
            'node_id': self.node_id,
            'vector_clock': self.vector_clock.copy(),
            'old_content_hash': self._hash_content(old_content)
        }
    
    def delete_chunk(self) -> Dict[str, Any]:
        """Mark chunk as deleted and return delta"""
        self.vector_clock[self.node_id] = self.vector_clock.get(self.node_id, 0) + 1
        self.version += 1
        timestamp = time.time()
        
        self.is_deleted = True
        self.content = b""
        
        return {
            'type': 'file_chunk_delete',
            'entity_id': f"{self.file_id}#{self.chunk_id}",
            'file_id': self.file_id,
            'chunk_id': self.chunk_id,
            'version': self.version,
            'timestamp': timestamp,
            'node_id': self.node_id,
            'vector_clock': self.vector_clock.copy()
        }
    
    def merge_delta(self, delta: Dict[str, Any]) -> bool:
        """Merge incoming delta using CRDT rules"""
        try:
            delta_version = delta.get('version', 0)
            delta_timestamp = delta.get('timestamp', 0)
            delta_node = delta.get('node_id')
            delta_vector_clock = delta.get('vector_clock', {})
            
            # Update vector clock
            for node, clock in delta_vector_clock.items():
                self.vector_clock[node] = max(self.vector_clock.get(node, 0), clock)
            
            # Only accept if delta is newer
            accept_delta = False
            
            if delta_version > self.version:
                accept_delta = True
            elif delta_version == self.version:
                # Same version - use timestamp + node_id tiebreaker
                if delta_timestamp > self.metadata.get('timestamp', 0):
                    accept_delta = True
                elif delta_timestamp == self.metadata.get('timestamp', 0):
                    # Use content hash for deterministic tiebreaking
                    if delta.get('type') == 'file_chunk_update':
                        delta_content = delta.get('content', b"")
                        delta_hash = self._hash_content(delta_content)
                        current_hash = self._hash_content(self.content)
                        accept_delta = delta_hash > current_hash
                    else:
                        accept_delta = delta_node > self.node_id
            
            if accept_delta:
                if delta.get('type') == 'file_chunk_update':
                    self.content = delta.get('content', b"")
                    self.metadata.update(delta.get('metadata', {}))
                    self.metadata['timestamp'] = delta_timestamp
                    self.is_deleted = False
                elif delta.get('type') == 'file_chunk_delete':
                    self.content = b""
                    self.is_deleted = True
                
                self.version = delta_version
                return True
                
            return False
            
        except Exception as e:
            return False
    
    def _hash_content(self, content: bytes) -> str:
        """Hash content for comparison"""
        import hashlib
        return hashlib.sha256(content).hexdigest()
    
    def to_dict(self) -> Dict[str, Any]:
        """Serialize to dict"""
        return {
            'file_id': self.file_id,
            'chunk_id': self.chunk_id,
            'node_id': self.node_id,
            'content': self.content,
            'metadata': self.metadata,
            'version': self.version,
            'vector_clock': self.vector_clock,
            'is_deleted': self.is_deleted
        }


# sp_subsystem/event_integration.py (Enhanced v5 Component)
import asyncio
import logging
from typing import Dict, Any, Callable, Optional, List
from datetime import datetime, timezone

class SPEventIntegration:
    """Enhanced Event Bus integration for SP-SUB v5"""
    
    def __init__(self, sync_coordinator, event_bus=None):
        self.sync_coordinator = sync_coordinator
        self.event_bus = event_bus
        self.logger = logging.getLogger("SPEventIntegration")
        
        # Event handlers
        self.handlers = {}
        self.running = False
        
    async def initialize(self):
        """Initialize event integration"""
        if self.event_bus:
            await self._subscribe_to_events()
            self.running = True
            self.logger.info("Event integration initialized")
        else:
            self.logger.warning("No event bus provided - running without event integration")
    
    async def shutdown(self):
        """Shutdown event integration"""
        self.running = False
        if self.event_bus:
            await self._unsubscribe_from_events()
    
    async def _subscribe_to_events(self):
        """Subscribe to relevant Event Bus events"""
        try:
            # Core sync events
            await self.event_bus.subscribe('SYNC_REQUEST', self._on_sync_request)
            await self.event_bus.subscribe('SYNC_RESPONSE', self._on_sync_response)
            
            # File system events
            await self.event_bus.subscribe('FILE_CREATED', self._on_file_created)
            await self.event_bus.subscribe('FILE_MODIFIED', self._on_file_modified)
            await self.event_bus.subscribe('FILE_DELETED', self._on_file_deleted)
            
            # Security events
            await self.event_bus.subscribe('SECURITY_THREAT_DETECTED', self._on_security_threat)
            await self.event_bus.subscribe('INTEGRITY_VIOLATION', self._on_integrity_violation)
            
            # Network events
            await self.event_bus.subscribe('PEER_CONNECTED', self._on_peer_connected)
            await self.event_bus.subscribe('PEER_DISCONNECTED', self._on_peer_disconnected)
            
            # System events
            await self.event_bus.subscribe('SYSTEM_STARTUP', self._on_system_startup)
            await self.event_bus.subscribe('SYSTEM_SHUTDOWN', self._on_system_shutdown)
            
            self.logger.info("Subscribed to event bus events")
            
        except Exception as e:
            self.logger.error(f"Failed to subscribe to events: {e}")
    
    async def _unsubscribe_from_events(self):
        """Unsubscribe from all events"""
        try:
            events = [
                'SYNC_REQUEST', 'SYNC_RESPONSE', 'FILE_CREATED', 'FILE_MODIFIED',
                'FILE_DELETED', 'SECURITY_THREAT_DETECTED', 'INTEGRITY_VIOLATION',
                'PEER_CONNECTED', 'PEER_DISCONNECTED', 'SYSTEM_STARTUP', 'SYSTEM_SHUTDOWN'
            ]
            
            for event in events:
                await self.event_bus.unsubscribe(event, self.handlers.get(event))
                
        except Exception as e:
            self.logger.error(f"Failed to unsubscribe from events: {e}")
    
    async def _on_sync_request(self, event_data: Dict[str, Any]):
        """Handle sync request from event bus"""
        try:
            self.logger.info(f"Received sync request: {event_data}")
            
            # Extract parameters
            peers = event_data.get('peers')
            dry_run = event_data.get('dry_run', False)
            
            # Run verification first
            if self.sync_coordinator.integrity_verifier:
                # Would verify any incoming deltas
                pass
            
            # Execute sync
            result = await self.sync_coordinator.start_sync_cycle(
                peers=peers, 
                dry_run=dry_run
            )
            
            # Publish sync completion event
            await self._publish_event('SYNC_COMPLETED', {
                'request_id': event_data.get('request_id'),
                'result': result,
                'timestamp': datetime.now(timezone.utc).isoformat()
            })
            
        except Exception as e:
            self.logger.error(f"Error handling sync request: {e}")
            
            await self._publish_event('SYNC_ERROR', {
                'request_id': event_data.get('request_id'),
                'error': str(e),
                'timestamp': datetime.now(timezone.utc).isoformat()
            })
    
    async def _on_sync_response(self, event_data: Dict[str, Any]):
        """Handle sync response from event bus"""
        try:
            deltas = event_data.get('deltas', [])
            source_node = event_data.get('source_node')
            
            if deltas:
                # Verify and apply deltas
                if self.sync_coordinator.sync_protocol:
                    applied, failed = await self.sync_coordinator.sync_protocol.verify_and_apply(deltas)
                    
                    # Return status
                    await self._publish_event('SYNC_MERGE_STATUS', {
                        'source_node': source_node,
                        'applied': applied,
                        'failed': failed,
                        'timestamp': datetime.now(timezone.utc).isoformat()
                    })
                    
        except Exception as e:
            self.logger.error(f"Error handling sync response: {e}")
    
    async def _on_file_created(self, event_data: Dict[str, Any]):
        """Handle file creation event"""
        try:
            file_path = event_data.get('path')
            if file_path and self.sync_coordinator.delta_engine:
                # Create delta for new file
                delta = await self.sync_coordinator.delta_engine.create_manual_delta(
                    file_path, 'create', event_data
                )
                
                # Queue for sync
                await self._queue_delta_for_sync(delta)
                
        except Exception as e:
            self.logger.error(f"Error handling file creation: {e}")
    
    async def _on_file_modified(self, event_data: Dict[str, Any]):
        """Handle file modification event"""
        try:
            file_path = event_data.get('path')
            if file_path and self.sync_coordinator.delta_engine:
                delta = await self.sync_coordinator.delta_engine.create_manual_delta(
                    file_path, 'update', event_data
                )
                
                await self._queue_delta_for_sync(delta)
                
        except Exception as e:
            self.logger.error(f"Error handling file modification: {e}")
    
    async def _on_file_deleted(self, event_data: Dict[str, Any]):
        """Handle file deletion event"""
        try:
            file_path = event_data.get('path')
            if file_path and self.sync_coordinator.delta_engine:
                delta = await self.sync_coordinator.delta_engine.create_manual_delta(
                    file_path, 'delete', event_data
                )
                
                await self._queue_delta_for_sync(delta)
                
        except Exception as e:
            self.logger.error(f"Error handling file deletion: {e}")
    
    async def _on_security_threat_detected(self, event_data: Dict[str, Any]):
        """Handle security threat detection"""
        try:
            threat_level = event_data.get('level', 'medium')
            
            if threat_level in ['high', 'critical']:
                # Pause sync operations temporarily
                self.logger.warning(f"Security threat detected ({threat_level}) - pausing sync")
                
                # Publish sync pause event
                await self._publish_event('SYNC_PAUSED', {
                    'reason': f'security_threat_{threat_level}',
                    'timestamp': datetime.now(timezone.utc).isoformat()
                })
                
        except Exception as e:
            self.logger.error(f"Error handling security threat: {e}")
    
    async def _on_integrity_violation(self, event_data: Dict[str, Any]):
        """Handle integrity violation"""
        try:
            violation_type = event_data.get('type')
            affected_entity = event_data.get('entity_id')
            
            self.logger.error(f"Integrity violation detected: {violation_type} on {affected_entity}")
            
            # Add to pending conflicts for manual resolution
            if self.sync_coordinator.sync_state:
                conflict = {
                    'entity_id': affected_entity,
                    'type': 'integrity_violation',
                    'violation_type': violation_type,
                    'detected_at': datetime.now(timezone.utc).isoformat(),
                    'event_data': event_data
                }
                
                self.sync_coordinator.sync_state.setdefault('pending_conflicts', []).append(conflict)
                await self.sync_coordinator.save_sync_state()
                
        except Exception as e:
            self.logger.error(f"Error handling integrity violation: {e}")
    
    async def _on_peer_connected(self, event_data: Dict[str, Any]):
        """Handle peer connection event"""
        try:
            peer_id = event_data.get('peer_id')
            peer_address = event_data.get('address')
            
            if peer_id and peer_address and self.sync_coordinator.sync_protocol:
                # Add peer to known peers
                await self.sync_coordinator.sync_protocol.add_manual_peer(
                    peer_id, peer_address, event_data.get('port', 8443)
                )
                
                self.logger.info(f"Peer connected via event: {peer_id}")
                
        except Exception as e:
            self.logger.error(f"Error handling peer connection: {e}")
    
    async def _on_peer_disconnected(self, event_data: Dict[str, Any]):
        """Handle peer disconnection event"""
        try:
            peer_id = event_data.get('peer_id')
            
            if peer_id and self.sync_coordinator.sync_protocol:
                # Mark peer as offline
                if peer_id in self.sync_coordinator.sync_protocol.known_peers:
                    self.sync_coordinator.sync_protocol.known_peers[peer_id].is_online = False
                
                self.logger.info(f"Peer disconnected via event: {peer_id}")
                
        except Exception as e:
            self.logger.error(f"Error handling peer disconnection: {e}")
    
    async def _on_system_startup(self, event_data: Dict[str, Any]):
        """Handle system startup event"""
        try:
            # Trigger initial peer discovery
            if self.sync_coordinator.sync_protocol:
                await self.sync_coordinator.sync_protocol.discover_peers()
                
            # Process offline queue
            if hasattr(self.sync_coordinator.sync_protocol, 'offline_queue'):
                await self.sync_coordinator.sync_protocol._process_offline_queue()
                
            self.logger.info("System startup - sync protocol activated")
            
        except Exception as e:
            self.logger.error(f"Error handling system startup: {e}")
    
    async def _on_system_shutdown(self, event_data: Dict[str, Any]):
        """Handle system shutdown event"""
        try:
            # Graceful shutdown of sync components
            if self.sync_coordinator:
                await self.sync_coordinator.save_sync_state()
                
            if self.sync_coordinator.sync_protocol:
                await self.sync_coordinator.sync_protocol.shutdown()
                
            self.logger.info("System shutdown - sync protocol deactivated")
            
        except Exception as e:
            self.logger.error(f"Error handling system shutdown: {e}")
    
    async def _queue_delta_for_sync(self, delta: Dict[str, Any]):
        """Queue delta for synchronization"""
        try:
            if self.sync_coordinator.sync_protocol:
                await self.sync_coordinator.sync_protocol.push_deltas([delta])
            else:
                self.logger.warning("No sync protocol available to queue delta")
                
        except Exception as e:
            self.logger.error(f"Error queueing delta for sync: {e}")
    
    async def _publish_event(self, event_type: str, event_data: Dict[str, Any]):
        """Publish event to event bus"""
        try:
            if self.event_bus:
                await self.event_bus.publish(event_type, event_data)
            else:
                self.logger.debug(f"Would publish event {event_type}: {event_data}")
                
        except Exception as e:
            self.logger.error(f"Error publishing event {event_type}: {e}")
    
    def get_event_stats(self) -> Dict[str, Any]:
        """Get event handling statistics"""
        return {
            'running': self.running,
            'has_event_bus': self.event_bus is not None,
            'subscribed_events': len(self.handlers),
            'event_bus_type': type(self.event_bus).__name__ if self.event_bus else None
        }


# sp_subsystem/cli_enhanced.py (Enhanced CLI v5)
import argparse
import asyncio
import json
import sys
import logging
import signal
import os
from pathlib import Path
from typing import Dict, Any, Optional
import yaml
from datetime import datetime

from  sync_coordinator import SyncCoordinator
from .event_integration import SPEventIntegration

class GhostSyncCLI:
    """Enhanced CLI for Ghost Sync operations"""
    
    def __init__(self):
        self.logger = self._setup_logging()
        self.coordinator = None
        self.event_integration = None
        self.daemon_mode = False
        self.shutdown_event = asyncio.Event()
        
    def _setup_logging(self, log_file: Optional[str] = None, verbose: bool = False) -> logging.Logger:
        """Enhanced logging setup with file output"""
        log_level = logging.DEBUG if verbose else logging.INFO
        log_format = '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
        
        # Configure root logger
        logging.basicConfig(
            level=log_level,
            format=log_format,
            handlers=[]
        )
        
        logger = logging.getLogger("GhostSync")
        
        # Console handler
        console_handler = logging.StreamHandler(sys.stdout)
        console_handler.setLevel(log_level)
        console_handler.setFormatter(logging.Formatter(log_format))
        logger.addHandler(console_handler)
        
        # File handler if specified
        if log_file:
            try:
                file_handler = logging.FileHandler(log_file)
                file_handler.setLevel(logging.DEBUG)  # Always debug to file
                file_handler.setFormatter(logging.Formatter(log_format))
                logger.addHandler(file_handler)
                logger.info(f"Logging to file: {log_file}")
            except Exception as e:
                logger.warning(f"Failed to setup file logging: {e}")
        
        return logger
    
    async def run(self, args: argparse.Namespace) -> int:
        """Main CLI entry point"""
        try:
            # Update logging if needed
            if args.log_file or args.verbose:
                self.logger = self._setup_logging(args.log_file, args.verbose)
            
            command = args.command
            
            if command == 'start':
                return await self._cmd_start(args)
            elif command == 'status':
                return await self._cmd_status(args)
            elif command == 'push':
                return await self._cmd_push(args)
            elif command == 'pull':
                return await self._cmd_pull(args)
            elif command == 'daemon':
                return await self._cmd_daemon(args)
            elif command == 'stop':
                return await self._cmd_stop(args)
            else:
                self.logger.error(f"Unknown command: {command}")
                return 1
                
        except KeyboardInterrupt:
            self.logger.info("Interrupted by user")
            return 1
        except Exception as e:
            self.logger.error(f"Command failed: {e}")
            return 1
        finally:
            await self._cleanup()
    
    async def _get_coordinator(self, config_path: Optional[str] = None) -> SyncCoordinator:
        """Get initialized sync coordinator"""
        if not self.coordinator:
            config_file = config_path or "sp_sub_config.yaml"
            self.coordinator = SyncCoordinator(config_file)
            await self.coordinator.initialize()
            
            # Initialize event integration
            self.event_integration = SPEventIntegration(self.coordinator)
            await self.event_integration.initialize()
            
        return self.coordinator
    
    async def _cmd_start(self, args: argparse.Namespace) -> int:
        """Start sync operation"""
        coordinator = await self._get_coordinator(args.config)
        
        peers = args.peers.split(',') if args.peers else None
        dry_run = args.dry_run
        
        self.logger.info(f"Starting Ghost sync (dry_run={dry_run})")
        
        try:
            result = await coordinator.start_sync_cycle(peers=peers, dry_run=dry_run)
            
            if args.json:
                print(json.dumps(result, indent=2))
            else:
                self._print_sync_result(result)
                
            return 0 if result.get('status') == 'success' else 1
            
        except Exception as e:
            self.logger.error(f"Sync failed: {e}")
            return 1
    
    def _print_sync_result(self, result: Dict[str, Any]):
        """Print human-readable sync result"""
        status = result.get('status', 'unknown')
        print(f"Ghost Sync Result: {status.upper()}")
        
        if status == 'success':
            duration = result.get('duration_seconds', 0)
            peers = result.get('peers_contacted', 0)
            deltas = result.get('deltas_processed', 0)
            conflicts = result.get('conflicts_found', 0)
            
            print(f"  Duration: {duration:.1f}s")
            print(f"  Peers: {peers}")
            print(f"  Deltas: {deltas}")
            print(f"  Conflicts: {conflicts}")
            
            if result.get('dry_run'):
                print("  Mode: DRY RUN (no changes applied)")
            elif result.get('changes_applied'):
                print("  Changes: APPLIED")
            else:
                print("  Changes: NONE")
                
        elif status == 'failed':
            print(f"  Error: {result.get('error', 'Unknown error')}")
    
    async def _cmd_status(self, args: argparse.Namespace) -> int:
        """Show sync status"""
        coordinator = await self._get_coordinator(args.config)
        
        try:
            status = await coordinator.get_sync_status()
            
            if args.json:
                print(json.dumps(status, indent=2))
            else:
                self._print_status(status)
                
            return 0
            
        except Exception as e:
            self.logger.error(f"Status check failed: {e}")
            return 1
    
    def _print_status(self, status: Dict[str, Any]):
        """Print human-readable status"""
        print("Ghost Sync Status:")
        print("=" * 40)
        print(f"Node ID: {status.get('node_id', 'unknown')[:16]}...")
        print(f"Sync Active: {status.get('sync_in_progress', False)}")
        print(f"Last Sync: {status.get('last_sync_time', 'Never')}")
        print(f"Conflicts: {status.get('pending_conflicts', 0)}")
        print(f"Checkpoints: {status.get('checkpoint_count', 0)}")
        
        version_vector = status.get('version_vector', {})
        if version_vector:
            print("\nVersion Vector:")
            for node, version in version_vector.items():
                node_short = node[:8] + "..." if len(node) > 8 else node
                print(f"  {node_short}: v{version}")
    
    async def _cmd_push(self, args: argparse.Namespace) -> int:
        """Push local changes to peers"""
        coordinator = await self._get_coordinator(args.config)
        
        try:
            if not coordinator.sync_protocol:
                self.logger.error("Sync protocol not available")
                return 1
            
            # Discover peers
            peers = await coordinator.sync_protocol.discover_peers()
            
            if not peers:
                self.logger.warning("No peers available for push")
                return 1
            
            # Get local deltas (simplified - would need proper delta collection)
            if coordinator.delta_engine:
                # Create a manual delta for demonstration
                delta = await coordinator.delta_engine.create_manual_delta(
                    "push_operation", "update", {"timestamp": datetime.now().isoformat()}
                )
                deltas = [delta]
            else:
                deltas = []
            
            if deltas:
                success = await coordinator.sync_protocol.push_deltas(deltas)
                
                if success:
                    self.logger.info(f"Successfully pushed {len(deltas)} deltas to {len(peers)} peers")
                    return 0
                else:
                    self.logger.error("Push operation failed")
                    return 1
            else:
                self.logger.info("No changes to push")
                return 0
                
        except Exception as e:
            self.logger.error(f"Push failed: {e}")
            return 1
    
    async def _cmd_pull(self, args: argparse.Namespace) -> int:
        """Pull changes from peers"""
        coordinator = await self._get_coordinator(args.config)
        
        try:
            if not coordinator.sync_protocol:
                self.logger.error("Sync protocol not available")
                return 1
            
            # Pull from peers
            deltas = await coordinator.sync_protocol.pull_from_peers()
            
            if deltas:
                # Verify and apply
                applied, failed = await coordinator.sync_protocol.verify_and_apply(deltas)
                
                self.logger.info(f"Pull complete: {applied} applied, {failed} failed")
                
                if args.json:
                    print(json.dumps({"applied": applied, "failed": failed, "total": len(deltas)}, indent=2))
                else:
                    print(f"Pulled and applied {applied} changes ({failed} failed)")
                
                return 0 if failed == 0 else 1
            else:
                self.logger.info("No changes to pull")
                return 0
                
        except Exception as e:
            self.logger.error(f"Pull failed: {e}")
            return 1
    
    async def _cmd_daemon(self, args: argparse.Namespace) -> int:
        """Run in daemon mode"""
        coordinator = await self._get_coordinator(args.config)
        
        self.daemon_mode = True
        interval = args.sync_interval
        
        # Setup signal handlers
        def signal_handler(signum, frame):
            self.logger.info(f"Received signal {signum}, shutting down...")
            self.shutdown_event.set()
        
        signal.signal(signal.SIGINT, signal_handler)
        signal.signal(signal.SIGTERM, signal_handler)
        
        self.logger.info(f"Starting Ghost sync daemon (interval: {interval}s)")
        
        try:
            # Create PID file
            pid_file = Path("ghost_sync.pid")
            with open(pid_file, 'w') as f:
                f.write(str(os.getpid()))
            
            # Main daemon loop
            while not self.shutdown_event.is_set():
                try:
                    # Periodic sync
                    self.logger.debug("Running periodic sync...")
                    result = await coordinator.start_sync_cycle(dry_run=False)
                    
                    if result.get('status') == 'success':
                        deltas = result.get('deltas_processed', 0)
                        if deltas > 0:
                            self.logger.info(f"Daemon sync: processed {deltas} deltas")
                    else:
                        self.logger.warning(f"Daemon sync failed: {result.get('error')}")
                    
                    # Wait for next cycle or shutdown signal
                    try:
                        await asyncio.wait_for(self.shutdown_event.wait(), timeout=interval)
                        break  # Shutdown requested
                    except asyncio.TimeoutError:
                        continue  # Next cycle
                        
                except Exception as e:
                    self.logger.error(f"Daemon cycle error: {e}")
                    await asyncio.sleep(min(interval, 30))  # Shorter wait on error
            
            # Cleanup
            pid_file.unlink(missing_ok=True)
            self.logger.info("Ghost sync daemon stopped")
            return 0
            
        except Exception as e:
            self.logger.error(f"Daemon failed: {e}")
            return 1
    
    async def _cmd_stop(self, args: argparse.Namespace) -> int:
        """Stop running daemon"""
        pid_file = Path("ghost_sync.pid")
        
        if not pid_file.exists():
            print("No daemon PID file found")
            return 1
        
        try:
            with open(pid_file, 'r') as f:
                pid = int(f.read().strip())
            
            # Send SIGTERM
            os.kill(pid, signal.SIGTERM)
            print(f"Sent stop signal to daemon (PID: {pid})")
            
            # Wait a moment and check if it's gone
            await asyncio.sleep(2)
            
            if pid_file.exists():
                print("Warning: PID file still exists - daemon may not have stopped cleanly")
                return 1
            else:
                print("Daemon stopped successfully")
                return 0
                
        except (ValueError, ProcessLookupError, OSError) as e:
            print(f"Failed to stop daemon: {e}")
            return 1
    
    async def _cleanup(self):
        """Cleanup resources"""
        try:
            if self.event_integration:
                await self.event_integration.shutdown()
                
            if self.coordinator:
                await self.coordinator.save_sync_state()
                if self.coordinator.sync_protocol:
                    await self.coordinator.sync_protocol.shutdown()
                    
        except Exception as e:
            self.logger.error(f"Cleanup error: {e}")


