# Error handling wrapper and context managers
class SPSubsystemContext:
    """Context manager for SP-SUB operations"""
    
    def __init__(self, config_path: str = None):
        self.config_path = config_path
        self.coordinator = None
        self.protocol = None
        
    async def __aenter__(self):
        """Async context entry"""
        try:
            from sync_coordinator import SyncCoordinator
            
            self.coordinator = SyncCoordinator(self.config_path)
            await self.coordinator.initialize()
            
            self.protocol = self.coordinator.sync_protocol
            if self.protocol:
                await self.protocol.initialize()
                
            return self
            
        except Exception as e:
            await self.__aexit__(type(e), e, e.__traceback__)
            raise
    
    async def __aexit__(self, exc_type, exc_val, exc_tb):
        """Async context exit with cleanup"""
        try:
            if self.protocol:
                await self.protocol.shutdown()
                
            if self.coordinator:
                await self.coordinator.save_sync_state()
                
        except Exception as e:
            # Log cleanup errors but don't raise
            import logging
            logging.getLogger("SPSubsystemContext").error(f"Cleanup error: {e}")
    
    async def sync(self, peers=None, dry_run=False):
        """Perform sync operation"""
        if not self.coordinator:
            raise RuntimeError("SP-SUB context not initialized")
        
        return await self.coordinator.start_sync_cycle(peers=peers, dry_run=dry_run)


# Production error handling
class SPSubsystemError(Exception):
    """Base exception for SP-SUB operations"""
    pass

class SyncError(SPSubsystemError):
