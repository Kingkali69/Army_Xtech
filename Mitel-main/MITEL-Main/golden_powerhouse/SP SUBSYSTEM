# Enhanced delta_engine.py additions for v5
class EnhancedDeltaEngine:
    """Enhanced Delta Engine with CRDT support and pending delta management"""
    
    def __init__(self, config: Dict[str, Any]):
        # ... (existing init code) ...
        
        # CRDT models
        self.crdt_user_states = {}  # user_id -> CRDTUserState
        self.crdt_file_chunks = {}  # file_id#chunk_id -> CRDTFileChunk
        
        # Pending deltas for sync
        self.pending_deltas = []
        
    async def get_pending_deltas(self) -> List[Dict[str, Any]]:
        """Get pending deltas for synchronization"""
        # Return copy and clear pending
        deltas = self.pending_deltas.copy()
        self.pending_deltas.clear()
        return deltas
    
    async def create_user_state_delta(self, user_id: str, field: str, value: Any) -> Dict[str, Any]:
        """Create CRDT delta for user state change"""
        if user_id not in self.crdt_user_states:
            self.crdt_user_states[user_id] = CRDTUserState(user_id, self.node_id)
        
        user_state = self.crdt_user_states[user_id]
        delta = user_state.set_field(field, value)
        
        # Add to pending deltas
        self.pending_deltas.append(delta)
        
        return delta
    
    async def create_file_chunk_delta(self, file_id: str, chunk_id: str, 
                                    content: bytes, metadata: Dict[str, Any] = None) -> Dict[str, Any]:
        """Create CRDT delta for file chunk change"""
        chunk_key = f"{file_id}#{chunk_id}"
        
        if chunk_key not in self.crdt_file_chunks:
            self.crdt_file_chunks[chunk_key] = CRDTFileChunk(file_id, chunk_id, self.node_id)
        
        file_chunk = self.crdt_file_chunks[chunk_key]
        delta = file_chunk.update_content(content, metadata)
        
        # Add to pending deltas
        self.pending_deltas.append(delta)
        
        return delta
    
    async def apply_crdt_delta(self, delta: Dict[str, Any]) -> bool:
        """Apply CRDT delta with proper conflict resolution"""
        try:
            delta_type = delta.get('type')
            
            if delta_type in ['user_state_set', 'user_state_delete']:
                user_id = delta.get('entity_id')
                if user_id not in self.crdt_user_states:
                    self.crdt_user_states[user_id] = CRDTUserState(user_id, self.node_id)
                
                return self.crdt_user_states[user_id].merge_delta(delta)
                
            elif delta_type in ['file_chunk_update', 'file_chunk_delete']:
                entity_id = delta.get('entity_id')
                if '#' in entity_id:
                    file_id, chunk_id = entity_id.split('#', 1)
                    
                    if entity_id not in self.crdt_file_chunks:
                        self.crdt_file_chunks[entity_id] = CRDTFileChunk(file_id, chunk_id, self.node_id)
                    
                    return self.crdt_file_chunks[entity_id].merge_delta(delta)
            
            # Fallback to regular delta application
            return await self.apply_delta(delta)
            
        except Exception as e:
            self.logger.error(f"CRDT delta application failed: {e}")
            return False


