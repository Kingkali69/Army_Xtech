#!/usr/bin/env python3
"""
G.Legion Cybersecurity Framework - Main Engine Launcher
KK&GDevOps - Production Ready Modular Security Engine

This launcher initializes and manages all G.Legion subsystems with proper
configuration management, logging, and graceful shutdown capabilities.
"""

import asyncio
import argparse
import logging
import logging.handlers
import os
import signal
import sys
import yaml
from pathlib import Path
from typing import Dict, List, Optional, Any
from datetime import datetime
import json

# G.Legion subsystem imports
from subsystem_scaffolds import (
    EventBusSubsystem,
    SessionControlSubsystem,
    AuthSubsystem,
    SecuritySubsystem,
    AOSubsystem,
    SPSubsystem
)


class GLegionEngine:
    """
    G.Legion Cybersecurity Framework Main Engine
    Manages all subsystems with proper lifecycle and health monitoring.
    """
    
    def __init__(self, config_path: str = "config/engine_config.yaml"):
        self.config_path = config_path
        self.config: Dict[str, Any] = {}
        self.logger = None
        self.subsystems: Dict[str, Any] = {}
        self.running = False
        self.shutdown_event = asyncio.Event()
        
        # Subsystem initialization order (dependencies matter)
        self.subsystem_classes = {
            'event_bus': EventBusSubsystem,
            'security': SecuritySubsystem,
            'auth': AuthSubsystem,
            'session_control': SessionControlSubsystem,
            'ao': AOSubsystem,
            'sp': SPSubsystem
        }
        
        # Signal handlers for graceful shutdown
        for sig in [signal.SIGTERM, signal.SIGINT]:
            signal.signal(sig, self._signal_handler)
    
    def _signal_handler(self, signum: int, frame):
        """Handle shutdown signals gracefully."""
        if self.logger:
            self.logger.info(f"Received signal {signum}, initiating graceful shutdown...")
        else:
            print(f"Received signal {signum}, initiating shutdown...")
        
        self.shutdown_event.set()
    
    def _setup_logging(self):
        """Configure logging with file and console handlers."""
        # Create logs directory if it doesn't exist
        log_dir = Path("logs")
        log_dir.mkdir(exist_ok=True)
        
        # Configure logging
        log_level = self.config.get('logging', {}).get('level', 'INFO').upper()
        log_file = self.config.get('logging', {}).get('file', 'logs/engine.log')
        
        # Create formatter
        formatter = logging.Formatter(
            '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
        )
        
        # Setup root logger
        root_logger = logging.getLogger()
        root_logger.setLevel(getattr(logging, log_level))
        
        # Clear any existing handlers
        root_logger.handlers.clear()
        
        # File handler with rotation
        file_handler = logging.handlers.RotatingFileHandler(
            log_file,
            maxBytes=10*1024*1024,  # 10MB
            backupCount=5
        )
        file_handler.setFormatter(formatter)
        root_logger.addHandler(file_handler)
        
        # Console handler
        console_handler = logging.StreamHandler(sys.stdout)
        console_handler.setFormatter(formatter)
        root_logger.addHandler(console_handler)
        
        # Create engine logger
        self.logger = logging.getLogger('GLegion.Engine')
        self.logger.info("Logging system initialized")
    
    def load_config(self) -> bool:
        """Load configuration from YAML file."""
        try:
            config_file = Path(self.config_path)
            
            if not config_file.exists():
                # Create default configuration if it doesn't exist
                self._create_default_config(config_file)
                print(f"Created default configuration at {self.config_path}")
            
            with open(config_file, 'r') as f:
                self.config = yaml.safe_load(f)
            
            if not self.config:
                self.config = {}
            
            return True
            
        except Exception as e:
            error_msg = f"Failed to load configuration from {self.config_path}: {e}"
            if self.logger:
                self.logger.error(error_msg)
            else:
                print(f"ERROR: {error_msg}")
            return False
    
    def _create_default_config(self, config_file: Path):
        """Create a default configuration file."""
        config_file.parent.mkdir(parents=True, exist_ok=True)
        
        default_config = {
            'engine': {
                'name': 'G.Legion',
                'version': '2.0.0',
                'description': 'Modular Cybersecurity Framework',
                'max_workers': 4,
                'startup_timeout': 30
            },
            'logging': {
                'level': 'INFO',
                'file': 'logs/engine.log',
                'format': '%(asctime)s - %(name)s - %(levelname)s - %(message)s'
            },
            'subsystems': {
                'event_bus': {
                    'enabled': True,
                    'max_events': 10000,
                    'worker_threads': 2
                },
                'security': {
                    'enabled': True,
                    'threat_detection': True,
                    'auto_response': True
                },
                'auth': {
                    'enabled': True,
                    'session_timeout': 3600,
                    'max_attempts': 5
                },
                'session_control': {
                    'enabled': True,
                    'cleanup_interval': 300,
                    'anomaly_detection': True
                },
                'ao': {
                    'enabled': True,
                    'automation_level': 'medium',
                    'response_time': 5
                },
                'sp': {
                    'enabled': True,
                    'sync_interval': 60,
                    'redundancy': True
                }
            },
            'network': {
                'bind_address': '127.0.0.1',
                'api_port': 8443,
                'management_port': 8444,
                'tls_enabled': True
            },
