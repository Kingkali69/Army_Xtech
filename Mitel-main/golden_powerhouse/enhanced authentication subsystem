class TOTPMFAProvider(MFAProvider):
    def __init__(self, config: Dict):
        self.config = config
        self.secrets_store = {}  # In production, this would be encrypted storage

    async def initiate_mfa(self, user_id: str, method: MFAType) -> Dict:
        if method == MFAType.TOTP:
            # TOTP doesn't need initiation, just return success
            return {
                'challenge_id': str(uuid.uuid4()),
                'method': method.value,
                'expires_at': (datetime.now() + timedelta(minutes=5)).isoformat()
            }
        else:
            return {'error': 'unsupported_method'}

    async def verify_mfa(self, user_id: str, token: str, challenge_id: str) -> bool:
        # Mock TOTP verification - in production use pyotp library
        if len(token) == 6 and token.isdigit():
            # Simple mock: accept any 6-digit code ending with user_id hash
            return token[-1] == str(abs(hash(user_id)) % 10)
        return False

class SMSMFAProvider(MFAProvider):
    def __init__(self, config: Dict):
        self.config = config
        self.pending_challenges = {}

    async def initiate_mfa(self, user_id: str, method: MFAType) -> Dict:
        if method == MFAType.SMS:
            challenge_id = str(uuid.uuid4())
            code = f"{secrets.randbelow(900000) + 100000:06d}"
            
            self.pending_challenges[challenge_id] = {
                'user_id': user_id,
                'code': code,
                'expires_at': datetime.now() + timedelta(minutes=5)
            }
            
            # In production, send SMS here
            return {
                'challenge_id': challenge_id,
                'method': method.value,
                'expires_at': self.pending_challenges[challenge_id]['expires_at'].isoformat()
            }
        else:
            return {'error': 'unsupported_method'}

    async def verify_mfa(self, user_id: str, token: str, challenge_id: str) -> bool:
        challenge = self.pending_challenges.get(challenge_id)
        if not challenge:
            return False
        
        if challenge['expires_at'] < datetime.now():
            del self.pending_challenges[challenge_id]
            return False
        
        if challenge['code'] == token and challenge['user_id'] == user_id:
            del self.pending_challenges[challenge_id]
            return True
        
        return False

class IdentityValidator:
    def __init__(self, config: Dict):
        self.config = config
        self.providers = {}
        self.default_provider = config.get('default_provider', 'local')
        self.rate_limiter = {}
        
        # Initialize identity providers
        self._initialize_providers()

    def _initialize_providers(self):
        provider_configs = self.config.get('identity_providers', {})
        
        for provider_name, provider_config in provider_configs.items():
            provider_type = provider_config['type']
            
            if provider_type == 'local':
                self.providers[provider_name] = LocalIdentityProvider(provider_config)
            elif provider_type == 'ldap':
                self.providers[provider_name] = LDAPIdentityProvider(provider_config)
            # Add more providers as needed

    async def validate_identity(self, credentials: Dict, context: Dict) -> Dict:
        # Rate limiting check
        client_id = context.get('client_ip', 'unknown')
        if not self._check_rate_limit(client_id):
            return {
                'valid': False,
                'reason': 'rate_limited',
                'retry_after': 300
            }

        # Determine which provider to use
        provider_name = credentials.get('provider', self.default_provider)
        provider = self.providers.get(provider_name)
        
        if not provider:
            return {'valid': False, 'reason': 'provider_not_found'}

        # Validate with the provider
        result = await provider.validate_credentials(credentials)
        
        # Update rate limiting
        self._update_rate_limit(client_id, result.get('valid', False))
        
        return result

    def _check_rate_limit(self, client_id: str) -> bool:
        now = time.time()
        window = 300  # 5 minutes
        max_attempts = 5

        if client_id not in self.rate_limiter:
            self.rate_limiter[client_id] = []

        # Clean old attempts
        attempts = self.rate_limiter[client_id]
        self.rate_limiter[client_id] = [t for t in attempts if now - t < window]

        return len(self.rate_limiter[client_id]) < max_attempts

    def _update_rate_limit(self, client_id: str, success: bool):
        if not success:
            if client_id not in self.rate_limiter:
                self.rate_limiter[client_id] = []
            self.rate_limiter[client_id].append(time.time())

class MFAHandler:
    def __init__(self, config: Dict):
        self.config = config
        self.providers = {}
        self.user_mfa_preferences = {}
        
        self._initialize_providers()

    def _initialize_providers(self):
        mfa_configs = self.config.get('mfa_providers', {})
        
        for provider_name, provider_config in mfa_configs.items():
            provider_type = provider_config['type']
            
            if provider_type == 'totp':
                self.providers[provider_name] = TOTPMFAProvider(provider_config)
            elif provider_type == 'sms':
                self.providers[provider_name] = SMSMFAProvider(provider_config)
            # Add more MFA providers

    async def initiate_mfa(self, user_id: str, available_methods: List[MFAType] = None) -> Dict:
        if available_methods is None:
            available_methods = [MFAType.TOTP, MFAType.SMS]

        # Get user's preferred MFA method
        user_prefs = self.user_mfa_preferences.get(user_id, {})
        preferred_method = user_prefs.get('preferred_method')
        
        # Select MFA method
        if preferred_method and preferred_method in [m.value for m in available_methods]:
            selected_method = MFAType(preferred_method)
        else:
            selected_method = available_methods[0]

        # Find appropriate provider
        provider = self._get_provider_for_method(selected_method)
        if not provider:
            return {'error': 'no_suitable_provider'}

        result = await provider.initiate_mfa(user_id, selected_method)
        result['method'] = selected_method.value
        return result

    async def verify_mfa(self, user_id: str, token: str, challenge_id: str, method: str) -> bool:
        mfa_type = MFAType(method)
        provider = self._get_provider_for_method(mfa_type)
        
        if not provider:
            return False

        return await provider.verify_mfa(user_id, token, challenge_id)

    def _get_provider_for_method(self, method: MFAType) -> Optional[MFAProvider]:
        for provider in self.providers.values():
            # This is simplified - in reality, you'd check provider capabilities
            if method in [MFAType.TOTP, MFAType.SMS]:
                return provider
        return None

class TrustScoreAssessor:
    def __init__(self, config: Dict):
        self.config = config
        self.risk_factors = config.get('risk_factors', {})
        self.baseline_score = config.get('baseline_score', 50)
        self.device_fingerprints = {}
        self.geo_patterns = {}

    async def assess_trust(self, user_id: str, context: Dict) -> Dict:
        score = self.baseline_score
        risk_factors = []
        
        # Assess various risk factors
        score, factors = self._assess_authentication_history(user_id, context, score)
        risk_factors.extend(factors)
        
        score, factors = self._assess_device_trust(user_id, context, score)
        risk_factors.extend(factors)
        
        score, factors = self._assess_network_trust(context, score)
        risk_factors.extend(factors)
        
        score, factors = self._assess_behavioral_patterns(user_id, context, score)
        risk_factors.extend(factors)
        
        score, factors = self._assess_temporal_patterns(user_id, context, score)
        risk_factors.extend(factors)

        # Determine trust level
        trust_level = self._determine_trust_level(score)
        
        return {
            'score': max(0, min(100, score)),
            'level': trust_level.name,
            'risk_factors': risk_factors,
            'recommendations': self._get_recommendations(trust_level, risk_factors),
            'requires_step_up': trust_level.value < TrustLevel.MEDIUM.value
        }

    def _assess_authentication_history(self, user_id: str, context: Dict, score: int) -> Tuple[int, List[str]]:
        factors = []
        failed_attempts = context.get('recent_failures', 0)
        
        if failed_attempts > 3:
            score -= 20
            factors.append('high_failure_rate')
        elif failed_attempts > 0:
            score -= 5 * failed_attempts
            factors.append('some_recent_failures')
            
        return score, factors

    def _assess_device_trust(self, user_id: str, context: Dict, score: int) -> Tuple[int, List[str]]:
        factors = []
        device_fingerprint = context.get('device_fingerprint')
        
        if not device_fingerprint:
            score -= 15
            factors.append('unknown_device')
            return score, factors
            
        # Check if device is known
        user_devices = self.device_fingerprints.get(user_id, set())
        
        if device_fingerprint not in user_devices:
            score -= 25
            factors.append('new_device')
            
            # Add device to known devices if score is still reasonable
            if score > 30:
                user_devices.add(device_fingerprint)
                self.device_fingerprints[user_id] = user_devices
        else:
            score += 10  # Bonus for known device
            
        return score, factors

    def _assess_network_trust(self, context: Dict, score: int) -> Tuple[int, List[str]]:
        factors = []
        
        # Check IP reputation
        client_ip = context.get('client_ip')
        if self._is_suspicious_ip(client_ip):
            score -= 30
            factors.append('suspicious_ip')
            
        # Check for VPN/Proxy usage
        if context.get('behind_proxy', False):
            score -= 10
            factors.append('proxy_usage')
            
        # Check geographic location
        location = context.get('geo_location', {})
        country = location.get('country')
        
        if country in self.config.get('high_risk_countries', []):
            score -= 15
            factors.append('high_risk_location')
            
        return score, factors

    def _assess_behavioral_patterns(self, user_id: str, context: Dict, score: int) -> Tuple[int, List[str]]:
        factors = []
        
        # Check user agent patterns
        user_agent = context.get('user_agent', '')
        if self._is_suspicious_user_agent(user_agent):
            score -= 20
            factors.append('suspicious_user_agent')
            
        # Check session patterns
        session_duration = context.get('typical_session_duration', 0)
        if session_duration > 0 and session_duration < 60:  # Very short sessions
            score -= 5
            factors.append('unusual_session_pattern')
            
        return score, factors

    def _assess_temporal_patterns(self, user_id: str, context: Dict, score: int) -> Tuple[int, List[str]]:
        factors = []
        
        current_hour = datetime.now().hour
        
        # Check if login is during unusual hours
        if current_hour < 6 or current_hour > 22:
            score -= 10
            factors.append('unusual_login_time')
            
        # Check login frequency
        if context.get('logins_today', 0) > 20:
            score -= 15
            factors.append('excessive_login_frequency')
            
        return score, factors

    def _is_suspicious_ip(self, ip: str) -> bool:
        # Mock implementation - in production, check against threat intelligence
        if not ip:
            return True
        return ip.startswith('192.168.') == False and '.' not in ip

    def _is_suspicious_user_agent(self, user_agent: str) -> bool:
        suspicious_patterns = ['bot', 'crawler', 'scanner', 'automated']
        return any(pattern in user_agent.lower() for pattern in suspicious_patterns)

    def _determine_trust_level(self, score: int) -> TrustLevel:
        if score >= 90:
            return TrustLevel.VERIFIED
        elif score >= 75:
            return TrustLevel.HIGH
        elif score >= 50:
            return TrustLevel.MEDIUM
        elif score >= 25:
            return TrustLevel.LOW
        else:
            return TrustLevel.UNTRUSTED

    def _get_recommendations(self, trust_level: TrustLevel, risk_factors: List[str]) -> List[str]:
        recommendations = []
        
        if trust_level.value < TrustLevel.MEDIUM.value:
            recommendations.append('require_additional_mfa')
            
        if 'new_device' in risk_factors:
            recommendations.append('device_registration_required')
            
        if 'suspicious_ip' in risk_factors:
            recommendations.append('enhanced_monitoring')
            
        if trust_level == TrustLevel.UNTRUSTED:
            recommendations.append('block_access')
            
        return recommendations

class CredentialManager:
    def __init__(self, config: Dict):
        self.config = config
        self.active_credentials = {}
        self.revoked_credentials = set()
        self.rotation_policies = config.get('rotation_policies', {})

    async def issue_access_token(self, user_id: str, claims: Dict, expires_in: int = 3600) -> str:
        """Issue a JWT access token"""
        payload = {
            'user_id': user_id,
            'exp': time.time() + expires_in,
            'iat': time.time(),
            'jti': str(uuid.uuid4()),
            **claims
        }
        
        # Sign with secret key
        secret = self.config.get('jwt_secret', 'default_secret')
        token = jwt.encode(payload, secret, algorithm='HS256')
        
        # Track active token
        self.active_credentials[payload['jti']] = {
            'user_id': user_id,
            'token': token,
            'expires_at': payload['exp'],
            'claims': claims
        }
        
        return token

    async def validate_access_token(self, token: str) -> Dict:
        """Validate and decode JWT access token"""
        try:
            secret = self.config.get('jwt_secret', 'default_secret')
            payload = jwt.decode(token, secret, algorithms=['HS256'])
            
            # Check if token is revoked
            jti = payload.get('jti')
            if jti in self.revoked_credentials:
                return {'valid': False, 'reason': 'token_revoked'}
            
            return {
                'valid': True,
                'user_id': payload['user_id'],
                'claims': payload,
                'expires_at': payload['exp']
            }
        except jwt.ExpiredSignatureError:
            return {'valid': False, 'reason': 'token_expired'}
        except jwt.InvalidTokenError:
            return {'valid': False, 'reason': 'invalid_token'}

    async def revoke_token(self, token: str) -> bool:
        """Revoke a specific token"""
        try:
            secret = self.config.get('jwt_secret', 'default_secret')
            payload = jwt.decode(token, secret, algorithms=['HS256'], options={'verify_exp': False})
            jti = payload.get('jti')
            
            if jti:
                self.revoked_credentials.add(jti)
                if jti in self.active_credentials:
                    del self.active_credentials[jti]
                return True
        except:
            pass
        return False

    async def revoke_user_tokens(self, user_id: str) -> int:
        """Revoke all tokens for a user"""
        revoked_count = 0
        
        to_revoke = []
        for jti, cred in self.active_credentials.items():
            if cred['user_id'] == user_id:
                to_revoke.append(jti)
        
        for jti in to_revoke:
            self.revoked_credentials.add(jti)
            del self.active_credentials[jti]
            revoked_count += 1
            
        return revoked_count

    async def rotate_credentials(self, user_id: str, credential_type: str) -> Dict:
        """Force credential rotation for a user"""
        rotation_result = {
            'user_id': user_id,
            'credential_type': credential_type,
            'rotated_at': datetime.now().isoformat(),
            'actions_taken': []
        }
        
        if credential_type == 'password':
            # Force password change on next login
            rotation_result['actions_taken'].append('password_reset_required')
            
        elif credential_type == 'api_key':
            # Revoke existing API keys
            revoked = await self.revoke_user_tokens(user_id)
            rotation_result['actions_taken'].append(f'revoked_{revoked}_tokens')
            
        elif credential_type == 'all':
            # Revoke everything
            revoked = await self.revoke_user_tokens(user_id)
            rotation_result['actions_taken'].extend([
                'password_reset_required',
                f'revoked_{revoked}_tokens',
                'mfa_reset_required'
            ])
            
        return rotation_result

    async def cleanup_expired_credentials(self):
        """Clean up expired tokens and credentials"""
        now = time.time()
        expired_tokens = []
        
        for jti, cred in self.active_credentials.items():
            if cred['expires_at'] < now:
                expired_tokens.append(jti)
        
        for jti in expired_tokens:
            del self.active_credentials[jti]
            
        return len(expired_tokens)

class AuthenticationSubsystem:
    def __init__(self, config: Dict):
        self.config = config
        self.iv = IdentityValidator(config)
        self.mh = MFAHandler(config)
        self.tsa = TrustScoreAssessor(config)
        self.cm = CredentialManager(config)
        
        # Event pipeline
        self.event_queue = asyncio.Queue()
        self.running = False
        
        # Zero Trust policy
        self.zero_trust_enabled = config.get('zero_trust', True)
        self.continuous_validation = config.get('continuous_validation', True)
        
        # Integration with other subsystems
        self.sec_sub_queue = None  # Will be set by engine
        self.sc_sub_queue = None   # Will be set by engine
        
        # Logging
        self.logger = logging.getLogger(__name__)

    async def start(self):
        """Start the authentication subsystem"""
        self.running = True
        
        # Start background tasks
        asyncio.create_task(self._event_processor())
        asyncio.create_task(self._credential_cleanup_task())
        
        if self.continuous_validation:
            asyncio.create_task(self._continuous_validation_task())
            
        self.logger.info("Authentication Subsystem started")

    async def stop(self):
        """Stop the authentication subsystem"""
        self.running = False
        self.logger.info("Authentication Subsystem stopped")

    async def handle_event(self, event: Dict):
        """Main event handler for authentication events"""
        event_type = event.get('type')
        
        try:
            if event_type == 'authentication_request':
                await self._handle_authentication_request(event)
            elif event_type == 'mfa_initiation_request':
                await self._handle_mfa_initiation(event)
            elif event_type == 'mfa_verification_request':
                await self._handle_mfa_verification(event)
            elif event_type == 'token_validation_request':
                await self._handle_token_validation(event)
            elif event_type == 'credential_rotation_request':
                await self._handle_credential_rotation(event)
            elif event_type == 'trust_assessment_request':
                await self._handle_trust_assessment(event)
            elif event_type == 'logout_request':
                await self._handle_logout(event)
            else:
                self.logger.warning(f"Unknown event type: {event_type}")
                
        except Exception as e:
            self.logger.error(f"Error handling event {event_type}: {str(e)}")
            await self._emit_event({
                'type': 'authentication_error',
                'request_id': event.get('request_id'),
                'error': str(e),
                'timestamp': datetime.now()
            })

    async def _handle_authentication_request(self, event: Dict):
        """Handle primary authentication requests"""
        request_id = event.get('request_id', str(uuid.uuid4()))
        credentials = event.get('credentials', {})
        context = event.get('context', {})
        
        # Step 1: Identity validation
        identity_result = await self.iv.validate_identity(credentials, context)
        
        if not identity_result.get('valid'):
            await self._emit_event({
                'type': 'authentication_failed',
                'request_id': request_id,
                'reason': identity_result.get('reason'),
                'timestamp': datetime.now()
            })
            
            # Notify security subsystem of failed attempt
            if self.sec_sub_queue:
                await self.sec_sub_queue.put({
                    'type': 'security_event',
                    'subtype': 'authentication_failure',
                    'user_id': credentials.get('username'),
                    'context': context,
                    'timestamp': datetime.now()
                })
            return

        user_id = identity_result['user_id']
        
        # Step 2: Trust assessment (Zero Trust approach)
        trust_result = await self.tsa.assess_trust(user_id, context)
        
        # Step 3: Determine if MFA is required
        requires_mfa = (
            identity_result.get('requires_mfa', False) or
            trust_result.get('requires_step_up', False) or
            self.zero_trust_enabled
        )
        
        if requires_mfa and not event.get('skip_mfa'):
            # Initiate MFA process
            mfa_result = await self.mh.initiate_mfa(user_id)
            
            await self._emit_event({
                'type': 'mfa_required',
                'request_id': request_id,
                'user_id': user_id,
                'mfa_challenge': mfa_result,
                'trust_score': trust_result['score'],
                'timestamp': datetime.now()
            })
            return

        # Step 4: Issue access token
        claims = {
            'roles': identity_result.get('roles', []),
            'trust_level': trust_result['level'],
            'trust_score': trust_result['score'],
            'auth_method': credentials.get('method', 'unknown')
        }
        
        access_token = await self.cm.issue_access_token(user_id, claims)
        
        # Step 5: Success response
        await self._emit_event({
            'type': 'authentication_success',
            'request_id': request_id,
            'user_id': user_id,
            'access_token': access_token,
            'trust_assessment': trust_result,
            'session_data': {
                'user_id': user_id,
                'permissions': identity_result.get('roles', []),
                'trust_level': trust_result['level']
            },
            'timestamp': datetime.now()
        })
        
        # Notify session control subsystem to create session
        if self.sc_sub_queue:
            await self.sc_sub_queue.put({
                'type': 'session_create_request',
                'user_id': user_id,
                'session_data': {
                    'permissions': identity_result.get('roles', []),
                    'trust_level': trust_result['level'],
                    'auth_method': credentials.get('method'),
                    'access_token': access_token
                },
                'timestamp': datetime.now()
            })

    async def _handle_mfa_initiation(self, event: Dict):
        """Handle MFA initiation requests"""
        request_id = event.get('request_id', str(uuid.uuid4()))
        user_id = event.get('user_id')
        methods = event.get('methods', [MFAType.TOTP, MFAType.SMS])
        
        mfa_result = await self.mh.initiate_mfa(user_id, methods)
        
        await self._emit_event({
            'type': 'mfa_initiated',
            'request_id': request_id,
            'user_id': user_id,
            'challenge': mfa_result,
            'timestamp': datetime.now()
        })

    async def _handle_mfa_verification(self, event: Dict):
        """Handle MFA verification requests"""
        request_id = event.get('request_id', str(uuid.uuid4()))
        user_id = event.get('user_id')
        token = event.get('token')
        challenge_id = event.get('challenge_id')
        method = event.get('method')
        context = event.get('context', {})
        
        # Verify MFA token
        mfa_valid = await self.mh.verify_mfa(user_id, token, challenge_id, method)
        
        if not mfa_valid:
            await self._emit_event({
                'type': 'mfa_verification_failed',
                'request_id': request_id,
                'user_id': user_id,
                'method': method,
                'timestamp': datetime.now()
            })
            
            # Notify security subsystem
            if self.sec_sub_queue:
                await self.sec_sub_queue.put({
                    'type': 'security_event',
                    'subtype': 'mfa_failure',
                    'user_id': user_id,
                    'method': method,
                    'context': context,
                    'timestamp': datetime.now()
                })
            return
        
        # MFA successful - complete authentication process
        # Re-assess trust with successful MFA
        trust_result = await self.tsa.assess_trust(user_id, context)
        trust_result['score'] += 15  # Bonus for successful MFA
        
        # Issue access token with enhanced privileges
        claims = {
            'roles': event.get('user_roles', []),
            'trust_level': trust_result['level'],
            'trust_score': trust_result['score'],
            'mfa_verified': True,
            'mfa_method': method
        }
        
        access_token = await self.cm.issue_access_token(user_id, claims)
        
        await self._emit_event({
            'type': 'mfa_verification_success',
            'request_id': request_id,
            'user_id': user_id,
            'access_token': access_token,
            'trust_assessment': trust_result,
            'timestamp': datetime.now()
        })

    async def _handle_token_validation(self, event: Dict):
        """Handle token validation requests"""
        request_id = event.get('request_id', str(uuid.uuid4()))
        token = event.get('token')
        
        validation_result = await self.cm.validate_access_token(token)
        
        await self._emit_event({
            'type': 'token_validation_result',
            'request_id': request_id,
            'validation_result': validation_result,
            'timestamp': datetime.now()
        })

    async def _handle_credential_rotation(self, event: Dict):
        """Handle credential rotation requests"""
        request_id = event.get('request_id', str(uuid.uuid4()))
        user_id = event.get('user_id')
        credential_type = event.get('credential_type', 'all')
        reason = event.get('reason', 'security_policy')
        
        rotation_result = await self.cm.rotate_credentials(user_id, credential_type)
        
        await self._emit_event({
            'type': 'credential_rotation_completed',
            'request_id': request_id,
            'user_id': user_id,
            'rotation_result': rotation_result,
            'reason': reason,
            'timestamp': datetime.now()
        })
        
        # Notify session control to terminate user sessions if needed
        if credential_type in ['password', 'all']:
            if self.sc_sub_queue:
                await self.sc_sub_queue.put({
                    'type': 'user_sessions_terminate',
                    'user_id': user_id,
                    'reason': f'credential_rotation_{reason}',
                    'timestamp': datetime.now()
                })

    async def _handle_trust_assessment(self, event: Dict):
        """Handle trust assessment requests"""
        request_id = event.get('request_id', str(uuid.uuid4()))
        user_id = event.get('user_id')
        context = event.get('context', {})
        
        trust_result = await self.tsa.assess_trust(user_id, context)
        
        await self._emit_event({
            'type': 'trust_assessment_result',
            'request_id': request_id,
            'user_id': user_id,
            'trust_assessment': trust_result,
            'timestamp': datetime.now()
        })

    async def _handle_logout(self, event: Dict):
        """Handle logout requests"""
        request_id = event.get('request_id', str(uuid.uuid4()))
        user_id = event.get('user_id')
        token = event.get('token')
        session_id = event.get('session_id')
        
        # Revoke the specific token if provided
        if token:
            await self.cm.revoke_token(token)
        
        # Or revoke all tokens for user
        if not token and user_id:
            await self.cm.revoke_user_tokens(user_id)
        
        await self._emit_event({
            'type': 'logout_completed',
            'request_id': request_id,
            'user_id': user_id,
            'session_id': session_id,
            'timestamp': datetime.now()
        })
        
        # Notify session control subsystem
        if self.sc_sub_queue and session_id:
            await self.sc_sub_queue.put({
                'type': 'session_terminate_request',
                'session_id': session_id,
                'reason': 'user_logout',
                'timestamp': datetime.now()
            })

    async def _event_processor(self):
        """Background event processor"""
        while self.running:
            try:
                event = await asyncio.wait_for(self.event_queue.get(), timeout=1.0)
                await self.handle_event(event)
            except asyncio.TimeoutError:
                continue
            except Exception as e:
                self.logger.error(f"Event processor error: {str(e)}")

    async def _credential_cleanup_task(self):
        """Background task for credential cleanup"""
        cleanup_interval = self.config.get('cleanup_interval', 3600)  # 1 hour
        
        while self.running:
            try:
                expired_count = await self.cm.cleanup_expired_credentials()
                if expired_count > 0:
                    self.logger.info(f"Cleaned up {expired_count} expired credentials")
                
                await asyncio.sleep(cleanup_interval)
            except Exception as e:
                self.logger.error(f"Credential cleanup error: {str(e)}")

    async def _continuous_validation_task(self):
        """Background task for continuous trust validation"""
        validation_interval = self.config.get('validation_interval', 300)  # 5 minutes
        
        while self.running:
            try:
                # Get active sessions from session control subsystem
                # This would be implemented with proper inter-subsystem communication
                active_sessions = []  # Placeholder
                
                for session in active_sessions:
                    user_id = session.get('user_id')
                    if not user_id:
                        continue
                        
                    # Re-assess trust for active sessions
                    context = {
                        'session_id': session.get('session_id'),
                        'last_activity': session.get('last_activity'),
                        'client_ip': session.get('client_ip'),
                        # Add more context as needed
                    }
                    
                    trust_result = await self.tsa.assess_trust(user_id, context)
                    
                    # Take action if trust level drops
                    if trust_result['level'] == TrustLevel.UNTRUSTED.name:
                        await self._emit_event({
                            'type': 'trust_violation_detected',
                            'user_id': user_id,
                            'session_id': session.get('session_id'),
                            'trust_assessment': trust_result,
                            'action': 'terminate_session',
                            'timestamp': datetime.now()
                        })
                    elif trust_result.get('requires_step_up'):
                        await self._emit_event({
                            'type': 'step_up_authentication_required',
                            'user_id': user_id,
                            'session_id': session.get('session_id'),
                            'trust_assessment': trust_result,
                            'timestamp': datetime.now()
                        })
                
                await asyncio.sleep(validation_interval)
            except Exception as e:
                self.logger.error(f"Continuous validation error: {str(e)}")

    async def _emit_event(self, event: Dict):
        """Emit events to the engine pipeline"""
        await self.event_queue.put(event)

