class SessionMonitor:
    """Enhanced session monitor with advanced anomaly detection capabilities."""
    
    def __init__(self, config: Dict[str, Any], logger: logging.Logger, 
                 session_manager=None, security_subsystem=None, event_bus=None):
        self.config = config
        self.logger = logger.getChild("SessionMonitor")
        
        # External dependencies
        self.session_manager = session_manager
        self.security_subsystem = security_subsystem
        self.event_bus = event_bus
        
        # Core components
        self.anomaly_detector = AnomalyDetector(config, logger)
        
        # Metrics storage
        self.metrics = {
            'sessions_created': 0,
            'sessions_expired': 0,
            'sessions_revoked': 0,
            'failed_authentications': 0,
            'active_sessions_peak': 0,
            'anomalies_detected': 0,
            'high_threat_anomalies': 0,
            'auto_revocations': 0,
            'last_collection': None
        }
        
        # Configuration
        self.collect_interval = self.config.get('monitor_interval', 60)
        self.anomaly_config = self.config.get('anomaly_detection', {})
        self.auto_revoke_enabled = self.anomaly_config.get('auto_revoke', True)
        self.report_only = self.anomaly_config.get('report_only', False)
        
        # State
        self._running = False
    
    async def initialize(self):
        """Initialize the session monitor."""
        self.logger.info("Initializing Enhanced SessionMonitor with Anomaly Detection")
        await self.anomaly_detector.initialize()
    
    async def start(self):
        """Start the session monitor."""
        self.logger.info("Starting Enhanced SessionMonitor")
        self._running = True
    
    async def stop(self):
        """Stop the session monitor."""
        self.logger.info("Stopping Enhanced SessionMonitor")
        self._running = False
    
    async def health_check(self) -> Dict[str, Any]:
        """Perform comprehensive health check."""
        return {
            'status': 'healthy',
            'anomaly_detector': 'active',
            'baselines_count': len(self.anomaly_detector.user_baselines),
            'recent_anomalies': len(self.anomaly_detector.recent_anomalies)
        }
    
    async def get_status(self) -> Dict[str, Any]:
        """Get detailed status including anomaly detection metrics."""
        return {
            'metrics': self.metrics.copy(),
            'collect_interval': self.collect_interval,
            'anomaly_detection': {
                'enabled': True,
                'auto_revoke': self.auto_revoke_enabled,
                'report_only': self.report_only,
                'user_baselines': len(self.anomaly_detector.user_baselines),
                'recent_anomalies': len(self.anomaly_detector.recent_anomalies),
                'thresholds': self.anomaly_detector.thresholds
            }
        }
    
    async def collect_metrics(self):
        """Enhanced metrics collection with anomaly analysis."""
        try:
            self.metrics['last_collection'] = datetime.utcnow().isoformat()
            
            # Collect session metrics from session manager if available
            if self.session_manager:
                status = await self.session_manager.get_status()
                self.metrics['active_sessions_peak'] = max(
                    self.metrics['active_sessions_peak'],
                    status.get('active_sessions', 0)
                )
            
            # Perform periodic anomaly analysis
            await self._analyze_user_behaviors()
            
            self.logger.debug("Enhanced metrics collection completed")
            
        except Exception as e:
            self.logger.error(f"Error collecting enhanced metrics: {str(e)}")
    
    async def record_session_event(self, event_type: str, session_data: Dict[str, Any]):
        """Record and analyze session events for anomalies."""
        try:
            # Update basic metrics
            if event_type == 'session_created':
                self.metrics['sessions_created'] += 1
            elif event_type == 'session_expired':
                self.metrics['sessions_expired'] += 1
            elif event_type == 'session_revoked':
                self.metrics['sessions_revoked'] += 1
            elif event_type == 'failed_authentication':
                self.metrics['failed_authentications'] += 1
            
            # Perform anomaly analysis
            anomalies = await self.anomaly_detector.analyze_session_event(session_data, event_type)
            
            if anomalies:
                self.metrics['anomalies_detected'] += len(anomalies)
                
                # Process each detected anomaly
                for anomaly in anomalies:
                    await self._process_anomaly(anomaly)
            
        except Exception as e:
            self.logger.error(f"Error recording session event: {str(e)}")
    
    async def _process_anomaly(self, anomaly: AnomalyEvent):
        """Process a detected anomaly with appropriate security actions."""
        try:
            self.logger.warning(f"Processing anomaly: {anomaly.anomaly_type.value} "
                              f"for user {anomaly.user_id} (threat: {anomaly.threat_level.value})")
            
            # Count high-threat anomalies
            if anomaly.threat_level == ThreatLevel.HIGH:
                self.metrics['high_threat_anomalies'] += 1
            
            # Publish anomaly event to event bus
            if self.event_bus:
                await self.event_bus.publish('session.anomaly', anomaly.to_dict())
            
            # Trigger security subsystem detection
            if self.security_subsystem:
                await self.security_subsystem.detect_threat({
                    'type': 'session_anomaly',
                    'user_id': anomaly.user_id,
                    'session_id': anomaly.session_id,
                    'threat_level': anomaly.threat_level.value,
                    'details': anomaly.details
                })
            
            # Auto-revoke session for high-threat anomalies
            if (not self.report_only and 
                self.auto_revoke_enabled and 
                anomaly.threat_level == ThreatLevel.HIGH and
                anomaly.session_id and 
                self.session_manager):
                
                success = await self.session_manager.revoke_session(
                    anomaly.session_id, 
                    f"auto_revocation_{anomaly.anomaly_type.value}"
                )
                
                if success:
                    self.metrics['auto_revocations'] += 1
                    self.logger.warning(f"Auto-revoked session {anomaly.session_id} "
                                      f"due to {anomaly.anomaly_type.value}")
                    
                    # Publish revocation event
                    if self.event_bus:
                        await self.event_bus.publish('session.auto_revoked', {
                            'session_id': anomaly.session_id,
                            'user_id': anomaly.user_id,
                            'reason': anomaly.anomaly_type.value,
                            'threat_level': anomaly.threat_level.value,
                            'timestamp': datetime.utcnow().isoformat()
                        })
        
        except Exception as e:
            self.logger.error(f"Error processing anomaly: {str(e)}")
    
    async def _analyze_user_behaviors(self):
        """Perform periodic analysis of user behavioral patterns."""
        try:
            # Get risk scores for all users with recent activity
            for user_id in self.anomaly_detector.user_baselines.keys():
                risk_score = await self.anomaly_detector.get_user_risk_score(user_id)
                
                if risk_score > 0.7:  # High overall risk
                    self.logger.warning(f"User {user_id} has elevated risk score: {risk_score:.2f}")
                    
                    # Could trigger additional security measures here
                    if self.event_bus:
                        await self.event_bus.publish('user.high_risk', {
                            'user_id': user_id,
                            'risk_score': risk_score,
                            'timestamp': datetime.utcnow().isoformat()
                        })
        
        except Exception as e:
            self.logger.error(f"Error analyzing user behaviors: {str(e)}")
    
    async def get_user_anomalies(self, user_id: str, hours: int = 24) -> List[Dict[str, Any]]:
        """Get recent anomalies for a specific user."""
        try:
            cutoff_time = datetime.utcnow() - timedelta(hours=hours)
            user_anomalies = []
            
            for anomaly in self.anomaly_detector.recent_anomalies:
                if (anomaly.user_id == user_id and 
                    anomaly.detected_at >= cutoff_time):
                    user_anomalies.append(anomaly.to_dict())
            
            return sorted(user_anomalies, key=lambda x: x['detected_at'], reverse=True)
            
        except Exception as e:
            self.logger.error(f"Error getting user anomalies: {str(e)}")
            return []
    
    async def get_anomaly_summary(self, hours: int = 24) -> Dict[str, Any]:
        """Get summary of detected anomalies."""
        try:
            cutoff_time = datetime.utcnow() - timedelta(hours=hours)
            
            summary = {
                'total_anomalies': 0,
                'by_type': defaultdict(int),
                'by_threat_level': defaultdict(int),
                'unique_users': set(),
                'time_range_hours': hours
            }
            
            for anomaly in self.anomaly_detector.recent_anomalies:
                if anomaly.detected_at >= cutoff_time:
                    summary['total_anomalies'] += 1
                    summary['by_type'][anomaly.anomaly_type.value] += 1
                    summary['by_threat_level'][anomaly.threat_level.value] += 1
                    summary['unique_users'].add(anomaly.user_id)
            
            summary['unique_users'] = len(summary['unique_users'])
            summary['by_type'] = dict(summary['by_type'])
            summary['by_threat_level'] = dict(summary['by_threat_level'])
            
            return summary
            
        except Exception as e:
            self.logger.error(f"Error getting anomaly summary: {str(e)}")
            return {}
    
