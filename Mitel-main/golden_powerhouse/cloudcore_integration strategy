class SessionManager:
    """Manages user sessions and access control"""
    
    def __init__(self, config: Dict[str, Any]):
        self.config = config
        self.logger = logging.getLogger("SessionManager")
        self.sessions = {}
        self.user_sessions = {}
        self.max_sessions = config.get('max_sessions', 10000)
        self.session_timeout = config.get('session_timeout', 3600)
        self.max_user_sessions = config.get('max_user_sessions', 5)
        
    async def create_session(self, user_id: str, metadata: Dict = None) -> str:
        """Create a new session"""
        # Check limits
        if len(self.sessions) >= self.max_sessions:
            raise RuntimeError("Maximum sessions exceeded")
        
        user_session_count = len(self.user_sessions.get(user_id, []))
        if user_session_count >= self.max_user_sessions:
            # Clean up oldest session for this user
            oldest_session = min(self.user_sessions[user_id], 
                               key=lambda s: self.sessions[s]['created_at'])
            await self.destroy_session(oldest_session)
        
        # Create session
        session_id = f"sess_{uuid.uuid4().hex[:16]}"
        session_data = {
            'session_id': session_id,
            'user_id': user_id,
            'created_at': datetime.now(),
            'last_activity': datetime.now(),
            'metadata': metadata or {}
        }
        
        self.sessions[session_id] = session_data
        
        # Track user sessions
        if user_id not in self.user_sessions:
            self.user_sessions[user_id] = []
        self.user_sessions[user_id].append(session_id)
        
        self.logger.debug(f"Created session {session_id} for user {user_id}")
        return session_id
    
    async def get_session(self, session_id: str) -> Optional[Dict]:
        """Get session data"""
        if session_id not in self.sessions:
            return None
        
        session = self.sessions[session_id]
        
        # Check if expired
        if self._is_expired(session):
            await self.destroy_session(session_id)
            return None
        
        # Update activity
        session['last_activity'] = datetime.now()
        return session.copy()
    
    async def destroy_session(self, session_id: str) -> bool:
        """Destroy a session"""
        if session_id not in self.sessions:
            return False
        
        session = self.sessions[session_id]
        user_id = session['user_id']
        
        # Remove from sessions
        del self.sessions[session_id]
        
        # Remove from user sessions
        if user_id in self.user_sessions:
            self.user_sessions[user_id] = [
                s for s in self.user_sessions[user_id] if s != session_id
            ]
            if not self.user_sessions[user_id]:
                del self.user_sessions[user_id]
        
        self.logger.debug(f"Destroyed session {session_id}")
        return True
    
    def _is_expired(self, session: Dict) -> bool:
        """Check if session is expired"""
        last_activity = session['last_activity']
        return (datetime.now() - last_activity).total_seconds() > self.session_timeout
    
    async def cleanup_expired_sessions(self) -> int:
        """Clean up expired sessions and return count cleaned"""
        expired_sessions = []
        for session_id, session in self.sessions.items():
            if self._is_expired(session):
                expired_sessions.append(session_id)
        
        for session_id in expired_sessions:
            await self.destroy_session(session_id)
        
        return len(expired_sessions)
    
    def get_active_sessions_count(self) -> int:
        """Get count of active sessions"""
        return len(self.sessions)
    
    def get_user_sessions(self, user_id: str) -> List[str]:
        """Get sessions for a specific user"""
        return self.user_sessions.get(user_id, [])

class AccessControlManager:
    """Manages access control and permissions"""
    
    def __init__(self, config: Dict[str, Any]):
        self.config = config
        self.logger = logging.getLogger("AccessControlManager")
        self.permissions = {}
        self.roles = {}
        self.user_roles = {}
        
        # Initialize default roles and permissions
        self._setup_default_permissions()
    
    def _setup_default_permissions(self):
        """Setup default roles and permissions"""
        self.roles = {
            'admin': ['read', 'write', 'delete', 'manage_users', 'manage_system'],
            'user': ['read', 'write'],
            'guest': ['read']
        }
        
        self.permissions = {
            'read': 'Read access to resources',
            'write': 'Write access to resources',
            'delete': 'Delete access to resources',
            'manage_users': 'User management permissions',
            'manage_system': 'System management permissions'
        }
    
    def assign_role(self, user_id: str, role: str) -> bool:
        """Assign a role to a user"""
        if role not in self.roles:
            return False
        
        if user_id not in self.user_roles:
            self.user_roles[user_id] = set()
        
        self.user_roles[user_id].add(role)
        self.logger.debug(f"Assigned role {role} to user {user_id}")
        return True
    
    def revoke_role(self, user_id: str, role: str) -> bool:
        """Revoke a role from a user"""
        if user_id not in self.user_roles:
            return False
        
        if role in self.user_roles[user_id]:
            self.user_roles[user_id].discard(role)
            self.logger.debug(f"Revoked role {role} from user {user_id}")
            return True
        
        return False
    
    def has_permission(self, user_id: str, permission: str) -> bool:
        """Check if user has a specific permission"""
        user_roles = self.user_roles.get(user_id, set())
        
        for role in user_roles:
            if permission in self.roles.get(role, []):
                return True
        
        return False
    
    def get_user_permissions(self, user_id: str) -> Set[str]:
        """Get all permissions for a user"""
        user_roles = self.user_roles.get(user_id, set())
        permissions = set()
        
        for role in user_roles:
            permissions.update(self.roles.get(role, []))
        
        return permissions

class SessionLifecycleHandler:
    """Handles session lifecycle events"""
    
    def __init__(self, session_manager: SessionManager, event_bus=None):
        self.session_manager = session_manager
        self.event_bus = event_bus
        self.logger = logging.getLogger("SessionLifecycleHandler")
        self.session_events = []
        
    async def on_session_created(self, session_id: str, user_id: str, metadata: Dict = None):
        """Handle session creation event"""
        event_data = {
            'type': 'session_created',
            'session_id': session_id,
            'user_id': user_id,
            'metadata': metadata or {},
            'timestamp': datetime.now().isoformat()
        }
        
        self.session_events.append(event_data)
        self.logger.info(f"Session created: {session_id} for user {user_id}")
        
        if self.event_bus:
            await self.event_bus.publish('session_created', event_data)
    
    async def on_session_destroyed(self, session_id: str, user_id: str = None):
        """Handle session destruction event"""
        event_data = {
            'type': 'session_destroyed',
            'session_id': session_id,
            'user_id': user_id,
            'timestamp': datetime.now().isoformat()
        }
        
        self.session_events.append(event_data)
        self.logger.info(f"Session destroyed: {session_id}")
        
        if self.event_bus:
            await self.event_bus.publish('session_destroyed', event_data)
    
    async def on_session_activity(self, session_id: str, activity_type: str = 'access'):
        """Handle session activity event"""
        event_data = {
            'type': 'session_activity',
            'session_id': session_id,
            'activity_type': activity_type,
            'timestamp': datetime.now().isoformat()
        }
        
        self.session_events.append(event_data)
        
        if self.event_bus:
            await self.event_bus.publish('session_activity', event_data)

class SessionMonitor:
    """Monitors session health and metrics"""
    
    def __init__(self, session_manager: SessionManager):
        self.session_manager = session_manager
        self.logger = logging.getLogger("SessionMonitor")
        self.metrics = {
            'total_sessions_created': 0,
            'total_sessions_destroyed': 0,
            'sessions_expired': 0,
            'peak_concurrent_sessions': 0
        }
        self.monitoring_task = None
        
    async def start_monitoring(self):
        """Start session monitoring"""
        if self.monitoring_task:
            return
        
        self.monitoring_task = asyncio.create_task(self._monitoring_loop())
        self.logger.info("Session monitoring started")
    
    async def stop_monitoring(self):
        """Stop session monitoring"""
        if self.monitoring_task:
            self.monitoring_task.cancel()
            try:
                await self.monitoring_task
            except asyncio.CancelledError:
                pass
            self.monitoring_task = None
        
        self.logger.info("Session monitoring stopped")
    
    async def _monitoring_loop(self):
        """Main monitoring loop"""
        while True:
            try:
                # Update metrics
                current_sessions = self.session_manager.get_active_sessions_count()
                self.metrics['peak_concurrent_sessions'] = max(
                    self.metrics['peak_concurrent_sessions'], 
                    current_sessions
                )
                
                # Clean up expired sessions
                expired_count = await self.session_manager.cleanup_expired_sessions()
                if expired_count > 0:
                    self.metrics['sessions_expired'] += expired_count
                    self.logger.info(f"Cleaned up {expired_count} expired sessions")
                
                await asyncio.sleep(60)  # Check every minute
                
            except asyncio.CancelledError:
                break
            except Exception as e:
                self.logger.error(f"Error in monitoring loop: {e}")
                await asyncio.sleep(10)
    
    def get_metrics(self) -> Dict[str, Any]:
        """Get session metrics"""
        current_sessions = self.session_manager.get_active_sessions_count()
        
        return {
            **self.metrics,
            'current_active_sessions': current_sessions,
            'timestamp': datetime.now().isoformat()
        }

class SessionControlSubsystem(BaseSubsystem):
    """Session Control Subsystem - Manages user sessions and access control"""
    
    def __init__(self, config: Dict[str, Any] = None):
        super().__init__(config)
        
        # Core components
        self.session_manager = None
        self.access_control = None
        self.lifecycle_handler = None
        self.session_monitor = None
        
        # Configuration
        self.cleanup_interval = self.config.get('cleanup_interval', 300)
        
    async def initialize(self):
        """Initialize SC-SUB"""
        try:
            # Initialize session manager
            self.session_manager = SessionManager(self.config)
            
            # Initialize access control
            self.access_control = AccessControlManager(self.config)
            
            # Initialize lifecycle handler
            self.lifecycle_handler = SessionLifecycleHandler(self.session_manager)
            
            # Initialize session monitor
            self.session_monitor = SessionMonitor(self.session_manager)
            
            self.initialized = True
            self.logger.info("SC-SUB initialized successfully")
            
        except Exception as e:
            self.logger.error(f"SC-SUB initialization failed: {e}")
            raise
    
    async def start(self):
        """Start SC-SUB"""
        if not self.initialized:
            raise RuntimeError("SC-SUB not initialized")
        
        if self.running:
            return
        
        # Start session monitoring
        await self.session_monitor.start_monitoring()
        
        self.running = True
        self.start_time = datetime.now()
        self.logger.info("SC-SUB started")
    
    async def stop(self):
        """Stop SC-SUB"""
        if not self.running:
            return
        
        # Stop session monitoring
        if self.session_monitor:
            await self.session_monitor.stop_monitoring()
        
        self.running = False
        self.logger.info("SC-SUB stopped")
    
    # Session management interface
    async def create_session(self, user_id: str, metadata: Dict = None) -> str:
        """Create a new user session"""
        if not self.running:
            raise RuntimeError("SC-SUB not running")
        
        session_id = await self.session_manager.create_session(user_id, metadata)
        await self.lifecycle_handler.on_session_created(session_id, user_id, metadata)
        return session_id
    
    async def get_session(self, session_id: str) -> Optional[Dict]:
        """Get session information"""
        if not self.running:
            return None
        
        session = await self.session_manager.get_session(session_id)
        if session:
            await self.lifecycle_handler.on_session_activity(session_id)
        return session
    
    async def destroy_session(self, session_id: str) -> bool:
        """Destroy a session"""
        if not self.running:
            return False
        
        # Get session info before destroying
        session = await self.session_manager.get_session(session_id)
        user_id = session.get('user_id') if session else None
        
        success = await self.session_manager.destroy_session(session_id)
        if success:
            await self.lifecycle_handler.on_session_destroyed(session_id, user_id)
        
        return success
    
    # Access control interface
    def assign_role(self, user_id: str, role: str) -> bool:
        """Assign role to user"""
        if not self.running:
            return False
        
        return self.access_control.assign_role(user_id, role)
    
    def has_permission(self, user_id: str, permission: str) -> bool:
        """Check user permission"""
        if not self.running:
            return False
        
        return self.access_control.has_permission(user_id, permission)
    
    def get_session_metrics(self) -> Dict[str, Any]:
        """Get session metrics"""
        if not self.running or not self.session_monitor:
            return {}
        
        return self.session_monitor.get_metrics()
    
    def get_status(self) -> Dict[str, Any]:
        """Get detailed SC-SUB status"""
        base_status = super().get_status()
        
        if self.running:
            base_status.update({
                'active_sessions': self.session_manager.get_active_sessions_count() if self.session_manager else 0,
                'metrics': self.get_session_metrics()
            })
        
        return base_status

