async def main():
    """Main CLI interface for testing the integrated system"""
    import argparse
    
    parser = argparse.ArgumentParser(description="G.Legion CloudCore Sync v2 + SP-SUB + SC-SUB")
    parser.add_argument('--config', default='config/sp_config.yaml', help='Configuration file')
    parser.add_argument('--node-id', help='Node ID (auto-generated if not provided)')
    parser.add_argument('--command', choices=['start', 'sync', 'status', 'test'], default='start')
    parser.add_argument('--dry-run', action='store_true', help='Dry run mode')
    parser.add_argument('--peers', nargs='*', help='Peer nodes to sync with')
    
    args = parser.parse_args()
    
    # Setup logging
    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
    )
    
    # Create configuration
    config = {
        'config_file': args.config,
        'event_bus': None  # Could be injected here
    }
    
    node_id = args.node_id or str(uuid.uuid4())
    
    # Initialize protocol
    protocol = EnhancedGhostSyncProtocol(config, node_id)
    
    try:
        await protocol.initialize()
        await protocol.start()
        
        if args.command == 'sync':
            result = await protocol.sync(args.peers, args.dry_run)
            print(json.dumps(result, indent=2, default=str))
        
        elif args.command == 'status':
            status = await protocol.get_status()
            print(json.dumps(status, indent=2, default=str))
        
        elif args.command == 'test':
            # Test session creation
            print("Testing Session Control...")
            session_id = await protocol.create_session('test_user', {'test': True})
            print(f"Created session: {session_id}")
            
            session = await protocol.get_session(session_id)
            print(f"Session data: {session}")
            
            # Test permissions
            protocol.assign_user_role('test_user', 'admin')
            has_perm = protocol.check_user_permission('test_user', 'read')
            print(f"User has read permission: {has_perm}")
            
            # Test sync
            delta = await protocol.create_test_delta('test_user')
            print(f"Created test delta: {delta}")
            
            # Health check
            health = await protocol.health_check()
            print("Health check:")
            print(json.dumps(health, indent=2, default=str))
        
        elif args.command == 'start':
            print("Protocol started. Press Ctrl+C to stop...")
            try:
                while True:
                    await asyncio.sleep(1)
            except KeyboardInterrupt:
                print("Shutting down...")
        
    except Exception as e:
        print(f"Error: {e}")
    finally:
        await protocol.stop()

if __name__ == "__main__":
    asyncio.run(main())
