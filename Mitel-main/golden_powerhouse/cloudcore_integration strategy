# SYNC COORDINATOR (ENHANCED WITH SC-SUB)
# ============================================================================

class SyncCoordinator:
    """Central coordinator for Ghost synchronization operations with integrated subsystems"""
    
    def __init__(self, config_file: str = None):
        self.config_file = config_file or "config/sp_config.yaml"
        self.config = self._load_config()
        self.logger = logging.getLogger("SyncCoordinator")
        
        # Core components
        self.sync_protocol = None
        self.delta_engine = None
        
        # Integrated subsystems
        self.session_control = None
        
        # State management
        self.node_id = str(uuid.uuid4())
        self.sync_state = {}
        self.sync_state_file = "data/ghost_sync_state.json"
        self.subsystems = {}
        
    def _load_config(self) -> Dict[str, Any]:
        """Load configuration from file"""
        try:
            if os.path.exists(self.config_file):
                with open(self.config_file, 'r') as f:
                    return yaml.safe_load(f)
        except Exception as e:
            self.logger.warning(f"Could not load config from {self.config_file}: {e}")
        
        return self._get_default_config()
    
    def _get_default_config(self) -> Dict[str, Any]:
        """Get default configuration"""
        return {
            'sync': {
                'interval_seconds': 300,
                'batch_size': 100,
                'max_retries': 3,
                'timeout_seconds': 30,
                'offline_mode': True
            },
            'protocol': {
                'mode': 'mesh',
                'discovery_enabled': True,
                'listen_port': 8443,
                'discovery_port': 8444,
                'timeout_seconds': 10,
                'max_connections': 20
            },
            'delta': {
                'compression_enabled': True,
                'max_delta_size': 1048576,
                'crdt_mode': True
            },
            'session_control': {
                'max_sessions': 10000,
                'session_timeout': 3600,
                'max_user_sessions': 5,
                'cleanup_interval': 300
            }
        }
    
    async def initialize(self):
        """Initialize sync coordinator and all subsystems"""
        try:
            # Ensure data directory exists
            os.makedirs(os.path.dirname(self.sync_state_file), exist_ok=True)
            
            # Load existing state
            await self._load_sync_state()
            
            # Initialize delta engine
            self.delta_engine = EnhancedDeltaEngine(self.config.get('delta', {}))
            self.delta_engine.node_id = self.node_id
            
            # Initialize sync protocol
            protocol_config = self.config.get('protocol', {})
            self.sync_protocol = GhostSyncProtocol(
                protocol_config, 
                None,  # integrity_verifier
                self.delta_engine
            )
            await self.sync_protocol.initialize(self.node_id)
            
            # Initialize Session Control Subsystem
            await self._initialize_session_control()
            
            # Register subsystems
            self._register_subsystems()
            
            self.logger.info(f"Sync coordinator initialized with node_id: {self.node_id[:8]}...")
            
        except Exception as e:
            self.logger.error(f"Coordinator initialization failed: {e}")
            raise
    
    async def _initialize_session_control(self):
        """Initialize Session Control Subsystem"""
        try:
            sc_config = self.config.get('session_control', {})
            self.session_control = SessionControlSubsystem(sc_config)
            await self.session_control.initialize()
            
            self.logger.info("Session Control Subsystem initialized")
            
        except Exception as e:
            self.logger.error(f"Failed to initialize Session Control: {e}")
            raise
    
    def _register_subsystems(self):
        """Register all subsystems for centralized management"""
        self.subsystems = {
            'session_control': self.session_control
        }
        
        self.logger.info(f"Registered {len(self.subsystems)} subsystems")
    
    async def _load_sync_state(self):
        """Load sync state from disk"""
        try:
            if os.path.exists(self.sync_state_file):
                with open(self.sync_state_file, 'r') as f:
                    self.sync_state = json.load(f)
                    if 'node_id' in self.sync_state:
                        self.node_id = self.sync_state['node_id']
        except FileNotFoundError:
            self.logger.info("No existing sync state found, starting fresh")
        except Exception as e:
            self.logger.error(f"Failed to load sync state: {e}")
    
    async def save_sync_state(self):
        """Save sync state to disk"""
        try:
            self.sync_state.update({
                'node_id': self.node_id,
                'last_save': datetime.now(timezone.utc).isoformat(),
                'sync_count': self.sync_state.get('sync_count', 0)
            })
            
            with open(self.sync_state_file, 'w') as f:
                json.dump(self.sync_state, f, indent=2)
                
        except Exception as e:
            self.logger.error(f"Failed to save sync state: {e}")
    
    async def start_sync_cycle(self, peers: List[str] = None, dry_run: bool = False) -> Dict[str, Any]:
        """Start a complete sync cycle"""
        start_time = time.time()
        result = {
            'status': 'started',
            'dry_run': dry_run,
            'start_time': datetime.now(timezone.utc).isoformat(),
            'peers_requested': peers or [],
            'peers_contacted': 0,
            'deltas_processed': 0,
            'conflicts_found': 0,
            'errors': []
        }
        
        try:
            self.logger.info(f"Starting sync cycle (dry_run={dry_run})")
            
            # Discover peers if none specified
            if not peers:
                peers = await self.sync_protocol.discover_peers()
            
            result['peers_contacted'] = len(peers)
            
            if not peers:
                self.logger.warning("No peers available for sync")
                result['status'] = 'no_peers'
                return result
            
            # Pull deltas from peers
            incoming_deltas = await self.sync_protocol.pull_from_peers()
            result['deltas_received'] = len(incoming_deltas)
            
            # Push our pending deltas
            if self.delta_engine:
                pending_deltas = await self.delta_engine.get_pending_deltas()
                if pending_deltas and not dry_run:
                    push_success = await self.sync_protocol.push_deltas(pending_deltas)
                    result['deltas_pushed'] = len(pending_deltas) if push_success else 0
                else:
                    result['deltas_pushed'] = 0
            
            # Process incoming deltas
            if incoming_deltas and not dry_run:
                applied, failed = await self.sync_protocol.verify_and_apply(incoming_deltas)
                result['deltas_applied'] = applied
                result['deltas_failed'] = failed
                result['deltas_processed'] = applied + failed
            else:
                result['deltas_processed'] = len(incoming_deltas)
                result['deltas_applied'] = 0
                result['deltas_failed'] = 0
            
            # Update sync state
            if not dry_run:
                self.sync_state['sync_count'] = self.sync_state.get('sync_count', 0) + 1
                self.sync_state['last_sync_time'] = datetime.now(timezone.utc).isoformat()
                await self.save_sync_state()
            
            result['status'] = 'success'
            result['changes_applied'] = not dry_run and (result['deltas_applied'] > 0 or result['deltas_pushed'] > 0)
            
        except Exception as e:
            self.logger.error(f"Sync cycle failed: {e}")
            result['status'] = 'failed'
            result['error'] = str(e)
            result['errors'].append(str(e))
        
        finally:
            result['duration_seconds'] = time.time() - start_time
            result['end_time'] = datetime.now(timezone.utc).isoformat()
        
        return result
    
    async def get_sync_status(self) -> Dict[str, Any]:
        """Get current sync status with subsystem information"""
        status = {
            'node_id': self.node_id,
            'last_sync_time': self.sync_state.get('last_sync_time', 'Never'),
            'sync_count': self.sync_state.get('sync_count', 0),
            'pending_conflicts': len(self.sync_state.get('pending_conflicts', [])),
            'checkpoint_count': self.sync_state.get('checkpoint_count', 0),
            'subsystems': {}
        }
        
        # Add protocol status if available
        if self.sync_protocol:
            protocol_status = await self.sync_protocol.get_protocol_status()
            status.update({
                'protocol_running': protocol_status['running'],
                'known_peers': protocol_status['total_known_peers'],
                'online_peers': protocol_status['online_peers'],
                'offline_queue_size': protocol_status['offline_queue_size']
            })
        
        # Add subsystem status
        for name, subsystem in self.subsystems.items():
            if subsystem:
                status['subsystems'][name] = subsystem.get_status()
        
        return status

    async def create_test_delta(self, user_id: str = None, operation: str = 'test') -> Dict[str, Any]:
        """Create a test delta for demonstration"""
        if not user_id:
            user_id = f"test_user_{int(time.time())}"
        
        if self.delta_engine and operation == 'user_state':
            return await self.delta_engine.create_user_state_delta(
                user_id, 'status', f'updated_at_{int(time.time())}'
            )
        else:
            return await self.delta_engine.create_manual_delta(
                user_id, operation, {'test_data': f'value_{int(time.time())}'}
            )

    async def start(self):
        """Start the coordinator and all subsystems"""
        if self.sync_protocol:
            # Protocol is already initialized, just ensure it's running
            pass
        
        # Start all subsystems
        for name, subsystem in self.subsystems.items():
            if subsystem and not subsystem.running:
                try:
                    await subsystem.start()
                    self.logger.info(f"Started subsystem: {name}")
                except Exception as e:
                    self.logger.error(f"Failed to start subsystem {name}: {e}")
    
    async def stop(self):
        """Stop the coordinator and all subsystems"""
        # Stop all subsystems
        for name, subsystem in self.subsystems.items():
            if subsystem and subsystem.running:
                try:
                    await subsystem.stop()
                    self.logger.info(f"Stopped subsystem: {name}")
                except Exception as e:
                    self.logger.error(f"Failed to stop subsystem {name}: {e}")
        
        if self.sync_protocol:
            await self.sync_protocol.shutdown()
    
    # Session Control Interface
    async def create_session(self, user_id: str, metadata: Dict = None) -> str:
        """Create a new user session through SC-SUB"""
        if not self.session_control or not self.session_control.running:
            raise RuntimeError("Session Control subsystem not available")
        
        return await self.session_control.create_session(user_id, metadata)
    
    async def get_session(self, session_id: str) -> Optional[Dict]:
        """Get session information through SC-SUB"""
        if not self.session_control or not self.session_control.running:
            return None
        
        return await self.session_control.get_session(session_id)
    
    async def destroy_session(self, session_id: str) -> bool:
        """Destroy a session through SC-SUB"""
        if not self.session_control or not self.session_control.running:
            return False
        
        return await self.session_control.destroy_session(session_id)
    
    def assign_user_role(self, user_id: str, role: str) -> bool:
        """Assign role to user through SC-SUB"""
        if not self.session_control or not self.session_control.running:
            return False
        
        return self.session_control.assign_role(user_id, role)
    
    def check_user_permission(self, user_id: str, permission: str) -> bool:
        """Check user permission through SC-SUB"""
        if not self.session_control or not self.session_control.running:
            return False
        
        return self.session_control.has_permission(user_id, permission)

