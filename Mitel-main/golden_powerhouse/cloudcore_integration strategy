# EVENT BUS INTEGRATION (ENHANCED FOR SC-SUB)
# ============================================================================

class SPEventBusIntegration:
    """Event Bus integration for SP-SUB + SC-SUB v5"""
    
    def __init__(self, sync_coordinator, event_bus=None):
        self.sync_coordinator = sync_coordinator
        self.event_bus = event_bus
        self.logger = logging.getLogger("SPEventIntegration")
        self.running = False
        
    async def initialize(self):
        """Initialize event integration"""
        if self.event_bus:
            await self._subscribe_to_events()
            self.running = True
            self.logger.info("SP + SC Event Bus integration initialized")
        else:
            self.logger.warning("No event bus provided - running without event integration")
    
    async def shutdown(self):
        """Shutdown event integration"""
        self.running = False
    
    async def _subscribe_to_events(self):
        """Subscribe to relevant Event Bus events"""
        try:
            # SP-SUB events
            await self.event_bus.subscribe('sync_request', self._on_sync_request)
            await self.event_bus.subscribe('file_changed', self._on_file_changed)
            
            # SC-SUB events
            await self.event_bus.subscribe('session_request', self._on_session_request)
            await self.event_bus.subscribe('user_login', self._on_user_login)
            await self.event_bus.subscribe('user_logout', self._on_user_logout)
            
        except Exception as e:
            self.logger.error(f"Failed to subscribe to events: {e}")
    
    async def _on_sync_request(self, event_data: Dict[str, Any]):
        """Handle sync request from event bus"""
        try:
            self.logger.info(f"Received sync request: {event_data}")
            
            peers = event_data.get('peers')
            dry_run = event_data.get('dry_run', False)
            
            result = await self.sync_coordinator.start_sync_cycle(
                peers=peers, 
                dry_run=dry_run
            )
            
            if self.event_bus and hasattr(self.event_bus, 'publish'):
                await self.event_bus.publish('sync_completed', {
                    'request_id': event_data.get('request_id'),
                    'result': result,
                    'timestamp': datetime.now(timezone.utc).isoformat()
                })
            
        except Exception as e:
            self.logger.error(f"Error handling sync request: {e}")
    
    async def _on_file_changed(self, event_data: Dict[str, Any]):
        """Handle file change event"""
        try:
            file_path = event_data.get('path')
            if file_path and self.sync_coordinator.delta_engine:
                delta = await self.sync_coordinator.delta_engine.create_manual_delta(
                    file_path, 'file_change', event_data
                )
                # Delta is automatically queued in create_manual_delta
                
        except Exception as e:
            self.logger.error(f"Error handling file change: {e}")
    
    async def _on_session_request(self, event_data: Dict[str, Any]):
        """Handle session-related requests"""
        try:
            request_type = event_data.get('type')
            
            if request_type == 'create_session':
                user_id = event_data.get('user_id')
                metadata = event_data.get('metadata', {})
                
                if user_id:
                    session_id = await self.sync_coordinator.create_session(user_id, metadata)
                    
                    if self.event_bus:
                        await self.event_bus.publish('session_created', {
                            'session_id': session_id,
                            'user_id': user_id,
                            'request_id': event_data.get('request_id'),
                            'timestamp': datetime.now(timezone.utc).isoformat()
                        })
            
            elif request_type == 'destroy_session':
                session_id = event_data.get('session_id')
                
                if session_id:
                    success = await self.sync_coordinator.destroy_session(session_id)
                    
                    if self.event_bus:
                        await self.event_bus.publish('session_destroyed', {
                            'session_id': session_id,
                            'success': success,
                            'request_id': event_data.get('request_id'),
                            'timestamp': datetime.now(timezone.utc).isoformat()
                        })
                
        except Exception as e:
            self.logger.error(f"Error handling session request: {e}")
    
    async def _on_user_login(self, event_data: Dict[str, Any]):
        """Handle user login event"""
        try:
            user_id = event_data.get('user_id')
            
            if user_id:
                # Create session for logged in user
                metadata = {
                    'login_time': datetime.now().isoformat(),
                    'login_method': event_data.get('method', 'unknown'),
                    'ip_address': event_data.get('ip_address')
                }
                
                session_id = await self.sync_coordinator.create_session(user_id, metadata)
                
                # Assign default user role if not already assigned
                self.sync_coordinator.assign_user_role(user_id, 'user')
                
                self.logger.info(f"Created session {session_id} for user login: {user_id}")
                
        except Exception as e:
            self.logger.error(f"Error handling user login: {e}")
    
    async def _on_user_logout(self, event_data: Dict[str, Any]):
        """Handle user logout event"""
        try:
            user_id = event_data.get('user_id')
            session_id = event_data.get('session_id')
            
            if session_id:
                # Destroy specific session
                await self.sync_coordinator.destroy_session(session_id)
                self.logger.info(f"Destroyed session {session_id} for user logout")
            elif user_id:
                # Destroy all sessions for user
                if self.sync_coordinator.session_control:
                    user_sessions = self.sync_coordinator.session_control.session_manager.get_user_sessions(user_id)
                    for sess_id in user_sessions:
                        await self.sync_coordinator.destroy_session(sess_id)
                    self.logger.info(f"Destroyed {len(user_sessions)} sessions for user {user_id}")
                
        except Exception as e:
            self.logger.error(f"Error handling user logout: {e}")

