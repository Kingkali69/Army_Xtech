# ENHANCED GHOST SYNC PROTOCOL (Main Entry Point)
# ============================================================================

class EnhancedGhostSyncProtocol:
    """Enhanced Ghost Sync Protocol v5 - Main subsystem interface with SC-SUB integration"""
    
    def __init__(self, config: Dict[str, Any], node_id: str):
        self.config = config
        self.node_id = node_id
        self.logger = logging.getLogger("EnhancedGhostSyncProtocol")
        
        # Core coordinator
        self.coordinator = None
        self.event_integration = None
        self.running = False
    
    async def initialize(self):
        """Initialize the enhanced sync protocol with all subsystems"""
        try:
            # Create sync coordinator
            config_file = self.config.get('config_file', 'config/sp_config.yaml')
            self.coordinator = SyncCoordinator(config_file)
            self.coordinator.node_id = self.node_id
            
            # Initialize coordinator (includes all subsystems)
            await self.coordinator.initialize()
            
            # Initialize event integration if event bus is available
            event_bus = self.config.get('event_bus')
            if event_bus:
                self.event_integration = SPEventBusIntegration(self.coordinator, event_bus)
                await self.event_integration.initialize()
            
            self.running = True
            self.logger.info("Enhanced Ghost Sync Protocol v5 with SC-SUB initialized")
            
        except Exception as e:
            self.logger.error(f"Enhanced protocol initialization failed: {e}")
            raise
    
    async def start(self):
        """Start the sync protocol and all subsystems"""
        if self.coordinator:
            await self.coordinator.start()
    
    async def stop(self):
        """Stop the sync protocol and all subsystems"""
        if self.event_integration:
            await self.event_integration.shutdown()
        
        if self.coordinator:
            await self.coordinator.stop()
        
        self.running = False
    
    async def sync(self, peers: List[str] = None, dry_run: bool = False) -> Dict[str, Any]:
        """Perform sync operation"""
        if not self.coordinator:
            return {'error': 'Coordinator not initialized'}
        
        return await self.coordinator.start_sync_cycle(peers, dry_run)
    
    async def get_status(self) -> Dict[str, Any]:
        """Get sync status including all subsystems"""
        if not self.coordinator:
            return {'error': 'Coordinator not initialized'}
        
        return await self.coordinator.get_sync_status()
    
    async def create_test_delta(self, user_id: str = None) -> Dict[str, Any]:
        """Create test delta for demonstration"""
        if not self.coordinator:
            return {'error': 'Coordinator not initialized'}
        
        return await self.coordinator.create_test_delta(user_id)
    
    # Session Control Interface
    async def create_session(self, user_id: str, metadata: Dict = None) -> str:
        """Create user session through SC-SUB"""
        if not self.coordinator:
            raise RuntimeError('Coordinator not initialized')
        
        return await self.coordinator.create_session(user_id, metadata)
    
    async def get_session(self, session_id: str) -> Optional[Dict]:
        """Get session information through SC-SUB"""
        if not self.coordinator:
            return None
        
        return await self.coordinator.get_session(session_id)
    
    async def destroy_session(self, session_id: str) -> bool:
        """Destroy session through SC-SUB"""
        if not self.coordinator:
            return False
        
        return await self.coordinator.destroy_session(session_id)
    
    def assign_user_role(self, user_id: str, role: str) -> bool:
        """Assign role to user through SC-SUB"""
        if not self.coordinator:
            return False
        
        return self.coordinator.assign_user_role(user_id, role)
    
    def check_user_permission(self, user_id: str, permission: str) -> bool:
        """Check user permission through SC-SUB"""
        if not self.coordinator:
            return False
        
        return self.coordinator.check_user_permission(user_id, permission)
    
    async def health_check(self) -> Dict[str, Any]:
        """Perform comprehensive health check"""
        if not self.running or not self.coordinator:
            return {'status': 'unhealthy', 'reason': 'Not running or initialized'}
        
        health_status = {
            'status': 'healthy',
            'timestamp': datetime.now(timezone.utc).isoformat(),
            'components': {}
        }
        
        # Check all subsystems
        for name, subsystem in self.coordinator.subsystems.items():
            if subsystem:
                try:
                    is_healthy = await subsystem.health_check()
                    health_status['components'][name] = {
                        'status': 'healthy' if is_healthy else 'unhealthy',
                        'details': subsystem.get_status()
                    }
                except Exception as e:
                    health_status['components'][name] = {
                        'status': 'error',
                        'error': str(e)
                    }
        
        # Check protocol
        if self.coordinator.sync_protocol:
            protocol_status = await self.coordinator.sync_protocol.get_protocol_status()
            health_status['components']['sync_protocol'] = {
                'status': 'healthy' if protocol_status['running'] else 'unhealthy',
                'details': protocol_status
            }
        
        # Overall health determination
        component_statuses = [comp.get('status') for comp in health_status['components'].values()]
        if any(status == 'error' for status in component_statuses):
            health_status['status'] = 'degraded'
        elif any(status == 'unhealthy' for status in component_statuses):
            health_status['status'] = 'degraded'
        
        return health_status

