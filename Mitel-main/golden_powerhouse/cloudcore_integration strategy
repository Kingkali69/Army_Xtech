class GhostSyncProtocol:
    """Enhanced P2P/mesh sync protocol with offline-first design"""
    
    def __init__(self, config: Dict[str, Any], integrity_verifier=None, delta_engine=None):
        self.config = config
        self.mode = config.get('mode', 'mesh')
        self.discovery_enabled = config.get('discovery_enabled', True)
        
        self.logger = logging.getLogger("GhostSyncProtocol")
        
        # Component dependencies
        self.integrity_verifier = integrity_verifier
        self.delta_engine = delta_engine
        
        # Peer management
        self.known_peers: Dict[str, PeerInfo] = {}
        self.active_connections: Set[str] = set()
        
        # Protocol settings
        self.listen_port = config.get('listen_port', 8443)
        self.discovery_port = config.get('discovery_port', 8444)
        self.timeout_seconds = config.get('timeout_seconds', 10)
        self.max_connections = config.get('max_connections', 20)
        
        # Node identity
        self.node_id = str(uuid.uuid4())
        
        # Servers
        self.server = None
        self.discovery_socket = None
        self.running = False
        
        # Offline queue for when no peers available
        self.offline_queue = []
        
    async def initialize(self, node_id: str = None):
        """Initialize protocol services"""
        if node_id:
            self.node_id = node_id
            
        try:
            if self.mode in ['mesh', 'p2p']:
                await self._start_server()
                
            if self.discovery_enabled:
                await self._start_discovery()
                
            self.running = True
            asyncio.create_task(self._maintenance_loop())
            
            self.logger.info(f"Ghost sync protocol v5 initialized in {self.mode} mode")
            
        except Exception as e:
            self.logger.error(f"Protocol initialization failed: {e}")
            # Continue in offline mode
            self.running = True
            asyncio.create_task(self._maintenance_loop())
    
    async def shutdown(self):
        """Shutdown protocol services"""
        self.running = False
        
        try:
            if self.server:
                self.server.close()
                await self.server.wait_closed()
                
            if self.discovery_socket:
                self.discovery_socket.close()
                
            for peer_id in list(self.active_connections):
                await self._disconnect_peer(peer_id)
                
            self.logger.info("Ghost sync protocol shut down")
            
        except Exception as e:
            self.logger.error(f"Protocol shutdown error: {e}")
    
    async def _start_server(self):
        """Start server for incoming sync connections"""
        try:
            self.server = await asyncio.start_server(
                self._handle_peer_connection,
                '0.0.0.0',
                self.listen_port
            )
            
            self.logger.info(f"Sync server listening on port {self.listen_port}")
            
        except Exception as e:
            self.logger.warning(f"Failed to start server: {e} - continuing in offline mode")
    
    async def _start_discovery(self):
        """Start UDP peer discovery"""
        try:
            self.discovery_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            self.discovery_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            self.discovery_socket.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
            self.discovery_socket.bind(('', self.discovery_port))
            self.discovery_socket.setblocking(False)
            
            asyncio.create_task(self._discovery_listener())
            asyncio.create_task(self._periodic_discovery())
            
            self.logger.info(f"Discovery service started on port {self.discovery_port}")
            
        except Exception as e:
            self.logger.warning(f"Failed to start discovery: {e}")
    
    async def _maintenance_loop(self):
        """Background maintenance tasks"""
        while self.running:
            try:
                # Clean up stale peers
                current_time = datetime.now(timezone.utc)
                stale_peers = []
                
                for peer_id, peer in self.known_peers.items():
                    if (current_time - peer.last_seen).total_seconds() > 300:  # 5 minutes
                        stale_peers.append(peer_id)
                
                for peer_id in stale_peers:
                    del self.known_peers[peer_id]
                    self.active_connections.discard(peer_id)
                
                # Process offline queue if we have peers
                if self.offline_queue and self.known_peers:
                    await self._process_offline_queue()
                
                await asyncio.sleep(60)  # Run every minute
                
            except Exception as e:
                self.logger.error(f"Maintenance loop error: {e}")
                await asyncio.sleep(60)
    
    async def _process_offline_queue(self):
        """Process queued operations from offline mode"""
        try:
            while self.offline_queue and len(self.offline_queue) > 0:
                operation = self.offline_queue.pop(0)
                await self._execute_queued_operation(operation)
                
        except Exception as e:
            self.logger.error(f"Offline queue processing error: {e}")
    
    async def _execute_queued_operation(self, operation: Dict[str, Any]):
        """Execute a queued sync operation"""
        op_type = operation.get('type')
        
        if op_type == 'sync_deltas':
            deltas = operation.get('deltas', [])
            await self._sync_deltas_to_peers(deltas)
    
    async def _discovery_listener(self):
        """Listen for discovery broadcasts"""
        while self.running:
            try:
                loop = asyncio.get_event_loop()
                data, addr = await loop.sock_recvfrom(self.discovery_socket, 1024)
                await self._process_discovery_message(data, addr)
            except Exception:
                await asyncio.sleep(0.1)
    
    async def _periodic_discovery(self):
        """Periodically broadcast discovery messages"""
        while self.running:
            try:
                await self._broadcast_discovery()
                await asyncio.sleep(30)
            except Exception:
                await asyncio.sleep(30)
    
    async def _broadcast_discovery(self):
        """Broadcast discovery message"""
        try:
            message = {
                'type': 'ghost_discovery',
                'node_id': self.node_id,
                'port': self.listen_port,
                'capabilities': ['sync', 'crdt', 'offline'],
                'timestamp': time.time()
            }
            
            data = json.dumps(message).encode('utf-8')
            self.discovery_socket.sendto(data, ('<broadcast>', self.discovery_port))
            
        except Exception:
            pass
    
    async def _process_discovery_message(self, data: bytes, addr: Tuple[str, int]):
        """Process incoming discovery message"""
        try:
            message = json.loads(data.decode('utf-8'))
            
            if message.get('type') == 'ghost_discovery':
                node_id = message.get('node_id')
                if node_id and node_id != self.node_id:
                    peer = PeerInfo(
                        node_id,
                        addr[0],
                        message.get('port', self.listen_port),
                        message.get('capabilities', [])
                    )
                    self.known_peers[node_id] = peer
                    
        except Exception:
            pass
    
    async def _handle_peer_connection(self, reader: asyncio.StreamReader, 
                                     writer: asyncio.StreamWriter):
        """Handle incoming peer connection"""
        try:
            peer_info = await self._peer_handshake(reader, writer)
            
            if peer_info:
                self.known_peers[peer_info.node_id] = peer_info
                self.active_connections.add(peer_info.node_id)
                await self._handle_sync_session(reader, writer, peer_info)
                
        except Exception as e:
            self.logger.error(f"Peer connection error: {e}")
        finally:
            try:
                writer.close()
                await writer.wait_closed()
            except Exception:
                pass
    
    async def _peer_handshake(self, reader: asyncio.StreamReader, 
                             writer: asyncio.StreamWriter) -> Optional[PeerInfo]:
        """Perform handshake with peer"""
        try:
            handshake = {
                'protocol': 'ghost_sync',
                'version': '5.0',
                'node_id': self.node_id,
                'capabilities': ['sync', 'crdt', 'offline'],
                'timestamp': time.time()
            }
            
            await self._send_json(writer, handshake)
            peer_handshake = await self._receive_json(reader)
            
            if peer_handshake and peer_handshake.get('protocol') == 'ghost_sync':
                return PeerInfo(
                    peer_handshake['node_id'],
                    writer.get_extra_info('peername')[0],
                    writer.get_extra_info('peername')[1],
                    peer_handshake.get('capabilities', [])
                )
                
        except Exception:
            pass
            
        return None
    
    async def _send_json(self, writer: asyncio.StreamWriter, data: Dict[str, Any]):
        """Send JSON message with length prefix"""
        try:
            json_data = json.dumps(data, default=str)
            message_bytes = json_data.encode('utf-8')
            
            length = len(message_bytes)
            writer.write(struct.pack('>I', length))
            writer.write(message_bytes)
            
            await writer.drain()
            
        except Exception as e:
            raise
    
    async def _receive_json(self, reader: asyncio.StreamReader) -> Optional[Dict[str, Any]]:
        """Receive JSON message with length prefix"""
        try:
            length_data = await asyncio.wait_for(reader.read(4), timeout=self.timeout_seconds)
            if len(length_data) != 4:
                return None
            
            length = struct.unpack('>I', length_data)[0]
            if length > 10 * 1024 * 1024:  # 10MB limit
                return None
            
            message_data = await asyncio.wait_for(reader.read(length), timeout=self.timeout_seconds)
            if len(message_data) != length:
                return None
            
            return json.loads(message_data.decode('utf-8'))
            
        except Exception:
            return None
    
    async def _handle_sync_session(self, reader: asyncio.StreamReader,
                                  writer: asyncio.StreamWriter, peer: PeerInfo):
        """Handle sync session with peer"""
        try:
            while True:
                message = await self._receive_json(reader)
                if not message:
                    break
                
                response = await self._process_sync_message(message, peer)
                if response:
                    await self._send_json(writer, response)
                    
        except Exception:
            pass
        finally:
            self.active_connections.discard(peer.node_id)
    
    async def _process_sync_message(self, message: Dict[str, Any], 
                                   peer: PeerInfo) -> Optional[Dict[str, Any]]:
        """Process sync message from peer"""
        msg_type = message.get('type')
        
        if msg_type == 'push_deltas':
            return await self._handle_push_deltas(message, peer)
        elif msg_type == 'pull_request':
            return await self._handle_pull_request(message, peer)
        
        return None
    
    async def _handle_push_deltas(self, message: Dict[str, Any], 
                                 peer: PeerInfo) -> Dict[str, Any]:
        """Handle incoming delta push"""
        deltas = message.get('deltas', [])
        
        try:
            applied_count, failed_count = await self.verify_and_apply(deltas)
            
            return {
                'type': 'push_response',
                'status': 'success',
                'applied': applied_count,
                'failed': failed_count,
                'timestamp': time.time()
            }
            
        except Exception as e:
            return {
                'type': 'push_response',
                'status': 'error',
                'error': str(e),
                'timestamp': time.time()
            }
    
    async def _handle_pull_request(self, message: Dict[str, Any], 
                                  peer: PeerInfo) -> Dict[str, Any]:
        """Handle pull request from peer"""
        try:
            if self.delta_engine:
                pending_deltas = await self.delta_engine.get_pending_deltas()
            else:
                pending_deltas = []
            
            return {
                'type': 'pull_response',
                'deltas': pending_deltas,
                'timestamp': time.time()
            }
            
        except Exception as e:
            return {
                'type': 'pull_response',
                'status': 'error',
                'error': str(e),
                'timestamp': time.time()
            }
    
    async def verify_and_apply(self, deltas: List[Dict[str, Any]]) -> Tuple[int, int]:
        """Verify deltas and apply with DeltaEngine"""
        applied_count = 0
        failed_count = 0
        
        for delta in deltas:
            try:
                if self.delta_engine:
                    success = await self.delta_engine.apply_delta(delta)
                    if success:
                        applied_count += 1
                    else:
                        failed_count += 1
                else:
                    applied_count += 1
                    
            except Exception:
                failed_count += 1
        
        return applied_count, failed_count
    
    async def discover_peers(self) -> List[str]:
        """Discover available peers"""
        if not self.running:
            return []
        
        if self.discovery_enabled and self.discovery_socket:
            await self._broadcast_discovery()
            await asyncio.sleep(2)  # Wait for responses
        
        online_peers = [peer_id for peer_id, peer in self.known_peers.items() if peer.is_online]
        return online_peers
    
    async def push_deltas(self, deltas: List[Dict[str, Any]]) -> bool:
        """Push deltas to available peers"""
        if not deltas:
            return True
        
        online_peers = [p for p in self.known_peers.values() if p.is_online]
        
        if not online_peers:
            # Queue for offline mode
            self.offline_queue.append({
                'type': 'sync_deltas',
                'deltas': deltas,
                'timestamp': time.time()
            })
            self.logger.info(f"Queued {len(deltas)} deltas for offline sync")
            return True
        
        return await self._sync_deltas_to_peers(deltas)
    
    async def _sync_deltas_to_peers(self, deltas: List[Dict[str, Any]]) -> bool:
        """Sync deltas to connected peers"""
        success_count = 0
        
        for peer in [p for p in self.known_peers.values() if p.is_online]:
            try:
                success = await self._push_to_peer(peer, deltas)
                if success:
                    success_count += 1
                    
            except Exception:
                peer.connection_failures += 1
                if peer.connection_failures > 3:
                    peer.is_online = False
        
        return success_count > 0
    
    async def _push_to_peer(self, peer: PeerInfo, deltas: List[Dict[str, Any]]) -> bool:
        """Push deltas to a specific peer"""
        try:
            reader, writer = await asyncio.wait_for(
                asyncio.open_connection(peer.address, peer.port),
                timeout=self.timeout_seconds
            )
            
            handshake_peer = await self._peer_handshake(reader, writer)
            if not handshake_peer:
                return False
            
            push_message = {
                'type': 'push_deltas',
                'deltas': deltas,
                'from_node': self.node_id,
                'timestamp': time.time()
            }
            
            await self._send_json(writer, push_message)
            response = await self._receive_json(reader)
            
            writer.close()
            await writer.wait_closed()
            
            if response and response.get('status') == 'success':
                peer.last_seen = datetime.now(timezone.utc)
                peer.connection_failures = 0
                return True
            
        except Exception:
            pass
            
        return False
    
    async def pull_from_peers(self) -> List[Dict[str, Any]]:
        """Pull deltas from available peers"""
        all_deltas = []
        
        for peer in [p for p in self.known_peers.values() if p.is_online]:
            try:
                deltas = await self._pull_from_peer(peer)
                all_deltas.extend(deltas)
            except Exception:
                pass
        
        return all_deltas
    
    async def _pull_from_peer(self, peer: PeerInfo) -> List[Dict[str, Any]]:
        """Pull deltas from a specific peer"""
        try:
            reader, writer = await asyncio.wait_for(
                asyncio.open_connection(peer.address, peer.port),
                timeout=self.timeout_seconds
            )
            
            handshake_peer = await self._peer_handshake(reader, writer)
            if not handshake_peer:
                return []
            
            pull_message = {
                'type': 'pull_request',
                'from_node': self.node_id,
                'timestamp': time.time()
            }
            
            await self._send_json(writer, pull_message)
            response = await self._receive_json(reader)
            
            writer.close()
            await writer.wait_closed()
            
            if response and 'deltas' in response:
                return response['deltas']
            
        except Exception:
            pass
            
        return []
    
    async def _disconnect_peer(self, peer_id: str):
        """Disconnect from a peer"""
        try:
            self.active_connections.discard(peer_id)
            if peer_id in self.known_peers:
                self.known_peers[peer_id].is_online = False
        except Exception:
            pass
    
    async def get_protocol_status(self) -> Dict[str, Any]:
        """Get detailed protocol status"""
        online_peers = [p for p in self.known_peers.values() if p.is_online]
        
        return {
            'node_id': self.node_id,
            'mode': self.mode,
            'running': self.running,
            'listening_port': self.listen_port,
            'discovery_enabled': self.discovery_enabled,
            'total_known_peers': len(self.known_peers),
            'online_peers': len(online_peers),
            'active_connections': len(self.active_connections),
            'offline_queue_size': len(self.offline_queue),
            'peers': [p.to_dict() for p in online_peers[:5]]
        }

    async def add_manual_peer(self, node_id: str, address: str, port: int):
        """Manually add a peer"""
        peer = PeerInfo(node_id, address, port, ['sync'])
        self.known_peers[node_id] = peer

