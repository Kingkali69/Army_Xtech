        # Check network indicators
        if 'network' in raw_event:
            dest_ip = raw_event['network'].get('dest_ip')
            if dest_ip and dest_ip in self.ioc_database:
                ioc_matches.append(self.ioc_database[dest_ip])
        
        # Check file hashes
        if 'file' in raw_event:
            file_hash = raw_event['file'].get('hash')
            if file_hash and file_hash in self.ioc_database:
                ioc_matches.append(self.ioc_database[file_hash])
        
        # Check process hashes
        if 'process' in raw_event:
            process_hash = raw_event['process'].get('hash')
            if process_hash and process_hash in self.ioc_database:
                ioc_matches.append(self.ioc_database[process_hash])
        
        # Add enrichment data
        enriched['enrichment'] = {
            'threat_intel': {
                'ioc_matches': ioc_matches,
                'threat_score': max([ioc.get('threat_score', 0) for ioc in ioc_matches], default=0)
            },
            'asset_context': await self._get_asset_context(raw_event.get('host', {})),
            'user_context': await self._get_user_context(raw_event.get('process', {}).get('user')),
            'timestamp_processed': datetime.now().isoformat()
        }
        
        return enriched
    
    async def _detect_threat_indicators(self, event: Dict[str, any]) -> List[ThreatIndicator]:
        """Detect threat indicators using signature-based detection"""
        indicators = []
        raw_event = event.get('raw_event', {})
        
        # Network-based indicators
        if 'network' in raw_event:
            dest_ip = raw_event['network'].get('dest_ip')
            if dest_ip:
                # Check against known malicious IPs
                if await self._is_malicious_ip(dest_ip):
                    indicators.append(ThreatIndicator(
                        ioc_type='ip_address',
                        value=dest_ip,
                        confidence=0.85,
                        threat_types=['command_and_control'],
                        first_seen=datetime.now(),
                        last_seen=datetime.now(),
                        source='internal_intelligence'
                    ))
        
        # Process-based indicators
        if 'process' in raw_event:
            process_name = raw_event['process'].get('name', '').lower()
            command_line = raw_event['process'].get('command_line', '').lower()
            
            # Suspicious process names
            suspicious_patterns = ['mimikatz', 'psexec', 'powershell.exe -enc', 'cmd.exe /c']
            for pattern in suspicious_patterns:
                if pattern in process_name or pattern in command_line:
                    indicators.append(ThreatIndicator(
                        ioc_type='process_pattern',
                        value=pattern,
                        confidence=0.75,
                        threat_types=['credential_access', 'lateral_movement'],
                        first_seen=datetime.now(),
                        last_seen=datetime.now(),
                        source='signature_detection'
                    ))
        
        return indicators
    
    async def _calculate_anomaly_score(self, event: Dict[str, any]) -> float:
        """Calculate anomaly score using behavioral analysis"""
        raw_event = event.get('raw_event', {})
        hostname = raw_event.get('host', {}).get('hostname', 'unknown')
        
        # Get baseline behavior for this host
        baseline = self.behavioral_baselines.get(hostname, {})
        anomaly_score = 0.0
        
        # Check process execution anomalies
        if 'process' in raw_event:
            process_name = raw_event['process'].get('name')
            normal_processes = baseline.get('normal_processes', set())
            
            if process_name not in normal_processes:
                anomaly_score += 0.3
        
        # Check network connection anomalies
        if 'network' in raw_event:
            dest_ip = raw_event['network'].get('dest_ip')
            normal_destinations = baseline.get('normal_destinations', set())
            
            if dest_ip not in normal_destinations:
                anomaly_score += 0.4
        
        # Check time-based anomalies
        current_hour = datetime.now().hour
        normal_activity_hours = baseline.get('normal_activity_hours', set(range(6, 23)))
        
        if current_hour not in normal_activity_hours:
            anomaly_score += 0.2
        
        return min(anomaly_score, 1.0)
    
