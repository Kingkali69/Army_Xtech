    async def _calculate_risk_score(self, indicators: List[ThreatIndicator], 
                                  anomaly_score: float, correlation_results: Dict[str, any],
                                  event: Dict[str, any]) -> float:
        """Calculate overall risk score for the event"""
        risk_score = 0.0
        
        # Indicator-based scoring
        if indicators:
            indicator_score = sum(indicator.confidence for indicator in indicators) * 20
            risk_score += min(indicator_score, 40.0)
        
        # Anomaly-based scoring
        risk_score += anomaly_score * 30
        
        # Correlation-based scoring
        risk_score += correlation_results.get('attack_chain_score', 0) * 20
        
        # Asset criticality multiplier
        asset_criticality = event.get('enrichment', {}).get('asset_context', {}).get('criticality', 'medium')
        criticality_multipliers = {'low': 1.0, 'medium': 1.2, 'high': 1.5, 'critical': 2.0}
        risk_score *= criticality_multipliers.get(asset_criticality, 1.0)
        
        return min(risk_score, 100.0)
    
    def _determine_threat_level(self, risk_score: float) -> ThreatLevel:
        """Map risk score to threat level"""
        if risk_score >= 80:
            return ThreatLevel.CRITICAL
        elif risk_score >= 60:
            return ThreatLevel.HIGH
        elif risk_score >= 40:
            return ThreatLevel.MEDIUM
        else:
            return ThreatLevel.LOW
    
