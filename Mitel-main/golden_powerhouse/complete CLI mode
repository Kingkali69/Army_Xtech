import argparse
import asyncio
import json
import sys
import logging
from pathlib import Path
from typing import Dict, Any, Optional
import yaml
from datetime import datetime

from .sync_coordinator import SyncCoordinator
from .merkle_tree_comparer import MerkleTreeComparer
from .delta_engine import DeltaEngine
from .integrity_verifier import IntegrityVerifier
from .ghost_sync_protocol import GhostSyncProtocol

class SPCLI:
    """Command-line interface for SP-SUB operations"""
    
    def __init__(self):
        self.logger = self._setup_logging()
        self.coordinator = None
        
    def _setup_logging(self) -> logging.Logger:
        """Set up logging configuration"""
        logging.basicConfig(
            level=logging.INFO,
            format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
        )
        return logging.getLogger("SP-CLI")
    
    async def run(self, args: argparse.Namespace):
        """Main CLI entry point"""
        try:
            command = args.command
            
            if command == 'sync':
                await self._cmd_sync(args)
            elif command == 'status':
                await self._cmd_status(args)
            elif command == 'tree':
                await self._cmd_tree(args)
            elif command == 'verify':
                await self._cmd_verify(args)
            elif command == 'peers':
                await self._cmd_peers(args)
            elif command == 'conflicts':
                await self._cmd_conflicts(args)
            elif command == 'config':
                await self._cmd_config(args)
            elif command == 'diagnostics':
                await self._cmd_diagnostics(args)
            else:
                self.logger.error(f"Unknown command: {command}")
                return 1
                
            return 0
            
        except Exception as e:
            self.logger.error(f"Command failed: {e}")
            return 1
    
    async def _get_coordinator(self, config_path: Optional[str] = None) -> SyncCoordinator:
        """Get initialized sync coordinator"""
        if not self.coordinator:
            config_file = config_path or "sp_sub_config.yaml"
            self.coordinator = SyncCoordinator(config_file)
            await self.coordinator.initialize()
        return self.coordinator
    
    async def _cmd_sync(self, args: argparse.Namespace):
        """Execute sync command"""
        coordinator = await self._get_coordinator(args.config)
        
        peers = args.peers.split(',') if args.peers else None
        dry_run = args.dry_run
        
        self.logger.info(f"Starting sync (dry_run={dry_run})")
        
        result = await coordinator.start_sync_cycle(peers=peers, dry_run=dry_run)
        
        if args.json:
            print(json.dumps(result, indent=2))
        else:
            self._print_sync_result(result)
    
    def _print_sync_result(self, result: Dict[str, Any]):
        """Print human-readable sync result"""
        status = result.get('status', 'unknown')
        print(f"Sync Status: {status.upper()}")
        
        if status == 'success':
            print(f"Duration: {result.get('duration_seconds', 0):.1f} seconds")
            print(f"Peers contacted: {result.get('peers_contacted', 0)}")
            print(f"Deltas processed: {result.get('deltas_processed', 0)}")
            print(f"Conflicts found: {result.get('conflicts_found', 0)}")
            
            if result.get('dry_run'):
                print("DRY RUN - No changes applied")
            elif result.get('changes_applied'):
                print("Changes applied successfully")
            else:
                print("No changes applied")
                
        elif status == 'failed':
            print(f"Error: {result.get('error', 'Unknown error')}")
    
    async def _cmd_status(self, args: argparse.Namespace):
        """Show sync status"""
        coordinator = await self._get_coordinator(args.config)
        status = await coordinator.get_sync_status()
        
        if args.json:
            print(json.dumps(status, indent=2))
        else:
            self._print_status(status)
    
    def _print_status(self, status: Dict[str, Any]):
        """Print human-readable status"""
        print("SP-SUB Status:")
        print(f"  Node ID: {status.get('node_id', 'unknown')}")
        print(f"  Sync in progress: {status.get('sync_in_progress', False)}")
        print(f"  Last sync: {status.get('last_sync_time', 'Never')}")
        print(f"  Pending conflicts: {status.get('pending_conflicts', 0)}")
        print(f"  Checkpoints: {status.get('checkpoint_count', 0)}")
        
        version_vector = status.get('version_vector', {})
        if version_vector:
            print("  Version vector:")
            for node, version in version_vector.items():
                print(f"    {node}: {version}")
    
    async def _cmd_tree(self, args: argparse.Namespace):
        """Tree operations"""
        if args.tree_action == 'build':
            await self._tree_build(args)
        elif args.tree_action == 'compare':
            await self._tree_compare(args)
        elif args.tree_action == 'show':
            await self._tree_show(args)
    
    async def _tree_build(self, args: argparse.Namespace):
        """Build Merkle tree"""
        config = {}
        if args.config:
            try:
                with open(args.config, 'r') as f:
                    full_config = yaml.safe_load(f)
                    config = full_config.get('merkle', {})
            except Exception as e:
                self.logger.warning(f"Failed to load config: {e}")
        
        comparer = MerkleTreeComparer(config)
        tree = await comparer.build_local_tree(args.path or ".")
        
        if args.json:
            print(json.dumps(tree, indent=2))
        else:
            print(f"Tree built for path: {args.path or '.'}")
            print(f"Root hash: {tree.get('root_hash', 'N/A')}")
            print(f"Total files: {tree.get('metadata', {}).get('total_files', 0)}")
    
    async def _tree_compare(self, args: argparse.Namespace):
        """Compare trees"""
        if not args.tree1 or not args.tree2:
            print("Error: Both --tree1 and --tree2 are required for comparison")
            return
        
        try:
            with open(args.tree1, 'r') as f:
                tree1 = json.load(f)
            with open(args.tree2, 'r') as f:
                tree2 = json.load(f)
            
            config = {}
            comparer = MerkleTreeComparer(config)
            diff = await comparer.compare_trees(tree1, tree2)
            
            if args.json:
                print(json.dumps(diff, indent=2))
            else:
                self._print_tree_diff(diff)
                
        except Exception as e:
            self.logger.error(f"Tree comparison failed: {e}")
    
    def _print_tree_diff(self, diff: Dict[str, Any]):
        """Print tree comparison results"""
        if diff.get('identical'):
            print("Trees are identical")
        else:
            summary = diff.get('summary', {})
            print(f"Tree differences found:")
            print(f"  Total differences: {summary.get('total_differences', 0)}")
            print(f"  Local only: {summary.get('local_only_count', 0)}")
            print(f"  Remote only: {summary.get('remote_only_count', 0)}")
            print(f"  Modified: {summary.get('modified_count', 0)}")
    
    async def _tree_show(self, args: argparse.Namespace):
        """Show tree structure"""
        tree_file = args.tree_file or "merkle_tree.json"
        try:
            with open(tree_file, 'r') as f:
                tree = json.load(f)
            
            print(f"Merkle Tree: {tree_file}")
            print(f"Root Hash: {tree.get('root_hash', 'N/A')}")
            
            metadata = tree.get('metadata', {})
            print(f"Files: {metadata.get('total_files', 0)}")
            print(f"Algorithm: {metadata.get('algorithm', 'N/A')}")
            
        except Exception as e:
            self.logger.error(f"Failed to show tree: {e}")
    
    async def _cmd_verify(self, args: argparse.Namespace):
        """Verify delta integrity"""
        if not args.delta_file:
            print("Error: --delta-file is required")
            return
        
        try:
            with open(args.delta_file, 'r') as f:
                deltas = json.load(f)
            
            if not isinstance(deltas, list):
                deltas = [deltas]
            
            config = {}
            verifier = IntegrityVerifier(config)
            
            if len(deltas) == 1:
                result = await verifier.verify_delta(deltas[0])
            else:
                result = await verifier.batch_verify_deltas(deltas)
            
            if args.json:
                print(json.dumps(result, indent=2))
            else:
                self._print_verification_result(result)
                
        except Exception as e:
            self.logger.error(f"Verification failed: {e}")
    
    def _print_verification_result(self, result: Dict[str, Any]):
        """Print verification results"""
        if 'total' in result:  # Batch result
            print(f"Batch Verification Results:")
            print(f"  Total deltas: {result.get('total', 0)}")
            print(f"  Valid: {result.get('valid', 0)}")
            print(f"  Invalid: {result.get('invalid', 0)}")
            print(f"  All valid: {result.get('all_valid', False)}")
        else:  # Single result
            print(f"Delta Verification: {'VALID' if result.get('valid') else 'INVALID'}")
            
            if result.get('errors'):
                print("Errors:")
                for error in result['errors']:
                    print(f"  - {error}")
    
    async def _cmd_peers(self, args: argparse.Namespace):
        """Peer management"""
        coordinator = await self._get_coordinator(args.config)
        
        if args.peer_action == 'list':
            await self._peers_list(coordinator, args)
        elif args.peer_action == 'add':
            await self._peers_add(coordinator, args)
        elif args.peer_action == 'discover':
            await self._peers_discover(coordinator, args)
    
    async def _peers_list(self, coordinator: SyncCoordinator, args: argparse.Namespace):
        """List known peers"""
        if coordinator.sync_protocol:
            status = await coordinator.sync_protocol.get_protocol_status()
            peers = status.get('peer_details', {})
            
            if args.json:
                print(json.dumps(peers, indent=2))
            else:
                if peers:
                    print("Known Peers:")
                    for peer_id, peer_info in peers.items():
                        print(f"  {peer_id}: {peer_info.get('address')}:{peer_info.get('port')}")
                        print(f"    Online: {peer_info.get('is_online', False)}")
                        print(f"    Capabilities: {', '.join(peer_info.get('capabilities', []))}")
                else:
                    print("No known peers")
        else:
            print("Sync protocol not initialized")
    
    async def _peers_add(self, coordinator: SyncCoordinator, args: argparse.Namespace):
        """Add manual peer"""
        if not all([args.node_id, args.address, args.port]):
            print("Error: --node-id, --address, and --port are required")
            return
        
        if coordinator.sync_protocol:
            success = await coordinator.sync_protocol.add_manual_peer(
                args.node_id, args.address, args.port
            )
            print(f"Peer {'added' if success else 'failed to add'}: {args.node_id}")
        else:
            print("Sync protocol not initialized")
    
    async def _peers_discover(self, coordinator: SyncCoordinator, args: argparse.Namespace):
        """Discover peers"""
        if coordinator.sync_protocol:
            peers = await coordinator.sync_protocol.discover_peers()
            print(f"Discovered {len(peers)} peers:")
            for peer in peers:
                print(f"  - {peer}")
        else:
            print("Sync protocol not initialized")
    
    async def _cmd_conflicts(self, args: argparse.Namespace):
        """Conflict management"""
        coordinator = await self._get_coordinator(args.config)
        
        if args.conflict_action == 'list':
            await self._conflicts_list(coordinator, args)
        elif args.conflict_action == 'resolve':
            await self._conflicts_resolve(coordinator, args)
    
    async def _conflicts_list(self, coordinator: SyncCoordinator, args: argparse.Namespace):
        """List pending conflicts"""
        status = await coordinator.get_sync_status()
        # Would need to extend coordinator to expose conflict details
        pending_count = status.get('pending_conflicts', 0)
        
        if args.json:
            print(json.dumps({'pending_conflicts': pending_count}, indent=2))
        else:
            print(f"Pending conflicts: {pending_count}")
    
    async def _conflicts_resolve(self, coordinator: SyncCoordinator, args: argparse.Namespace):
        """Resolve a conflict"""
        if not args.conflict_id or not args.resolution:
            print("Error: --conflict-id and --resolution are required")
            return
        
        success = await coordinator.manual_conflict_resolution(
            args.conflict_id, args.resolution
        )
        print(f"Conflict {'resolved' if success else 'resolution failed'}: {args.conflict_id}")
    
    async def _cmd_config(self, args: argparse.Namespace):
        """Configuration management"""
        if args.config_action == 'show':
            await self._config_show(args)
        elif args.config_action == 'validate':
            await self._config_validate(args)
        elif args.config_action == 'generate':
            await self._config_generate(args)
    
    async def _config_show(self, args: argparse.Namespace):
        """Show current configuration"""
        config_file = args.config or "sp_sub_config.yaml"
        
        try:
            with open(config_file, 'r') as f:
                config = yaml.safe_load(f)
            
            if args.json:
                print(json.dumps(config, indent=2))
            else:
                print(yaml.dump(config, default_flow_style=False, indent=2))
                
        except Exception as e:
            self.logger.error(f"Failed to load config: {e}")
    
    async def _config_validate(self, args: argparse.Namespace):
        """Validate configuration"""
        config_file = args.config or "sp_sub_config.yaml"
        
        try:
            coordinator = SyncCoordinator(config_file)
            await coordinator.initialize()
            print(f"Configuration is valid: {config_file}")
        except Exception as e:
            print(f"Configuration is invalid: {e}")
    
    async def _config_generate(self, args: argparse.Namespace):
        """Generate default configuration"""
        config_file = args.output or "sp_sub_config_default.yaml"
        
        coordinator = SyncCoordinator()
        default_config = coordinator._get_default_config()
        
        with open(config_file, 'w') as f:
            yaml.dump(default_config, f, default_flow_style=False, indent=2)
        
        print(f"Default configuration generated: {config_file}")
    
    async def _cmd_diagnostics(self, args: argparse.Namespace):
        """Run system diagnostics"""
        coordinator = await self._get_coordinator(args.config)
        
        print("SP-SUB Diagnostics")
        print("=" * 50)
        
        # Basic status
        status = await coordinator.get_sync_status()
        print(f"Node ID: {status.get('node_id')}")
        print(f"Config loaded: {status.get('config_loaded')}")
        print(f"Last sync: {status.get('last_sync_time', 'Never')}")
        
        # Component status
        components = []
        if coordinator.merkle_comparer:
            components.append("MerkleTreeComparer")
        if coordinator.delta_engine:
            components.append("DeltaEngine")
        if coordinator.integrity_verifier:
            components.append("IntegrityVerifier")
        if coordinator.sync_protocol:
            components.append("GhostSyncProtocol")
        
        print(f"Initialized components: {', '.join(components)}")
        
        # Protocol status
        if coordinator.sync_protocol:
            protocol_status = await coordinator.sync_protocol.get_protocol_status()
            print(f"Protocol mode: {protocol_status.get('mode')}")
            print(f"Known peers: {protocol_status.get('known_peers', 0)}")
            print(f"Active connections: {protocol_status.get('active_connections', 0)}")
        
        # File system check
        current_dir = Path(".")
        file_count = len(list(current_dir.rglob("*")))
        print(f"Local files: {file_count}")
        
        print("\nDiagnostics completed")


def create_parser() -> argparse.ArgumentParser:
    """Create CLI argument parser"""
    parser = argparse.ArgumentParser(
        description='SP-SUB: Synchronization Protocol Subsystem CLI',
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    
    # Global options
    parser.add_argument('--config', '-c', help='Configuration file path')
    parser.add_argument('--json', action='store_true', help='Output in JSON format')
    parser.add_argument('--verbose', '-v', action='store_true', help='Verbose output')
    
    # Subcommands
    subparsers = parser.add_subparsers(dest='command', help='Available commands')
    
    # Sync command
    sync_parser = subparsers.add_parser('sync', help='Execute synchronization')
    sync_parser.add_argument('--peers', help='Comma-separated list of peer addresses')
    sync_parser.add_argument('--dry-run', action='store_true', help='Dry run mode')
    
    # Status command
    status_parser = subparsers.add_parser('status', help='Show sync status')
    
    # Tree command
    tree_parser = subparsers.add_parser('tree', help='Merkle tree operations')
    tree_subparsers = tree_parser.add_subparsers(dest='tree_action', help='Tree actions')
    
    tree_build = tree_subparsers.add_parser('build', help='Build Merkle tree')
    tree_build.add_argument('--path', help='Path to build tree for')
    
    tree_compare = tree_subparsers.add_parser('compare', help='Compare trees')
    tree_compare.add_argument('--tree1', required=True, help='First tree file')
    tree_compare.add_argument('--tree2', required=True, help='Second tree file')
    
    tree_show = tree_subparsers.add_parser('show', help='Show tree details')
    tree_show.add_argument('--tree-file', help='Tree file to show')
    
    # Verify command
    verify_parser = subparsers.add_parser('verify', help='Verify delta integrity')
    verify_parser.add_argument('--delta-file', required=True, help='Delta file to verify')
    
    # Peers command
    peers_parser = subparsers.add_parser('peers', help='Peer management')
    peers_subparsers = peers_parser.add_subparsers(dest='peer_action', help='Peer actions')
    
    peers_list = peers_subparsers.add_parser('list', help='List known peers')
    
    peers_add = peers_subparsers.add_parser('add', help='Add manual peer')
    peers_add.add_argument('--node-id', required=True, help='Peer node ID')
    peers_add.add_argument('--address', required=True, help='Peer address')
    peers_add.add_argument('--port', type=int, required=True, help='Peer port')
    
    peers_discover = peers_subparsers.add_parser('discover', help='Discover peers')
    
    # Conflicts command
    conflicts_parser = subparsers.add_parser('conflicts', help='Conflict management')
    conflicts_subparsers = conflicts_parser.add_subparsers(dest='conflict_action', help='Conflict actions')
    
    conflicts_list = conflicts_subparsers.add_parser('list', help='List pending conflicts')
    
    conflicts_resolve = conflicts_subparsers.add_parser('resolve', help='Resolve conflict')
    conflicts_resolve.add_argument('--conflict-id', required=True, help='Conflict ID')
    conflicts_resolve.add_argument('--resolution', required=True, help='Resolution strategy')
    
    # Config command
    config_parser = subparsers.add_parser('config', help='Configuration management')
    config_subparsers = config_parser.add_subparsers(dest='config_action', help='Config actions')
    
    config_show = config_subparsers.add_parser('show', help='Show configuration')
    config_validate = config_subparsers.add_parser('validate', help='Validate configuration')
    config_generate = config_subparsers.add_parser('generate', help='Generate default config')
    config_generate.add_argument('--output', help='Output file path')
    
    # Diagnostics command
    diag_parser = subparsers.add_parser('diagnostics', help='Run system diagnostics')
    
    return parser


async def main():
    """CLI main entry point"""
    parser = create_parser()
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 1
    
    # Set up verbose logging if requested
    if args.verbose:
        logging.getLogger().setLevel(logging.DEBUG)
    
    cli = SPCLI()
    return await cli.run(args)


if __name__ == "__main__":
    sys.exit(asyncio.run(main()))
                
