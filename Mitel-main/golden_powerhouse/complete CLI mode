class SyncCoordinator:
    """Central orchestrator for SP-SUB synchronization lifecycle"""
    
    def __init__(self, config_path: str = "sp_sub_config.yaml"):
        self.config_path = config_path
        self.node_id = str(uuid.uuid4())
        self.config = {}
