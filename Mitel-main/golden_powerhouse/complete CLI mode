        """Initialize all SP-SUB components"""
        await self.load_config()
        
        # Initialize subsystem components
        self.merkle_comparer = MerkleTreeComparer(self.config.get('merkle', {}))
        self.delta_engine = DeltaEngine(self.config.get('delta', {}))
        self.integrity_verifier = IntegrityVerifier(self.config.get('integrity', {}))
        self.sync_protocol = GhostSyncProtocol(self.config.get('protocol', {}))
        
        await self.load_sync_state()
        self.logger.info(f"SP-SUB initialized with node_id: {self.node_id}")
        
    async def load_config(self):
        """Load sync configuration from YAML"""
        try:
            config_file = Path(self.config_path)
            if config_file.exists():
                with open(config_file, "r") as f:
                    self.config = yaml.safe_load(f) or {}
            else:
                self.config = self._get_default_config()
                await self.save_config()
            
            self.logger.info(f"SP-SUB config loaded from {self.config_path}")
        except Exception as e:
            self.logger.error(f"Failed to load SP-SUB config: {e}")
            self.config = self._get_default_config()
    
    async def save_config(self):
        """Save current configuration to YAML"""
        try:
            with open(self.config_path, 'w') as f:
                yaml.dump(self.config, f, default_flow_style=False, indent=2)
        except Exception as e:
            self.logger.error(f"Failed to save config: {e}")
    
