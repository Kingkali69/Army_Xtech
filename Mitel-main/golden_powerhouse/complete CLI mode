        if deltas:
            # Keep the delta with the latest timestamp
            winner = max(deltas, key=lambda d: d.get('timestamp', 0))
            self.logger.info(f"Conflict resolved via last-write-wins: {conflict['entity_id']}")
            # The winner delta will be applied normally
    
