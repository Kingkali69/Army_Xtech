            'last_sync_time': self.last_sync_time.isoformat() if self.last_sync_time else None,
            'version_vector': self.sync_state.get('version_vectors', {}),
            'pending_conflicts': len(self.sync_state.get('pending_conflicts', [])),
            'checkpoint_count': len(self.sync_state.get('checkpoint_history', [])),
            'config_loaded': bool(self.config)
        }
    
    async def manual_conflict_resolution(self, conflict_id: str, resolution: str) -> bool:
        """Manually resolve a pending conflict"""
        pending = self.sync_state.get('pending_conflicts', [])
        
        for i, conflict in enumerate(pending):
            if conflict.get('entity_id') == conflict_id:
                # Apply manual resolution
                self.logger.info(f"Manual conflict resolution applied: {conflict_id}")
                # Remove from pending
                pending.pop(i)
                await self.save_sync_state()
                return True
        
        return False

