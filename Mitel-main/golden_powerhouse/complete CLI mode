import hashlib
import json
import logging
from pathlib import Path
from typing import Dict, List, Optional, Any, Tuple
import asyncio

class MerkleNode:
    """A node in the Merkle tree"""
    def __init__(self, hash_value: str, is_leaf: bool = False, 
                 data: Optional[Any] = None):
        self.hash = hash_value
        self.is_leaf = is_leaf
        self.data = data
        self.children: List['MerkleNode'] = []
        self.parent: Optional['MerkleNode'] = None
    
    def add_child(self, child: 'MerkleNode'):
        child.parent = self
        self.children.append(child)

class MerkleTreeComparer:
    """Hash-based comparison of state between nodes/files using Merkle trees"""
    
    def __init__(self, config: Dict[str, Any]):
        self.config = config
        self.hash_algorithm = config.get('hash_algorithm', 'sha256')
        self.chunk_size = config.get('chunk_size', 4096)
        self.max_depth = config.get('max_depth', 10)
        self.logger = logging.getLogger("MerkleTreeComparer")
        
    def _hash_data(self, data: bytes) -> str:
        """Generate hash for data using configured algorithm"""
        hasher = hashlib.new(self.hash_algorithm)
        hasher.update(data)
        return hasher.hexdigest()
    
    def _hash_string(self, text: str) -> str:
        """Generate hash for string data"""
        return self._hash_data(text.encode('utf-8'))
    
    async def build_local_tree(self, root_path: str = ".", 
                              entity_filter: Optional[List[str]] = None) -> Dict[str, Any]:
        """Build Merkle tree for local filesystem or data"""
        try:
            root = Path(root_path)
            if not root.exists():
                return {'root_hash': '', 'nodes': {}, 'metadata': {}}
            
            tree_nodes = {}
            file_hashes = {}
            
            # Scan files and build leaf nodes
            for file_path in self._scan_files(root, entity_filter):
                try:
                    file_hash = await self._hash_file(file_path)
                    rel_path = str(file_path.relative_to(root))
                    file_hashes[rel_path] = file_hash
                    
                    # Create leaf node
                    leaf_node = MerkleNode(file_hash, is_leaf=True, data={
                        'path': rel_path,
                        'size': file_path.stat().st_size,
                        'modified': file_path.stat().st_mtime
                    })
                    tree_nodes[rel_path] = leaf_node
                    
                except Exception as e:
                    self.logger.warning(f"Failed to hash file {file_path}: {e}")
            
            # Build tree structure bottom-up
            root_node = await self._build_tree_structure(tree_nodes, file_hashes)
            
            return {
                'root_hash': root_node.hash if root_node else '',
                'nodes': self._serialize_tree(root_node) if root_node else {},
                'metadata': {
                    'total_files': len(file_hashes),
                    'algorithm': self.hash_algorithm,
                    'chunk_size': self.chunk_size,
                    'build_timestamp': asyncio.get_event_loop().time()
                }
            }
            
        except Exception as e:
            self.logger.error(f"Failed to build local tree: {e}")
            return {'root_hash': '', 'nodes': {}, 'metadata': {'error': str(e)}}
    
    def _scan_files(self, root: Path, entity_filter: Optional[List[str]] = None) -> List[Path]:
        """Scan files in directory tree"""
        files = []
        
        try:
            for path in root.rglob('*'):
                if path.is_file():
                    # Apply entity filter if provided
                    if entity_filter:
                        if not any(pattern in str(path) for pattern in entity_filter):
                            continue
                    
                    # Skip hidden files and temp files
                    if path.name.startswith('.') or path.name.startswith('~'):
                        continue
                    
                    files.append(path)
                    
        except Exception as e:
            self.logger.warning(f"Error scanning {root}: {e}")
        
        return sorted(files)  # Ensure consistent ordering
    
    async def _hash_file(self, file_path: Path) -> str:
        """Generate hash for a single file"""
        hasher = hashlib.new(self.hash_algorithm)
        
        try:
            with open(file_path, 'rb') as f:
                while chunk := f.read(self.chunk_size):
                    hasher.update(chunk)
            return hasher.hexdigest()
        except Exception as e:
            self.logger.error(f"Failed to hash file {file_path}: {e}")
            return self._hash_string(f"ERROR:{e}")
    
    async def _build_tree_structure(self, leaf_nodes: Dict[str, MerkleNode], 
                                   file_hashes: Dict[str, str]) -> Optional[MerkleNode]:
        """Build hierarchical tree structure from leaf nodes"""
        if not leaf_nodes:
            return None
        
        # Group nodes by directory structure
        dir_structure = {}
        
        for path, node in leaf_nodes.items():
            parts = Path(path).parts
            current_level = dir_structure
            
            # Build nested dictionary structure
            for part in parts[:-1]:  # Exclude filename
                if part not in current_level:
                    current_level[part] = {'_dirs': {}, '_files': []}
                current_level = current_level[part]['_dirs']
            
            # Add file to final directory
            final_dir = parts[-2] if len(parts) > 1 else '.'
            if final_dir not in current_level:
                current_level[final_dir] = {'_dirs': {}, '_files': []}
            current_level[final_dir]['_files'].append(node)
        
        # Build tree from structure
        return await self._create_tree_from_structure(dir_structure)
    
    async def _create_tree_from_structure(self, structure: Dict) -> MerkleNode:
        """Recursively create tree nodes from directory structure"""
        # Collect all hashes at this level
        level_hashes = []
        children = []
        
        # Process subdirectories
        for dir_name, dir_content in structure.items():
            if isinstance(dir_content, dict):
                # Process files in this directory
                files = dir_content.get('_files', [])
                file_hashes = [node.hash for node in files]
                
                # Process subdirectories
                subdirs = dir_content.get('_dirs', {})
                subdir_nodes = []
                
                if subdirs:
                    subdir_node = await self._create_tree_from_structure(subdirs)
                    subdir_nodes.append(subdir_node)
                
                # Create directory node
                combined_hashes = file_hashes + [node.hash for node in subdir_nodes]
                dir_hash = self._hash_string(''.join(sorted(combined_hashes)))
                
                dir_node = MerkleNode(dir_hash, data={'type': 'directory', 'name': dir_name})
                
                # Add children
                for file_node in files:
                    dir_node.add_child(file_node)
                for subdir_node in subdir_nodes:
                    dir_node.add_child(subdir_node)
                
                children.append(dir_node)
                level_hashes.append(dir_hash)
        
        # Create root node for this level
        if children:
            root_hash = self._hash_string(''.join(sorted(level_hashes)))
            root_node = MerkleNode(root_hash, data={'type': 'root'})
            for child in children:
                root_node.add_child(child)
            return root_node
        else:
            # Single empty node
            return MerkleNode(self._hash_string('empty'), data={'type': 'empty'})
    
    def _serialize_tree(self, node: MerkleNode) -> Dict[str, Any]:
        """Serialize tree structure for transmission/storage"""
        if not node:
            return {}
        
        serialized = {
            'hash': node.hash,
            'is_leaf': node.is_leaf,
            'data': node.data,
            'children': []
        }
        
        for child in node.children:
            serialized['children'].append(self._serialize_tree(child))
        
        return serialized
    
    def _deserialize_tree(self, data: Dict[str, Any]) -> Optional[MerkleNode]:
        """Deserialize tree from stored format"""
        if not data:
            return None
        
        node = MerkleNode(
            data['hash'],
            data.get('is_leaf', False),
            data.get('data')
        )
        
        for child_data in data.get('children', []):
            child = self._deserialize_tree(child_data)
            if child:
                node.add_child(child)
        
        return node
    
    async def get_peer_tree(self, peer_address: str) -> Dict[str, Any]:
        """Get Merkle tree from a peer node"""
        try:
            # This would typically involve network communication
            # For now, simulate peer tree retrieval
            self.logger.debug(f"Retrieving tree from peer {peer_address}")
            
            # In production, this would make HTTP/gRPC call to peer
            # For demo purposes, return empty tree
            return {
                'root_hash': '',
                'nodes': {},
                'metadata': {
                    'peer': peer_address,
                    'retrieved_at': asyncio.get_event_loop().time()
                }
            }
            
        except Exception as e:
            self.logger.error(f"Failed to get tree from peer {peer_address}: {e}")
            raise
    
    async def compare_trees(self, local_tree: Dict[str, Any], 
                           remote_tree: Dict[str, Any]) -> Dict[str, Any]:
        """Compare two Merkle trees and identify differences"""
        try:
            comparison_result = {
                'identical': False,
                'differences': [],
                'local_only': [],
                'remote_only': [],
                'modified': [],
                'summary': {}
            }
            
            local_root_hash = local_tree.get('root_hash', '')
            remote_root_hash = remote_tree.get('root_hash', '')
            
            # Quick comparison - if root hashes match, trees are identical
            if local_root_hash and remote_root_hash and local_root_hash == remote_root_hash:
                comparison_result['identical'] = True
                return comparison_result
            
            # Detailed comparison
            local_nodes = local_tree.get('nodes', {})
            remote_nodes = remote_tree.get('nodes', {})
            
            differences = await self._compare_node_trees(local_nodes, remote_nodes)
            comparison_result.update(differences)
            
            # Generate summary
            comparison_result['summary'] = {
                'total_differences': len(comparison_result['differences']),
                'local_only_count': len(comparison_result['local_only']),
                'remote_only_count': len(comparison_result['remote_only']),
                'modified_count': len(comparison_result['modified']),
                'sync_required': not comparison_result['identical']
            }
            
            return comparison_result
            
        except Exception as e:
            self.logger.error(f"Tree comparison failed: {e}")
            return {
                'identical': False,
                'error': str(e),
                'differences': [],
                'summary': {'error': True}
            }
    
    async def _compare_node_trees(self, local_nodes: Dict[str, Any], 
                                 remote_nodes: Dict[str, Any]) -> Dict[str, List]:
        """Compare node structures recursively"""
        differences = []
        local_only = []
        remote_only = []
        modified = []
        
        # Collect all paths from both trees
        local_paths = self._extract_paths_from_tree(local_nodes)
        remote_paths = self._extract_paths_from_tree(remote_nodes)
        
        all_paths = set(local_paths.keys()) | set(remote_paths.keys())
        
        for path in all_paths:
            local_hash = local_paths.get(path)
            remote_hash = remote_paths.get(path)
            
            if local_hash and not remote_hash:
                local_only.append({
                    'path': path,
                    'hash': local_hash,
                    'type': 'local_only'
                })
                differences.append(path)
                
            elif remote_hash and not local_hash:
                remote_only.append({
                    'path': path,
                    'hash': remote_hash,
                    'type': 'remote_only'
                })
                differences.append(path)
                
            elif local_hash != remote_hash:
                modified.append({
                    'path': path,
                    'local_hash': local_hash,
                    'remote_hash': remote_hash,
                    'type': 'modified'
                })
                differences.append(path)
        
        return {
            'differences': differences,
            'local_only': local_only,
            'remote_only': remote_only,
            'modified': modified
        }
    
    def _extract_paths_from_tree(self, tree_nodes: Dict[str, Any]) -> Dict[str, str]:
        """Extract all file paths and their hashes from tree structure"""
        paths = {}
        
        def traverse(node_data, current_path=""):
            if not isinstance(node_data, dict):
                return
            
            node_hash = node_data.get('hash', '')
            is_leaf = node_data.get('is_leaf', False)
            data = node_data.get('data', {})
            
            if is_leaf and 'path' in data:
                # This is a file leaf
                file_path = data['path']
                paths[file_path] = node_hash
            
            # Traverse children
            for child in node_data.get('children', []):
                traverse(child, current_path)
        
        traverse(tree_nodes)
        return paths
    
    async def get_subtree_diff(self, local_tree: Dict[str, Any], 
                              remote_tree: Dict[str, Any],
                              path_filter: str) -> Dict[str, Any]:
        """Get differences for a specific subtree/path"""
        try:
            full_diff = await self.compare_trees(local_tree, remote_tree)
            
            # Filter differences by path
            filtered_diff = {
                'path_filter': path_filter,
                'differences': [],
                'local_only': [],
                'remote_only': [],
                'modified': []
            }
            
            for diff_type in ['differences', 'local_only', 'remote_only', 'modified']:
                items = full_diff.get(diff_type, [])
                
                if diff_type == 'differences':
                    # differences is just a list of paths
                    filtered_items = [item for item in items if path_filter in item]
                else:
                    # other types are lists of dicts with 'path' key
                    filtered_items = [item for item in items if path_filter in item.get('path', '')]
                
                filtered_diff[diff_type] = filtered_items
            
            return filtered_diff
            
        except Exception as e:
            self.logger.error(f"Subtree diff failed: {e}")
            return {'error': str(e)}

# sp_subsystem/delta_engine.py
import json
import gzip
import base64
import logging
from typing import Dict, List, Any, Optional, Union
from datetime import datetime, timezone
import asyncio
import difflib

class CRDTOperation:
    """Represents a Conflict-free Replicated Data Type operation"""
    def __init__(self, op_type: str, entity_id: str, field: str, 
                 value: Any, vector_clock: Dict[str, int], 
                 node_id: str, timestamp: float):
        self.op_type = op_type  # 'set', 'delete', 'increment', 'merge'
        self.entity_id = entity_id
        self.field = field
        self.value = value
        self.vector_clock = vector_clock.copy()
        self.node_id = node_id
        self.timestamp = timestamp
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            'op_type': self.op_type,
            'entity_id': self.entity_id,
            'field': self.field,
            'value': self.value,
            'vector_clock': self.vector_clock,
            'node_id': self.node_id,
            'timestamp': self.timestamp
        }
    
    @classmethod
    def from_dict(cls, data: Dict[str, Any]) -> 'CRDTOperation':
        return cls(
            data['op_type'],
            data['entity_id'],
            data['field'],
            data['value'],
            data['vector_clock'],
            data['node_id'],
            data['timestamp']
        )

class DeltaEngine:
    """Computes and applies CRDT-compatible differences"""
    
    def __init__(self, config: Dict[str, Any]):
        self.config = config
        self.compression_enabled = config.get('compression_enabled', True)
        self.max_delta_size = config.get('max_delta_size', 1048576)  # 1MB
        self.crdt_mode = config.get('crdt_mode', True)
        self.logger = logging.getLogger("DeltaEngine")
        
        # Local state for CRDT operations
        self.local_state = {}
        self.vector_clock = {}
        self.node_id = None
    
    def set_node_id(self, node_id: str):
        """Set the node ID for CRDT operations"""
        self.node_id = node_id
        if node_id not in self.vector_clock:
            self.vector_clock[node_id] = 0
    
    async def compute_deltas(self, tree_differences: Dict[str, Any]) -> List[Dict[str, Any]]:
        """Compute delta operations from tree differences"""
        try:
            deltas = []
            
            # Process each type of difference
            for local_only in tree_differences.get('local_only', []):
                delta = await self._create_delta_for_local_only(local_only)
                if delta:
                    deltas.append(delta)
            
            for remote_only in tree_differences.get('remote_only', []):
                delta = await self._create_delta_for_remote_only(remote_only)
                if delta:
                    deltas.append(delta)
            
            for modified in tree_differences.get('modified', []):
                delta = await self._create_delta_for_modified(modified)
                if delta:
                    deltas.append(delta)
            
            # Apply compression if enabled
            if self.compression_enabled:
                deltas = await self._compress_deltas(deltas)
            
            self.logger.info(f"Computed {len(deltas)} deltas")
            return deltas
            
        except Exception as e:
            self.logger.error(f"Delta computation failed: {e}")
            return []
    
    async def _create_delta_for_local_only(self, local_item: Dict[str, Any]) -> Optional[Dict[str, Any]]:
        """Create delta for item that exists only locally"""
        path = local_item.get('path', '')
        
        try:
            # Read local file content
            content = await self._read_file_content(path)
            
            delta = {
                'type': 'create',
                'entity_id': path,
                'path': path,
                'content': content,
                'hash': local_item.get('hash', ''),
                'timestamp': datetime.now(timezone.utc).timestamp(),
                'node_id': self.node_id,
                'vector_clock': self._increment_vector_clock()
            }
            
            if self.crdt_mode:
                delta['crdt_operation'] = CRDTOperation(
                    'set', path, 'content', content,
                    self.vector_clock, self.node_id,
                    delta['timestamp']
                ).to_dict()
            
            return delta
            
        except Exception as e:
            self.logger.warning(f"Failed to create delta for {path}: {e}")
            return None
    
    async def _create_delta_for_remote_only(self, remote_item: Dict[str, Any]) -> Optional[Dict[str, Any]]:
        """Create delta for item that exists only on remote"""
        path = remote_item.get('path', '')
        
        # This represents a delete operation from local perspective
        delta = {
            'type': 'delete',
            'entity_id': path,
            'path': path,
            'hash': remote_item.get('hash', ''),
            'timestamp': datetime.now(timezone.utc).timestamp(),
            'node_id': self.node_id,
            'vector_clock': self._increment_vector_clock()
        }
        
        if self.crdt_mode:
            delta['crdt_operation'] = CRDTOperation(
                'delete', path, 'content', None,
                self.vector_clock, self.node_id,
                delta['timestamp']
            ).to_dict()
        
        return delta
    
    async def _create_delta_for_modified(self, modified_item: Dict[str, Any]) -> Optional[Dict[str, Any]]:
        """Create delta for modified item"""
        path = modified_item.get('path', '')
        
        try:
            # Read current local content
            local_content = await self._read_file_content(path)
            
            # For now, we'll create a full replacement delta
            # In a more sophisticated system, we'd compute line-by-line diffs
            delta = {
                'type': 'update',
                'entity_id': path,
                'path': path,
                'content': local_content,
                'local_hash': modified_item.get('local_hash', ''),
                'remote_hash': modified_item.get('remote_hash', ''),
                'timestamp': datetime.now(timezone.utc).timestamp(),
                'node_id': self.node_id,
                'vector_clock': self._increment_vector_clock()
            }
            
            # Add diff information for better merging
            diff_info = await self._compute_text_diff(path, local_content)
            if diff_info:
                delta['diff'] = diff_info
            
            if self.crdt_mode:
                delta['crdt_operation'] = CRDTOperation(
                    'set', path, 'content', local_content,
                    self.vector_clock, self.node_id,
                    delta['timestamp']
                ).to_dict()
            
            return delta
            
        except Exception as e:
            self.logger.warning(f"Failed to create delta for modified {path}: {e}")
            return None
    
    async def _read_file_content(self, path: str) -> str:
        """Read file content as string"""
        try:
            with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                return f.read()
        except Exception as e:
            self.logger.warning(f"Failed to read {path}: {e}")
            return ""
    
    async def _compute_text_diff(self, path: str, content: str) -> Optional[Dict[str, Any]]:
        """Compute unified diff for text content"""
        try:
            # In a real implementation, we'd compare with the remote version
            # For now, just return basic diff info
            lines = content.splitlines()
            return {
                'line_count': len(lines),
                'char_count': len(content),
                'has_binary': any(ord(c) > 127 for c in content[:1000])  # Simple binary check
            }
        except Exception:
            return None
    
    def _increment_vector_clock(self) -> Dict[str, int]:
        """Increment local vector clock"""
        if self.node_id:
            self.vector_clock[self.node_id] = self.vector_clock.get(self.node_id, 0) + 1
        return self.vector_clock.copy()
    
    async def _compress_deltas(self, deltas: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        """Compress delta payloads"""
        compressed_deltas = []
        
        for delta in deltas:
            try:
                # Serialize delta
                delta_json = json.dumps(delta, sort_keys=True)
                
                # Check size
                if len(delta_json) > self.max_delta_size:
                    self.logger.warning(f"Delta too large: {len(delta_json)} bytes")
                    continue
                
                # Compress if beneficial
                compressed_data = gzip.compress(delta_json.encode('utf-8'))
                
                if len(compressed_data) < len(delta_json):
                    # Compression helped
                    compressed_delta = {
                        'compressed': True,
                        'data': base64.b64encode(compressed_data).decode('ascii'),
                        'original_size': len(delta_json),
                        'compressed_size': len(compressed_data)
                    }
                    compressed_deltas.append(compressed_delta)
                else:
                    # No compression benefit
                    delta['compressed'] = False
                    compressed_deltas.append(delta)
                    
            except Exception as e:
                self.logger.warning(f"Failed to compress delta: {e}")
                compressed_deltas.append(delta)
        
        return compressed_deltas
    
    async def apply_delta(self, delta: Dict[str, Any]) -> bool:
        """Apply a delta to local state"""
        try:
            # Decompress if needed
            if delta.get('compressed'):
                delta = await self._decompress_delta(delta)
            
            delta_type = delta.get('type')
            entity_id = delta.get('entity_id')
            
            if delta_type == 'create':
                return await self._apply_create_delta(delta)
            elif delta_type == 'update':
                return await self._apply_update_delta(delta)
            elif delta_type == 'delete':
                return await self._apply_delete_delta(delta)
            else:
                self.logger.warning(f"Unknown delta type: {delta_type}")
                return False
                
        except Exception as e:
            self.logger.error(f"Failed to apply delta: {e}")
            return False
    
    async def _decompress_delta(self, compressed_delta: Dict[str, Any]) -> Dict[str, Any]:
        """Decompress a compressed delta"""
        try:
            compressed_data = base64.b64decode(compressed_delta['data'])
            decompressed_json = gzip.decompress(compressed_data).decode('utf-8')
            return json.loads(decompressed_json)
        except Exception as e:
            self.logger.error(f"Failed to decompress delta: {e}")
            raise
    
    async def _apply_create_delta(self, delta: Dict[str, Any]) -> bool:
        """Apply a create delta"""
        path = delta.get('path', '')
        content = delta.get('content', '')
        
        try:
            # Create directory if needed
            import os
            os.makedirs(os.path.dirname(path), exist_ok=True)
            
            # Write file
            with open(path, 'w', encoding='utf-8') as f:
                f.write(content)
            
            self.logger.debug(f"Created file: {path}")
            return True
            
        except Exception as e:
            self.logger.error(f"Failed to create {path}: {e}")
            return False
    
    async def _apply_update_delta(self, delta: Dict[str, Any]) -> bool:
        """Apply an update delta"""
        path = delta.get('path', '')
        content = delta.get('content', '')
        
        try:
            # Handle CRDT merge if available
            if self.crdt_mode and 'crdt_operation' in delta:
                return await self._apply_crdt_operation(delta['crdt_operation'])
            
            # Simple replacement for now
            with open(path, 'w', encoding='utf-8') as f:
                f.write(content)
            
            self.logger.debug(f"Updated file: {path}")
            return True
            
        except Exception as e:
            self.logger.error(f"Failed to update {path}: {e}")
            return False
    
    async def _apply_delete_delta(self, delta: Dict[str, Any]) -> bool:
        """Apply a delete delta"""
        path = delta.get('path', '')
        
        try:
            import os
            if os.path.exists(path):
                os.remove(path)
                self.logger.debug(f"Deleted file: {path}")
            return True
            
        except Exception as e:
            self.logger.error(f"Failed to delete {path}: {e}")
            return False
    
    async def _apply_crdt_operation(self, crdt_op_data: Dict[str, Any]) -> bool:
        """Apply a CRDT operation"""
        try:
            crdt_op = CRDTOperation.from_dict(crdt_op_data)
            
            # Update vector clock
            self._merge_vector_clock(crdt_op.vector_clock)
            
            # Apply operation based on type
            if crdt_op.op_type == 'set':
                return await self._crdt_set(crdt_op)
            elif crdt_op.op_type == 'delete':
                return await self._crdt_delete(crdt_op)
            elif crdt_op.op_type == 'merge':
                return await self._crdt_merge(crdt_op)
            
            return True
            
        except Exception as e:
            self.logger.error(f"CRDT operation failed: {e}")
            return False
    
    def _merge_vector_clock(self, remote_clock: Dict[str, int]):
        """Merge remote vector clock with local"""
        for node, timestamp in remote_clock.items():
            self.vector_clock[node] = max(
                self.vector_clock.get(node, 0),
                timestamp
            )
    
    async def _crdt_set(self, crdt_op: CRDTOperation) -> bool:
        """Apply CRDT set operation"""
        # For file content, this is equivalent to write
        try:
            with open(crdt_op.entity_id, 'w', encoding='utf-8') as f:
                f.write(str(crdt_op.value))
            return True
        except Exception:
            return False
    
    async def _crdt_delete(self, crdt_op: CRDTOperation) -> bool:
        """Apply CRDT delete operation"""
        try:
            import os
            if os.path.exists(crdt_op.entity_id):
                os.remove(crdt_op.entity_id)
            return True
        except Exception:
            return False
    
    async def _crdt_merge(self, crdt_op: CRDTOperation) -> bool:
        """Apply CRDT merge operation"""
        # Simplified merge - in practice this would be more sophisticated
        return await self._crdt_set(crdt_op)
    
    async def create_manual_delta(self, entity_id: str, operation: str, 
                                 data: Any) -> Dict[str, Any]:
        """Create a manual delta operation"""
        delta = {
            'type': operation,
            'entity_id': entity_id,
            'content': data,
            'timestamp': datetime.now(timezone.utc).timestamp(),
            'node_id': self.node_id,
            'vector_clock': self._increment_vector_clock(),
            'manual': True
        }
        
        if self.crdt_mode:
            delta['crdt_operation'] = CRDTOperation(
                operation, entity_id, 'content', data,
                self.vector_clock, self.node_id,
                delta['timestamp']
            ).to_dict()
        
        return delta
    
    async def get_delta_stats(self) -> Dict[str, Any]:
        """Get statistics about delta operations"""
        return {
            'node_id': self.node_id,
            'vector_clock': self.vector_clock.copy(),
            'compression_enabled': self.compression_enabled,
            'max_delta_size': self.max_delta_size,
            'crdt_mode': self.crdt_mode
        }

# sp_subsystem/integrity_verifier.py
import hmac
import hashlib
import secrets
import time
import json
import logging
from typing import Dict, Any, Optional, List
from datetime import datetime, timezone
import base64

class IntegrityVerifier:
    """Validates authenticity and integrity of sync changes"""
    
    def __init__(self, config: Dict[str, Any]):
        self.config = config
        self.hmac_algorithm = config.get('hmac_algorithm', 'sha256')
        self.signature_required = config.get('signature_required', True)
        self.nonce_length = config.get('nonce_length', 16)
        self.timestamp_tolerance = config.get('timestamp_tolerance_seconds', 300)
        self.logger = logging.getLogger("IntegrityVerifier")
        
        # Keys for HMAC (in production, these would be securely managed)
        self.hmac_key = config.get('hmac_key', self._generate_key())
        self.node_keys = config.get('node_keys', {})  # Per-node keys
        
        # Nonce tracking to prevent replay attacks
        self.used_nonces = set()
        self.nonce_cleanup_counter = 0
    
    def _generate_key(self) -> bytes:
        """Generate a new HMAC key"""
        return secrets.token_bytes(32)  # 256-bit key
    
    async def sign_delta(self, delta: Dict[str, Any], node_id: str) -> Dict[str, Any]:
        """Add integrity signature to a delta"""
        try:
            # Create a copy to avoid modifying original
            signed_delta = delta.copy()
            
            # Add timestamp if not present
            if 'timestamp' not in signed_delta:
                signed_delta['timestamp'] = datetime.now(timezone.utc).timestamp()
            
            # Generate nonce
            nonce = secrets.token_hex(self.nonce_length)
            signed_delta['nonce'] = nonce
            signed_delta['node_id'] = node_id
            
            # Create canonical representation for signing
            canonical_data = self._canonicalize_delta(signed_delta)
            
            # Generate HMAC signature
            signature = self._generate_hmac(canonical_data, node_id)
            signed_delta['signature'] = signature
            
            # Add integrity metadata
            signed_delta['integrity'] = {
                'algorithm': self.hmac_algorithm,
                'signed_at': datetime.now(timezone.utc).isoformat(),
                'signed_by': node_id
            }
            
            return signed_delta
            
        except Exception as e:
            self.logger.error(f"Failed to sign delta: {e}")
            raise
    
    async def verify_delta(self, delta: Dict[str, Any]) -> Dict[str, Any]:
        """Verify integrity of a delta"""
        try:
            verification_result = {
                'valid': True,
                'checks': {},
                'errors': [],
                'warnings': []
            }
            
            # Check if signature is required
            if self.signature_required and 'signature' not in delta:
                verification_result['valid'] = False
                verification_result['errors'].append("Signature required but not present")
                return verification_result
            
            # Verify timestamp
            timestamp_check = await self._verify_timestamp(delta)
            verification_result['checks']['timestamp'] = timestamp_check
            if not timestamp_check['valid']:
                verification_result['valid'] = False
                verification_result['errors'].extend(timestamp_check.get('errors', []))
            
            # Verify nonce (replay protection)
            nonce_check = await self._verify_nonce(delta)
            verification_result['checks']['nonce'] = nonce_check
            if not nonce_check['valid']:
                verification_result['valid'] = False
                verification_result['errors'].extend(nonce_check.get('errors', []))
            
            # Verify HMAC signature
            if 'signature' in delta:
                signature_check = await self._verify_signature(delta)
                verification_result['checks']['signature'] = signature_check
                if not signature_check['valid']:
                    verification_result['valid'] = False
                    verification_result['errors'].extend(signature_check.get('errors', []))
            
            # Verify data integrity
            data_check = await self._verify_data_integrity(delta)
            verification_result['checks']['data'] = data_check
            if not data_check['valid']:
                verification_result['valid'] = False
                verification_result['errors'].extend(data_check.get('errors', []))
            
            # Mark nonce as used if all checks pass
            if verification_result['valid'] and 'nonce' in delta:
                self._mark_nonce_used(delta['nonce'])
            
            return verification_result
            
        except Exception as e:
            self.logger.error(f"Delta verification failed: {e}")
            return {
                'valid': False,
                'error': str(e),
                'checks': {},
                'errors': [f"Verification exception: {e}"]
            }
    
    async def _verify_timestamp(self, delta: Dict[str, Any]) -> Dict[str, Any]:
        """Verify delta timestamp is within acceptable range"""
        try:
            delta_timestamp = delta.get('timestamp')
            if not delta_timestamp:
                return {
                    'valid': False,
                    'errors': ['Timestamp missing from delta']
                }
            
            current_time = time.time()
            time_diff = abs(current_time - delta_timestamp)
            
            if time_diff > self.timestamp_tolerance:
                return {
                    'valid': False,
                    'errors': [f'Timestamp outside tolerance: {time_diff}s > {self.timestamp_tolerance}s']
                }
            
            return {
                'valid': True,
                'time_diff': time_diff,
                'tolerance': self.timestamp_tolerance
            }
            
        except Exception as e:
            return {
                'valid': False,
                'errors': [f'Timestamp verification error: {e}']
            }
    
    async def _verify_nonce(self, delta: Dict[str, Any]) -> Dict[str, Any]:
        """Verify nonce to prevent replay attacks"""
        try:
            nonce = delta.get('nonce')
            if not nonce:
                return {
                    'valid': False,
                    'errors': ['Nonce missing from delta']
                }
            
            # Check if nonce has been used before
            if nonce in self.used_nonces:
                return {
                    'valid': False,
                    'errors': ['Nonce already used - possible replay attack']
                }
            
            # Validate nonce format and length
            if len(nonce) != self.nonce_length * 2:  # Hex encoding doubles length
                return {
                    'valid': False,
                    'errors': [f'Invalid nonce length: expected {self.nonce_length * 2}, got {len(nonce)}']
                }
            
            # Verify nonce is valid hex
            try:
                bytes.fromhex(nonce)
            except ValueError:
                return {
                    'valid': False,
                    'errors': ['Invalid nonce format - not valid hex']
                }
            
            return {'valid': True}
            
        except Exception as e:
            return {
                'valid': False,
                'errors': [f'Nonce verification error: {e}']
            }
    
    async def _verify_signature(self, delta: Dict[str, Any]) -> Dict[str, Any]:
        """Verify HMAC signature"""
        try:
            stored_signature = delta.get('signature')
            node_id = delta.get('node_id')
            
            if not stored_signature:
                return {
                    'valid': False,
                    'errors': ['Signature missing from delta']
                }
            
            if not node_id:
                return {
                    'valid': False,
                    'errors': ['Node ID missing from delta']
                }
            
            # Create delta copy without signature for verification
            unsigned_delta = {k: v for k, v in delta.items() if k != 'signature'}
            canonical_data = self._canonicalize_delta(unsigned_delta)
            
            # Generate expected signature
            expected_signature = self._generate_hmac(canonical_data, node_id)
            
            # Compare signatures using secure comparison
            if not hmac.compare_digest(stored_signature, expected_signature):
                return {
                    'valid': False,
                    'errors': ['HMAC signature verification failed']
                }
            
            return {
                'valid': True,
                'algorithm': self.hmac_algorithm,
                'node_id': node_id
            }
            
        except Exception as e:
            return {
                'valid': False,
                'errors': [f'Signature verification error: {e}']
            }
    
    async def _verify_data_integrity(self, delta: Dict[str, Any]) -> Dict[str, Any]:
        """Verify data integrity and structure"""
        try:
            errors = []
            warnings = []
            
            # Check required fields
            required_fields = ['type', 'entity_id', 'timestamp', 'node_id']
            for field in required_fields:
                if field not in delta:
                    errors.append(f'Required field missing: {field}')
            
            # Validate delta type
            valid_types = ['create', 'update', 'delete']
            delta_type = delta.get('type')
            if delta_type not in valid_types:
                errors.append(f'Invalid delta type: {delta_type}')
            
            # Check entity_id format
            entity_id = delta.get('entity_id', '')
            if not entity_id or len(entity_id) > 1000:  # Reasonable path limit
                errors.append('Invalid entity_id')
            
            # Verify content size if present
            content = delta.get('content')
            if content and len(str(content)) > 10 * 1024 * 1024:  # 10MB limit
                warnings.append('Large content size - may impact performance')
            
            # Check vector clock if present (CRDT mode)
            if 'vector_clock' in delta:
                vector_clock = delta['vector_clock']
                if not isinstance(vector_clock, dict):
                    errors.append('Invalid vector clock format')
                elif not all(isinstance(v, int) for v in vector_clock.values()):
                    errors.append('Vector clock values must be integers')
            
            return {
                'valid': len(errors) == 0,
                'errors': errors,
                'warnings': warnings
            }
            
        except Exception as e:
            return {
                'valid': False,
                'errors': [f'Data integrity check error: {e}']
            }
    
    def _canonicalize_delta(self, delta: Dict[str, Any]) -> str:
        """Create canonical string representation for signing"""
        # Sort keys for consistent representation
        canonical = json.dumps(delta, sort_keys=True, separators=(',', ':'))
        return canonical
    
    def _generate_hmac(self, data: str, node_id: str) -> str:
        """Generate HMAC signature for data"""
        # Get key for node (use default if not found)
        key = self.node_keys.get(node_id, self.hmac_key)
        if isinstance(key, str):
            key = key.encode('utf-8')
        
        # Generate HMAC
        mac = hmac.new(key, data.encode('utf-8'), hashlib.sha256)
        return base64.b64encode(mac.digest()).decode('ascii')
    
    def _mark_nonce_used(self, nonce: str):
        """Mark nonce as used and cleanup old nonces"""
        self.used_nonces.add(nonce)
        
        # Periodic cleanup to prevent memory bloat
        self.nonce_cleanup_counter += 1
        if self.nonce_cleanup_counter > 1000:
            # In production, this would be more sophisticated
            # keeping nonces for timestamp_tolerance period
            if len(self.used_nonces) > 10000:
                # Keep only recent half
                nonces_list = list(self.used_nonces)
                self.used_nonces = set(nonces_list[-5000:])
            self.nonce_cleanup_counter = 0
    
    async def batch_verify_deltas(self, deltas: List[Dict[str, Any]]) -> Dict[str, Any]:
        """Verify multiple deltas efficiently"""
        try:
            results = []
            valid_count = 0
            
            for i, delta in enumerate(deltas):
                result = await self.verify_delta(delta)
                result['index'] = i
                results.append(result)
                
                if result['valid']:
                    valid_count += 1
            
            return {
                'total': len(deltas),
                'valid': valid_count,
                'invalid': len(deltas) - valid_count,
                'results': results,
                'all_valid': valid_count == len(deltas)
            }
            
        except Exception as e:
            self.logger.error(f"Batch verification failed: {e}")
            return {
                'total': len(deltas),
                'valid': 0,
                'invalid': len(deltas),
                'error': str(e),
                'results': []
            }
    
    async def generate_integrity_report(self, deltas: List[Dict[str, Any]]) -> Dict[str, Any]:
        """Generate detailed integrity report"""
        batch_result = await self.batch_verify_deltas(deltas)
        
        # Analyze patterns
        node_stats = {}
        error_patterns = {}
        
        for result in batch_result.get('results', []):
            # Node statistics
            delta_index = result.get('index', 0)
            if delta_index < len(deltas):
                node_id = deltas[delta_index].get('node_id', 'unknown')
                if node_id not in node_stats:
                    node_stats[node_id] = {'valid': 0, 'invalid': 0}
                
                if result['valid']:
                    node_stats[node_id]['valid'] += 1
                else:
                    node_stats[node_id]['invalid'] += 1
            
            # Error patterns
            for error in result.get('errors', []):
                error_patterns[error] = error_patterns.get(error, 0) + 1
        
        return {
            'summary': batch_result,
            'node_statistics': node_stats,
            'error_patterns': error_patterns,
            'recommendations': self._generate_recommendations(error_patterns, node_stats)
        }
    
    def _generate_recommendations(self, error_patterns: Dict[str, int], 
                                node_stats: Dict[str, Dict[str, int]]) -> List[str]:
        """Generate security recommendations based on verification patterns"""
        recommendations = []
        
        # Check for timestamp issues
        timestamp_errors = sum(count for error, count in error_patterns.items() 
                             if 'timestamp' in error.lower())
        if timestamp_errors > 0:
            recommendations.append("Consider adjusting timestamp tolerance or checking system clocks")
        
        # Check for replay attacks
        nonce_errors = sum(count for error, count in error_patterns.items() 
                          if 'nonce' in error.lower() or 'replay' in error.lower())
        if nonce_errors > 0:
            recommendations.append("Possible replay attacks detected - investigate nonce issues")
        
        # Check node reliability
        for node_id, stats in node_stats.items():
            total = stats['valid'] + stats['invalid']
            if total > 0:
                error_rate = stats['invalid'] / total
                if error_rate > 0.1:  # 10% error rate
                    recommendations.append(f"Node {node_id} has high error rate ({error_rate:.1%})")
        
        # Check signature issues
        sig_errors = sum(count for error, count in error_patterns.items() 
                        if 'signature' in error.lower() or 'hmac' in error.lower())
        if sig_errors > 0:
            recommendations.append("Signature verification failures - check key management")
        
        return recommendations
    
    async def rotate_keys(self, new_key: Optional[bytes] = None) -> Dict[str, Any]:
        """Rotate HMAC keys for security"""
        try:
            old_key = self.hmac_key
            new_key = new_key or self._generate_key()
            
            # Update key
            self.hmac_key = new_key
            
            # Log rotation (don't log actual keys)
            self.logger.info("HMAC key rotated successfully")
            
            return {
                'rotated': True,
                'timestamp': datetime.now(timezone.utc).isoformat(),
                'algorithm': self.hmac_algorithm
            }
            
        except Exception as e:
            self.logger.error(f"Key rotation failed: {e}")
            return {
                'rotated': False,
                'error': str(e)
            }
    
    async def add_node_key(self, node_id: str, key: bytes) -> bool:
        """Add or update key for specific node"""
        try:
            self.node_keys[node_id] = key
            self.logger.info(f"Added/updated key for node {node_id}")
            return True
        except Exception as e:
            self.logger.error(f"Failed to add node key: {e}")
            return False
    
    def get_integrity_stats(self) -> Dict[str, Any]:
        """Get integrity verification statistics"""
        return {
            'hmac_algorithm': self.hmac_algorithm,
            'signature_required': self.signature_required,
            'nonce_length': self.nonce_length,
            'timestamp_tolerance': self.timestamp_tolerance,
            'used_nonces_count': len(self.used_nonces),
            'configured_nodes': len(self.node_keys)
        }

# sp_subsystem/ghost_sync_protocol.py
import asyncio
import logging
import json
import aiohttp
import socket
from typing import Dict, List, Any, Optional, Set
from datetime import datetime, timezone
import ssl
import hashlib

class PeerInfo:
    """Information about a sync peer"""
    def __init__(self, node_id: str, address: str, port: int, 
                 capabilities: List[str], last_seen: Optional[datetime] = None):
        self.node_id = node_id
        self.address = address
        self.port = port
        self.capabilities = capabilities
        self.last_seen = last_seen or datetime.now(timezone.utc)
        self.connection_failures = 0
        self.is_online = True
    
    @property
    def endpoint(self) -> str:
        return f"{self.address}:{self.port}"
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            'node_id': self.node_id,
            'address': self.address,
            'port': self.port,
            'capabilities': self.capabilities,
            'last_seen': self.last_seen.isoformat(),
            'is_online': self.is_online,
            'connection_failures': self.connection_failures
        }

class GhostSyncProtocol:
    """Manages P2P/mesh sync flow with fallback modes"""
    
    def __init__(self, config: Dict[str, Any]):
        self.config = config
        self.mode = config.get('mode', 'mesh')  # 'mesh', 'hub', 'p2p'
        self.discovery_enabled = config.get('discovery_enabled', True)
        self.encryption_enabled = config.get('encryption_enabled', True)
        self.fallback_modes = config.get('fallback_modes', ['hub', 'offline'])
        
        self.logger = logging.getLogger("GhostSyncProtocol")
        
        # Peer management
        self.known_peers: Dict[str, PeerInfo] = {}
        self.active_connections: Set[str] = set()
        
        # Protocol settings
        self.listen_port = config.get('listen_port', 8443)
        self.discovery_port = config.get('discovery_port', 8444)
        self.timeout_seconds = config.get('timeout_seconds', 30)
        self.max_connections = config.get('max_connections', 50)
        
        # Hub settings (for fallback)
        self.hub_endpoints = config.get('hub_endpoints', [])
        
        # Server for incoming connections
        self.server = None
        self.discovery_server = None
        
    async def initialize(self):
        """Initialize protocol services"""
        try:
            if self.mode in ['mesh', 'p2p']:
                # Start listening server
                await self._start_server()
                
            if self.discovery_enabled:
                # Start discovery service
                await self._start_discovery()
                
            self.logger.info(f"Ghost sync protocol initialized in {self.mode} mode")
            
        except Exception as e:
            self.logger.error(f"Protocol initialization failed: {e}")
            raise
    
    async def shutdown(self):
        """Shutdown protocol services"""
        try:
            if self.server:
                self.server.close()
                await self.server.wait_closed()
                
            if self.discovery_server:
                self.discovery_server.close()
                
            # Close active connections
            for peer_id in list(self.active_connections):
                await self._disconnect_peer(peer_id)
                
            self.logger.info("Ghost sync protocol shut down")
            
        except Exception as e:
            self.logger.error(f"Protocol shutdown error: {e}")
    
    async def _start_server(self):
        """Start server for incoming sync connections"""
        try:
            # Create SSL context if encryption enabled
            ssl_context = None
            if self.encryption_enabled:
                ssl_context = self._create_ssl_context()
            
            self.server = await asyncio.start_server(
                self._handle_client_connection,
                '0.0.0.0',
                self.listen_port,
                ssl=ssl_context
            )
            
            self.logger.info(f"Sync server listening on port {self.listen_port}")
            
        except Exception as e:
            self.logger.error(f"Failed to start server: {e}")
            raise
    
    async def _start_discovery(self):
        """Start peer discovery service"""
        try:
            # UDP discovery server
            loop = asyncio.get_event_loop()
            
            transport, protocol = await loop.create_datagram_endpoint(
                lambda: DiscoveryProtocol(self),
                local_addr=('0.0.0.0', self.discovery_port)
            )
            
            self.discovery_server = transport
            self.logger.info(f"Discovery service started on port {self.discovery_port}")
            
            # Start periodic discovery broadcasts
            asyncio.create_task(self._periodic_discovery())
            
        except Exception as e:
            self.logger.error(f"Failed to start discovery: {e}")
    
    def _create_ssl_context(self) -> ssl.SSLContext:
        """Create SSL context for encrypted connections"""
        # In production, use proper certificates
        context = ssl.create_default_context(ssl.Purpose.SERVER_AUTH)
        context.check_hostname = False
        context.verify_mode = ssl.CERT_NONE
        return context
    
    async def _handle_client_connection(self, reader: asyncio.StreamReader, 
                                       writer: asyncio.StreamWriter):
        """Handle incoming client connection"""
        client_addr = writer.get_extra_info('peername')
        self.logger.debug(f"New connection from {client_addr}")
        
        try:
            # Perform handshake
            peer_info = await self._perform_handshake(reader, writer)
            
            if peer_info:
                self.known_peers[peer_info.node_id] = peer_info
                self.active_connections.add(peer_info.node_id)
                
                # Handle sync session
                await self._handle_sync_session(reader, writer, peer_info)
                
        except Exception as e:
            self.logger.error(f"Client connection error: {e}")
            
        finally:
            try:
                writer.close()
                await writer.wait_closed()
            except Exception:
                pass
    
    async def _perform_handshake(self, reader: asyncio.StreamReader, 
                                writer: asyncio.StreamWriter) -> Optional[PeerInfo]:
        """Perform protocol handshake with peer"""
        try:
            # Send our info
            our_info = {
                'protocol_version': '1.0',
                'node_id': 'local_node',  # Would be set by SyncCoordinator
                'capabilities': ['merkle', 'delta', 'crdt'],
                'supported_modes': ['mesh', 'p2p']
            }
            
            await self._send_message(writer, our_info)
            
            # Receive peer info
            peer_data = await self._receive_message(reader)
            
            if peer_data:
                return PeerInfo(
                    peer_data['node_id'],
                    writer.get_extra_info('peername')[0],
                    writer.get_extra_info('peername')[1],
                    peer_data.get('capabilities', [])
                )
                
        except Exception as e:
            self.logger.error(f"Handshake failed: {e}")
            
        return None
    
    async def _send_message(self, writer: asyncio.StreamWriter, message: Dict[str, Any]):
        """Send JSON message over connection"""
        try:
            json_data = json.dumps(message)
            message_bytes = json_data.encode('utf-8')
            
            # Send length prefix
            length = len(message_bytes)
            writer.write(length.to_bytes(4, 'big'))
            writer.write(message_bytes)
            
            await writer.drain()
            
        except Exception as e:
            self.logger.error(f"Failed to send message: {e}")
            raise
    
    async def _receive_message(self, reader: asyncio.StreamReader) -> Optional[Dict[str, Any]]:
        """Receive JSON message from connection"""
        try:
            # Read length prefix
            length_bytes = await reader.read(4)
            if len(length_bytes) != 4:
                return None
            
            length = int.from_bytes(length_bytes, 'big')
            
            # Read message data
            message_bytes = await reader.read(length)
            if len(message_bytes) != length:
                return None
            
            # Parse JSON
            json_data = message_bytes.decode('utf-8')
            return json.loads(json_data)
            
        except Exception as e:
            self.logger.error(f"Failed to receive message: {e}")
            return None
    
    async def _handle_sync_session(self, reader: asyncio.StreamReader,
                                  writer: asyncio.StreamWriter, peer: PeerInfo):
        """Handle sync session with peer"""
        try:
            while True:
                message = await self._receive_message(reader)
                if not message:
                    break
                
                response = await self._process_sync_message(message, peer)
                if response:
                    await self._send_message(writer, response)
                    
        except Exception as e:
            self.logger.error(f"Sync session error with {peer.node_id}: {e}")
        finally:
            self.active_connections.discard(peer.node_id)
    
    async def _process_sync_message(self, message: Dict[str, Any], 
                                   peer: PeerInfo) -> Optional[Dict[str, Any]]:
        """Process sync message from peer"""
        msg_type = message.get('type')
        
        if msg_type == 'tree_request':
            # Peer requesting our tree
            return await self._handle_tree_request(message, peer)
        elif msg_type == 'tree_response':
            # Peer sent their tree
            return await self._handle_tree_response(message, peer)
        elif msg_type == 'delta_exchange':
            # Delta exchange
            return await self._handle_delta_exchange(message, peer)
        elif msg_type == 'sync_complete':
            # Sync completion notification
            return await self._handle_sync_complete(message, peer)
        
        return None
    
    async def _handle_tree_request(self, message: Dict[str, Any], 
                                  peer: PeerInfo) -> Dict[str, Any]:
        """Handle tree request from peer"""
        # This would integrate with MerkleTreeComparer
        return {
            'type': 'tree_response',
            'tree': {},  # Placeholder
            'timestamp': datetime.now(timezone.utc).isoformat()
        }
    
    async def _handle_tree_response(self, message: Dict[str, Any], 
                                   peer: PeerInfo) -> Optional[Dict[str, Any]]:
        """Handle tree response from peer"""
        # Process received tree
        return None
    
    async def _handle_delta_exchange(self, message: Dict[str, Any], 
                                    peer: PeerInfo) -> Dict[str, Any]:
        """Handle delta exchange message"""
        deltas = message.get('deltas', [])
        
        # Process deltas (integrate with DeltaEngine)
        processed_count = len(deltas)
        
        return {
            'type': 'delta_ack',
            'processed': processed_count,
            'timestamp': datetime.now(timezone.utc).isoformat()
        }
    
    async def _handle_sync_complete(self, message: Dict[str, Any], 
                                   peer: PeerInfo) -> Optional[Dict[str, Any]]:
        """Handle sync completion notification"""
        self.logger.info(f"Sync completed with peer {peer.node_id}")
        return None
    
    async def discover_peers(self) -> List[str]:
        """Discover available sync peers"""
        try:
            discovered_peers = []
            
            if self.mode == 'mesh':
                # Use discovery protocol
                if self.discovery_enabled:
                    await self._broadcast_discovery()
                    # Wait for responses
                    await asyncio.sleep(2)
                    
                # Add known peers
                for peer_id, peer in self.known_peers.items():
                    if peer.is_online:
                        discovered_peers.append(peer_id)
                        
            elif self.mode == 'hub':
                # Connect to configured hubs
                for hub_endpoint in self.hub_endpoints:
                    try:
                        if await self._check_hub_availability(hub_endpoint):
                            discovered_peers.append(f"hub:{hub_endpoint}")
                    except Exception as e:
                        self.logger.warning(f"Hub {hub_endpoint} unavailable: {e}")
                        
            elif self.mode == 'p2p':
                # Direct P2P connections (requires manual peer configuration)
                discovered_peers = list(self.known_peers.keys())
            
            self.logger.info(f"Discovered {len(discovered_peers)} peers")
            return discovered_peers
            
        except Exception as e:
            self.logger.error(f"Peer discovery failed: {e}")
            return []
    
    async def _broadcast_discovery(self):
        """Broadcast discovery message"""
        try:
            discovery_msg = {
                'type': 'discovery',
                'node_id': 'local_node',  # Would be set by coordinator
                'address': self._get_local_ip(),
                'port': self.listen_port,
                'capabilities': ['merkle', 'delta', 'crdt'],
                'timestamp': datetime.now(timezone.utc).isoformat()
            }
            
            # Broadcast on local network
            sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
            
            message_bytes = json.dumps(discovery_msg).encode('utf-8')
            sock.sendto(message_bytes, ('<broadcast>', self.discovery_port))
            sock.close()
            
        except Exception as e:
            self.logger.error(f"Discovery broadcast failed: {e}")
    
    def _get_local_ip(self) -> str:
        """Get local IP address"""
        try:
            # Connect to a remote address to determine local IP
            with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
                s.connect(("8.8.8.8", 80))
                return s.getsockname()[0]
        except Exception:
            return "127.0.0.1"
    
    async def _periodic_discovery(self):
        """Periodic peer discovery"""
        while True:
            try:
                await asyncio.sleep(60)  # Discovery every minute
                if self.discovery_enabled:
                    await self._broadcast_discovery()
                    
                # Clean up offline peers
                await self._cleanup_offline_peers()
                
            except Exception as e:
                self.logger.error(f"Periodic discovery error: {e}")
    
    async def _cleanup_offline_peers(self):
        """Remove peers that haven't been seen recently"""
        cutoff_time = datetime.now(timezone.utc).timestamp() - 300  # 5 minutes
        
        offline_peers = []
        for peer_id, peer in self.known_peers.items():
            if peer.last_seen.timestamp() < cutoff_time:
                offline_peers.append(peer_id)
        
        for peer_id in offline_peers:
            self.logger.debug(f"Removing offline peer: {peer_id}")
            del self.known_peers[peer_id]
            self.active_connections.discard(peer_id)
    
    async def _check_hub_availability(self, hub_endpoint: str) -> bool:
        """Check if hub is available"""
        try:
            # Parse endpoint
            parts = hub_endpoint.split(':')
            host = parts[0]
            port = int(parts[1]) if len(parts) > 1 else 443
            
            # Try to connect
            reader, writer = await asyncio.wait_for(
                asyncio.open_connection(host, port),
                timeout=5
            )
            
            writer.close()
            await writer.wait_closed()
            
            return True
            
        except Exception:
            return False
    
    async def exchange_deltas(self, peer_id: str, 
                             deltas: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        """Exchange deltas with a specific peer"""
        try:
            if peer_id.startswith('hub:'):
                return await self._exchange_deltas_hub(peer_id[4:], deltas)
            else:
                return await self._exchange_deltas_peer(peer_id, deltas)
                
        except Exception as e:
            self.logger.error(f"Delta exchange failed with {peer_id}: {e}")
            return []
    
    async def _exchange_deltas_peer(self, peer_id: str, 
                                   deltas: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        """Exchange deltas with P2P peer"""
        peer = self.known_peers.get(peer_id)
        if not peer:
            self.logger.warning(f"Unknown peer: {peer_id}")
            return []
        
        try:
            # Connect to peer
            reader, writer = await asyncio.wait_for(
                asyncio.open_connection(peer.address, peer.port),
                timeout=self.timeout_seconds
            )
            
            # Perform handshake
            handshake_peer = await self._perform_handshake(reader, writer)
            
            if handshake_peer:
                # Send deltas
                delta_message = {
                    'type': 'delta_exchange',
                    'deltas': deltas,
                    'timestamp': datetime.now(timezone.utc).isoformat()
                }
                
                await self._send_message(writer, delta_message)
                
                # Receive response
                response = await self._receive_message(reader)
                
                if response and response.get('type') == 'delta_ack':
                    self.logger.debug(f"Deltas exchanged with {peer_id}")
                    return []  # No incoming deltas in this simple implementation
            
            writer.close()
            await writer.wait_closed()
            
        except Exception as e:
            self.logger.error(f"P2P delta exchange failed: {e}")
            peer.connection_failures += 1
            if peer.connection_failures > 3:
                peer.is_online = False
        
        return []
    
    async def _exchange_deltas_hub(self, hub_endpoint: str, 
                                  deltas: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        """Exchange deltas with hub server"""
        try:
            # Parse hub endpoint
            parts = hub_endpoint.split(':')
            host = parts[0]
            port = int(parts[1]) if len(parts) > 1 else 443
            
            # Use HTTP/HTTPS for hub communication
            connector = aiohttp.TCPConnector(ssl=False if port != 443 else None)
            
            async with aiohttp.ClientSession(connector=connector) as session:
                url = f"{'https' if port == 443 else 'http'}://{host}:{port}/sync/deltas"
                
                payload = {
                    'node_id': 'local_node',
                    'deltas': deltas,
                    'timestamp': datetime.now(timezone.utc).isoformat()
                }
                
                async with session.post(url, json=payload, timeout=self.timeout_seconds) as response:
                    if response.status == 200:
                        result = await response.json()
                        return result.get('incoming_deltas', [])
                    else:
                        self.logger.error(f"Hub returned status {response.status}")
                        
        except Exception as e:
            self.logger.error(f"Hub delta exchange failed: {e}")
        
        return []
    
    async def _disconnect_peer(self, peer_id: str):
        """Disconnect from a peer"""
        try:
            self.active_connections.discard(peer_id)
            self.logger.debug(f"Disconnected from peer {peer_id}")
        except Exception as e:
            self.logger.error(f"Error disconnecting from {peer_id}: {e}")
    
    async def get_protocol_status(self) -> Dict[str, Any]:
        """Get current protocol status"""
        return {
            'mode': self.mode,
            'listening_port': self.listen_port,
            'discovery_enabled': self.discovery_enabled,
            'encryption_enabled': self.encryption_enabled,
            'known_peers': len(self.known_peers),
            'active_connections': len(self.active_connections),
            'peer_details': {peer_id: peer.to_dict() for peer_id, peer in self.known_peers.items()}
        }
    
    async def add_manual_peer(self, node_id: str, address: str, port: int) -> bool:
        """Manually add a peer"""
        try:
            peer = PeerInfo(node_id, address, port, ['merkle', 'delta'])
            self.known_peers[node_id] = peer
            self.logger.info(f"Added manual peer: {node_id} at {address}:{port}")
            return True
        except Exception as e:
            self.logger.error(f"Failed to add manual peer: {e}")
            return False

class DiscoveryProtocol(asyncio.DatagramProtocol):
    """UDP protocol for peer discovery"""
    
    def __init__(self, sync_protocol: GhostSyncProtocol):
        self.sync_protocol = sync_protocol
        self.logger = logging.getLogger("DiscoveryProtocol")
    
    def connection_made(self, transport):
        self.transport = transport
    
    def datagram_received(self, data, addr):
        try:
            message = json.loads(data.decode('utf-8'))
            
            if message.get('type') == 'discovery':
                # Received discovery broadcast
                node_id = message.get('node_id')
                peer_addr = message.get('address', addr[0])
                peer_port = message.get('port', 8443)
                capabilities = message.get('capabilities', [])
                
                if node_id and node_id != 'local_node':  # Don't add ourselves
                    peer = PeerInfo(node_id, peer_addr, peer_port, capabilities)
                    self.sync_protocol.known_peers[node_id] = peer
                    
                    self.logger.debug(f"Discovered peer: {node_id} at {peer_addr}:{peer_port}")
                    
                    # Send discovery response
                    response = {
                        'type': 'discovery_response',
                        'node_id': 'local_node',
                        'address': self.sync_protocol._get_local_ip(),
                        'port': self.sync_protocol.listen_port,
                        'capabilities': ['merkle', 'delta', 'crdt'],
                        'timestamp': datetime.now(timezone.utc).isoformat()
                    }
                    
                    response_data = json.dumps(response).encode('utf-8')
                    self.transport.sendto(response_data, addr)
                    
        except Exception as e:
            self.logger.error(f"Discovery message processing error: {e}")

