    async def start_sync_cycle(self, peers: Optional[List[str]] = None, 
                              dry_run: bool = False) -> Dict[str, Any]:
        """Main entry point for sync cycle execution"""
        if self.sync_in_progress:
            self.logger.warning("Sync cycle already in progress")
            return {'status': 'already_running'}
        
        self.sync_in_progress = True
        sync_id = str(uuid.uuid4())
        start_time = datetime.now(timezone.utc)
        
        try:
            self.logger.info(f"Starting sync cycle {sync_id} (dry_run={dry_run})")
            
            # Phase 1: Discovery and preparation
            available_peers = await self._discover_peers(peers)
            sync_manifest = await self._prepare_sync_manifest()
            
            # Phase 2: Merkle tree comparison
            tree_comparison = await self._compute_merkle_comparison(available_peers)
            
            # Phase 3: Delta computation and exchange
            deltas = await self._exchange_deltas(tree_comparison, dry_run)
            
            # Phase 4: Integrity verification
            verification_result = await self._verify_integrity(deltas)
            
            # Phase 5: Conflict detection and resolution
            conflicts = await self._detect_conflicts(deltas)
            if conflicts and not dry_run:
                await self._resolve_conflicts(conflicts)
            
            # Phase 6: Apply changes (unless dry run)
            apply_result = None
            if not dry_run and verification_result['valid']:
                apply_result = await self._apply_deltas(deltas)
            
            # Phase 7: Finalization
            await self._finalize_sync(sync_id, start_time)
            
            end_time = datetime.now(timezone.utc)
            duration = (end_time - start_time).total_seconds()
            
            result = {
                'sync_id': sync_id,
                'status': 'success',
                'duration_seconds': duration,
                'peers_contacted': len(available_peers),
                'deltas_processed': len(deltas),
                'conflicts_found': len(conflicts),
                'dry_run': dry_run,
                'verification_passed': verification_result['valid'],
                'changes_applied': bool(apply_result) if not dry_run else False
            }
            
            self.logger.info(f"Sync cycle {sync_id} completed successfully")
            return result
            
        except Exception as e:
            self.logger.error(f"Sync cycle {sync_id} failed: {e}")
            return {
                'sync_id': sync_id,
                'status': 'failed',
                'error': str(e),
                'dry_run': dry_run
            }
        finally:
            self.sync_in_progress = False
    
    async def _discover_peers(self, specified_peers: Optional[List[str]]) -> List[str]:
        """Discover available sync peers"""
        if specified_peers:
            return specified_peers
        
        if self.sync_protocol:
            return await self.sync_protocol.discover_peers()
        
        return []
    
    async def _prepare_sync_manifest(self) -> Dict[str, Any]:
        """Prepare manifest of local state for sync"""
        return {
            'node_id': self.node_id,
            'timestamp': datetime.now(timezone.utc).isoformat(),
            'version_vector': self.sync_state.get('version_vectors', {}),
            'capabilities': ['merkle', 'delta', 'crdt', 'conflict_resolution']
        }
    
    async def _compute_merkle_comparison(self, peers: List[str]) -> Dict[str, Any]:
        """Compute and compare Merkle trees with peers"""
        if not self.merkle_comparer:
            return {}
        
        local_tree = await self.merkle_comparer.build_local_tree()
        comparisons = {}
        
        for peer in peers:
            try:
                peer_tree = await self.merkle_comparer.get_peer_tree(peer)
                diff = await self.merkle_comparer.compare_trees(local_tree, peer_tree)
                comparisons[peer] = diff
            except Exception as e:
                self.logger.warning(f"Failed to compare with peer {peer}: {e}")
        
        return {
            'local_tree': local_tree,
            'comparisons': comparisons
        }
    
    async def _exchange_deltas(self, tree_comparison: Dict[str, Any], 
                              dry_run: bool) -> List[Dict[str, Any]]:
        """Exchange delta payloads with peers"""
        if not self.delta_engine:
            return []
        
        deltas = []
        comparisons = tree_comparison.get('comparisons', {})
        
        for peer, diff in comparisons.items():
            try:
                # Compute deltas for differences
                peer_deltas = await self.delta_engine.compute_deltas(diff)
                
                if not dry_run:
                    # Exchange with peer
                    exchanged_deltas = await self.sync_protocol.exchange_deltas(
                        peer, peer_deltas
                    )
                    deltas.extend(exchanged_deltas)
                else:
                    # In dry run, just simulate
                    deltas.extend(peer_deltas)
                    
            except Exception as e:
                self.logger.warning(f"Delta exchange failed with peer {peer}: {e}")
        
        return deltas
    
    async def _verify_integrity(self, deltas: List[Dict[str, Any]]) -> Dict[str, Any]:
        """Verify integrity of received deltas"""
        if not self.integrity_verifier:
            return {'valid': True, 'details': 'No verifier configured'}
        
        verification_results = []
        
        for delta in deltas:
            try:
                result = await self.integrity_verifier.verify_delta(delta)
                verification_results.append(result)
            except Exception as e:
                self.logger.error(f"Integrity verification failed: {e}")
                verification_results.append({'valid': False, 'error': str(e)})
        
        all_valid = all(r.get('valid', False) for r in verification_results)
        
        return {
            'valid': all_valid,
            'results': verification_results,
            'total_verified': len(verification_results)
        }
    
    async def _detect_conflicts(self, deltas: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        """Detect conflicts in delta set"""
        conflicts = []
        
        # Group deltas by target entity/document
        entity_deltas = {}
        for delta in deltas:
            entity_id = delta.get('entity_id', 'unknown')
            if entity_id not in entity_deltas:
                entity_deltas[entity_id] = []
            entity_deltas[entity_id].append(delta)
        
        # Check for conflicts within each entity
        for entity_id, entity_delta_list in entity_deltas.items():
            if len(entity_delta_list) > 1:
                # Multiple changes to same entity - potential conflict
                conflict = await self._analyze_conflict(entity_id, entity_delta_list)
                if conflict:
                    conflicts.append(conflict)
        
        return conflicts
    
    async def _analyze_conflict(self, entity_id: str, 
                               deltas: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
        """Analyze if deltas represent a true conflict"""
        # Vector clock comparison
        strategy = self.config.get('conflict_resolution', {}).get('strategy', 'vector_clocks')
        
        if strategy == 'vector_clocks':
            return await self._vector_clock_analysis(entity_id, deltas)
        elif strategy == 'last_write_wins':
            return await self._timestamp_analysis(entity_id, deltas)
        else:
            # Mark as conflict for manual resolution
            return {
                'entity_id': entity_id,
                'type': 'manual_resolution_required',
                'deltas': deltas,
                'detected_at': datetime.now(timezone.utc).isoformat()
            }
    
    async def _vector_clock_analysis(self, entity_id: str, 
                                    deltas: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
        """Use vector clocks to detect concurrent modifications"""
        # Simplified vector clock conflict detection
        timestamps = [d.get('timestamp') for d in deltas]
        vector_clocks = [d.get('vector_clock', {}) for d in deltas]
        
        # If any two vector clocks are concurrent (neither dominates), it's a conflict
        for i in range(len(vector_clocks)):
            for j in range(i + 1, len(vector_clocks)):
                if self._are_concurrent(vector_clocks[i], vector_clocks[j]):
                    return {
                        'entity_id': entity_id,
                        'type': 'concurrent_modification',
                        'conflicting_deltas': [deltas[i], deltas[j]],
                        'resolution_strategy': 'vector_clocks'
                    }
        
        return None
    
    def _are_concurrent(self, vc1: Dict, vc2: Dict) -> bool:
        """Check if two vector clocks are concurrent"""
        if not vc1 or not vc2:
            return True  # Treat missing vector clocks as concurrent
        
        vc1_dominates = False
        vc2_dominates = False
        
        all_nodes = set(vc1.keys()) | set(vc2.keys())
        
        for node in all_nodes:
            v1 = vc1.get(node, 0)
            v2 = vc2.get(node, 0)
            
            if v1 > v2:
                vc1_dominates = True
            elif v2 > v1:
                vc2_dominates = True
        
        # Concurrent if neither dominates
        return not (vc1_dominates and not vc2_dominates) and not (vc2_dominates and not vc1_dominates)
    
    async def _timestamp_analysis(self, entity_id: str, 
                                 deltas: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
        """Use timestamps for last-write-wins analysis"""
        tolerance = self.config.get('integrity', {}).get('timestamp_tolerance_seconds', 300)
        
        # Sort by timestamp
        sorted_deltas = sorted(deltas, key=lambda d: d.get('timestamp', 0))
        
        if len(sorted_deltas) >= 2:
            latest = sorted_deltas[-1]
            second_latest = sorted_deltas[-2]
            
            time_diff = latest.get('timestamp', 0) - second_latest.get('timestamp', 0)
            
            # If timestamps are very close, consider it a conflict
            if time_diff < tolerance:
                return {
                    'entity_id': entity_id,
                    'type': 'timestamp_conflict',
                    'conflicting_deltas': [latest, second_latest],
                    'time_difference': time_diff
                }
        
        return None
    
