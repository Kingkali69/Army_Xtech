    async def _apply_deltas(self, deltas: List[Dict[str, Any]]) -> Dict[str, Any]:
        """Apply validated deltas to local state"""
        if not self.delta_engine:
            return {'applied': 0, 'failed': 0}
        
        applied = 0
        failed = 0
        
        for delta in deltas:
            try:
                await self.delta_engine.apply_delta(delta)
                applied += 1
            except Exception as e:
                self.logger.error(f"Failed to apply delta: {e}")
                failed += 1
        
        return {
            'applied': applied,
            'failed': failed,
            'total': len(deltas)
        }
    
    async def _finalize_sync(self, sync_id: str, start_time: datetime):
        """Finalize sync operation and update state"""
        self.last_sync_time = datetime.now(timezone.utc)
        
        # Update version vector
        current_vector = self.sync_state.setdefault('version_vectors', {})
        current_vector[self.node_id] = current_vector.get(self.node_id, 0) + 1
        
        # Record sync timestamp
        self.sync_state.setdefault('last_sync_timestamps', {})[sync_id] = self.last_sync_time.isoformat()
        
        # Create checkpoint if enabled
        if self.config.get('checkpoint', {}).get('enabled', True):
            await self._create_checkpoint(sync_id)
        
        # Persist state
        await self.save_sync_state()
        
        self.logger.info(f"Sync {sync_id} finalized at {self.last_sync_time.isoformat()}")
    
    async def _create_checkpoint(self, sync_id: str):
        """Create a sync checkpoint for resumability"""
        checkpoint = {
            'sync_id': sync_id,
            'timestamp': datetime.now(timezone.utc).isoformat(),
            'node_id': self.node_id,
            'state_snapshot': {
                'version_vectors': self.sync_state.get('version_vectors', {}),
                'last_sync_time': self.last_sync_time.isoformat() if self.last_sync_time else None
            }
        }
        
        checkpoints = self.sync_state.setdefault('checkpoint_history', [])
        checkpoints.append(checkpoint)
        
        # Limit checkpoint history
        max_checkpoints = self.config.get('checkpoint', {}).get('max_checkpoints', 10)
        if len(checkpoints) > max_checkpoints:
            checkpoints[:] = checkpoints[-max_checkpoints:]
    
