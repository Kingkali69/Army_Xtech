class SessionLifecycleManager:
    def __init__(self, config):
        self.config = config
        self.lifecycle_hooks = {}
        self.resource_cleanup_handlers = {}
        
    async def initialize_session(self, session: Dict):
        session['state'] = SessionState.ACTIVE
        session['initialized_at'] = datetime.now()
        
        # Execute initialization hooks
        for hook in self.lifecycle_hooks.get('init', []):
            await hook(session)
    
    async def suspend_session(self, session_id: str, reason: str):
        session = self.sessions.get(session_id)
        if session:
            session['state'] = SessionState.SUSPENDED
            session['suspend_reason'] = reason
            session['suspended_at'] = datetime.now()
            
            # Execute suspension hooks
            for hook in self.lifecycle_hooks.get('suspend', []):
                await hook(session)
    
    async def resume_session(self, session_id: str):
        session = self.sessions.get(session_id)
        if session and session['state'] == SessionState.SUSPENDED:
            session['state'] = SessionState.ACTIVE
            session['resumed_at'] = datetime.now()
            
            # Execute resume hooks
            for hook in self.lifecycle_hooks.get('resume', []):
                await hook(session)
    
    async def cleanup_session_resources(self, session: Dict):
        session_id = session['id']
        resources = session.get('resources', set())
        
        for resource in resources:
            handler = self.resource_cleanup_handlers.get(resource)
            if handler:
                await handler(session_id, resource)
    
    def register_lifecycle_hook(self, event: str, handler):
        if event not in self.lifecycle_hooks:
            self.lifecycle_hooks[event] = []
        self.lifecycle_hooks[event].append(handler)

class SessionMonitor:
    def __init__(self, config):
        self.config = config
        self.monitoring_enabled = config.get('monitoring_enabled', True)
        self.anomaly_thresholds = config.get('anomaly_thresholds', {})
        self.session_metrics = {}
        
    def track_session_event(self, session_id: str, event_type: str, metadata: Dict):
        if not self.monitoring_enabled:
            return
            
        if session_id not in self.session_metrics:
            self.session_metrics[session_id] = {
                'events': [],
                'request_count': 0,
                'data_transfer': 0,
                'error_count': 0
            }
        
        metrics = self.session_metrics[session_id]
        metrics['events'].append({
            'type': event_type,
            'timestamp': datetime.now(),
            'metadata': metadata
        })
        
        if event_type == 'request':
            metrics['request_count'] += 1
        elif event_type == 'error':
            metrics['error_count'] += 1
        elif event_type == 'data_transfer':
            metrics['data_transfer'] += metadata.get('bytes', 0)
    
    def detect_anomalies(self, session_id: str) -> List[str]:
        anomalies = []
        metrics = self.session_metrics.get(session_id, {})
        
        # High request rate
        if metrics.get('request_count', 0) > self.anomaly_thresholds.get('max_requests', 1000):
            anomalies.append('high_request_rate')
        
        # High error rate
        error_rate = metrics.get('error_count', 0) / max(metrics.get('request_count', 1), 1)
        if error_rate > self.anomaly_thresholds.get('max_error_rate', 0.1):
            anomalies.append('high_error_rate')
        
        # Excessive data transfer
        if metrics.get('data_transfer', 0) > self.anomaly_thresholds.get('max_data_transfer', 100_000_000):
            anomalies.append('excessive_data_transfer')
        
        return anomalies
    
    def get_session_health(self, session_id: str) -> Dict:
        metrics = self.session_metrics.get(session_id, {})
        anomalies = self.detect_anomalies(session_id)
        
        return {
            'session_id': session_id,
            'health_score': max(0, 100 - len(anomalies) * 25),
            'anomalies': anomalies,
            'metrics': metrics
        }

class SessionControlSubsystem:
    def __init__(self, config):
        self.config = config
        self.sm = SessionManager(config)
        self.av = AuthenticationValidator(config)
        self.acm = AccessControlManager(config)
        self.slm = SessionLifecycleManager(config)
        self.smon = SessionMonitor(config)
        
        # Event pipeline configuration
        self.event_queue = asyncio.Queue()
        self.running = False
        self.cleanup_interval = config.get('cleanup_interval', 300)
        
        # Initialize logging
        self.logger = logging.getLogger(__name__)
        
    async def start(self):
        """Initialize and start the session control subsystem"""
        self.running = True
        
        # Start background tasks
        asyncio.create_task(self._event_processor())
        asyncio.create_task(self._periodic_cleanup())
        
        self.logger.info("Session Control Subsystem started")
    
    async def stop(self):
        """Shutdown the session control subsystem"""
        self.running = False
        
        # Cleanup all active sessions
        for session_id in list(self.sm.sessions.keys()):
            await self._terminate_session(session_id, "system_shutdown")
        
        self.logger.info("Session Control Subsystem stopped")
    
    async def handle_event(self, event: Dict):
        """Main event handler for session control events"""
        event_type = event.get('type')
        
        try:
            if event_type == 'session_create_request':
                await self._handle_session_create(event)
            elif event_type == 'session_authenticate':
                await self._handle_authentication(event)
            elif event_type == 'session_access_request':
                await self._handle_access_request(event)
            elif event_type == 'session_terminate_request':
                await self._handle_session_terminate(event)
            elif event_type == 'session_heartbeat':
                await self._handle_heartbeat(event)
            elif event_type == 'resource_allocation':
                await self._handle_resource_allocation(event)
            else:
                self.logger.warning(f"Unknown event type: {event_type}")
                
        except Exception as e:
            self.logger.error(f"Error handling event {event_type}: {str(e)}")
            await self._emit_event({
                'type': 'session_error',
                'session_id': event.get('session_id'),
                'error': str(e),
                'timestamp': datetime.now()
            })
    
    async def _handle_session_create(self, event: Dict):
        """Handle session creation requests"""
        user_id = event.get('user_id')
        session_data = event.get('session_data', {})
        
        # Check session limits
        user_sessions = [s for s in self.sm.sessions.values() if s['user_id'] == user_id]
        max_user_sessions = self.config.get('max_user_sessions', 5)
        
        if len(user_sessions) >= max_user_sessions:
            await self._emit_event({
                'type': 'session_create_rejected',
                'user_id': user_id,
                'reason': 'session_limit_exceeded',
                'timestamp': datetime.now()
            })
            return
        
        # Create new session
        session_id = self.sm.create_session(user_id, session_data)
        session = self.sm.get_session(session_id)
        
        # Initialize session lifecycle
        await self.slm.initialize_session(session)
        
        # Start monitoring
        self.smon.track_session_event(session_id, 'created', {'user_id': user_id})
        
        await self._emit_event({
            'type': 'session_created',
            'session_id': session_id,
            'user_id': user_id,
            'timestamp': datetime.now()
        })
    
    async def _handle_authentication(self, event: Dict):
        """Handle session authentication"""
        session_id = event.get('session_id')
        credentials = event.get('credentials')
        
        session = self.sm.get_session(session_id)
        if not session:
            await self._emit_event({
                'type': 'authentication_failed',
                'session_id': session_id,
                'reason': 'session_not_found',
                'timestamp': datetime.now()
            })
            return
        
        # Validate credentials
        auth_result = await self.av.validate_credentials(credentials)
        
        if auth_result.get('valid'):
            session['authenticated'] = True
            session['user_id'] = auth_result['user_id']
            session['permissions'] = auth_result.get('permissions', [])
            session['auth_expires'] = auth_result.get('expires')
            
            self.smon.track_session_event(session_id, 'authenticated', {'user_id': session['user_id']})
            
            await self._emit_event({
                'type': 'authentication_success',
                'session_id': session_id,
                'user_id': session['user_id'],
                'timestamp': datetime.now()
            })
        else:
            session['auth_attempts'] = session.get('auth_attempts', 0) + 1
            self.smon.track_session_event(session_id, 'auth_failed', {'reason': auth_result.get('reason')})
            
            await self._emit_event({
                'type': 'authentication_failed',
                'session_id': session_id,
                'reason': auth_result.get('reason'),
                'attempts': session['auth_attempts'],
                'timestamp': datetime.now()
            })
    
    async def _handle_access_request(self, event: Dict):
        """Handle resource access requests"""
        session_id = event.get('session_id')
        resource = event.get('resource')
        action = event.get('action')
        
        session = self.sm.get_session(session_id)
        if not session:
            await self._emit_event({
                'type': 'access_denied',
                'session_id': session_id,
                'reason': 'session_not_found',
                'timestamp': datetime.now()
            })
            return
        
        # Update session activity
        self.sm.update_activity(session_id)
        
        # Check permissions
        if self.acm.check_permission(session, resource, action):
            # Check rate limits
            if self.acm.enforce_rate_limits(session, action):
                session['resources'].add(resource)
                self.smon.track_session_event(session_id, 'access_granted', {
                    'resource': resource,
                    'action': action
                })
                
                await self._emit_event({
                    'type': 'access_granted',
                    'session_id': session_id,
                    'resource': resource,
                    'action': action,
                    'timestamp': datetime.now()
                })
            else:
                await self._emit_event({
                    'type': 'access_denied',
                    'session_id': session_id,
                    'reason': 'rate_limit_exceeded',
                    'resource': resource,
                    'timestamp': datetime.now()
                })
        else:
            self.smon.track_session_event(session_id, 'access_denied', {
                'resource': resource,
                'action': action,
                'reason': 'insufficient_permissions'
            })
            
            await self._emit_event({
                'type': 'access_denied',
                'session_id': session_id,
                'reason': 'insufficient_permissions',
                'resource': resource,
                'timestamp': datetime.now()
            })
    
    async def _handle_session_terminate(self, event: Dict):
        """Handle session termination requests"""
        session_id = event.get('session_id')
        reason = event.get('reason', 'user_request')
        
        await self._terminate_session(session_id, reason)
    
    async def _handle_heartbeat(self, event: Dict):
        """Handle session heartbeat/keepalive"""
        session_id = event.get('session_id')
        
        session = self.sm.get_session(session_id)
        if session:
            self.sm.update_activity(session_id)
            
            # Check for anomalies
            anomalies = self.smon.detect_anomalies(session_id)
            if anomalies:
                await self._emit_event({
                    'type': 'session_anomaly_detected',
                    'session_id': session_id,
                    'anomalies': anomalies,
                    'timestamp': datetime.now()
                })
            
            await self._emit_event({
                'type': 'session_heartbeat_ack',
                'session_id': session_id,
                'timestamp': datetime.now()
            })
    
    async def _handle_resource_allocation(self, event: Dict):
        """Handle resource allocation for sessions"""
        session_id = event.get('session_id')
        resource_type = event.get('resource_type')
        allocation_request = event.get('allocation_request')
        
        session = self.sm.get_session(session_id)
        if not session:
            return
        
        # Track resource allocation
        if 'allocated_resources' not in session:
            session['allocated_resources'] = {}
        
        session['allocated_resources'][resource_type] = allocation_request
        session['resources'].add(resource_type)
        
        self.smon.track_session_event(session_id, 'resource_allocated', {
            'resource_type': resource_type,
            'allocation': allocation_request
        })
    
    async def _terminate_session(self, session_id: str, reason: str):
        """Internal session termination handler"""
        session = self.sm.get_session(session_id)
        if not session:
            return
        
        # Cleanup resources
        await self.slm.cleanup_session_resources(session)
        
        # Track termination
        self.smon.track_session_event(session_id, 'terminated', {'reason': reason})
        
        # Remove session
        self.sm.terminate_session(session_id)
        
        await self._emit_event({
            'type': 'session_terminated',
            'session_id': session_id,
            'reason': reason,
            'timestamp': datetime.now()
        })
    
    async def _event_processor(self):
        """Background event processor"""
        while self.running:
            try:
                # Process events from queue
                event = await asyncio.wait_for(self.event_queue.get(), timeout=1.0)
                await self.handle_event(event)
            except asyncio.TimeoutError:
                continue
            except Exception as e:
                self.logger.error(f"Event processor error: {str(e)}")
    
    async def _periodic_cleanup(self):
        """Background cleanup task"""
        while self.running:
            try:
                # Cleanup expired sessions
                self.sm.cleanup_expired_sessions()
                
                # Cleanup monitoring data
                cutoff = datetime.now() - timedelta(hours=24)
                for session_id in list(self.smon.session_metrics.keys()):
                    if session_id not in self.sm.sessions:
                        del self.smon.session_metrics[session_id]
                
                await asyncio.sleep(self.cleanup_interval)
            except Exception as e:
                self.logger.error(f"Cleanup task error: {str(e)}")
    
    async def _emit_event(self, event: Dict):
        """Emit events to the engine pipeline"""
        await self.event_queue.put(event)
    
    # Public API methods
    async def create_session(self, user_id: str, session_data: Dict) -> str:
        """Public method to create a new session"""
        await self._emit_event({
            'type': 'session_create_request',
            'user_id': user_id,
            'session_data': session_data,
            'timestamp': datetime.now()
        })
        
        # Wait for session creation (simplified - in real implementation would use proper async coordination)
        await asyncio.sleep(0.1)
        
        # Find the created session
        for session in self.sm.sessions.values():
            if session['user_id'] == user_id and session['state'] == SessionState.ACTIVE:
                return session['id']
        
        raise Exception("Session creation failed")
    
    async def authenticate_session(self, session_id: str, credentials: Dict):
        """Public method to authenticate a session"""
        await self._emit_event({
            'type': 'session_authenticate',
            'session_id': session_id,
            'credentials': credentials,
            'timestamp': datetime.now()
        })
    
    async def request_access(self, session_id: str, resource: str, action: str):
        """Public method to request resource access"""
        await self._emit_event({
            'type': 'session_access_request',
            'session_id': session_id,
            'resource': resource,
            'action': action,
            'timestamp': datetime.now()
        })
    
    async def terminate_session(self, session_id: str, reason: str = "user_request"):
        """Public method to terminate a session"""
        await self._emit_event({
            'type': 'session_terminate_request',
            'session_id': session_id,
            'reason': reason,
            'timestamp': datetime.now()
        })
    
    async def send_heartbeat(self, session_id: str):
        """Public method to send session heartbeat"""
        await self._emit_event({
            'type': 'session_heartbeat',
            'session_id': session_id,
            'timestamp': datetime.now()
        })
    
    def get_session_info(self, session_id: str) -> Optional[Dict]:
        """Get current session information"""
        session = self.sm.get_session(session_id)
        if session:
            health = self.smon.get_session_health(session_id)
            return {
                'session': session,
                'health': health,
                'accessible_resources': self.acm.get_accessible_resources(session)
            }
        return None
    
    def get_user_sessions(self, user_id: str) -> List[Dict]:
        """Get all sessions for a user"""
        return [s for s in self.sm.sessions.values() if s['user_id'] == user_id]
