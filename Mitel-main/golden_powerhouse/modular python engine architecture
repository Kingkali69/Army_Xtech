        self.config = config
        self.role_permissions = config.get('role_permissions', {})
        self.resource_policies = {}
        
    def check_permission(self, session: Dict, resource: str, action: str) -> bool:
        user_permissions = session.get('permissions', [])
        required_permission = f"{resource}:{action}"
        
        return (
            required_permission in user_permissions or
            f"{resource}:*" in user_permissions or
            "*:*" in user_permissions
        )
    
    def get_accessible_resources(self, session: Dict) -> Set[str]:
        permissions = session.get('permissions', [])
        resources = set()
        
        for perm in permissions:
            if ':' in perm:
                resource, action = perm.split(':', 1)
                resources.add(resource)
        
        return resources
    
