            'stop': self._cmd_stop,
            'status': self._cmd_status,
            'threats': self._cmd_threats,
            'devices': self._cmd_devices,
            'sessions': self._cmd_sessions,
            'mitel': self._cmd_mitel,
            'sec': self._cmd_sec,
            'help': self._cmd_help
        }
        
    async def execute_command(self, command: str, args: List[str] = None) -> str:
        """Execute CLI command"""
        args = args or []
        
        if command in self.commands:
            return await self.commands[command](args)
        else:
            return f"Unknown command: {command}. Type 'help' for available commands."
            
    async def _cmd_start(self, args: List[str]) -> str:
        """Start CloudCore system"""
        if self.engine.status == "running":
            return "CloudCore_Sync_2 is already running"
            
        await self.engine.initialize()
        await self.engine.start()
        return "🚀 CloudCore_Sync_2 started successfully!"
        
    async def _cmd_stop(self, args: List[str]) -> str:
        """Stop CloudCore system"""
        if self.engine.status != "running":
            return "CloudCore_Sync_2 is not running"
            
        await self.engine.stop()
        return "🛑 CloudCore_Sync_2 stopped successfully!"
        
    async def _cmd_status(self, args: List[str]) -> str:
        """Get system status"""
        status = await self.engine.get_system_status()
        
        output = [
            "📊 CloudCore_Sync_2 System Status",
            "=" * 40,
            f"System Status: {status['system_status']}",
            f"Uptime: {status['uptime_seconds']:.2f} seconds",
            f"Platform: {status['platform']}",
            f"Version: {status['version']}",
            "",
            "🔧 Subsystem Status:"
        ]
        
        for name, sub_status in status['subsystems'].items():
            status_icon = "🟢" if sub_status['status'] == 'running' else "🔴"
            output.append(f"  {status_icon} {name}: {sub_status['status']} (uptime: {sub_status['uptime']:.2f}s)")
            
        return "\n".join(output)
        
    async def _cmd_threats(self, args: List[str]) -> str:
        """Get threat information"""
        sec_subsystem = self.engine.subsystems.get('SEC-SUB')
        if not sec_subsystem:
            return "SEC-SUB not available"
            
        active_threats = len(sec_subsystem.active_threats)
        return f"🛡️ SEC-SUB Threat Status:\nActive Threats: {active_threats}"
        
