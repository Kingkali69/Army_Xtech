class RateLimiter:
    """API rate limiting"""
    
    def __init__(self):
        self.client_requests = defaultdict(deque)
        self.rate_limits = {
            'default': {'requests': 100, 'window': 3600}  # 100 requests per hour
        }
        
    async def check_rate_limit(self, client_ip: str) -> bool:
        """Check if client is within rate limits"""
        now = time.time()
        client_queue = self.client_requests[client_ip]
        
        # Remove old requests outside the window
        while client_queue and now - client_queue[0] > self.rate_limits['default']['window']:
            client_queue.popleft()
            
        # Check if under limit
        if len(client_queue) < self.rate_limits['default']['requests']:
            client_queue.append(now)
            return True
        else:
            return False

