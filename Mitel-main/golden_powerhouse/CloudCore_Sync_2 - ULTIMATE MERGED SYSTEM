class GhostSubsystem(ABC):
    """Base class for all CloudCore_Sync_2 subsystems"""
    
    def __init__(self, name: str):
        self.name = name
        self.status = SubsystemStatus.INITIALIZING
        self.event_bus = None
        self.config = {}
        self.logger = logging.getLogger(f"CloudCore.{name}")
        self.event_handlers = {}
        self.metrics = defaultdict(int)
        self.start_time = None
        
    @abstractmethod
    async def initialize(self) -> bool:
        """Initialize the subsystem"""
        pass
        
    @abstractmethod
    async def start(self) -> bool:
        """Start the subsystem"""
        pass
        
    @abstractmethod
    async def stop(self) -> bool:
        """Stop the subsystem"""
        pass
        
    async def handle_event(self, event: CloudCoreEvent) -> Optional[CloudCoreEvent]:
        """Handle incoming events"""
        handler = self.event_handlers.get(event.event_type)
        if handler:
            return await handler(event)
        return None
        
    def register_event_handler(self, event_type: str, handler: Callable):
        """Register an event handler"""
        self.event_handlers[event_type] = handler
        
    async def emit_event(self, event_type: str, data: Dict[str, Any], 
                        priority: EventPriority = EventPriority.MEDIUM):
        """Emit an event to the event bus"""
        if self.event_bus:
            event = CloudCoreEvent(
                event_id=str(uuid.uuid4()),
                event_type=event_type,
                source_subsystem=self.name,
                timestamp=datetime.now(),
                priority=priority,
                data=data
            )
            await self.event_bus.publish_event(event)

