class DeviceMonitor:
    """Cross-platform device monitoring"""
    
    async def scan_devices(self) -> List[Dict]:
        """Scan for connected devices"""
        devices = []
        
        try:
            # USB devices
            usb_devices = await self._scan_usb_devices()
            devices.extend(usb_devices)
            
            # Network interfaces
            network_devices = await self._scan_network_devices()
            devices.extend(network_devices)
            
        except Exception as e:
            logging.error(f"Device scan error: {e}")
            
        return devices
        
    async def _scan_usb_devices(self) -> List[Dict]:
        """Scan USB devices"""
        devices = []
        
        # Cross-platform USB scanning
        if platform.system() == "Linux":
            devices = await self._scan_linux_usb()
        elif platform.system() == "Windows":
            devices = await self._scan_windows_usb()
        elif platform.system() == "Darwin":  # macOS
            devices = await self._scan_macos_usb()
            
        return devices
        
    async def _scan_linux_usb(self) -> List[Dict]:
        """Scan USB devices on Linux"""
        devices = []
        try:
            result = subprocess.run(['lsusb'], capture_output=True, text=True)
            for line in result.stdout.split('\n'):
                if line.strip():
                    parts = line.split()
                    if len(parts) >= 6:
                        devices.append({
                            'id': f"usb_{parts[1]}_{parts[3]}",
                            'type': 'usb_device',
                            'vendor_id': parts[5].split(':')[0],
                            'product_id': parts[5].split(':')[1],
                            'description': ' '.join(parts[6:])
                        })
        except Exception as e:
            logging.error(f"Linux USB scan error: {e}")
        return devices
        
    async def _scan_windows_usb(self) -> List[Dict]:
        """Scan USB devices on Windows"""
        # Simplified Windows USB scanning
        return [{'id': 'win_usb_1', 'type': 'usb_device', 'vendor_id': 'unknown'}]
        
    async def _scan_macos_usb(self) -> List[Dict]:
        """Scan USB devices on macOS"""
        # Simplified macOS USB scanning
        return [{'id': 'mac_usb_1', 'type': 'usb_device', 'vendor_id': 'unknown'}]
        
    async def _scan_network_devices(self) -> List[Dict]:
        """Scan network interfaces"""
        devices = []
        try:
            for interface, addrs in psutil.net_if_addrs().items():
                devices.append({
                    'id': f"net_{interface}",
                    'type': 'network_interface',
                    'name': interface,
                    'addresses': [addr.address for addr in addrs]
                })
        except Exception as e:
            logging.error(f"Network scan error: {e}")
        return devices

