    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Create cloudcore user and group
print_status "Creating cloudcore user and group..."
if ! id "cloudcore" &>/dev/null; then
    groupadd --system cloudcore
    useradd --system --gid cloudcore --home-dir $INSTALL_DIR --shell /bin/false \
            --comment "CloudCore_Sync_2 Service Account" cloudcore
    print_status "Created cloudcore user and group"
else
    print_warning "cloudcore user already exists"
fi

# Create directories
print_status "Creating directory structure..."
mkdir -p $INSTALL_DIR $CONFIG_DIR $LOG_DIR $DATA_DIR
mkdir -p $INSTALL_DIR/{bin,lib,config,logs,temp}

# Set ownership and permissions
chown -R cloudcore:cloudcore $INSTALL_DIR $LOG_DIR $DATA_DIR
chown -R root:cloudcore $CONFIG_DIR
chmod 755 $INSTALL_DIR $LOG_DIR $DATA_DIR
chmod 750 $CONFIG_DIR
chmod 700 $INSTALL_DIR/temp

