            os.chmod(self.pid_file, 0o644)
            return True
        except Exception as e:
            self.logger.error(f"Failed to create PID file: {e}")
            return False
    
    def remove_pid_file(self):
        """Remove PID file."""
        try:
            if os.path.exists(self.pid_file):
                os.unlink(self.pid_file)
        except Exception as e:
