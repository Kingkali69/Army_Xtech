class ProductionDaemon:
    """Production-ready daemon wrapper for CloudCore_Sync_2."""
    
    def __init__(self, config_file: str = "/etc/cloudcore_sync_2/cloudcore.conf"):
        self.config_file = config_file
        self.config = {}
        self.engine = None
        self.running = False
        self.logger = None
        self.pid_file = "/var/run/cloudcore-sync.pid"
        
        # Set process title
        setproctitle.setproctitle("cloudcore-sync")
        
        # Signal handlers
        signal.signal(signal.SIGTERM, self._signal_handler)
        signal.signal(signal.SIGINT, self._signal_handler)
        signal.signal(signal.SIGHUP, self._signal_handler)
        signal.signal(signal.SIGUSR1, self._signal_handler)
    
    def _signal_handler(self, signum: int, frame):
        """Handle system signals."""
        if signum in [signal.SIGTERM, signal.SIGINT]:
            self.logger.info(f"Received signal {signum}, initiating shutdown...")
            self.running = False
        elif signum == signal.SIGHUP:
            self.logger.info("Received SIGHUP, reloading configuration...")
            asyncio.create_task(self.reload_config())
        elif signum == signal.SIGUSR1:
            self.logger.info("Received SIGUSR1, dumping status...")
            asyncio.create_task(self.dump_status())
    
    def load_config(self):
        """Load configuration from file."""
        try:
            config = configparser.ConfigParser()
            config.read(self.config_file)
            
            self.config = {
                'core': dict(config['core']) if 'core' in config else {},
                'network': dict(config['network']) if 'network' in config else {},
                'security': dict(config['security']) if 'security' in config else {},
                'subsystems': dict(config['subsystems']) if 'subsystems' in config else {},
                'logging': dict(config['logging']) if 'logging' in config else {},
                'monitoring': dict(config['monitoring']) if 'monitoring' in config else {},
            }
            
            return True
            
        except Exception as e:
            if self.logger:
                self.logger.error(f"Failed to load configuration: {e}")
            else:
                print(f"Failed to load configuration: {e}")
            return False
    
    def setup_logging(self):
        """Setup production logging."""
        log_level = self.config.get('core', {}).get('log_level', 'INFO').upper()
        log_file = self.config.get('core', {}).get('log_file', '/var/log/cloudcore_sync_2/cloudcore.log')
        
        # Ensure log directory exists
        log_dir = Path(log_file).parent
        log_dir.mkdir(parents=True, exist_ok=True)
        
        # Configure root logger
        logging.basicConfig(
            level=getattr(logging, log_level),
            format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
            handlers=[
                logging.handlers.RotatingFileHandler(
                    log_file,
                    maxBytes=100*1024*1024,  # 100MB
                    backupCount=10
                ),
                logging.StreamHandler(sys.stdout)
            ]
        )
        
        self.logger = logging.getLogger('cloudcore.daemon')
        
        # Setup syslog if enabled
