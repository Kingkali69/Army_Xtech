echo -e "${GREEN}║              Installation Completed Successfully             ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════════════════════════╝${NC}"
echo
echo -e "${BLUE}Next steps:${NC}"
echo -e "1. Review configuration: ${YELLOW}$CONFIG_DIR/cloudcore.conf${NC}"
echo -e "2. Test configuration: ${YELLOW}cloudcore-sync test${NC}"
echo -e "3. Start the service: ${YELLOW}cloudcore-sync start${NC}"
echo -e "4. Check status: ${YELLOW}cloudcore-sync status${NC}"
echo -e "5. View logs: ${YELLOW}cloudcore-sync logs${NC}"
echo
echo -e "${YELLOW}Configuration file: ${NC}$CONFIG_DIR/cloudcore.conf"
echo -e "${YELLOW}Log files: ${NC}$LOG_DIR/"
echo -e "${YELLOW}Service control: ${NC}cloudcore-sync {start|stop|status|logs}"
echo -e "${YELLOW}Manual service: ${NC}systemctl {start|stop|status} $SERVICE_NAME"
EOF

