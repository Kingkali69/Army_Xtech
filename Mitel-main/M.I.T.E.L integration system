class CloudCoreEngine:
    def __init__(self):
        # ... existing init code ...
        self.mitel_handlers = None
        
    async def initialize_subsystems(self):
        """Initialize all subsystems including M.I.T.E.L."""
        
        # ... existing subsystem initialization ...
        
        # Initialize M.I.T.E.L.
        if 'MITEL' in self.subsystems:
            success = await self.subsystems['MITEL'].initialize()
            if success:
                self.logger.info("✅ M.I.T.E.L. subsystem initialized")
                
                # Setup M.I.T.E.L. event handlers
                self.mitel_handlers = MITELEventHandlers(self)
                await self.mitel_handlers.setup_handlers()
            else:
                self.logger.error("❌ M.I.T.E.L. subsystem failed to initialize")
                
    async def start_subsystems(self):
        """Start all subsystems including M.I.T.E.L."""
        
        # ... existing subsystem starting ...
        
        # Start M.I.T.E.L.
        if 'MITEL' in self.subsystems:
            success = await self.subsystems['MITEL'].start()
            if success:
                self.logger.info("🛡️  M.I.T.E.L. protection started")
            else:
                self.logger.error("❌ M.I.T.E.L. failed to start")

