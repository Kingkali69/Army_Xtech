# ADD THESE EVENT HANDLERS TO YOUR EVENT BUS:

class MITELEventHandlers:
    """Event handlers for M.I.T.E.L. integration"""
    
    def __init__(self, engine):
        self.engine = engine
        self.mitel = None
        
    async def setup_handlers(self):
        """Setup M.I.T.E.L. event handlers"""
        self.mitel = self.engine.subsystems.get('MITEL')
        if not self.mitel:
            return
            
        # Subscribe to relevant events
        await self.engine.event_bus.subscribe('device_connected', self.handle_device_connected)
        await self.engine.event_bus.subscribe('security_alert', self.handle_security_alert)
        await self.engine.event_bus.subscribe('user_login', self.handle_user_login)
        
    async def handle_device_connected(self, event):
        """Handle device connection events"""
        if self.mitel and self.mitel.is_running:
            # Forward to M.I.T.E.L. for processing
            device_info = event.get('device_info', {})
            await self.mitel._process_device_event(device_info)
            
    async def handle_security_alert(self, event):
        """Handle security alerts from other subsystems"""
        if event.get('subsystem') == 'M.I.T.E.L.':
            # Log M.I.T.E.L. security alerts
            print(f"🚨 M.I.T.E.L. ALERT: {event.get('description', 'Unknown threat')}")
            
    async def handle_user_login(self, event):
        """Handle user login events for behavioral analysis"""
        if self.mitel and self.mitel.is_running:
            # Notify M.I.T.E.L. of user session start
            pass

