async def handle_mitel_commands(self, command: str, args: list):
    """Handle M.I.T.E.L.-specific commands"""
    
    mitel = self.engine.subsystems.get('MITEL')
    if not mitel:
        print("❌ M.I.T.E.L. subsystem not loaded")
        return
    
    if command == "status":
        status = await mitel.get_status()
        print(f"🛡️  M.I.T.E.L. Status:")
        print(f"   Status: {status['status']}")
        print(f"   Registered Devices: {status['registered_devices']}")
        print(f"   Quarantined Devices: {status['quarantined_devices']}")
        print(f"   Threat Events: {status['threat_events']}")
        print(f"   POS Mode: {status['pos_mode']}")
        
    elif command == "scan":
        print("🔍 Scanning for devices...")
        # Trigger device scan
        
    elif command == "register":
        if len(args) < 1:
            print("Usage: mitel register <device_id>")
            return
        device_id = args[0]
        print(f"📝 Registering device: {device_id}")
        # Implement device registration
        
    elif command == "quarantine":
        if len(args) < 1:
            print("Usage: mitel quarantine <device_id>")
            return
        device_id = args[0]
        print(f"🚫 Quarantining device: {device_id}")
        mitel.quarantined_devices.add(device_id)
        
    elif command == "threats":
        print("🚨 Recent Threat Events:")
        for event in mitel.threat_events[-10:]:  # Last 10 events
            print(f"   [{event.timestamp}] {event.threat_type}: {event.description}")
            
    elif command == "devices":
        print("📱 Registered Devices:")
        for device_id in mitel.registered_devices:
            status = "🟢 Active" if device_id not in mitel.quarantined_devices else "🔴 Quarantined"
            print(f"   {device_id[:16]}... - {status}")
            
    else:
        print("M.I.T.E.L. Commands:")
        print("  status      - Show M.I.T.E.L. status")
        print("  scan        - Scan for connected devices")
        print("  register    - Register a new device")
        print("  quarantine  - Quarantine a device")
        print("  threats     - Show recent threat events")
        print("  devices     - List registered devices")

